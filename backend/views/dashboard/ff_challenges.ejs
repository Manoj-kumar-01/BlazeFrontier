<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weekly Challenge | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        :root {
            --ai-primary: #a855f7;
            --ai-secondary: #ec4899;
            --ai-bg: #030014;
        }
        body {
            background-color: var(--ai-bg);
            margin: 0;
            font-family: 'Outfit', sans-serif;
            color: #fff;
            overflow-x: hidden;
        }

        /* AI Ambient Background */
        .ambient-bg {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: -1;
            overflow: hidden; pointer-events: none;
        }
        .orb {
            position: absolute; border-radius: 50%; filter: blur(100px); opacity: 0.5;
            animation: orbFloat 20s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
        }
        .orb-1 { width: 600px; height: 600px; background: rgba(168, 85, 247, 0.4); top: -10%; left: -10%; }
        .orb-2 { width: 500px; height: 500px; background: rgba(236, 72, 153, 0.3); bottom: -20%; right: -10%; animation-delay: -5s; }
        .orb-3 { width: 400px; height: 400px; background: rgba(59, 130, 246, 0.3); top: 40%; left: 40%; animation-delay: -10s; }
        
        .grid-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: -1;
            background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            mask-image: radial-gradient(circle at center, black, transparent 80%);
            -webkit-mask-image: radial-gradient(circle at center, black, transparent 80%);
        }

        @keyframes orbFloat {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(100px, 100px) scale(1.2); }
        }

        /* Container */
        .challenge-container {
            max-width: 900px;
            margin: 120px auto 60px;
            padding: 0 24px;
        }

        .header-title {
            font-size: 3.5rem; font-weight: 700; text-align: center; margin-bottom: 8px;
            background: linear-gradient(135deg, #fff 0%, #a855f7 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            letter-spacing: -1px;
        }
        .header-sub { text-align: center; color: rgba(255,255,255,0.6); font-size: 1.1rem; margin-bottom: 40px; }

        /* Glass Card */
        .glass-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-top: 1px solid rgba(255, 255, 255, 0.15);
            border-left: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5), inset 0 0 0 1px rgba(255,255,255,0.05);
            position: relative; overflow: hidden;
        }

        .glass-card::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
            transform: skewX(-20deg); animation: shine 6s infinite;
        }

        @keyframes shine {
            0% { left: -100%; } 20% { left: 200%; } 100% { left: 200%; }
        }

        /* Challenge Info */
        .ch-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 20px; }
        .ch-status {
            padding: 6px 16px; border-radius: 30px; font-size: 0.85rem; font-weight: 600; font-family: 'JetBrains Mono', monospace;
            background: rgba(34, 197, 94, 0.1); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.3);
            display: inline-flex; align-items: center; gap: 8px;
        }
        .ch-status::before { content: ''; display: block; width: 8px; height: 8px; border-radius: 50%; background: #4ade80; box-shadow: 0 0 10px #4ade80; animation: pulseDot 2s infinite; }
        
        @keyframes pulseDot { 0% { opacity: 0.5; } 50% { opacity: 1; } 100% { opacity: 0.5; } }

        .ch-reward { display: flex; gap: 12px; }
        .reward-pill {
            background: rgba(0,0,0,0.4); padding: 8px 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05);
            font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; font-weight: bold;
        }
        .rp-coin { color: #fbbf24; }
        .rp-point { color: #60a5fa; }

        .ch-title { font-size: 2.2rem; font-weight: 600; margin-bottom: 16px; line-height: 1.2; }
        .ch-desc { color: rgba(255,255,255,0.7); font-size: 1.1rem; line-height: 1.6; margin-bottom: 32px; }

        /* Upload Area */
        .upload-area {
            border: 2px dashed rgba(168,85,247,0.4);
            border-radius: 16px; padding: 40px 20px; text-align: center;
            background: rgba(168,85,247,0.05);
            transition: all 0.3s; position: relative;
        }
        .upload-area:hover, .upload-area.dragover {
            border-color: #a855f7; background: rgba(168,85,247,0.1);
        }
        .upload-icon { font-size: 3rem; margin-bottom: 16px; filter: drop-shadow(0 0 10px rgba(168,85,247,0.6)); }
        .upload-text { font-size: 1.1rem; font-weight: 500; margin-bottom: 8px; }
        .upload-sub { color: rgba(255,255,255,0.5); font-size: 0.9rem; }
        
        #clip-input { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; }

        /* Submit Button */
        .submit-btn {
            width: 100%; margin-top: 24px; padding: 18px; border-radius: 12px;
            background: linear-gradient(90deg, #a855f7, #ec4899);
            border: none; color: #fff; font-size: 1.1rem; font-weight: 700; font-family: 'Outfit', sans-serif;
            cursor: pointer; text-transform: uppercase; letter-spacing: 1px;
            box-shadow: 0 10px 20px rgba(168,85,247,0.3); transition: all 0.3s;
            display: flex; justify-content: center; align-items: center; gap: 10px;
        }
        .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 15px 25px rgba(168,85,247,0.4); }
        .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; box-shadow: none; }

        /* States */
        #loading-state { text-align: center; padding: 60px 0; }
        .spinner { width: 40px; height: 40px; border: 4px solid rgba(255,255,255,0.1); border-left-color: #a855f7; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 20px; }
        @keyframes spin { to { transform: rotate(360deg); } }

        #empty-state { text-align: center; padding: 60px 0; display: none; }
    </style>
</head>
<body>
    <div class="ambient-bg">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="grid-overlay"></div>
    </div>

    <%- include('../partials/navbar') %>

    <div class="challenge-container">
        <div class="header-title">WEEKLY CHALLENGE</div>
        <div class="header-sub">Prove your skills. Earn rewards.</div>

        <div class="glass-card">
            
            <div id="loading-state">
                <div class="spinner"></div>
                <div style="color: rgba(255,255,255,0.6);">Initializing challenge matrix...</div>
            </div>

            <div id="empty-state">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2" style="margin-bottom:16px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div style="font-size: 1.5rem; font-weight:600; margin-bottom:8px;">No Active Challenge</div>
                <div style="color:rgba(255,255,255,0.6);">The organizers are currently crafting the next challenge. Check back later!</div>
            </div>

            <div id="content-state" style="display: none;">
                <div class="ch-meta">
                    <div class="ch-status">LIVE NOW</div>
                    <div class="ch-reward">
                        <div class="reward-pill rp-coin"><span id="r-coins">100</span> BZC</div>
                        <div class="reward-pill rp-point"><span id="r-points">20</span> BZP</div>
                    </div>
                </div>

                <div class="ch-title" id="ch-title-txt">Loading Title...</div>
                <div class="ch-desc" id="ch-desc-txt">Loading description...</div>

                <div id="submission-section">
                    <div style="font-size: 1.1rem; font-weight: 600; margin-bottom: 16px;">Submit Proof</div>
                    <form id="challenge-form">
                        <div class="upload-area" id="drop-zone">
                            <div class="upload-icon">📹</div>
                            <div class="upload-text" id="file-name-display">Click or drag video file here</div>
                            <div class="upload-sub">MP4, WebM (Max 50MB)</div>
                            <input type="file" id="clip-input" name="clip" accept="video/*" required>
                        </div>
                        <button type="submit" class="submit-btn" id="submit-btn">UPLOAD PROOF</button>
                    </form>
                </div>

                <div id="success-section" style="display: none; text-align: center; padding: 40px 20px; background: rgba(34, 197, 94, 0.05); border: 1px solid rgba(34, 197, 94, 0.2); border-radius: 16px;">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2" style="margin-bottom:16px"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <div style="font-size:1.5rem; font-weight:600; color:#4ade80; margin-bottom:8px;">Proof Submitted!</div>
                    <div style="color:rgba(255,255,255,0.7);">Your submission is currently under review by the organizers.<br>Rewards will be credited upon approval.</div>
                </div>
            </div>

        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('blaze_token');
            if(!token) { window.location.href = '/auth'; return; }

            let currentChallengeId = null;

            // Fetch active challenge
            try {
                const res = await fetch('/api/challenges/active', {
                    headers: { 'x-auth-token': token }
                });
                
                document.getElementById('loading-state').style.display = 'none';

                if (!res.ok) throw new Error('Failed to fetch');
                const data = await res.json();

                if (!data || !data._id) {
                    document.getElementById('empty-state').style.display = 'block';
                    return;
                }

                currentChallengeId = data._id;
                document.getElementById('content-state').style.display = 'block';
                document.getElementById('ch-title-txt').innerText = data.title;
                document.getElementById('ch-desc-txt').innerText = data.description;
                document.getElementById('r-coins').innerText = data.rewardCoins;
                document.getElementById('r-points').innerText = data.rewardPoints;

            } catch(e) {
                document.getElementById('loading-state').style.display = 'none';
                document.getElementById('empty-state').style.display = 'block';
                console.error(e);
            }

            // File input handling
            const fileInput = document.getElementById('clip-input');
            const dropZone = document.getElementById('drop-zone');
            const fileNameDisplay = document.getElementById('file-name-display');

            fileInput.addEventListener('change', (e) => {
                if (e.target.files.length > 0) {
                    fileNameDisplay.innerText = e.target.files[0].name;
                    fileNameDisplay.style.color = '#a855f7';
                }
            });

            // Form submission
            document.getElementById('challenge-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = document.getElementById('submit-btn');
                const file = fileInput.files[0];

                if(!file || !currentChallengeId) return;

                btn.disabled = true;
                btn.innerHTML = '<div class="spinner" style="width:20px;height:20px;margin:0;border-width:2px;"></div> UPLOADING...';

                const formData = new FormData();
                formData.append('challengeId', currentChallengeId);
                formData.append('clip', file);

                try {
                    const res = await fetch('/api/challenges/submit', {
                        method: 'POST',
                        headers: { 'x-auth-token': token },
                        body: formData
                    });
                    const data = await res.json();
                    
                    if (res.ok) {
                        document.getElementById('submission-section').style.display = 'none';
                        document.getElementById('success-section').style.display = 'block';
                    } else {
                        alert(data.msg || 'Upload failed');
                        btn.disabled = false;
                        btn.innerHTML = 'UPLOAD PROOF';
                    }
                } catch(err) {
                    alert('An error occurred during upload.');
                    btn.disabled = false;
                    btn.innerHTML = 'UPLOAD PROOF';
                }
            });
        });
    </script>
</body>
</html>
