<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weekly Challenge | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        :root {
            --ai-primary: #a855f7;
            --ai-secondary: #ec4899;
            --ai-bg: #030014;
        }
        body {
            background-color: var(--ai-bg);
            margin: 0;
            font-family: 'Outfit', sans-serif;
            color: #fff;
            overflow-x: hidden;
        }

        /* AI Ambient Background */
        .ambient-bg {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: -1;
            overflow: hidden; pointer-events: none;
        }
        .orb {
            position: absolute; border-radius: 50%; filter: blur(100px); opacity: 0.5;
            animation: orbFloat 20s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
        }
        .orb-1 { width: 600px; height: 600px; background: rgba(168, 85, 247, 0.4); top: -10%; left: -10%; }
        .orb-2 { width: 500px; height: 500px; background: rgba(236, 72, 153, 0.3); bottom: -20%; right: -10%; animation-delay: -5s; }
        .orb-3 { width: 400px; height: 400px; background: rgba(59, 130, 246, 0.3); top: 40%; left: 40%; animation-delay: -10s; }
        
        .grid-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: -1;
            background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            mask-image: radial-gradient(circle at center, black, transparent 80%);
            -webkit-mask-image: radial-gradient(circle at center, black, transparent 80%);
        }

        @keyframes orbFloat {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(100px, 100px) scale(1.2); }
        }

        /* Container */
        .challenge-container {
            max-width: 1000px;
            margin: 100px auto 80px;
            padding: 0 24px;
        }

        .back-link {
            display: inline-flex; align-items: center; gap: 8px; 
            color: rgba(255,255,255,0.5); text-decoration: none; 
            font-weight: 500; font-size: 0.9rem; margin-bottom: 24px; 
            transition: all 0.3s ease;
            padding: 8px 16px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 30px;
        }
        .back-link:hover {
            color: #fff;
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.15);
            transform: translateX(-4px);
        }

        .page-header { margin-bottom: 40px; }
        .header-title {
            font-size: 4rem; font-weight: 800; line-height: 1.1; margin-bottom: 12px;
            background: linear-gradient(to right, #ffffff, #a855f7);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            letter-spacing: -2px;
        }
        .header-sub { 
            color: rgba(255,255,255,0.6); font-size: 1.25rem; font-weight: 300; 
            max-width: 600px;
        }

        /* Glass Card */
        .glass-card {
            background: rgba(10, 10, 15, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px);
            border-radius: 32px;
            padding: 50px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
            position: relative; overflow: hidden;
        }

        .glass-card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
            background: linear-gradient(90deg, transparent, rgba(168, 85, 247, 0.5), transparent);
        }

        /* Challenge Info Grid */
        .ch-info-grid {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 40px;
            margin-bottom: 40px;
            padding-bottom: 40px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .ch-title { 
            font-size: 2.5rem; font-weight: 700; margin-bottom: 16px; line-height: 1.2; 
            color: #fff; letter-spacing: -0.5px;
        }
        .ch-desc { 
            color: rgba(255,255,255,0.6); font-size: 1.15rem; line-height: 1.7; 
        }

        .ch-sidebar {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .meta-box {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 16px;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .meta-label { color: rgba(255,255,255,0.4); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
        
        .ch-status {
            font-size: 1.2rem; font-weight: 700; font-family: 'JetBrains Mono', monospace;
            color: #4ade80; display: flex; align-items: center; gap: 10px;
        }
        .ch-status::before { 
            content: ''; display: block; width: 10px; height: 10px; border-radius: 50%; 
            background: #4ade80; box-shadow: 0 0 12px #4ade80; animation: pulseDot 2s infinite; 
        }
        @keyframes pulseDot { 0% { opacity: 0.4; } 50% { opacity: 1; } 100% { opacity: 0.4; } }

        .reward-wrap { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
        .reward-pill {
            background: rgba(0,0,0,0.5); padding: 10px 16px; border-radius: 12px; 
            border: 1px solid rgba(255,255,255,0.08);
            font-family: 'JetBrains Mono', monospace; font-size: 1.1rem; font-weight: bold;
            display: flex; align-items: center; gap: 8px;
        }
        .rp-coin { color: #fbbf24; }
        .rp-point { color: #60a5fa; }
        .rp-icon { font-size: 1.2rem; }

        /* Link Input Area */
        .upload-section-title {
            font-size: 1.5rem; font-weight: 600; margin-bottom: 20px; color: #fff;
        }
        .link-input-area {
            position: relative; margin-bottom: 16px;
        }
        .link-input {
            width: 100%; padding: 20px 24px 20px 60px;
            background: rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 16px;
            color: #fff; font-size: 1.1rem;
            font-family: var(--font-body);
            transition: all 0.3s ease;
        }
        .link-input:focus {
            outline: none; border-color: #a855f7;
            background: rgba(168,85,247,0.05);
            box-shadow: 0 0 0 4px rgba(168,85,247,0.1);
        }
        .link-icon {
            position: absolute; left: 24px; top: 50%; transform: translateY(-50%);
            color: rgba(255,255,255,0.4); pointer-events: none;
            transition: color 0.3s;
        }
        .link-input:focus + .link-icon { color: #a855f7; }
        .upload-sub { color: rgba(255,255,255,0.4); font-size: 0.95rem; font-family: 'JetBrains Mono', monospace; margin-bottom: 24px; }

        /* Submit Button */
        .submit-btn {
            width: 100%; margin-top: 24px; padding: 20px; border-radius: 16px;
            background: #fff; color: #000; border: none; 
            font-size: 1.1rem; font-weight: 700; font-family: 'Outfit', sans-serif;
            cursor: pointer; text-transform: uppercase; letter-spacing: 2px;
            transition: all 0.3s;
            display: flex; justify-content: center; align-items: center; gap: 12px;
            position: relative; overflow: hidden;
        }
        .submit-btn::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(90deg, #a855f7, #ec4899);
            opacity: 0; transition: opacity 0.3s; z-index: 1;
        }
        .submit-btn span { position: relative; z-index: 2; transition: color 0.3s; }
        .submit-btn:hover::before { opacity: 1; }
        .submit-btn:hover span { color: #fff; }
        .submit-btn:disabled { opacity: 0.5; cursor: not-allowed; pointer-events: none; }

        /* Success & Winner States */
        .status-panel {
            background: rgba(34, 197, 94, 0.05); border: 1px solid rgba(34, 197, 94, 0.2); 
            border-radius: 20px; padding: 40px; text-align: center;
        }
        .status-icon {
            width: 80px; height: 80px; border-radius: 50%; background: rgba(34, 197, 94, 0.1);
            display: flex; align-items: center; justify-content: center; margin: 0 auto 24px;
        }

        .winner-panel {
            background: linear-gradient(135deg, rgba(251, 191, 36, 0.05), rgba(0,0,0,0)); 
            border: 1px solid rgba(251, 191, 36, 0.2); 
            border-radius: 24px; padding: 40px; margin-top: 40px;
            position: relative; overflow: hidden;
        }
        .winner-panel::before {
            content: ''; position: absolute; top: 0; left: 0; width: 200px; height: 200px;
            background: radial-gradient(circle, rgba(251,191,36,0.15) 0%, transparent 70%);
            transform: translate(-50%, -50%); pointer-events: none;
        }

        /* States */
        #loading-state { text-align: center; padding: 100px 0; }
        .spinner { width: 50px; height: 50px; border: 3px solid rgba(255,255,255,0.05); border-left-color: #a855f7; border-radius: 50%; animation: spin 1s cubic-bezier(0.6, 0.2, 0.4, 0.8) infinite; margin: 0 auto 24px; }
        @keyframes spin { to { transform: rotate(360deg); } }

        #empty-state { text-align: center; padding: 100px 0; display: none; }
        
        @media (max-width: 768px) {
            .ch-info-grid { grid-template-columns: 1fr; gap: 24px; }
            .header-title { font-size: 2.5rem; }
            .glass-card { padding: 30px 20px; }
        }
    </style>
</head>
<body>
    <div class="ambient-bg">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="grid-overlay"></div>
    </div>

    <%- include('../partials/navbar') %>

    <div class="challenge-container">
        <a href="/dashboard/verified_freefire" class="back-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to Arena
        </a>
        
        <div class="page-header">
            <div class="header-title">WEEKLY CHALLENGE</div>
            <div class="header-sub">Execute the objective. Upload your proof. Claim the exclusive bounty.</div>
        </div>

        <div class="glass-card">
            
            <div id="loading-state">
                <div class="spinner"></div>
                <div style="color: rgba(255,255,255,0.5); font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; letter-spacing: 2px; text-transform: uppercase;">Initializing Neural Link...</div>
            </div>

            <div id="empty-state">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1.5" style="margin-bottom:24px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                <div style="font-size: 1.8rem; font-weight:600; margin-bottom:12px; color: #fff;">No Active Intel</div>
                <div style="color:rgba(255,255,255,0.5); font-size: 1.1rem; max-width: 400px; margin: 0 auto;">High Command is currently formulating the next objective. Stand by.</div>
            </div>

            <div id="content-state" style="display: none;">
                
                <div class="ch-info-grid">
                    <div>
                        <div class="ch-title" id="ch-title-txt">Loading Objective...</div>
                        <div class="ch-desc" id="ch-desc-txt">Retrieving classified details...</div>
                    </div>
                    <div class="ch-sidebar">
                        <div class="meta-box">
                            <span class="meta-label">Status</span>
                            <div class="ch-status" id="ch-status-badge">LIVE NOW</div>
                        </div>
                        <div class="meta-box">
                            <span class="meta-label">Bounty Reward</span>
                            <div class="reward-wrap">
                                <div class="reward-pill rp-coin" style="display:flex; align-items:center; gap:8px;">
                                    <img src="/public/blaze_coin.jpg" alt="Blaze Coin" style="width: 24px; height: 24px; border-radius: 50%;"> 
                                    <span><span id="r-coins">100</span> Blaze Coins</span>
                                </div>
                                <div class="reward-pill rp-point" style="display:flex; align-items:center; gap:8px;">
                                    <span style="font-weight: 800; color: #60a5fa; letter-spacing: 1px;">BP</span> 
                                    <span><span id="r-points">20</span> Blaze Points</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="submission-section">
                    <div class="upload-section-title">Submit Proof Link</div>
                    <form id="challenge-form">
                        <div class="link-input-area">
                            <input type="url" id="clip-input" class="link-input" placeholder="Paste your Google Drive, YouTube, or public link here..." required>
                            <svg class="link-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                        </div>
                        <div class="upload-sub">Ensure the link is set to "Public" or "Anyone with the link can view" so our moderators can verify it.</div>
                        <button type="submit" class="submit-btn" id="submit-btn">
                            <span>TRANSMIT PROOF</span>
                        </button>
                    </form>
                </div>

                <div id="success-section" style="display: none;" class="status-panel">
                    <div class="status-icon">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <div style="font-size:1.8rem; font-weight:700; color:#fff; margin-bottom:12px;">Transmission Successful</div>
                    <div style="color:rgba(255,255,255,0.6); font-size:1.1rem; max-width:400px; margin:0 auto;">Your proof is securely uploaded and pending review by High Command. The bounty will be disbursed upon verification.</div>
                </div>

                <div id="winner-section" style="display: none;" class="winner-panel">
                    <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px;">
                        <span style="font-size: 2.5rem; filter: drop-shadow(0 0 10px rgba(251,191,36,0.5));">🏆</span>
                        <div>
                            <div style="color: #fbbf24; font-family: var(--font-display); font-size: 1.5rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 4px;">Objective Completed</div>
                            <div style="color: rgba(255,255,255,0.5); font-size: 1rem;">The bounty has been successfully claimed.</div>
                        </div>
                    </div>
                    <div style="background: rgba(0,0,0,0.4); border-radius: 16px; padding: 24px; display: flex; align-items: center; justify-content: space-between; border: 1px solid rgba(255,255,255,0.05);">
                        <div style="display: flex; align-items: center; gap: 16px;">
                            <div style="width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #fbbf24, #f59e0b); display: flex; justify-content: center; align-items: center; font-weight: 800; color: #000; font-size: 1.2rem; box-shadow: 0 0 20px rgba(251,191,36,0.3);">#1</div>
                            <div>
                                <div id="winner-name" style="font-weight: 700; font-size: 1.3rem; color: #fff; margin-bottom: 4px;">AgentName</div>
                                <div id="winner-id" style="color: rgba(255,255,255,0.4); font-size: 0.9rem; font-family: 'JetBrains Mono', monospace;">ID: 12345678</div>
                            </div>
                        </div>
                        <div style="color: #4ade80; font-weight: bold; font-family: 'JetBrains Mono', monospace; font-size: 1rem; padding: 8px 16px; background: rgba(34,197,94,0.1); border-radius: 30px; border: 1px solid rgba(34,197,94,0.2);">
                            BOUNTY AWARDED
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('blaze_token');
            if(!token) { window.location.href = '/auth'; return; }

            let currentChallengeId = null;

            // Fetch active challenge
            try {
                const res = await fetch('/api/challenges/active', {
                    headers: { 'x-auth-token': token }
                });
                
                document.getElementById('loading-state').style.display = 'none';

                if (!res.ok) throw new Error('Failed to fetch');
                const data = await res.json();

                if (!data || !data._id) {
                    document.getElementById('empty-state').style.display = 'block';
                    return;
                }

                currentChallengeId = data._id;
                document.getElementById('content-state').style.display = 'block';
                document.getElementById('ch-title-txt').innerText = data.title;
                document.getElementById('ch-desc-txt').innerText = data.description;
                document.getElementById('r-coins').innerText = data.rewardCoins;
                document.getElementById('r-points').innerText = data.rewardPoints;

                if (data.winner) {
                    // Update status badge
                    const statusBadge = document.querySelector('.ch-status');
                    statusBadge.innerHTML = 'COMPLETED';
                    statusBadge.style.background = 'rgba(251, 191, 36, 0.1)';
                    statusBadge.style.color = '#fbbf24';
                    statusBadge.style.borderColor = 'rgba(251, 191, 36, 0.3)';

                    // Hide submission form, show leaderboard
                    document.getElementById('submission-section').style.display = 'none';
                    document.getElementById('winner-section').style.display = 'block';
                    document.getElementById('winner-name').innerText = data.winner.inGameName || data.winner.username;
                    document.getElementById('winner-id').innerText = 'ID: ' + (data.winner.playerId || 'N/A');
                }

            } catch(e) {
                document.getElementById('loading-state').style.display = 'none';
                document.getElementById('empty-state').style.display = 'block';
                console.error(e);
            }

            // Form submission
            document.getElementById('challenge-form').addEventListener('submit', async (e) => {
                e.preventDefault();
                const btn = document.getElementById('submit-btn');
                const linkValue = document.getElementById('clip-input').value.trim();

                if(!linkValue || !currentChallengeId) return;

                btn.disabled = true;
                btn.innerHTML = '<span><div class="spinner" style="width:20px;height:20px;margin:0;border-width:2px;display:inline-block;vertical-align:middle;margin-right:10px;"></div> TRANSMITTING...</span>';

                try {
                    const res = await fetch('/api/challenges/submit', {
                        method: 'POST',
                        headers: { 
                            'Content-Type': 'application/json',
                            'x-auth-token': token 
                        },
                        body: JSON.stringify({ challengeId: currentChallengeId, videoUrl: linkValue })
                    });
                    const data = await res.json();
                    
                    if (res.ok) {
                        document.getElementById('submission-section').style.display = 'none';
                        document.getElementById('success-section').style.display = 'block';
                    } else {
                        alert(data.msg || 'Submission failed');
                        btn.disabled = false;
                        btn.innerHTML = '<span>TRANSMIT PROOF</span>';
                    }
                } catch(err) {
                    alert('An error occurred during submission.');
                    btn.disabled = false;
                    btn.innerHTML = '<span>TRANSMIT PROOF</span>';
                }
            });
        });
    </script>
</body>
</html>
