    <div id="toast-container"></div>

    <script src="/script.js?v=1.2"></script>
    <script>
        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            const toast = document.createElement('div');
            toast.className = `org-toast ${type} show`;
            toast.textContent = message;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        async function searchUserProfile() {
            const pid = document.getElementById('search-blaze-id').value.trim();
            if (!pid) return showToast('Please enter a Blaze ID', 'error');
            
            const modal = document.getElementById('viewProfileModal');
            modal.style.display = 'flex';
            modal.style.opacity = '1';
            modal.style.visibility = 'visible';
            
            document.getElementById('search-loading').style.display = 'block';
            document.getElementById('search-result').style.display = 'none';
            document.getElementById('search-error').style.display = 'none';
            
            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch(`/api/player/${pid}`, {
                    headers: { 'x-auth-token': token }
                });
                
                if (!res.ok) {
                    document.getElementById('search-loading').style.display = 'none';
                    document.getElementById('search-error').style.display = 'block';
                    return;
                }
                
                const data = await res.json();
                document.getElementById('sp-name').textContent = data.inGameName || data.username;
                document.getElementById('sp-avatar').src = data.profilePic || '/public/blaze_avatar.png';
                document.getElementById('sp-bc').textContent = data.blazeCoins || 0;
                document.getElementById('sp-matches').textContent = data.totalMatches || 0;
                document.getElementById('sp-wins').textContent = data.tournamentsWon || 0;
                document.getElementById('sp-user').textContent = data.username || '—';
                document.getElementById('sp-pid').textContent = data.playerId;
                document.getElementById('sp-uid').textContent = data.gameUid || '—';
                document.getElementById('sp-region').textContent = data.location || '—';
                
                const setupEl = document.getElementById('sp-setup');
                if (data.isSetupComplete) {
                    setupEl.textContent = 'COMPLETE';
                    setupEl.style.color = '#22c55e';
                } else {
                    setupEl.textContent = 'PENDING';
                    setupEl.style.color = '#ef4444';
                }
                
                const badge = document.getElementById('sp-badge');
                if (data.role === 'organizer') {
                    badge.textContent = 'ORGANIZER';
                    badge.style.background = 'rgba(139, 92, 246, 0.2)';
                    badge.style.color = '#a78bfa';
                    badge.style.border = '1px solid rgba(139, 92, 246, 0.4)';
                    document.getElementById('sp-avatar').style.borderColor = '#a78bfa';
                } else if (data.isGenuine) {
                    badge.textContent = 'TRUSTED';
                    badge.style.background = 'rgba(255, 215, 0, 0.2)';
                    badge.style.color = '#ffd700';
                    badge.style.border = '1px solid rgba(255, 215, 0, 0.4)';
                    document.getElementById('sp-avatar').style.borderColor = '#ffd700';
                } else {
                    badge.textContent = 'UNVERIFIED';
                    badge.style.background = 'rgba(255, 255, 255, 0.05)';
                    badge.style.color = 'var(--text-muted)';
                    badge.style.border = '1px solid rgba(255, 255, 255, 0.1)';
                    document.getElementById('sp-avatar').style.borderColor = 'rgba(255,255,255,0.1)';
                }
                
                document.getElementById('search-loading').style.display = 'none';
                document.getElementById('search-result').style.display = 'block';
                
            } catch (err) {
                console.error(err);
                closeViewProfileModal();
                showToast('Error fetching profile', 'error');
            }
        }
        
        function closeViewProfileModal() {
            const modal = document.getElementById('viewProfileModal');
            modal.style.display = 'none';
            modal.style.opacity = '0';
            modal.style.visibility = 'hidden';
        }

        function openEditProfileModal() {
            const modal = document.getElementById('editProfileModal');
            modal.style.display = 'flex';
            modal.style.opacity = '1';
            modal.style.visibility = 'visible';
            document.getElementById('editInGameName').value = document.getElementById('ph-name').innerText;
            document.getElementById('editGameUid').value = document.getElementById('ph-uid').innerText;
            document.getElementById('edit-avatar-preview').src = document.getElementById('ph-avatar').src;
        }

        function closeEditProfileModal() {
            const modal = document.getElementById('editProfileModal');
            modal.style.display = 'none';
            modal.style.opacity = '0';
            modal.style.visibility = 'hidden';
        }

        function previewAvatar(event) {
            const file = event.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('edit-avatar-preview').src = e.target.result;
                }
                reader.readAsDataURL(file);
            }
        }

        async function handleEditProfile(e) {
            e.preventDefault();
            const btn = document.getElementById('saveProfileBtn');
            const originalText = btn.innerText;
            btn.innerText = 'Saving...';
            btn.disabled = true;

            const inGameName = document.getElementById('editInGameName').value;
            const gameUid = document.getElementById('editGameUid').value;
            const fileInput = document.getElementById('profilePicInput');

            const formData = new FormData();
            if (inGameName) formData.append('inGameName', inGameName);
            if (gameUid) formData.append('gameUid', gameUid);
            if (fileInput.files[0]) formData.append('profilePic', fileInput.files[0]);

            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch('/api/profile', {
                    method: 'PUT',
                    headers: { 'x-auth-token': token },
                    body: formData
                });

                if (res.ok) {
                    const data = await res.json();
                    // Update DOM
                    if (data.inGameName) document.getElementById('ph-name').innerText = data.inGameName;
                    if (data.gameUid) document.getElementById('ph-uid').innerText = data.gameUid;
                    if (data.profilePic) document.getElementById('ph-avatar').src = data.profilePic;
                    
                    showToast('Profile updated successfully!', 'success');
                    closeEditProfileModal();
                } else {
                    showToast('Failed to update profile', 'error');
                }
            } catch (err) {
                console.error(err);
                showToast('An error occurred', 'error');
            } finally {
                btn.innerText = originalText;
                btn.disabled = false;
            }
        }
    </script>

        <script>
            document.addEventListener('DOMContentLoaded', async () => {
                const token = localStorage.getItem('blaze_token');
                if (!token) { window.location.href = '/auth'; return; }

                // --- UI Rendering Function ---
                const renderProfile = (u) => {
                    document.getElementById('ph-name').textContent = u.inGameName || u.username;
                    document.getElementById('ph-region').textContent = u.location || '—';
                    document.getElementById('ph-uid').textContent = u.gameUid || '—';
                    if (document.getElementById('ph-pid-header')) document.getElementById('ph-pid-header').textContent = u.playerId || '—';
                    
                    const avatarEl = document.getElementById('ph-avatar');
                    if (u.profilePic && u.profilePic.trim() !== '') {
                        const tempImg = new Image();
                        tempImg.onload = () => { avatarEl.src = u.profilePic; };
                        tempImg.onerror = () => { avatarEl.src = '/public/blaze_avatar.png'; };
                        tempImg.src = u.profilePic;
                    } else {
                        avatarEl.src = '/public/blaze_avatar.png';
                    }

                    if (document.getElementById('st-bc')) document.getElementById('st-bc').textContent = u.blazeCoins || 0;
                    if (document.getElementById('st-bp')) document.getElementById('st-bp').textContent = u.blazePoints || 0;
                    document.getElementById('st-matches').textContent = u.totalMatches || 0;
                    
                    // Render Streak Row
                    const currentStreak = u.currentStreak || 0;
                    const visualStreak = currentStreak % 7 === 0 && currentStreak > 0 ? 7 : currentStreak % 7;
                    const daysContainer = document.getElementById('streak-days');
                    let daysHTML = '';
                    for (let i = 1; i <= 7; i++) {
                        if (i <= visualStreak) {
                            daysHTML += `<div style="width: 24px; height: 24px; border-radius: 50%; background: var(--blaze-orange); display: flex; justify-content: center; align-items: center; box-shadow: 0 0 8px rgba(255,87,34,0.6);"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></div>`;
                        } else {
                            daysHTML += `<div style="width: 24px; height: 24px; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: center; align-items: center; color: var(--text-muted); font-size: 0.7rem; font-weight: bold;">${i}</div>`;
                        }
                    }
                    daysContainer.innerHTML = daysHTML;
                    
                    const stWinsEl = document.getElementById('st-wins');
                    if (stWinsEl) stWinsEl.textContent = u.tourneysWon || 0;
                    
                    // Platform Ranking logic
                    document.getElementById('rank-text').textContent = 'NATIONAL';
                    document.getElementById('rank-icon').textContent = u.globalRank ? `#${u.globalRank}` : '#0';
                    document.getElementById('rank-prog').style.width = u.globalRankPercentile ? `${100 - u.globalRankPercentile}%` : '0%';
                    
                    if (document.getElementById('rank-icon-regional')) {
                        document.getElementById('rank-text-regional').textContent = u.location || 'REGION';
                        document.getElementById('rank-icon-regional').textContent = u.regionalRank ? `#${u.regionalRank}` : '#0';
                    }

                    document.getElementById('dp-user').textContent = u.username || '—';
                    document.getElementById('dp-ign').textContent = u.inGameName || '—';
                    document.getElementById('dp-setup').textContent = u.isSetupComplete ? 'COMPLETE' : 'PENDING';
                    document.getElementById('dp-region').textContent = u.location || '—';
                    document.getElementById('dp-uid').textContent = u.gameUid || '—';
                    document.getElementById('dp-pid').textContent = u.playerId || '—';

                    // Avatar and badge styling based on role and genuine status
                    if (u.role === 'organizer') {
                        // Organizer: Purple theme
                        document.getElementById('ph-avatar').style.borderColor = '#a78bfa';
                        document.getElementById('ph-avatar').style.boxShadow = '0 0 20px rgba(139, 92, 246, 0.4)';
                        document.getElementById('ph-badge').style.display = 'none';
                        document.getElementById('ph-watermark').style.display = 'block';
                        document.getElementById('ph-watermark').querySelector('div').textContent = 'ORGANIZER';
                        document.getElementById('ph-watermark').querySelector('div').style.color = 'rgba(139, 92, 246, 0.06)';
                        document.getElementById('dp-pid').style.color = '#a78bfa';
                        document.getElementById('dp-pid').style.textShadow = '0 0 8px rgba(139,92,246,0.3)';
                        document.getElementById('profile-header').style.background = 'linear-gradient(180deg, rgba(139, 92, 246, 0.15) 0%, #111116 100%)';
                    } else if (u.isGenuine) {
                        document.getElementById('ph-avatar').style.borderColor = '#ffd700';
                        document.getElementById('ph-avatar').style.boxShadow = '0 0 20px rgba(255, 215, 0, 0.4)';
                        document.getElementById('ph-badge').style.display = 'none'; // Hide the badge
                        document.getElementById('ph-watermark').style.display = 'block'; // Show watermark
                        document.getElementById('ph-watermark').querySelector('div').textContent = 'TRUSTED';
                        document.getElementById('ph-watermark').querySelector('div').style.color = 'rgba(255, 215, 0, 0.04)';
                        document.getElementById('dp-pid').style.color = '#ffd700'; // Make Blaze ID golden
                        document.getElementById('dp-pid').style.textShadow = '0 0 8px rgba(255,215,0,0.3)';
                        document.getElementById('profile-header').style.background = 'linear-gradient(180deg, rgba(255, 215, 0, 0.15) 0%, #111116 100%)';
                    } else {
                        document.getElementById('ph-badge').style.display = 'block';
                        document.getElementById('ph-badge').textContent = 'UNVERIFIED';
                        document.getElementById('ph-badge').style.background = 'rgba(255, 255, 255, 0.05)';
                        document.getElementById('ph-badge').style.color = 'var(--text-muted)';
                        document.getElementById('ph-badge').style.border = '1px solid rgba(255, 255, 255, 0.1)';
                        document.getElementById('ph-watermark').style.display = 'none';
                        document.getElementById('dp-pid').style.color = '#fff';
                        document.getElementById('dp-pid').style.textShadow = 'none';
                    }

                    // Activity Heatmap
                    let seed = 0;
                    const nameForSeed = u.username || 'blaze';
                    for (let i = 0; i < nameForSeed.length; i++) seed += nameForSeed.charCodeAt(i);
                    const pseudoRandom = () => {
                        let x = Math.sin(seed++) * 10000;
                        return x - Math.floor(x);
                    };

                    const heatmapGrid = document.getElementById('heatmap-grid');
                    const heatmapMonths = document.getElementById('heatmap-months');
                    if (heatmapGrid && heatmapMonths) {
                        heatmapGrid.innerHTML = '';
                        heatmapMonths.innerHTML = '';
                        
                        const today = new Date();
                        
                        // Dynamically calculate grid start: 1st of the previous month, anchored to Sunday
                        const firstDayOfPrevMonth = new Date(today.getFullYear(), today.getMonth() - 1, 1);
                        const startOfGrid = new Date(firstDayOfPrevMonth);
                        startOfGrid.setDate(firstDayOfPrevMonth.getDate() - firstDayOfPrevMonth.getDay());
                        
                        // Exact days passed since the grid start
                        const totalDays = Math.floor((today - startOfGrid) / (1000 * 60 * 60 * 24)) + 1;
                        
                        let currentMonth = -1;
                        let lastLabelLeft = -50; // Track position of last label to avoid clustering
                        const colWidth = 20; // 14px width + 6px gap
                        const activity = u.activityLog || {};

                        for (let i = 0; i < totalDays; i++) { 
                            const box = document.createElement('div');
                            box.style.width = '14px';
                            box.style.height = '14px';
                            box.style.borderRadius = '3px';
                            box.style.transition = 'transform 0.2s, box-shadow 0.2s';
                            box.style.position = 'relative';
                            box.style.cursor = 'pointer';
                            
                            let tooltip = document.getElementById('heatmap-tooltip');
                            if (!tooltip) {
                                tooltip = document.createElement('div');
                                tooltip.id = 'heatmap-tooltip';
                                tooltip.style.position = 'absolute';
                                tooltip.style.display = 'none';
                                tooltip.style.background = 'rgba(17, 17, 22, 0.98)';
                                tooltip.style.border = '1px solid rgba(255, 87, 34, 0.4)';
                                tooltip.style.padding = '8px 12px';
                                tooltip.style.borderRadius = '8px';
                                tooltip.style.fontSize = '0.75rem';
                                tooltip.style.color = '#fff';
                                tooltip.style.zIndex = '9999';
                                tooltip.style.pointerEvents = 'none';
                                tooltip.style.boxShadow = '0 6px 16px rgba(0,0,0,0.8)';
                                tooltip.style.whiteSpace = 'nowrap';
                                tooltip.style.transform = 'translate(-50%, -100%)';
                                tooltip.style.fontFamily = 'var(--font-main)';
                                document.body.appendChild(tooltip);
                            }
                            
                            // Get date
                            const date = new Date(today.getFullYear(), today.getMonth(), today.getDate() - (totalDays - 1 - i));
                            
                            // Check for month change to place label
                            if (date.getMonth() !== currentMonth) {
                                currentMonth = date.getMonth();
                                const colIndex = Math.floor(i / 7);
                                const currentLeft = colIndex * colWidth;
                                
                                // Skip printing if it's the very first column but just the tail end of an unwanted month (e.g., May 31)
                                if (i < 7 && date.getDate() > 20) {
                                    // Skip to cleanly start labels with the target month
                                } else if (currentLeft - lastLabelLeft >= 45) {
                                    const monthLabel = document.createElement('div');
                                    monthLabel.textContent = date.toLocaleString('default', { month: 'short' });
                                    monthLabel.style.position = 'absolute';
                                    monthLabel.style.left = `${currentLeft}px`;
                                    heatmapMonths.appendChild(monthLabel);
                                    lastLabelLeft = currentLeft;
                                }
                            }

                            // Match the backend local date string key
                            const dateStrKey = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;
                            const activeMinutes = activity[dateStrKey] || 0;

                            let bg = 'rgba(255,255,255,0.05)'; // 0 activity
                            if (activeMinutes >= 30) bg = 'rgba(255,87,34,1)'; // High
                            else if (activeMinutes >= 15) bg = 'rgba(255,87,34,0.8)'; // Med
                            else if (activeMinutes >= 5) bg = 'rgba(255,87,34,0.6)'; // Low
                            else if (activeMinutes > 0) bg = 'rgba(255,87,34,0.3)'; // Very low (just logged in)

                            box.style.background = bg;
                            
                            // tooltip logic with accurate dynamic date and active minutes
                            const dateStr = date.toLocaleDateString(undefined, { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' });
                            
                            const showTooltip = (e) => {
                                box.style.transform = 'scale(1.2)'; 
                                box.style.boxShadow = '0 0 8px rgba(255,87,34,0.5)'; 
                                box.style.zIndex = '10';
                                
                                let info = '<span style="color:var(--text-muted)">Activity:</span> <span style="color:#fff">No logins</span>';
                                if (activeMinutes >= 30) info = '<span style="color:var(--text-muted)">Activity:</span> <span style="color:#ff5722; font-weight:bold;">High</span> (' + activeMinutes + ' mins)';
                                else if (activeMinutes >= 15) info = '<span style="color:var(--text-muted)">Activity:</span> <span style="color:#f4714d; font-weight:bold;">Med</span> (' + activeMinutes + ' mins)';
                                else if (activeMinutes > 0) info = '<span style="color:var(--text-muted)">Activity:</span> <span style="color:#e0937a;">Low</span> (' + activeMinutes + ' mins)';
                                
                                tooltip.innerHTML = `<strong>${dateStr}</strong><br><div style="margin-top: 4px;">${info}</div>`;
                                tooltip.style.display = 'block';
                                
                                const rect = box.getBoundingClientRect();
                                tooltip.style.left = `${rect.left + window.scrollX + (rect.width / 2)}px`;
                                tooltip.style.top = `${rect.top + window.scrollY - 8}px`;
                                
                                // Prevent click from instantly closing if clicking on mobile
                                e.stopPropagation();
                            };

                            const hideTooltip = () => {
                                box.style.transform = 'scale(1)'; 
                                box.style.boxShadow = 'none'; 
                                box.style.zIndex = '1';
                                tooltip.style.display = 'none';
                            };

                            box.onmouseover = showTooltip;
                            box.onclick = showTooltip;
                            box.onmouseout = hideTooltip;

                            heatmapGrid.appendChild(box);
                        }
                        
                        // Close tooltip globally on click elsewhere for mobile
                        document.addEventListener('click', () => {
                            const tooltip = document.getElementById('heatmap-tooltip');
                            if (tooltip) tooltip.style.display = 'none';
                        });
                    }

                    updateRewardsStatus(u);
                };

                // Update rewards status function
                const updateRewardsStatus = (userData) => {
                    const firstBtn = document.getElementById('first-login-btn');
                    const dailyBtn = document.getElementById('daily-login-btn');
                    const trustedBtn = document.getElementById('trusted-player-btn');

                    if (userData.firstLoginClaimed) {
                        document.getElementById('first-login-container').style.display = 'none';
                    } else {
                        document.getElementById('first-login-container').style.display = 'flex';
                        firstBtn.textContent = 'CLAIM';
                        firstBtn.disabled = false;
                        firstBtn.style.background = 'var(--blaze-orange)';
                        firstBtn.style.color = '#fff';
                        firstBtn.style.cursor = 'pointer';
                    }

                    if (!userData.isGenuine) {
                        trustedBtn.textContent = 'NOT ELIGIBLE';
                        trustedBtn.disabled = true;
                        trustedBtn.style.background = 'rgba(255,255,255,0.05)';
                        trustedBtn.style.color = 'var(--text-muted)';
                        trustedBtn.style.cursor = 'not-allowed';
                        trustedBtn.style.boxShadow = 'none';
                    } else if (userData.trustedPlayerClaimed) {
                        trustedBtn.textContent = 'CLAIMED';
                        trustedBtn.disabled = true;
                        trustedBtn.style.background = 'rgba(255,255,255,0.05)';
                        trustedBtn.style.color = 'var(--text-muted)';
                        trustedBtn.style.cursor = 'not-allowed';
                        trustedBtn.style.boxShadow = 'none';
                    } else {
                        trustedBtn.textContent = 'CLAIM';
                        trustedBtn.disabled = false;
                        trustedBtn.style.background = 'var(--blaze-orange)';
                        trustedBtn.style.color = '#fff';
                        trustedBtn.style.cursor = 'pointer';
                    }

                    let canClaimDaily = false;
                    if (!userData.lastLoginClaimDate) {
                        canClaimDaily = true;
                    } else {
                        const lastClaim = new Date(userData.lastLoginClaimDate);
                        const now = new Date();
                        const isSameDayUTC = lastClaim.getUTCFullYear() === now.getUTCFullYear() &&
                                             lastClaim.getUTCMonth() === now.getUTCMonth() &&
                                             lastClaim.getUTCDate() === now.getUTCDate();
                        if (!isSameDayUTC) {
                            canClaimDaily = true;
                        }
                    }

                    if (!canClaimDaily) {
                        dailyBtn.textContent = 'CLAIMED';
                        dailyBtn.disabled = true;
                        dailyBtn.style.background = 'rgba(255,255,255,0.05)';
                        dailyBtn.style.color = 'var(--text-muted)';
                        dailyBtn.style.cursor = 'not-allowed';
                        dailyBtn.style.boxShadow = 'none';
                    } else {
                        dailyBtn.textContent = 'CLAIM';
                        dailyBtn.disabled = false;
                        dailyBtn.style.background = 'var(--blaze-orange)';
                        dailyBtn.style.color = '#fff';
                        dailyBtn.style.cursor = 'pointer';
                    }
                };

                // Attach claim handlers (global function)
                window.handleClaim = async (type, btnId) => {
                    const btn = document.getElementById(btnId);
                    if (btn.disabled) return;

                    try {
                        btn.textContent = '...';
                        const claimRes = await fetch('/api/user/claim-bonus', {
                            method: 'POST',
                            headers: {
                                'x-auth-token': token,
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({ type })
                        });
                        const claimData = await claimRes.json();
                        
                        if (claimData.claimed) {
                            if (document.getElementById('st-bc')) document.getElementById('st-bc').textContent = claimData.totalBonus;
                            const freshRes = await fetch('/api/profile', { headers: { 'x-auth-token': token }, cache: 'no-store' });
                            if (freshRes.ok) {
                                const freshU = await freshRes.json();
                                localStorage.setItem(window.getBlazeCacheKey ? window.getBlazeCacheKey() : 'blaze_profile_cache', JSON.stringify(freshU));
                                renderProfile(freshU);
                            }
                        } else {
                            btn.textContent = 'CLAIMED';
                        }
                    } catch (e) {
                        console.error(e);
                        btn.textContent = 'ERROR';
                    }
                };

                document.getElementById('first-login-btn').addEventListener('click', () => window.handleClaim('first', 'first-login-btn'));
                document.getElementById('daily-login-btn').addEventListener('click', () => window.handleClaim('daily', 'daily-login-btn'));
                document.getElementById('trusted-player-btn').addEventListener('click', () => window.handleClaim('trusted', 'trusted-player-btn'));

                // --- Execution Logic ---
                // 1. Immediately load from cache
                const cacheKey = window.getBlazeCacheKey ? window.getBlazeCacheKey() : 'blaze_profile_cache';
                const cached = localStorage.getItem(cacheKey);
                if (cached) {
                    try {
                        renderProfile(JSON.parse(cached));
                    } catch (e) { console.error('Cache parse error', e); }
                }

                // 2. Fetch fresh data in the background
                try {
                    const res = await fetch('/api/profile', { headers: { 'x-auth-token': token }, cache: 'no-store' });
                    if (res.status === 401 || res.status === 404) {
                        localStorage.removeItem('blaze_token');
                        localStorage.removeItem(cacheKey);
                        window.location.href = '/auth';
                        return;
                    }
                    if (!res.ok) throw new Error();
                    const u = await res.json();
                    
                    // Save to cache and re-render
                    localStorage.setItem(cacheKey, JSON.stringify(u));
                    renderProfile(u);
                } catch (err) {
                    console.error('Failed to fetch profile', err);
                }
            });
        </script>
</body>

</html>
