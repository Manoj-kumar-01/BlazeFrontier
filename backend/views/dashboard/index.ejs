<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .dash {
            display: grid; grid-template-columns: 1fr 1fr 1fr 340px;
            grid-template-rows: auto auto 1fr;
            gap: 14px; padding: 88px 20px 20px; min-height: 100vh;
            max-width: 1500px; margin: 0 auto;
        }

        .card {
            background: #111116; border: 1px solid rgba(255,255,255,0.06);
            border-radius: 12px; padding: 24px;
        }

        /* Welcome — full width top */
        .c-welcome {
            grid-column: 1 / -1;
            display: flex; justify-content: space-between; align-items: center; gap: 20px;
            padding: 28px 32px;
        }
        .cw-title { font-family: var(--font-display); font-size: 2.2rem; color: #fff; letter-spacing: 1px; }
        .cw-sub { color: var(--text-muted); font-size: 0.85rem; margin-top: 2px; }
        .cw-btn {
            padding: 12px 28px; border-radius: 8px; border: none;
            background: var(--blaze-orange); color: #fff;
            font-family: var(--font-display); font-size: 1.1rem; letter-spacing: 1px;
            cursor: pointer; transition: all 0.2s; white-space: nowrap;
        }
        .cw-btn:hover { box-shadow: 0 4px 16px rgba(255,87,34,0.3); transform: translateY(-1px); }

        /* Stat cards — top row */
        .c-stat { display: flex; flex-direction: column; justify-content: center; }
        .cs-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); font-weight: 600; margin-bottom: 6px; }
        .cs-val { font-family: var(--font-display); font-size: 2.4rem; color: #fff; line-height: 1; }
        .cs-sub { font-size: 0.75rem; color: var(--text-muted); margin-top: 6px; font-family: var(--font-mono); }

        /* News — spans 3 cols, fills remaining height */
        .c-news { grid-column: 1 / 4; grid-row: 3; overflow-y: auto; }
        .cn-title {
            font-family: var(--font-display); font-size: 1.3rem; color: #fff; letter-spacing: 1px;
            margin-bottom: 16px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.06);
        }
        .news-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
        .n-item {
            background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.04);
            border-radius: 10px; padding: 18px; transition: border-color 0.2s;
        }
        .n-item:hover { border-color: rgba(255,255,255,0.1); }
        .n-tag {
            display: inline-block; font-size: 0.6rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 1.5px; padding: 2px 6px; border-radius: 3px; margin-bottom: 8px;
        }
        .n-tag.announce { background: rgba(255,87,34,0.1); color: var(--blaze-orange); }
        .n-tag.update { background: rgba(34,197,94,0.1); color: #22c55e; }
        .n-tag.event { background: rgba(240,165,0,0.1); color: #f0a500; }
        .n-tag.maint { background: rgba(255,255,255,0.05); color: var(--text-muted); }
        .n-title { color: #fff; font-size: 0.9rem; font-weight: 600; line-height: 1.4; margin-bottom: 4px; }
        .n-date { color: var(--text-muted); font-size: 0.7rem; font-family: var(--font-mono); }

        /* Sidebar — right column, spans rows 2+3 */
        .c-sidebar { grid-column: 4; grid-row: 2 / 4; display: flex; flex-direction: column; gap: 14px; }

        .side-panel {
            background: #111116; border: 1px solid rgba(255,255,255,0.06);
            border-radius: 12px; padding: 20px; flex: 1;
        }
        .sp-title {
            font-family: var(--font-display); font-size: 1.1rem; color: #fff; letter-spacing: 1px;
            margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        /* Live matches */
        .live-item { padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
        .live-item:last-child { border-bottom: none; }
        .li-game { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: var(--blaze-orange); margin-bottom: 3px; }
        .li-name { color: #fff; font-size: 0.85rem; font-weight: 500; margin-bottom: 3px; }
        .li-status { display: flex; align-items: center; gap: 5px; font-size: 0.7rem; font-weight: 600; color: #22c55e; }
        .li-dot { width: 5px; height: 5px; border-radius: 50%; background: #22c55e; animation: blink 1.2s infinite; }
        @keyframes blink { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }

        /* Quick stats */
        .qs-row { display: flex; justify-content: space-between; padding: 7px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
        .qs-row:last-child { border-bottom: none; }
        .qs-label { color: var(--text-muted); font-size: 0.8rem; }
        .qs-val { color: #fff; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 600; }

        .view-link {
            display: block; text-align: center; color: var(--blaze-orange); text-decoration: none;
            font-size: 0.75rem; font-weight: 600; letter-spacing: 1px; margin-top: 10px; transition: color 0.2s;
        }
        .view-link:hover { color: #fff; }

        @media (max-width: 1100px) {
            .dash { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto auto auto; }
            .c-welcome { grid-column: 1 / -1; }
            .c-news { grid-column: 1 / -1; }
            .c-sidebar { grid-column: 1 / -1; grid-row: auto; flex-direction: row; }
            .news-grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 700px) {
            .dash { grid-template-columns: 1fr 1fr; padding: 88px 10px 10px; }
            .c-welcome, .c-sidebar, .c-news { grid-column: 1 / -1; }
            .c-stat:nth-child(2) { display: none; }
            .c-welcome { flex-direction: column; text-align: center; }
            .c-sidebar { flex-direction: column; }
            .cs-val { font-size: 2rem; }
        }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="dash">
        <!-- Welcome -->
        <div class="card c-welcome">
            <div>
                <div class="cw-title">FRONTIER HUB</div>
                <div class="cw-sub">Platform updates, daily content, and cross-arena events.</div>
            </div>
            <button class="cw-btn" id="enter-arena-btn">ENTER ARENA →</button>
        </div>

        <!-- Stats row -->
        <div class="card c-stat" style="background: linear-gradient(135deg, rgba(255,87,34,0.15) 0%, rgba(15,15,20,0.95) 100%); border: 1px solid rgba(255,87,34,0.4); border-left: 4px solid var(--blaze-orange); position: relative; overflow: hidden; box-shadow: 0 0 20px rgba(255,87,34,0.15);">
            <div style="position: absolute; top: -10px; right: -15px; font-size: 6rem; opacity: 0.04; transform: rotate(15deg);">🔥</div>
            <div class="cs-label" style="color: var(--blaze-orange); font-weight: 800; letter-spacing: 1.5px; display: flex; align-items: center; gap: 8px; text-shadow: 0 0 10px rgba(255,87,34,0.3);">
                <span style="font-size: 1.2rem;">🔥</span> THE BLAZE ICON
            </div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                <div class="cs-val" id="stat-top-commander" style="font-size: 1.7rem; color: #fff; font-family: var(--font-display); letter-spacing: 1px;">Loading...</div>
                <div style="display: flex; align-items: center; gap: 6px; background: rgba(0,0,0,0.3); padding: 4px 10px; border-radius: 20px; border: 1px solid rgba(255,87,34,0.3);">
                    <span id="stat-tc-coins" style="color: #fbbf24; font-size: 1.1rem; font-family: var(--font-display); font-weight: bold;">...</span> 
                    <img src="/public/blaze_coin.jpg" style="height: 18px; width: 18px; border-radius: 50%; box-shadow: 0 0 5px rgba(255,193,7,0.5);" alt="BlazeCoins">
                </div>
            </div>
            <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 4px;">ID: <span id="stat-tc-id" style="color: var(--cyan); font-family: var(--font-mono);">...</span></div>
        </div>
        <div class="card c-stat">
            <div class="cs-label">Active</div>
            <div class="cs-val" id="stat-commanders">...</div>
            <div class="cs-sub">Global unique players</div>
        </div>
        <div class="card c-stat">
            <div class="cs-label">Matches Today</div>
            <div class="cs-val" id="stat-matches">...</div>
            <div class="cs-sub">Across all arenas</div>
        </div>

        <!-- Sidebar -->
        <div class="c-sidebar">
            <div class="side-panel" style="padding-bottom: 5px; margin-bottom: 10px;">
                <div class="sp-title" style="margin-bottom: 10px;">DAILY HIGHLIGHTS</div>
                <div id="live-matches-container">
                    <div class="live-item"><div class="li-name" style="color:var(--text-muted)">Loading...</div></div>
                </div>
            </div>
            <div class="side-panel potd-panel" id="potd-container" style="padding: 0; overflow: hidden; position: relative; min-height: 200px; display: flex; align-items: flex-end; justify-content: flex-start; border: 1px solid rgba(255,215,0,0.2); box-shadow: 0 8px 32px rgba(0,0,0,0.5); cursor: pointer; transition: transform 0.2s;">
                <video id="potd-video" autoplay loop muted playsinline style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; filter: brightness(0.5); transition: filter 0.3s;"></video>
                <div style="position: relative; z-index: 2; padding: 20px; width: 100%; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0) 100%);">
                    <div style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: #FFD700; margin-bottom: 4px; text-shadow: 0 2px 4px rgba(0,0,0,0.8);">★ PLAYER OF THE DAY ★</div>
                    <div id="potd-player" style="font-family: var(--font-display); font-size: 1.8rem; color: #fff; line-height: 1.1; margin-bottom: 2px; text-shadow: 0 2px 8px rgba(0,0,0,0.9);">Loading...</div>
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <span style="color: var(--text-muted); font-size: 0.8rem;">Blaze ID:</span>
                        <div id="potd-title" style="color: var(--cyan); font-family: var(--font-mono); font-size: 0.9rem; font-weight: 600;">Please wait</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- News -->
        <div class="card c-news">
            <div class="cn-title">PLATFORM UPDATES</div>
            <div class="news-grid" id="news-container">
                <div class="n-item"><div class="n-title" style="color:var(--text-muted)">Loading updates...</div></div>
            </div>
        </div>
    </div>

    <script src="/script.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('blaze_token');
            if (!token) { window.location.href = '/auth'; return; }
            try {
                const res = await fetch('/api/profile', { headers: { 'x-auth-token': token } });
                if (res.status === 401 || res.status === 404) {
                    localStorage.removeItem('blaze_token');
                    window.location.href = '/auth';
                    return;
                }
                if (res.ok) {
                    const user = await res.json();
                    document.getElementById('enter-arena-btn').addEventListener('click', () => {
                        window.location.href = '/dashboard/freefire';
                    });
                }
                
                // Fetch dynamic stats
                const statsRes = await fetch('/api/dashboard/stats', { headers: { 'x-auth-token': token } });
                if (statsRes.ok) {
                    const stats = await statsRes.json();
                    
                    const tcEl = document.getElementById('stat-top-commander');
                    if(tcEl && stats.topCommander) {
                        tcEl.innerHTML = stats.topCommander.name || 'No Player';
                        document.getElementById('stat-tc-id').innerText = stats.topCommander.id || 'N/A';
                        document.getElementById('stat-tc-coins').innerText = stats.topCommander.coins || '0';
                    } else if (tcEl) {
                        tcEl.innerHTML = 'No Player';
                    }
                    
                    document.getElementById('stat-commanders').innerText = stats.activeCommanders;
                    document.getElementById('stat-matches').innerText = stats.matchesToday;
                    
                    // Player of the Day
                    if (stats.potd) {
                        document.getElementById('potd-video').src = stats.potd.videoUrl;
                        document.getElementById('potd-player').innerText = stats.potd.playerName;
                        document.getElementById('potd-title').innerText = stats.potd.playerId;
                        document.getElementById('potd-container').onmouseover = function() { 
                            document.getElementById('potd-video').style.filter = 'brightness(0.9)'; 
                            this.style.transform = 'translateY(-2px)';
                        }
                        document.getElementById('potd-container').onmouseout = function() { 
                            document.getElementById('potd-video').style.filter = 'brightness(0.5)'; 
                            this.style.transform = 'none';
                        }
                    } else {
                        document.getElementById('potd-player').innerText = "NO RECORDING YET";
                        document.getElementById('potd-title').innerText = "AWAITING UPLOAD";
                        document.getElementById('potd-video').style.display = 'none';
                    }
                    
                    // Daily Highlights
                    if(stats.liveMatches) {
                        const lmCont = document.getElementById('live-matches-container');
                        let html = '';
                        
                        if (stats.liveMatches.length > 0) {
                            html += stats.liveMatches.map(m => `
                                <div class="highlight-card" onclick="window.location.href='/dashboard/content'" style="position: relative; background: linear-gradient(145deg, rgba(30,30,40,0.8) 0%, rgba(15,15,20,0.95) 100%), url('/public/blaze_coin.jpg') center/cover; border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 12px 16px; margin-bottom: 0; cursor: pointer; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); overflow: hidden; display: flex; flex-direction: column; gap: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);" onmouseover="this.style.transform='translateY(-2px)'; this.style.borderColor='rgba(34, 197, 94, 0.5)'; this.style.boxShadow='0 8px 25px rgba(34, 197, 94, 0.15), inset 0 0 0 1px rgba(255,255,255,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(255,255,255,0.05)'; this.style.boxShadow='0 4px 15px rgba(0,0,0,0.3)';">
                                    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: rgba(10,10,15,0.85); z-index: 0;"></div>
                                    
                                    <!-- Decorative Glow -->
                                    <div style="position: absolute; top: -30px; right: -30px; width: 100px; height: 100px; background: radial-gradient(circle, rgba(34,197,94,0.2) 0%, rgba(0,0,0,0) 70%); border-radius: 50%; pointer-events: none;"></div>

                                    <!-- Top Section: Logos & Badge -->
                                    <div style="display: flex; justify-content: space-between; align-items: center; z-index: 1;">
                                        <div style="display: flex; gap: 10px;">
                                            <!-- YouTube Logo -->
                                            <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(255,0,0,0.1); display: flex; align-items: center; justify-content: center;">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="#FF0000"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#fff"/></svg>
                                            </div>
                                            <!-- Facebook Logo -->
                                            <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(24,119,242,0.1); display: flex; align-items: center; justify-content: center;">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="#1877F2"/><path d="M16.671 15.542l.532-3.469h-3.328v-2.25c0-.949.465-1.874 1.956-1.874h1.514V5.04s-1.374-.235-2.686-.235c-2.741 0-4.533 1.662-4.533 4.669v2.644H7.078v3.469h3.047v8.385a12.09 12.09 0 0 0 3.75 0v-8.385h2.796z" fill="#fff"/></svg>
                                            </div>
                                        </div>
                                        <div style="display: inline-flex; align-items: center; gap: 6px; background: rgba(34, 197, 94, 0.15); color: #22c55e; padding: 4px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: bold; border: 1px solid rgba(34, 197, 94, 0.3); text-transform: uppercase; letter-spacing: 0.5px;">
                                            <div style="width: 6px; height: 6px; background: #22c55e; border-radius: 50%; box-shadow: 0 0 8px #22c55e;"></div> WATCH NOW
                                        </div>
                                    </div>

                                    <!-- Bottom Section: Info -->
                                    <div style="z-index: 1;">
                                        <div style="font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 4px;">LATEST CONTENT</div>
                                        <div style="font-size: 1.15rem; font-family: var(--font-display); font-weight: 600; color: #fff; line-height: 1.2; margin-bottom: 8px; letter-spacing: 0.5px;">${m.name}</div>
                                        <div style="display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: var(--cyan); font-weight: 600;">
                                            Click to view highlights <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                        </div>
                                    </div>
                                </div>
                            `).join('');
                        }

                        if (!html) {
                            html = '<div class="live-item" style="padding: 15px; text-align: center; border: 1px dashed rgba(255,255,255,0.1); border-radius: 10px;"><div class="li-name" style="color:var(--text-muted)">No content available</div></div>';
                        }
                        
                        lmCont.innerHTML = html;
                    }
                    
                    // News
                    if(stats.news) {
                        const newsCont = document.getElementById('news-container');
                        if (stats.news.length === 0) {
                            newsCont.innerHTML = '<div class="n-item"><div class="n-title" style="color:var(--text-muted)">No recent updates.</div></div>';
                        } else {
                            newsCont.innerHTML = stats.news.map(n => `
                                <div class="n-item">
                                    <div class="n-tag ${n.tagClass}">${n.tag}</div>
                                    <div class="n-title">${n.title}</div>
                                    <div class="n-date">${n.date}</div>
                                </div>
                            `).join('');
                        }
                    }
                }
            } catch (e) { console.error(e); }
        });
    </script>
</body>
</html>
