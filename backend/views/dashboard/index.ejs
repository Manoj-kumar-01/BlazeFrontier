                    <video id="potd-bg-video" autoplay loop muted playsinline
                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; filter: brightness(0.6); transition: filter 0.3s; display: none;"></video>
                    <div
                        style="position: relative; z-index: 2; padding: 24px; width: 100%; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.4) 60%, rgba(0,0,0,0) 100%);">
                        <div
                            style="font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; color: #ffd700; margin-bottom: 6px; text-shadow: 0 2px 4px rgba(0,0,0,0.9);">
                            ★ PLAYER OF THE DAY ★</div>
                        <div id="potd-player"
                            style="font-family: var(--font-display); font-size: 2.2rem; color: #fff; line-height: 1.1; margin-bottom: 4px; text-shadow: 0 2px 10px rgba(0,0,0,0.9); transition: color 0.3s;">
                            Loading...</div>
                        <div style="display: flex; align-items: center; gap: 6px;">
                            <div id="potd-title"
                                style="color: var(--cyan); font-family: var(--font-mono); font-size: 1rem; font-weight: 600;">
