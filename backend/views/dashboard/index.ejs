            <!-- Showcase: Weekly Scrims -->
            <div class="card c-showcase"
                style="padding: 0; position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: flex-end; transition: transform 0.2s; box-shadow: 0 10px 40px rgba(0,0,0,0.6); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.05); cursor: not-allowed;">

                <!-- Lock Overlay -->
                <div
                    style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(10, 10, 15, 0.4); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); z-index: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; pointer-events: none;">
                    <div style="font-size: 5rem; opacity: 0.15; filter: grayscale(100%);">🔒</div>
                </div>

                <!-- Background Image (Balanced) -->
                <div
                    style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: url('/public/scrims_balanced.png') center/cover; filter: brightness(0.7) grayscale(40%); transition: all 0.4s ease; z-index: 0;">
                </div>

                <!-- Inner Glass Panel -->
                <div
                    style="position: relative; z-index: 2; margin: 20px; padding: 24px; background: rgba(15, 10, 12, 0.4); backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.5);">
                    <!-- Header row -->
                    <div
                        style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 16px;">
                        <div>
                            <div
                                style="font-family: var(--font-display); font-size: 1.8rem; color: rgba(255,255,255,0.5); line-height: 1.1; letter-spacing: 0.5px; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
                                WEEKLY<br>SCRIMS</div>
                        </div>
                        <div
                            style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); padding: 4px 10px; border-radius: 6px; display: flex; align-items: center; gap: 6px;">
                            <span
                                style="font-size: 0.65rem; font-weight: 800; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1px;">LOCKED</span>
                        </div>
                    </div>

                    <div
                        style="font-size: 0.85rem; color: rgba(209,209,224,0.5); margin-bottom: 20px; line-height: 1.5;">
                        Currently locked by Command. Stay tuned for upcoming operations.</div>

                    <button disabled
                        style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.1); background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.4); font-weight: bold; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1.5px; display: flex; justify-content: center; align-items: center; gap: 8px; cursor: not-allowed;">
                        COMING SOON <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.5">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <script src="/script.js?v=1.2"></script>
        <script>
            document.addEventListener('DOMContentLoaded', async () => {
                const token = localStorage.getItem('blaze_token');
                if (!token) { window.location.href = '/auth'; return; }
                try {
                    const maxRetries = 3;
                    for (let i = 0; i < maxRetries; i++) {
                        try {
                            const res = await fetch('/api/profile', { headers: { 'x-auth-token': token }, cache: 'no-store' });

                            if (res.ok) {
                                const user = await res.json();
                                document.getElementById('enter-arena-btn').addEventListener('click', () => {
                                    window.location.href = '/dashboard/freefire';
                                });
                                break; // Success, exit loop
                            }

                            if (i === maxRetries - 1 && (res.status === 401 || res.status === 404)) {
                                localStorage.removeItem('blaze_token');
                                window.location.href = '/auth';
                                return;
                            }
                            await new Promise(r => setTimeout(r, 800)); // wait before retry
                        } catch (e) {
                            if (i === maxRetries - 1) {
                                window.location.href = '/auth';
                                return;
                            }
                            await new Promise(r => setTimeout(r, 800));
                        }
                    }

                    // Fetch dynamic stats
                    const graphqlQuery = {
                        query: `
                        query {
                            getDashboardStats {
                                topCommander { name id coins }
                                serverLoad
                                activeCommanders
                                matchesToday
                                network { activeTournaments totalBCAwarded region latency }
                                liveMatches { id game name status isLive color streamUrl youtubeLink facebookLink }
                                news { tag tagClass title date timestamp }
                                potd { videoUrl playerName playerId title isGenuine }
                            }
                        }
                    `
                    };

                    const statsRes = await fetch('/graphql', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'x-auth-token': token },
                        body: JSON.stringify(graphqlQuery)
                    });

                    if (statsRes.ok) {
                        const { data } = await statsRes.json();
                        const stats = data.getDashboardStats;

                        const tcEl = document.getElementById('stat-top-commander');
                        if (tcEl && stats.topCommander) {
                            tcEl.innerHTML = stats.topCommander.name || 'No Player';
                            document.getElementById('stat-tc-id').innerText = stats.topCommander.id || 'N/A';
                            document.getElementById('stat-tc-coins').innerText = stats.topCommander.coins || '0';
                        } else if (tcEl) {
                            tcEl.innerHTML = 'No Player';
                        }

                        document.getElementById('stat-commanders').innerText = stats.activeCommanders;
                        document.getElementById('stat-matches').innerText = stats.matchesToday;

                        // Player of the Day
                        if (stats.potd) {
                            document.getElementById('potd-player').innerText = stats.potd.playerName;
                            document.getElementById('potd-player').style.color = stats.potd.isGenuine ? '#ffd700' : '#fff';
                            document.getElementById('potd-title').innerText = stats.potd.playerId;
                            document.getElementById('potd-container').style.background = 'none';
                            
                            const bgImg = document.getElementById('potd-bg-img');
                            const bgVideo = document.getElementById('potd-bg-video');
                            
                            if (stats.potd.videoUrl) {
                                bgImg.style.display = 'none';
                                // Add a timestamp to bypass browser 206 caching issues on returning sessions
                                bgVideo.src = stats.potd.videoUrl + '?t=' + Date.now();
                                bgVideo.style.display = 'block';
                                document.getElementById('potd-mute-btn').style.display = 'flex';
                                bgVideo.load();
                                
                                const playPromise = bgVideo.play();
                                if (playPromise !== undefined) {
                                    playPromise.catch(e => {
                                        console.log('POTD Autoplay prevented', e);
                                        const forcePlay = () => {
                                            bgVideo.play();
                                            document.removeEventListener('click', forcePlay);
                                            document.removeEventListener('touchstart', forcePlay);
                                        };
                                        document.addEventListener('click', forcePlay);
                                        document.addEventListener('touchstart', forcePlay);
                                    });
                                }
                            } else {
                                bgVideo.style.display = 'none';
                                document.getElementById('potd-mute-btn').style.display = 'none';
                                bgImg.style.display = 'block';
                            }

                            document.getElementById('potd-container').onmouseover = function () {
                                if (stats.potd.videoUrl) bgVideo.style.filter = 'brightness(0.9)';
                                else bgImg.style.filter = 'brightness(0.9)';
                                this.style.transform = 'translateY(-2px)';
                            }
                            document.getElementById('potd-container').onmouseout = function () {
                                if (stats.potd.videoUrl) bgVideo.style.filter = 'brightness(0.6)';
                                else bgImg.style.filter = 'brightness(0.6)';
                                this.style.transform = 'none';
                            }
                        } else {
                            document.getElementById('potd-bg-img').style.display = 'block';
                            document.getElementById('potd-bg-video').style.display = 'none';
                            document.getElementById('potd-mute-btn').style.display = 'none';
                            document.getElementById('potd-bg-img').style.filter = 'brightness(0.3)';
                            document.getElementById('potd-player').innerText = 'AWAITING UPLOAD';
                            document.getElementById('potd-title').innerText = 'PENDING';
                            document.getElementById('potd-container').style.background = 'none';
                            document.getElementById('potd-container').style.border = '1px solid rgba(255,87,34,0.2)';
                            document.getElementById('potd-container').onmouseover = null;
                            document.getElementById('potd-container').onmouseout = null;
                        }

                        // Daily Highlights
                        if (stats.liveMatches) {
                            const lmCont = document.getElementById('live-matches-container');
                            let html = '';

                            const bgImages = ['/public/highlight_bg.png'];

                            if (stats.liveMatches.length > 0) {
                                html += stats.liveMatches.map((m, index) => {
                                    const bg = bgImages[index % bgImages.length];
                                    const randMins = Math.floor(Math.random() * 50) + 10;
                                    const randHours = Math.floor(Math.random() * 10) + 2;
                                    return `
                                <div class="highlight-card" style="position: relative; border-radius: 16px; overflow: hidden; transition: all 0.3s ease; box-shadow: 0 6px 20px rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.05); min-height: 200px; display: flex; flex-direction: column; justify-content: flex-end; background: url('${bg}') center/cover;" onmouseover="this.style.transform='translateY(-4px)'; this.style.borderColor='rgba(255, 60, 30, 0.4)'; this.style.boxShadow='0 12px 30px rgba(255, 60, 30, 0.2)';" onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(255,255,255,0.05)'; this.style.boxShadow='0 6px 20px rgba(0,0,0,0.5)';">
                                    
                                    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, rgba(12,12,18,0.2) 0%, rgba(12,12,18,0.9) 100%); z-index: 1; pointer-events: none;"></div>
                                    
                                    <div style="position: absolute; top: 0; right: 0; width: 150px; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,60,30,0.15)); transform: skewX(-20deg) translateX(20px); z-index: 1; pointer-events: none;"></div>

                                    <div style="position: relative; z-index: 2; padding: 16px; flex: 1; display: flex; flex-direction: column; justify-content: space-between;">
                                        
                                        <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                            <span style="background: rgba(255,60,30,0.2); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); color: #ff5722; font-size: 0.65rem; font-weight: 800; padding: 4px 8px; border-radius: 4px; text-transform: uppercase; letter-spacing: 1.5px; border: 1px solid rgba(255,60,30,0.3); box-shadow: 0 2px 8px rgba(0,0,0,0.5);">${m.game || 'ESPORTS'}</span>
                                            
                                            <div style="background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); padding: 4px 8px; border-radius: 6px; font-size: 0.7rem; color: #fff; display: flex; align-items: center; gap: 4px; border: 1px solid rgba(255,255,255,0.1);">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                                                ${randHours}:${randMins}
                                            </div>
                                        </div>

                                        <div style="margin-top: 24px;">
                                            <div style="font-family: var(--font-display); font-size: 1.3rem; color: #fff; line-height: 1.2; margin-bottom: 8px; text-shadow: 0 2px 4px rgba(0,0,0,0.8);">${m.name}</div>
                                            
                                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                                <div style="display: flex; gap: 6px;">
                                                    <a href="${m.youtubeLink || '#'}" target="_blank" style="width: 28px; height: 28px; border-radius: 6px; background: rgba(255,0,0,0.1); display: flex; align-items: center; justify-content: center; color: #f00; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,0,0,0.2)';" onmouseout="this.style.background='rgba(255,0,0,0.1)';"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#fff"/></svg></a>
                                                    <a href="${m.facebookLink || '#'}" target="_blank" style="width: 28px; height: 28px; border-radius: 6px; background: rgba(24,119,242,0.1); display: flex; align-items: center; justify-content: center; color: #1877F2; text-decoration: none; transition: all 0.2s;" onmouseover="this.style.background='rgba(24,119,242,0.2)';" onmouseout="this.style.background='rgba(24,119,242,0.1)';"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/><path d="M16.671 15.542l.532-3.469h-3.328v-2.25c0-.949.465-1.874 1.956-1.874h1.514V5.04s-1.374-.235-2.686-.235c-2.741 0-4.533 1.662-4.533 4.669v2.644H7.078v3.469h3.047v8.385a12.09 12.09 0 0 0 3.75 0v-8.385h2.796z" fill="#fff"/></svg></a>
                                                </div>
                                                
                                                <button onclick="window.location.href='/dashboard/content'" style="background: rgba(255, 60, 30, 0.15); color: #ff3c1e; padding: 6px 14px; border-radius: 6px; font-size: 0.75rem; font-weight: bold; border: 1px solid rgba(255, 60, 30, 0.3); transition: all 0.2s; cursor: pointer; display: flex; align-items: center; gap: 4px; text-transform: uppercase; letter-spacing: 1px;" onmouseover="this.style.background='rgba(255, 60, 30, 0.3)';" onmouseout="this.style.background='rgba(255, 60, 30, 0.15)';">
                                                    Watch <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                `
                                }).join('');
                            }

                            if (!html) {
                                html = '<div class="live-item" style="padding: 15px; text-align: center; border: 1px dashed rgba(255,255,255,0.1); border-radius: 10px;"><div class="li-name" style="color:var(--text-muted)">No content available</div></div>';
                            }

                            lmCont.innerHTML = html;
                        }

                        // News
                        if (stats.news) {
                            const newsCont = document.getElementById('news-container');
                            // maxHeight handled by CSS flex now
                            // paddingRight not needed since scrollbar is styled globally


                            let dismissedNews = [];
                            try {
                                const stored = localStorage.getItem('dismissed_updates');
                                if (stored) dismissedNews = JSON.parse(stored);
                            } catch (e) { }

                            const activeNews = stats.news.filter(n => !dismissedNews.includes(String(n.timestamp)));

                            if (activeNews.length === 0) {
                                newsCont.innerHTML = `
                                <div style="height: 100%; min-height: 250px; background: rgba(0,0,0,0.4); backdrop-filter: blur(4px); border-radius: 12px; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; padding-bottom: 40px; text-align: center; box-shadow: inset 0 -60px 80px -20px rgba(8,8,14,0.9);">
                                    <div style="font-size: 1.5rem; font-family: var(--font-display); color: #fff; text-shadow: 0 4px 10px rgba(0,0,0,0.8); margin-bottom: 10px; font-weight: 600;">You're all caught up!</div>
                                    <div style="font-size: 0.9rem; color: #a1a1b5;">Check back later for new updates and announcements.</div>
                                </div>
                            `;
                            } else {
                                newsCont.innerHTML = activeNews.map(n => `
                                <div class="n-item" id="news-${n.timestamp}" style="position: relative; padding-right: 40px; transition: all 0.3s var(--ease);">
                                    <div class="n-tag ${n.tagClass}">${n.tag}</div>
                                    <div class="n-title">${n.title}</div>
                                    <div class="n-date">${n.date}</div>
                                    <button onclick="dismissNews(String('${n.timestamp}'))" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: transparent; border: none; color: var(--text-muted); font-size: 1.2rem; cursor: pointer; transition: color 0.2s;">&times;</button>
                                </div>
                            `).join('');
                            }

                            if (!window.dismissNews) {
                                window.dismissNews = function (id) {
                                    let dismissed = [];
                                    try {
                                        const stored = localStorage.getItem('dismissed_updates');
                                        if (stored) dismissed = JSON.parse(stored);
                                    } catch (e) { }
                                    dismissed.push(id);
                                    localStorage.setItem('dismissed_updates', JSON.stringify(dismissed));

                                    const el = document.getElementById('news-' + id);
                                    if (el) {
                                        el.style.opacity = "0";
                                        el.style.transform = "translateX(20px)";
                                        setTimeout(() => {
                                            el.remove();
                                            if (newsCont.children.length === 0) {
                                                newsCont.innerHTML = '<div class="n-item" style="justify-content: center; border: 1px dashed rgba(255,255,255,0.1);"><div class="n-title" style="color:var(--text-muted); text-align:center; font-size: 0.9rem;">You\'re all caught up!</div></div>';
                                            }
                                        }, 300);
                                    }
                                };
                            }
                        }
                    }
                } catch (e) { console.error(e); }
            });

            window.togglePotdMute = function(e) {
                e.stopPropagation();
                const video = document.getElementById('potd-bg-video');
                const icon = document.getElementById('potd-mute-icon');
                if (!video) return;
                video.muted = !video.muted;
                if (video.muted) {
                    icon.innerHTML = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="23" y1="9" x2="17" y2="15"></line><line x1="17" y1="9" x2="23" y2="15"></line>';
                } else {
                    icon.innerHTML = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>';
                }
            };
        </script>
</body>

</html>