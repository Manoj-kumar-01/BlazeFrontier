<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=block" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .dash {
            display: grid; grid-template-columns: repeat(12, 1fr);
            gap: 20px; padding: 88px 20px 40px; min-height: 100vh;
            max-width: 1500px; margin: 0 auto;
        }

        .card {
            background: rgba(12, 12, 18, 0.7); 
            backdrop-filter: blur(20px) saturate(1.5);
            -webkit-backdrop-filter: blur(20px) saturate(1.5);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px; padding: 24px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255,255,255,0.05);
            position: relative; overflow: hidden;
            z-index: 2; transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
        }
        .card:hover {
            transform: translateY(-4px);
            border-color: rgba(0, 188, 212, 0.3);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(0, 188, 212, 0.1);
        }

        /* Welcome Hero */
        .c-welcome {
            grid-column: span 12;
            display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;
            padding: 70px 40px;
            background: linear-gradient(135deg, rgba(0, 188, 212, 0.15) 0%, rgba(12, 12, 18, 0.9) 100%), url('/public/blaze_bg.jpg') center/cover;
            background-blend-mode: overlay; border-bottom: 3px solid rgba(0, 188, 212, 0.4);
        }
        .cw-title { font-family: var(--font-display); font-size: 3.5rem; color: #fff; letter-spacing: 2px; text-shadow: 0 4px 15px rgba(0,0,0,0.5); margin-bottom: 15px; }
        .cw-sub { color: rgba(255,255,255,0.7); font-size: 1.15rem; max-width: 700px; line-height: 1.6; margin-bottom: 35px; }
        .cw-actions { display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
        .cw-btn {
            padding: 14px 32px; border-radius: 12px; border: none;
            font-family: var(--font-display); font-size: 1.2rem; letter-spacing: 1px;
            cursor: pointer; transition: all 0.3s; white-space: nowrap; text-decoration: none;
            display: inline-flex; align-items: center; gap: 10px; font-weight: 600;
        }
        .cw-btn-primary { background: var(--blaze-orange); color: #fff; box-shadow: 0 4px 20px rgba(255,87,34,0.4); }
        .cw-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(255,87,34,0.6); }
        .cw-btn-secondary { background: rgba(0, 188, 212, 0.15); color: #00bcd4; border: 1px solid rgba(0, 188, 212, 0.4); backdrop-filter: blur(10px); }
        .cw-btn-secondary:hover { background: rgba(0, 188, 212, 0.25); border-color: rgba(0, 188, 212, 0.8); transform: translateY(-3px); box-shadow: 0 8px 25px rgba(0, 188, 212, 0.3); color: #fff; }

        /* Stat cards */
        .c-stat { grid-column: span 4; display: flex; flex-direction: column; justify-content: center; padding: 30px; }
        .cs-label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 2px; color: var(--text-muted); font-weight: 700; margin-bottom: 10px; }
        .cs-val { font-family: var(--font-display); font-size: 3rem; color: #fff; line-height: 1; margin-bottom: 5px; text-shadow: 0 2px 10px rgba(0,0,0,0.5); }
        .cs-sub { font-size: 0.8rem; color: var(--text-muted); font-family: var(--font-mono); }

        /* Content Areas */
        .c-main-panel { grid-column: span 8; display: flex; flex-direction: column; gap: 20px; }
        .c-side-panel { grid-column: span 4; display: flex; flex-direction: column; gap: 20px; }

        .section-title {
            font-family: var(--font-display); font-size: 1.5rem; color: #fff; letter-spacing: 1px;
            margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        /* News Area */
        .news-grid { display: flex; flex-direction: column; gap: 15px; }
        .n-item {
            background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05);
            border-radius: 12px; padding: 16px; transition: all 0.3s;
            position: relative;
        }
        .n-item:hover { border-color: rgba(255,255,255,0.2); background: rgba(0,0,0,0.6); transform: translateX(5px); }
        .n-tag {
            display: inline-block; font-size: 0.65rem; font-weight: 800; text-transform: uppercase;
            letter-spacing: 1.5px; padding: 4px 8px; border-radius: 4px; margin-bottom: 8px;
        }
        .n-tag.announce { background: rgba(255,87,34,0.15); color: var(--blaze-orange); }
        .n-tag.update { background: rgba(34,197,94,0.15); color: #22c55e; }
        .n-tag.event { background: rgba(240,165,0,0.15); color: #f0a500; }
        .n-tag.maint { background: rgba(255,255,255,0.1); color: var(--text-muted); }
        .n-title { color: #fff; font-size: 1rem; font-weight: 600; line-height: 1.4; margin-bottom: 8px; }
        .n-date { color: var(--text-muted); font-size: 0.75rem; font-family: var(--font-mono); }
        
        .live-item { padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
        .live-item:last-child { border-bottom: none; }
        .li-name { color: #fff; font-size: 0.95rem; font-weight: 600; margin-bottom: 5px; }
        .li-status { display: flex; align-items: center; gap: 6px; font-size: 0.75rem; font-weight: 700; color: #22c55e; text-transform: uppercase; }
        .li-dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; animation: blink 1.2s infinite; box-shadow: 0 0 8px #22c55e; }
        @keyframes blink { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }

        /* Media Queries */
        @media (max-width: 1100px) {
            .c-stat { grid-column: span 6; }
            .c-main-panel, .c-side-panel { grid-column: span 12; }
        }
        @media (max-width: 700px) {
            .c-stat { grid-column: span 12; }
            .cw-title { font-size: 2.2rem; }
            .cw-actions { flex-direction: column; width: 100%; }
            .cw-btn { width: 100%; justify-content: center; }
        }

        /* ═══════ NEON BACKGROUND SYSTEM ═══════ */
        body {
            background-color: #08080e;
            margin: 0;
            position: relative;
            overflow-x: hidden;
        }

        /* Floating gradient blobs */
        .bg-scene {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            z-index: 0; pointer-events: none; overflow: hidden;
        }
        .blob {
            position: absolute; border-radius: 50%; filter: blur(80px);
            will-change: transform;
        }
        .blob-1 {
            width: 500px; height: 500px; top: -10%; left: -5%;
            background: radial-gradient(circle, rgba(255, 20, 0, 0.25) 0%, transparent 70%);
            animation: driftBlob1 15s ease-in-out infinite alternate;
        }
        .blob-2 {
            width: 400px; height: 400px; bottom: 10%; right: -5%;
            background: radial-gradient(circle, rgba(255, 80, 0, 0.2) 0%, transparent 70%);
            animation: driftBlob2 18s ease-in-out infinite alternate;
        }
        .blob-3 {
            width: 350px; height: 350px; top: 40%; left: 30%;
            background: radial-gradient(circle, rgba(200, 0, 0, 0.12) 0%, transparent 70%);
            animation: driftBlob3 22s ease-in-out infinite alternate;
        }

        /* Diagonal neon stripes */
        .stripe-overlay {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            z-index: 0; pointer-events: none;
            background: repeating-linear-gradient(
                -45deg,
                transparent,
                transparent 60px,
                rgba(255, 30, 0, 0.025) 60px,
                rgba(255, 30, 0, 0.025) 61px
            );
        }

        /* Scanline CRT effect */
        .scanlines {
            position: fixed; top: 0; left: 0; right: 0; bottom: 0;
            z-index: 1; pointer-events: none;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0, 0, 0, 0.06) 2px,
                rgba(0, 0, 0, 0.06) 4px
            );
        }

        /* Top neon glow bar */
        .neon-bar-top {
            position: fixed; top: 0; left: 0; right: 0; height: 2px;
            background: linear-gradient(90deg, transparent, #ff2200, #ff5500, #ff2200, transparent);
            z-index: 1000; pointer-events: none;
            box-shadow: 0 0 15px rgba(255, 34, 0, 0.6), 0 0 40px rgba(255, 34, 0, 0.3), 0 0 80px rgba(255, 34, 0, 0.15);
        }

        @keyframes driftBlob1 {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(80px, 60px) scale(1.15); }
        }
        @keyframes driftBlob2 {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(-60px, -80px) scale(1.2); }
        }
        @keyframes driftBlob3 {
            0% { transform: translate(0, 0) scale(0.9); }
            100% { transform: translate(50px, -40px) scale(1.1); }
        }
    </style>
</head>
<body>
    <!-- Neon Background System -->
    <div class="bg-scene">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
    </div>
    <div class="stripe-overlay"></div>
    <div class="scanlines"></div>
    <div class="neon-bar-top"></div>
    <%- include('../partials/navbar') %>

    <div class="dash">
        <!-- Hero Banner -->
        <div class="card c-welcome">
            <div class="cw-title">WELCOME TO FRONTIER HUB</div>
            <div class="cw-sub">Your central hub for elite matchmaking, live tournaments, and the latest esports updates. Gear up, track your stats, and dominate the arena.</div>
            <div class="cw-actions">
                <a href="/dashboard/freefire" class="cw-btn cw-btn-primary">JUMP TO MATCHMAKING</a>
                <a href="/dashboard/tournaments" class="cw-btn cw-btn-secondary">VIEW TOURNAMENTS</a>
                <a href="/dashboard/leaderboards" class="cw-btn cw-btn-secondary">LEADERBOARDS</a>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="card c-stat" style="background: linear-gradient(135deg, rgba(255,87,34,0.15) 0%, rgba(15,15,20,0.95) 100%); border: 1px solid rgba(255,87,34,0.4); border-left: 4px solid var(--blaze-orange);">
            <div style="position: absolute; top: -20px; right: -20px; font-size: 8rem; opacity: 0.03; transform: rotate(15deg);">🔥</div>
            <div class="cs-label" style="color: var(--blaze-orange); text-shadow: 0 0 10px rgba(255,87,34,0.3);">THE BLAZE ICON</div>
            <div class="cs-val" id="stat-top-commander">Loading...</div>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 10px;">
                <div class="cs-sub">ID: <span id="stat-tc-id" style="color: var(--cyan);">...</span></div>
                <div style="display: flex; align-items: center; gap: 6px; background: rgba(0,0,0,0.4); padding: 4px 12px; border-radius: 20px; border: 1px solid rgba(255,87,34,0.3);">
                    <span id="stat-tc-coins" style="color: #fbbf24; font-size: 1.1rem; font-family: var(--font-display); font-weight: bold;">...</span> 
                    <img src="/public/blaze_coin.jpg" style="height: 18px; width: 18px; border-radius: 50%;" alt="BlazeCoins">
                </div>
            </div>
        </div>
        
        <div class="card c-stat">
            <div style="position: absolute; top: -20px; right: -20px; font-size: 8rem; opacity: 0.03; transform: rotate(15deg);">🎮</div>
            <div class="cs-label">ACTIVE PLAYERS</div>
            <div class="cs-val" id="stat-commanders">...</div>
            <div class="cs-sub">Global unique players online</div>
        </div>
        
        <div class="card c-stat">
            <div style="position: absolute; top: -20px; right: -20px; font-size: 8rem; opacity: 0.03; transform: rotate(15deg);">⚔️</div>
            <div class="cs-label">MATCHES TODAY</div>
            <div class="cs-val" id="stat-matches">...</div>
            <div class="cs-sub">Across all arenas globally</div>
        </div>

        <!-- Main Content Area -->
        <div class="c-main-panel">
            <div class="card" id="potd-container" style="padding: 0; min-height: 280px; display: flex; align-items: flex-end; cursor: pointer; border: 1px solid rgba(255,215,0,0.3); box-shadow: 0 10px 40px rgba(0,0,0,0.6), inset 0 0 0 1px rgba(255,215,0,0.1);">
                <video id="potd-video" autoplay loop muted playsinline style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1; filter: brightness(0.6); transition: filter 0.4s;"></video>
                <div style="position: relative; z-index: 2; padding: 30px; width: 100%; background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.5) 60%, transparent 100%);">
                    <div style="font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 3px; color: #FFD700; margin-bottom: 8px; text-shadow: 0 2px 10px rgba(255,215,0,0.6);">★ PLAYER OF THE DAY ★</div>
                    <div id="potd-player" style="font-family: var(--font-display); font-size: 2.8rem; color: #fff; line-height: 1; margin-bottom: 5px; text-shadow: 0 4px 15px rgba(0,0,0,0.8);">Loading...</div>
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <span style="color: var(--text-muted); font-size: 0.9rem;">Blaze ID:</span>
                        <div id="potd-title" style="color: var(--cyan); font-family: var(--font-mono); font-size: 1.1rem; font-weight: 600;">Please wait</div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="section-title">DAILY HIGHLIGHTS</div>
                <div id="live-matches-container" style="display: flex; flex-direction: column; gap: 10px;">
                    <div class="live-item"><div class="li-name" style="color:var(--text-muted)">Loading highlights...</div></div>
                </div>
            </div>
        </div>

        <!-- Side Panel Area -->
        <div class="c-side-panel">
            <div class="card" style="flex: 1;">
                <div class="section-title">PLATFORM UPDATES</div>
                <div class="news-grid" id="news-container">
                    <div class="n-item"><div class="n-title" style="color:var(--text-muted)">Loading updates...</div></div>
                </div>
            </div>
        </div>
    </div>

    <script src="/script.js?v=1.2"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('blaze_token');
            if (!token) { window.location.href = '/auth'; return; }
            try {
                const res = await fetch('/api/profile', { headers: { 'x-auth-token': token } });
                if (res.status === 401 || res.status === 404) {
                    localStorage.removeItem('blaze_token');
                    window.location.href = '/auth';
                    return;
                }
                if (res.ok) {
                    const user = await res.json();
                }
                
                // Fetch dynamic stats (GraphQL vs REST Performance Comparison)
                const t0_gql = performance.now();
                const graphqlQuery = {
                    query: `
                        query {
                            getDashboardStats {
                                topCommander { name id coins }
                                serverLoad
                                activeCommanders
                                matchesToday
                                network { activeTournaments totalBCAwarded region latency }
                                liveMatches { id game name status isLive color streamUrl youtubeLink facebookLink }
                                news { tag tagClass title date timestamp }
                                potd { videoUrl playerName playerId title }
                            }
                        }
                    `
                };
                
                const statsRes = await fetch('/graphql', { 
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'x-auth-token': token },
                    body: JSON.stringify(graphqlQuery)
                });
                const t1_gql = performance.now();
                console.log(`[GraphQL] Hub Stats retrieved in ${(t1_gql - t0_gql).toFixed(2)} ms`);
                
                // Compare with REST (for console logging only)
                const t0_rest = performance.now();
                fetch('/api/dashboard/stats', { headers: { 'x-auth-token': token } })
                    .then(() => {
                        const t1_rest = performance.now();
                        console.log(`[REST API] Hub Stats retrieved in ${(t1_rest - t0_rest).toFixed(2)} ms`);
                    }).catch(e => console.error(e));

                if (statsRes.ok) {
                    const { data } = await statsRes.json();
                    const stats = data.getDashboardStats;
                    
                    const tcEl = document.getElementById('stat-top-commander');
                    if(tcEl && stats.topCommander) {
                        tcEl.innerHTML = stats.topCommander.name || 'No Player';
                        document.getElementById('stat-tc-id').innerText = stats.topCommander.id || 'N/A';
                        document.getElementById('stat-tc-coins').innerText = stats.topCommander.coins || '0';
                    } else if (tcEl) {
                        tcEl.innerHTML = 'No Player';
                    }
                    
                    document.getElementById('stat-commanders').innerText = stats.activeCommanders;
                    document.getElementById('stat-matches').innerText = stats.matchesToday;
                    
                    // Player of the Day
                    if (stats.potd) {
                        document.getElementById('potd-video').src = stats.potd.videoUrl;
                        document.getElementById('potd-player').innerText = stats.potd.playerName;
                        document.getElementById('potd-title').innerText = stats.potd.playerId;
                        document.getElementById('potd-container').onmouseover = function() { 
                            document.getElementById('potd-video').style.filter = 'brightness(0.9)'; 
                            this.style.transform = 'translateY(-2px)';
                        }
                        document.getElementById('potd-container').onmouseout = function() { 
                            document.getElementById('potd-video').style.filter = 'brightness(0.5)'; 
                            this.style.transform = 'none';
                        }
                    } else {
                        document.getElementById('potd-player').innerText = "NO RECORDING YET";
                        document.getElementById('potd-title').innerText = "AWAITING UPLOAD";
                        document.getElementById('potd-video').style.display = 'none';
                    }
                    
                    // Daily Highlights
                    if(stats.liveMatches) {
                        const lmCont = document.getElementById('live-matches-container');
                        let html = '';
                        
                        if (stats.liveMatches.length > 0) {
                            html += stats.liveMatches.map(m => `
                                <div class="highlight-card" onclick="window.location.href='/dashboard/content'" style="position: relative; background: linear-gradient(145deg, rgba(30,30,40,0.8) 0%, rgba(15,15,20,0.95) 100%), url('/public/blaze_coin.jpg') center/cover; border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 12px 16px; margin-bottom: 0; cursor: pointer; transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); overflow: hidden; display: flex; flex-direction: column; gap: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.3);" onmouseover="this.style.transform='translateY(-2px)'; this.style.borderColor='rgba(34, 197, 94, 0.5)'; this.style.boxShadow='0 8px 25px rgba(34, 197, 94, 0.15), inset 0 0 0 1px rgba(255,255,255,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.borderColor='rgba(255,255,255,0.05)'; this.style.boxShadow='0 4px 15px rgba(0,0,0,0.3)';">
                                    <div style="position: absolute; top:0; left:0; width:100%; height:100%; background: rgba(10,10,15,0.85); z-index: 0;"></div>
                                    
                                    <!-- Decorative Glow -->
                                    <div style="position: absolute; top: -30px; right: -30px; width: 100px; height: 100px; background: radial-gradient(circle, rgba(34,197,94,0.2) 0%, rgba(0,0,0,0) 70%); border-radius: 50%; pointer-events: none;"></div>

                                    <!-- Top Section: Logos & Badge -->
                                    <div style="display: flex; justify-content: space-between; align-items: center; z-index: 1;">
                                        <div style="display: flex; gap: 10px;">
                                            <!-- YouTube Logo -->
                                            <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(255,0,0,0.1); display: flex; align-items: center; justify-content: center;">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="#FF0000"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="#fff"/></svg>
                                            </div>
                                            <!-- Facebook Logo -->
                                            <div style="width: 32px; height: 32px; border-radius: 8px; background: rgba(24,119,242,0.1); display: flex; align-items: center; justify-content: center;">
                                                <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" fill="#1877F2"/><path d="M16.671 15.542l.532-3.469h-3.328v-2.25c0-.949.465-1.874 1.956-1.874h1.514V5.04s-1.374-.235-2.686-.235c-2.741 0-4.533 1.662-4.533 4.669v2.644H7.078v3.469h3.047v8.385a12.09 12.09 0 0 0 3.75 0v-8.385h2.796z" fill="#fff"/></svg>
                                            </div>
                                        </div>
                                        <div style="display: inline-flex; align-items: center; gap: 6px; background: rgba(34, 197, 94, 0.15); color: #22c55e; padding: 4px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: bold; border: 1px solid rgba(34, 197, 94, 0.3); text-transform: uppercase; letter-spacing: 0.5px;">
                                            <div style="width: 6px; height: 6px; background: #22c55e; border-radius: 50%; box-shadow: 0 0 8px #22c55e;"></div> WATCH NOW
                                        </div>
                                    </div>

                                    <!-- Bottom Section: Info -->
                                    <div style="z-index: 1;">
                                        <div style="font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 4px;">LATEST CONTENT</div>
                                        <div style="font-size: 1.15rem; font-family: var(--font-display); font-weight: 600; color: #fff; line-height: 1.2; margin-bottom: 8px; letter-spacing: 0.5px;">${m.name}</div>
                                        <div style="display: flex; align-items: center; gap: 8px; font-size: 0.8rem; color: var(--cyan); font-weight: 600;">
                                            Click to view highlights <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                                        </div>
                                    </div>
                                </div>
                            `).join('');
                        }

                        if (!html) {
                            html = '<div class="live-item" style="padding: 15px; text-align: center; border: 1px dashed rgba(255,255,255,0.1); border-radius: 10px;"><div class="li-name" style="color:var(--text-muted)">No content available</div></div>';
                        }
                        
                        lmCont.innerHTML = html;
                    }
                    
                    // News
                    if(stats.news) {
                        const newsCont = document.getElementById('news-container');
                        newsCont.style.maxHeight = "350px";
                        newsCont.style.overflowY = "auto";
                        newsCont.style.paddingRight = "8px";
                        
                        let dismissedNews = [];
                        try {
                            const stored = localStorage.getItem('dismissed_updates');
                            if (stored) dismissedNews = JSON.parse(stored);
                        } catch(e){}

                        const activeNews = stats.news.filter(n => !dismissedNews.includes(String(n.timestamp)));

                        if (activeNews.length === 0) {
                            newsCont.innerHTML = '<div class="n-item" style="justify-content: center; border: 1px dashed rgba(255,255,255,0.1);"><div class="n-title" style="color:var(--text-muted); text-align:center; font-size: 0.9rem;">You\'re all caught up!</div></div>';
                        } else {
                            newsCont.innerHTML = activeNews.map(n => `
                                <div class="n-item" id="news-${n.timestamp}" style="position: relative; padding-right: 40px; transition: all 0.3s var(--ease);">
                                    <div class="n-tag ${n.tagClass}">${n.tag}</div>
                                    <div class="n-title">${n.title}</div>
                                    <div class="n-date">${n.date}</div>
                                    <button onclick="dismissNews(String('${n.timestamp}'))" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: transparent; border: none; color: var(--text-muted); font-size: 1.2rem; cursor: pointer; transition: color 0.2s;">&times;</button>
                                </div>
                            `).join('');
                        }

                        if(!window.dismissNews) {
                            window.dismissNews = function(id) {
                                let dismissed = [];
                                try {
                                    const stored = localStorage.getItem('dismissed_updates');
                                    if (stored) dismissed = JSON.parse(stored);
                                } catch(e){}
                                dismissed.push(id);
                                localStorage.setItem('dismissed_updates', JSON.stringify(dismissed));
                                
                                const el = document.getElementById('news-' + id);
                                if(el) {
                                    el.style.opacity = "0";
                                    el.style.transform = "translateX(20px)";
                                    setTimeout(() => {
                                        el.remove();
                                        if(newsCont.children.length === 0) {
                                            newsCont.innerHTML = '<div class="n-item" style="justify-content: center; border: 1px dashed rgba(255,255,255,0.1);"><div class="n-title" style="color:var(--text-muted); text-align:center; font-size: 0.9rem;">You\'re all caught up!</div></div>';
                                        }
                                    }, 300);
                                }
                            };
                        }
                    }
                }
            } catch (e) { console.error(e); }
        });
    </script>
</body>
</html>
