            <!-- News -->
            <div class="card c-news"
                style="background: url('/public/platform_updates_bg_clean.png') center/cover no-repeat; position: relative; border: 1px solid rgba(255, 87, 34, 0.15); box-shadow: 0 8px 32px rgba(0,0,0,0.6), inset 0 0 20px rgba(255, 87, 34, 0.05); overflow: hidden;">

                <div class="cn-title"
                    style="position: relative; z-index: 1; border-bottom: 1px solid rgba(255, 87, 34, 0.1); display: flex; align-items: center; gap: 10px; background: rgba(0,0,0,0.4); backdrop-filter: blur(8px);">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ff5722" stroke-width="2"
