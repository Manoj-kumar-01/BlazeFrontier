<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Blaze Frontier</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=block"
        rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .dash {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 340px;
            grid-template-rows: auto auto 1fr;
            gap: 14px;
            padding: 88px 20px 20px;
            max-width: 1500px;
            margin: 0 auto;
        }

        .card {
            background: rgba(12, 12, 18, 0.65);
            backdrop-filter: blur(16px) saturate(1.4);
            -webkit-backdrop-filter: blur(16px) saturate(1.4);
            border: 1px solid rgba(255, 60, 30, 0.12);
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.04);
            position: relative;
            z-index: 2;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        .card:hover {
            border-color: rgba(255, 60, 30, 0.25);
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5), 0 0 30px rgba(255, 40, 20, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.06);
        }

        /* Welcome — main area top */
        .c-welcome {
            grid-column: 1 / 4;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            padding: 28px 32px;
        }

        .cw-title {
            font-family: var(--font-display);
            font-size: 2.2rem;
            color: #fff;
            letter-spacing: 1px;
        }

        .cw-sub {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-top: 2px;
        }

        .cw-btn {
            padding: 12px 28px;
            border-radius: 8px;
            border: none;
            background: var(--blaze-orange);
            color: #fff;
            font-family: var(--font-display);
            font-size: 1.1rem;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .cw-btn:hover {
            box-shadow: 0 4px 16px rgba(255, 87, 34, 0.3);
            transform: translateY(-1px);
        }

        /* Stat cards — top row */
        .c-stat {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .cs-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            font-weight: 600;
            margin-bottom: 6px;
        }

        .cs-val {
            font-family: var(--font-display);
            font-size: 2.4rem;
            color: #fff;
            line-height: 1;
        }

        .cs-sub {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 6px;
            font-family: var(--font-mono);
        }

        /* News — spans 2 cols, fills remaining grid space */
        .c-news {
            grid-column: 1 / 3;
            grid-row: 3;
            display: flex;
            flex-direction: column;
            padding: 0;
            min-height: 0;
            overflow: hidden;
        }

        .cn-title {
            font-family: var(--font-display);
            font-size: 1.3rem;
            color: #fff;
            letter-spacing: 1px;
            margin: 0;
            padding: 20px 24px 12px 24px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        .news-grid {
            display: flex;
            flex-direction: column;
            gap: 0;
            flex: 1;
            overflow-y: auto;
            -ms-overflow-style: none;
            /* IE and Edge */
            scrollbar-width: none;
            /* Firefox */
        }

        .news-grid::-webkit-scrollbar {
            display: none;
        }

        .n-item {
            background: transparent;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 0;
            padding: 14px 24px;
            transition: background 0.2s;
        }

        .n-item:last-child {
            border-bottom: none;
        }

        .n-item:hover {
            background: rgba(255, 255, 255, 0.02);
        }

        .n-tag {
            display: inline-block;
            font-size: 0.6rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 2px 6px;
            border-radius: 3px;
            margin-bottom: 4px;
        }

        .n-tag.announce {
            background: rgba(255, 87, 34, 0.1);
            color: var(--blaze-orange);
        }

        .n-tag.update {
            background: rgba(34, 197, 94, 0.1);
            color: #22c55e;
        }

        .n-tag.event {
            background: rgba(240, 165, 0, 0.1);
            color: #f0a500;
        }

        .n-tag.maint {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-muted);
        }

        .n-title {
            color: #fff;
            font-size: 0.9rem;
            font-weight: 600;
            line-height: 1.4;
            margin-bottom: 4px;
        }

        .n-date {
            color: var(--text-muted);
            font-size: 0.7rem;
            font-family: var(--font-mono);
        }

        /* Sidebar — right column, spans all rows from top to bottom */
        .c-sidebar {
            grid-column: 4;
            grid-row: 1 / 4;
            display: flex;
            flex-direction: column;
            gap: 10px;
            min-height: 0;
            overflow: hidden;
        }

        .side-panel {
            background: rgba(12, 12, 18, 0.6);
            backdrop-filter: blur(14px) saturate(1.3);
            -webkit-backdrop-filter: blur(14px) saturate(1.3);
            border: 1px solid rgba(255, 60, 30, 0.1);
            border-radius: 12px;
            padding: 20px;
            flex: 1;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.03);
        }

        .sp-title {
            font-family: var(--font-display);
            font-size: 1.1rem;
            color: #fff;
            letter-spacing: 1px;
            margin-bottom: 14px;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        }

        /* Live matches */
        .live-item {
            padding: 10px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }

        .live-item:last-child {
            border-bottom: none;
        }

        .li-game {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--blaze-orange);
            margin-bottom: 3px;
        }

        .li-name {
            color: #fff;
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 3px;
        }

        .li-status {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 0.7rem;
            font-weight: 600;
            color: #22c55e;
        }

        .li-dot {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: #22c55e;
            animation: blink 1.2s infinite;
        }

        @keyframes blink {

            0%,
            100% {
                opacity: 0.4;
            }

            50% {
                opacity: 1;
            }
        }

        /* Quick stats */
        .qs-row {
            display: flex;
            justify-content: space-between;
            padding: 7px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }

        .qs-row:last-child {
            border-bottom: none;
        }

        .qs-label {
            color: var(--text-muted);
            font-size: 0.8rem;
        }

        .qs-val {
            color: #fff;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            font-weight: 600;
        }

        .view-link {
            display: block;
            text-align: center;
            color: var(--blaze-orange);
            text-decoration: none;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 1px;
            margin-top: 10px;
            transition: color 0.2s;
        }

        .view-link:hover {
            color: #fff;
        }

        @media (max-width: 1100px) {
            .dash {
                grid-template-columns: 1fr 1fr;
                grid-template-rows: auto;
            }

            .c-welcome,
            .c-news,
            .c-showcase {
                grid-column: 1 / -1;
            }

            .c-sidebar {
                grid-column: 1 / -1;
                grid-row: auto;
                flex-direction: row;
            }

            .news-grid {
                grid-template-columns: 1fr;
            }

            #live-matches-container {
                overflow-y: visible !important;
                height: auto !important;
                max-height: none !important;
            }
        }

        @media (max-width: 700px) {
            .dash {
                grid-template-columns: 1fr;
                padding: 88px 10px 10px;
                width: 100%;
                box-sizing: border-box;
            }

            .c-welcome,
            .c-sidebar,
            .c-news,
            .c-showcase,
            .c-stat {
                grid-column: 1 / -1;
            }

            .c-welcome {
                flex-direction: column;
                text-align: center;
            }

            .c-sidebar {
                flex-direction: column;
            }

            .cs-val {
                font-size: 2rem;
            }

            body,
            html {
                overflow-x: hidden;
                width: 100%;
                max-width: 100vw;
            }

            .c-stat-active,
            .c-stat-matches {
                display: none !important;
            }

            .c-welcome {
                order: 1;
            }

            .c-stat {
                order: 2;
            }

            .c-sidebar {
                order: 3;
            }

            .c-news {
                order: 4;
            }

            .c-showcase {
                order: 5;
            }
        }

        /* ═══════ NEON BACKGROUND SYSTEM ═══════ */
        body {
            background-color: #08080e;
            margin: 0;
            position: relative;
            overflow-x: hidden;
        }

        /* Lock page scrolling on desktop */
        @media (min-width: 1101px) {
            body {
                overflow: hidden;
            }

            .dash {
                height: 100vh;
                box-sizing: border-box;
            }
        }

        /* Floating gradient blobs */
        .bg-scene {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            will-change: transform;
        }

        .blob-1 {
            width: 500px;
            height: 500px;
            top: -10%;
            left: -5%;
            background: radial-gradient(circle, rgba(255, 20, 0, 0.25) 0%, transparent 70%);
            animation: driftBlob1 15s ease-in-out infinite alternate;
        }

        .blob-2 {
            width: 400px;
            height: 400px;
            bottom: 10%;
            right: -5%;
            background: radial-gradient(circle, rgba(255, 80, 0, 0.2) 0%, transparent 70%);
            animation: driftBlob2 18s ease-in-out infinite alternate;
        }

        .blob-3 {
            width: 350px;
            height: 350px;
            top: 40%;
            left: 30%;
            background: radial-gradient(circle, rgba(200, 0, 0, 0.12) 0%, transparent 70%);
            animation: driftBlob3 22s ease-in-out infinite alternate;
        }

        /* Diagonal neon stripes */
        .stripe-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 0;
            pointer-events: none;
            background: repeating-linear-gradient(-45deg,
                    transparent,
                    transparent 60px,
                    rgba(255, 30, 0, 0.025) 60px,
                    rgba(255, 30, 0, 0.025) 61px);
        }

        /* Scanline CRT effect */
        .scanlines {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 1;
            pointer-events: none;
            background: repeating-linear-gradient(0deg,
                    transparent,
                    transparent 2px,
                    rgba(0, 0, 0, 0.06) 2px,
                    rgba(0, 0, 0, 0.06) 4px);
        }

        /* Top neon glow bar */
        .neon-bar-top {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, #ff2200, #ff5500, #ff2200, transparent);
            z-index: 1000;
            pointer-events: none;
            box-shadow: 0 0 15px rgba(255, 34, 0, 0.6), 0 0 40px rgba(255, 34, 0, 0.3), 0 0 80px rgba(255, 34, 0, 0.15);
        }

        @keyframes driftBlob1 {
            0% {
                transform: translate(0, 0) scale(1);
            }

            100% {
                transform: translate(80px, 60px) scale(1.15);
            }
        }

        @keyframes driftBlob2 {
            0% {
                transform: translate(0, 0) scale(1);
            }

            100% {
                transform: translate(-60px, -80px) scale(1.2);
            }
        }

        @keyframes driftBlob3 {
            0% {
                transform: translate(0, 0) scale(0.9);
            }

            100% {
                transform: translate(50px, -40px) scale(1.1);
            }
        }
    </style>
</head>

<body>
    <!-- Neon Background System -->
    <div class="bg-scene">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
        <div class="blob blob-3"></div>
    </div>
    <div class="stripe-overlay"></div>
    <div class="scanlines"></div>
    <div class="neon-bar-top"></div>
    <%- include('../partials/navbar') %>

        <div class="dash">
            <!-- Welcome -->
            <div class="card c-welcome"
                style="background: rgba(15, 10, 12, 0.45); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); position: relative; border: 1px solid rgba(255, 255, 255, 0.08); border-top: 1px solid rgba(255, 255, 255, 0.15); box-shadow: 0 8px 32px rgba(0,0,0,0.6), inset 0 2px 20px rgba(255, 255, 255, 0.03); overflow: hidden;">

                <div style="position: relative; z-index: 1;">
                    <div class="cw-title">FRONTIER HUB</div>
                    <div class="cw-sub">Platform updates, daily content, and cross-arena events.</div>
                </div>
                <button class="cw-btn" id="enter-arena-btn" style="position: relative; z-index: 1;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                        stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="5 3 19 12 5 21 5 3"></polygon>
                    </svg>
                    ENTER ARENA
                </button>
                <style>
                    #enter-arena-btn {
                        background: rgba(255, 60, 30, 0.15);
                        backdrop-filter: blur(12px);
                        -webkit-backdrop-filter: blur(12px);
                        border: 1px solid rgba(255, 122, 99, 0.4);
                        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3), inset 0 1px 10px rgba(255, 60, 30, 0.2);
                        padding: 12px 28px;
                        font-size: 1.15rem;
                        border-radius: 8px;
                        text-transform: uppercase;
                        letter-spacing: 2px;
                        display: flex;
                        align-items: center;
                        gap: 10px;
                        color: #fff;
                        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
                        position: relative;
                        overflow: hidden;
                    }

                    #enter-arena-btn::before {
                        content: '';
                        position: absolute;
                        top: 0;
                        left: -100%;
                        width: 50%;
                        height: 100%;
                        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
                        transition: left 0.6s ease;
                        z-index: 1;
                    }

                    #enter-arena-btn:hover::before {
                        left: 100%;
                    }

                    #enter-arena-btn:hover {
                        background: rgba(255, 60, 30, 0.35);
                        border-color: #ff7a63;
                        transform: translateY(-2px);
                        box-shadow:
                            0 10px 25px rgba(255, 60, 30, 0.3),
                            inset 0 1px 15px rgba(255, 255, 255, 0.2);
                        cursor: pointer;
                    }

                    #enter-arena-btn svg,
                    #enter-arena-btn span {
                        position: relative;
                        z-index: 2;
                    }
                </style>
            </div>

            <!-- Stats row -->
            <div class="card c-stat"
                style="padding: 0; background: linear-gradient(180deg, #2b2c36 0%, #1a1a20 100%); border: 2px solid #424651; border-radius: 12px; position: relative; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.8), inset 0 0 20px rgba(255,87,34,0.1);">
                <!-- Slanted Top Tab -->
                <div
                    style="position: absolute; top: 0; left: 0; padding: 10px 25px 10px 15px; z-index: 2; display: flex; align-items: center; gap: 8px;">
                    <div
                        style="position: absolute; top: -10px; left: -10px; right: 0; bottom: 0; background: linear-gradient(180deg, #3f2820, #241916); transform: skewX(-25deg); transform-origin: top left; border-right: 2px solid #754025; border-bottom: 2px solid #754025; border-bottom-right-radius: 8px; z-index: -1;">
                    </div>
                    <span style="font-size: 1.2rem; filter: drop-shadow(0 0 8px #ff5722);">🔥</span>
                    <span style="color: #d1bba8; font-weight: 800; letter-spacing: 1.5px; font-size: 0.75rem;">THE BLAZE
                        ICON</span>
                </div>

                <!-- Main Content -->
                <div style="padding: 55px 20px 20px 20px; position: relative; z-index: 1;">
                    <div class="cs-val" id="stat-top-commander"
                        style="font-size: 2.2rem; color: #ffe8a1; font-family: var(--font-display); letter-spacing: 1px; text-shadow: 0 2px 4px rgba(0,0,0,0.8);">
                        Loading...</div>
                    <div
                        style="font-size: 0.85rem; color: #6dbdbd; margin-top: 4px; font-weight: 700; letter-spacing: 0.5px;">
                        ID: <span id="stat-tc-id">...</span></div>
                </div>

                <!-- Right Side: Flame & Coins -->
                <div
                    style="position: absolute; right: 15px; top: 50%; transform: translateY(-20%); display: flex; flex-direction: column; align-items: center; z-index: 2;">
                    <!-- Glowing background flame -->
                    <div
                        style="position: absolute; top: -55px; right: 0px; font-size: 5rem; opacity: 0.9; filter: drop-shadow(0 0 15px #ff5722) drop-shadow(0 0 30px #ff2200); z-index: -1;">
                        🔥</div>
                    <!-- Coin Pill -->
                    <div
                        style="background: linear-gradient(180deg, #443729, #2b2319); border: 2px solid #726251; border-radius: 30px; padding: 4px 12px; display: flex; align-items: center; gap: 8px; box-shadow: 0 6px 12px rgba(0,0,0,0.9), inset 0 2px 4px rgba(255,255,255,0.1);">
                        <span id="stat-tc-coins"
                            style="color: #f7d58b; font-size: 1.1rem; font-family: var(--font-display); font-weight: bold; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">...</span>
                        <img src="/public/blaze_coin.jpg"
                            style="height: 20px; width: 20px; border-radius: 50%; box-shadow: 0 0 8px rgba(255,193,7,0.8); border: 1px solid #ffd700;"
                            alt="BlazeCoins">
                    </div>
                </div>
            </div>

            <!-- Active Players (Row 3, Col 1) -->
            <div class="card c-stat c-stat-active"
                style="position: relative; background: rgba(20,10,12,0.85); border: 1px solid rgba(255, 87, 34, 0.15); border-radius: 0; clip-path: polygon(0 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%); display: flex; flex-direction: row; align-items: center; justify-content: space-between; padding: 24px; box-shadow: inset 0 0 30px rgba(255, 87, 34, 0.05); transition: transform 0.2s;"
                onmouseover="this.style.transform='translateY(-2px)';"
                onmouseout="this.style.transform='translateY(0)';">
                <div
                    style="position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: linear-gradient(90deg, #ff5722, transparent);">
                </div>
                <div
                    style="position: absolute; bottom: 0; right: 0; width: 20px; height: 20px; border-bottom: 2px solid #ff5722; border-right: 2px solid #ff5722;">
                </div>
                <div style="position: relative; z-index: 1;">
                    <div class="cs-label"
                        style="color: #ff5722; font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase;">
                        Active</div>
                    <div class="cs-val" id="stat-commanders"
                        style="color: #fff; font-size: 2.4rem; text-shadow: 0 0 10px rgba(255,87,34,0.4);">...</div>
                    <div class="cs-sub" style="color: rgba(255,255,255,0.4);">Global unique players</div>
                </div>
                <div
                    style="position: relative; z-index: 1; width: 48px; height: 48px; background: linear-gradient(135deg, rgba(255, 87, 34, 0.2), transparent); border: 1px solid rgba(255,87,34,0.4); transform: rotate(45deg); display: flex; align-items: center; justify-content: center; box-shadow: 0 0 20px rgba(255,87,34,0.3);">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ff5722" stroke-width="2"
                        style="transform: rotate(-45deg); filter: drop-shadow(0 0 5px #ff5722);">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                        <circle cx="9" cy="7" r="4"></circle>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                    </svg>
                </div>
            </div>

            <!-- Matches Today (Row 3, Col 2) -->
            <div class="card c-stat c-stat-matches"
                style="position: relative; background: rgba(20,15,10,0.85); border: 1px solid rgba(255, 183, 0, 0.15); border-radius: 0; clip-path: polygon(0 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%); display: flex; flex-direction: row; align-items: center; justify-content: space-between; padding: 24px; box-shadow: inset 0 0 30px rgba(255, 183, 0, 0.05); transition: transform 0.2s;"
                onmouseover="this.style.transform='translateY(-2px)';"
                onmouseout="this.style.transform='translateY(0)';">
                <div
                    style="position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: linear-gradient(90deg, #ffb700, transparent);">
                </div>
                <div
                    style="position: absolute; bottom: 0; right: 0; width: 20px; height: 20px; border-bottom: 2px solid #ffb700; border-right: 2px solid #ffb700;">
                </div>
                <div style="position: relative; z-index: 1;">
                    <div class="cs-label"
                        style="color: #ffb700; font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase;">
                        Matches Today</div>
                    <div class="cs-val" id="stat-matches"
                        style="color: #fff; font-size: 2.4rem; text-shadow: 0 0 10px rgba(255,183,0,0.4);">...</div>
                    <div class="cs-sub" style="color: rgba(255,255,255,0.4);">Across all arenas</div>
                </div>
                <div
