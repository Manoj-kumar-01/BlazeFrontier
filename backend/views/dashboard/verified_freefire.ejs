    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Find a Squad Button — delegates to global-matchmaking.js
            document.getElementById('find-squad-btn').addEventListener('click', async () => {
                const proceed = await customConfirm('This will broadcast your request to all online players. 20 BlazeCoins will be deducted if someone accepts. Proceed?');
                if (!proceed) return;

                const btn = document.getElementById('find-squad-btn');
                btn.disabled = true;

                if (window.BlazeMatchmaking && window.BlazeMatchmaking.startSearch) {
                    const success = await window.BlazeMatchmaking.startSearch();
                    if (!success) {
                        btn.disabled = false;
                    }
                } else {
                    console.error('Matchmaking module not loaded.');
                    btn.disabled = false;
                }
            });

            // Clip Submission Form Handler
            const clipForm = document.getElementById('clip-submit-form');
            const fileInput = document.getElementById('cs-file');
            const trimmerUi = document.getElementById('cs-trimmer-ui');
            const videoPreview = document.getElementById('cs-video-preview');
            const trimStart = document.getElementById('cs-trim-start');
            const trimEnd = document.getElementById('cs-trim-end');
            const startDisplay = document.getElementById('cs-start-display');
            const endDisplay = document.getElementById('cs-end-display');
            const durationWarning = document.getElementById('cs-duration-warning');
            
            let videoDuration = 0;

            if (fileInput) {
                fileInput.addEventListener('change', (e) => {
                    const file = e.target.files[0];
                    if (file) {
                        const url = URL.createObjectURL(file);
                        videoPreview.src = url;
                        videoPreview.onloadedmetadata = () => {
                            videoDuration = videoPreview.duration;
                            trimmerUi.style.display = 'block';
                            
                            // Configure sliders
                            trimStart.max = videoDuration;
                            trimStart.value = 0;
                            
                            trimEnd.max = videoDuration;
                            trimEnd.value = Math.min(videoDuration, 10);
                            
                            updateTrimDisplay();
                        };
                    } else {
                        trimmerUi.style.display = 'none';
                        videoPreview.src = '';
                    }
                });
            }

            if (trimStart && trimEnd) {
                trimStart.addEventListener('input', () => {
                    let start = parseFloat(trimStart.value);
                    let end = parseFloat(trimEnd.value);
                    
                    if (start >= end) {
                        trimEnd.value = Math.min(videoDuration, start + 10);
                    } else if (end - start > 10) {
                        trimEnd.value = start + 10;
                    }
                    updateTrimDisplay();
                    videoPreview.currentTime = start;
                });
                
                trimEnd.addEventListener('input', () => {
                    let start = parseFloat(trimStart.value);
                    let end = parseFloat(trimEnd.value);
                    
                    if (end <= start) {
                        trimStart.value = Math.max(0, end - 10);
                    } else if (end - start > 10) {
                        trimStart.value = end - 10;
                    }
                    updateTrimDisplay();
                    videoPreview.currentTime = end;
                });
            }

            function updateTrimDisplay() {
                const start = parseFloat(trimStart.value);
                const end = parseFloat(trimEnd.value);
                startDisplay.innerText = `Start: ${start.toFixed(1)}s`;
                endDisplay.innerText = `End: ${end.toFixed(1)}s`;
                
                const submitBtn = document.getElementById('cs-submit-btn');
                if (end - start > 10.1) {
                    durationWarning.style.display = 'block';
                    if(submitBtn) submitBtn.disabled = true;
                } else {
                    durationWarning.style.display = 'none';
                    if(submitBtn) submitBtn.disabled = false;
                }
            }

            if (clipForm) {
                clipForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    const title = document.getElementById('cs-title').value;
                    const file = fileInput.files[0];
                    const submitBtn = document.getElementById('cs-submit-btn');

                    if (!file) return;

                    // Prevent massive video uploads that crash the server or timeout proxies
                    if (file.size > 40 * 1024 * 1024) {
                        alert('Your video file is too large! Please select a clip that is under 40MB.');
                        return;
                    }

                    submitBtn.disabled = true;
                    submitBtn.textContent = 'UPLOADING...';

                    const formData = new FormData();
                    formData.append('title', title);
                    formData.append('game', 'Free Fire');
                    formData.append('clip', file); // Backend expects 'clip'
                    let currentPlayerId = 'Unknown';
                    if (typeof playerBlazeId !== 'undefined') currentPlayerId = playerBlazeId;
                    else if (window.globalUserData && window.globalUserData.playerId) currentPlayerId = window.globalUserData.playerId;
                    
                    formData.append('playerId', currentPlayerId);
                    formData.append('startTime', parseFloat(trimStart.value) || 0);
                    formData.append('endTime', parseFloat(trimEnd.value) || 10);

                    try {
                        const token = localStorage.getItem('blaze_token');
                        
                        // Create a dynamic progress background on the button
                        submitBtn.style.position = 'relative';
                        submitBtn.style.overflow = 'hidden';
                        submitBtn.innerHTML = '<span style="position:relative; z-index:2;">UPLOADING... 0%</span><div id="upload-progress-bar" style="position:absolute; top:0; left:0; height:100%; width:0%; background:rgba(255,255,255,0.2); z-index:1; transition:width 0.2s;"></div>';
                        
                        const xhr = new XMLHttpRequest();
                        xhr.open('POST', '/api/clips/submit', true);
                        xhr.setRequestHeader('x-auth-token', token);

                        xhr.upload.onprogress = function(e) {
                            if (e.lengthComputable) {
                                const percentComplete = Math.round((e.loaded / e.total) * 100);
                                const progressDiv = document.getElementById('upload-progress-bar');
                                if (progressDiv) {
                                    progressDiv.style.width = percentComplete + '%';
                                    submitBtn.querySelector('span').innerText = `UPLOADING... ${percentComplete}%`;
                                }
                            }
                        };

                        xhr.onload = function() {
                            if (xhr.status >= 200 && xhr.status < 300) {
                                document.getElementById('clip-submit-modal').style.display = 'none';
                                clipForm.reset();
                                trimmerUi.style.display = 'none';
                                videoPreview.src = '';
                                
                                // Hide the submit UI so they can't submit again
                                const submitContainer = document.getElementById('submit-ui-container');
                                if (submitContainer) {
                                    submitContainer.innerHTML = '<div style="background: rgba(22, 163, 74, 0.1); border: 1px solid rgba(22, 163, 74, 0.3); border-radius: 12px; padding: 25px; text-align: center; margin-top: 20px;"><div style="color: #4ade80; font-size: 2rem; margin-bottom: 10px;">✅</div><h3 style="color: #fff; font-family: var(--font-display); font-size: 1.2rem; margin: 0 0 5px 0;">CLIP SUBMITTED!</h3><p style="color: rgba(255,255,255,0.7); font-size: 0.9rem; margin: 0;">Your highlight is now under review. Check back on Saturday!</p></div>';
                                }
                            } else {
                                let msg = 'Unknown error';
                                try {
                                    const data = JSON.parse(xhr.responseText);
                                    msg = data.msg || msg;
                                } catch (e) {
                                    if (xhr.status === 413) msg = 'File is too large for the server configuration.';
                                    else msg = `Server returned status ${xhr.status}`;
                                }
                                alert('Upload failed: ' + msg);
                                submitBtn.disabled = false;
                                submitBtn.innerHTML = 'SUBMIT CLIP FOR REVIEW';
                            }
                        };

                        xhr.onerror = function() {
                            alert('Network Error: The upload was interrupted. The file might be too large for your network/proxy.');
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = 'SUBMIT CLIP FOR REVIEW';
                        };

                        xhr.send(formData);

                    } catch (err) {
                        console.error('Upload Exception:', err);
                        alert('Error uploading clip: ' + err.message);
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = 'SUBMIT CLIP FOR REVIEW';
                    }
                });
            }
        });
    </script>
</body>
</html>
