    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            // Check for user weekly submission status and active event
            try {
                const token = localStorage.getItem('blaze_token');
                
                // 1. Check if user already submitted this week
                if(token) {
                    const statusRes = await fetch('/api/clip-submissions/me/this-week', {
                        headers: { 'x-auth-token': token }
                    });
                    if (statusRes.ok) {
                        const { hasSubmitted } = await statusRes.json();
                        if (hasSubmitted) {
                            const btn = document.getElementById('submit-clip-btn');
                            btn.innerHTML = '<span>SUBMITTED FOR THIS WEEK</span>';
                            btn.style.background = 'rgba(255,255,255,0.1)';
                            btn.style.color = 'rgba(255,255,255,0.5)';
                            btn.style.boxShadow = 'none';
                            btn.style.pointerEvents = 'none';
                            btn.removeAttribute('onclick');
                            
                            document.getElementById('submit-clip-text').innerHTML = 'You have already submitted a clip this week. Voting begins on Saturday!';
                        }
                    }
                }

                // 2. Fetch Latest Voting Event Clips & Check if Voting is Active
                const voteRes = await fetch('/api/voting-event/active');
                if (voteRes.ok) {
                    const event = await voteRes.json();
                    if (event) {
                        // Show Clips and Vote Button ONLY if Active and has clips
                        if (event.isActive && event.game === 'Free Fire' && event.clips && event.clips.length > 0) {
                            const container = document.getElementById('dynamic-clips-container');
                            if (container) {
                                container.innerHTML = '';
                                event.clips.forEach(clip => {
                                    container.innerHTML += `
                                        <div class="clip-item" style="display: flex; gap: 12px; align-items: center; padding: 8px; background: rgba(0,0,0,0.3); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,87,34,0.1)'" onmouseout="this.style.background='rgba(0,0,0,0.3)'" onclick="window.open('${clip.videoUrl}', '_blank')">
                                            <div style="width: 50px; height: 35px; border-radius: 4px; overflow: hidden; border: 1px solid rgba(255,87,34,0.3); flex-shrink: 0; background: #000;">
                                                <video src="${clip.videoUrl}" style="width: 100%; height: 100%; object-fit: cover;"></video>
                                            </div>
                                            <div style="flex: 1; min-width: 0;">
                                                <div style="color: #fff; font-size: 0.8rem; font-family: var(--font-display); letter-spacing: 0.5px; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${clip.title}</div>
                                                <div style="color: rgba(255,255,255,0.5); font-size: 0.7rem;">Player ID: <span style="color: #fff; font-weight: bold;">${clip.userId && clip.userId.playerId ? clip.userId.playerId : clip.playerId}</span></div>
                                            </div>
                                            <div style="color: rgba(255,255,255,0.3); font-size: 1.2rem;">▶</div>
                                        </div>
                                    `;
                                });
                            }

                            document.getElementById('submit-ui-container').style.display = 'none';
                            document.getElementById('voting-prompt-container').style.display = 'block';
                        } else {
                            const container = document.getElementById('dynamic-clips-container');
                            if (container) {
                                container.innerHTML = '<div style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-align: center; padding: 20px 0; margin: auto;">Voting clips will be revealed here on Saturday!</div>';
                            }
                        }
                    } else {
                        const container = document.getElementById('dynamic-clips-container');
                        if (container) {
                            container.innerHTML = '<div style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-align: center; padding: 20px 0; margin: auto;">Voting clips will be revealed here on Saturday!</div>';
                        }
                    }
                } else {
                    const container = document.getElementById('dynamic-clips-container');
                    if (container) {
                        container.innerHTML = '<div style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-align: center; padding: 20px 0; margin: auto;">Voting clips will be revealed here on Saturday!</div>';
                    }
                }
            } catch(e) {
                console.error("Error checking voting event", e);
                const container = document.getElementById('dynamic-clips-container');
                if (container) {
                    container.innerHTML = '<div style="color: rgba(255,255,255,0.5); font-size: 0.85rem; text-align: center; padding: 20px 0; margin: auto;">Voting clips will be revealed here on Saturday!</div>';
                }
            }
        });
    </script>

    <script src="/script.js?v=1.2"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('testToken')) {
                const tokenRes = await fetch('/api/test-token');
                const tokenData = await tokenRes.json();
                localStorage.setItem('blaze_token', tokenData.token);
                window.location.href = window.location.pathname;
                return;
            }

            const token = localStorage.getItem('blaze_token');
            if (!token) { window.location.href = '/auth'; return; }

            let isGenuine = false;
            let totalMatches = 0;
            let blockedUntil = null;
            let dailyCount = 0;
            try {
                const profRes = await fetch('/api/profile', { headers: { 'x-auth-token': token }, cache: 'no-store' });
                if (profRes.status === 401) {
                    localStorage.removeItem('blaze_token');
                    window.location.href = '/auth';
                    return;
                }
                if(profRes.ok) {
                    const prof = await profRes.json();
                    if (prof.isGenuine !== true) {
                        window.location.href = '/dashboard/freefire';
                        return;
                    }
                    isGenuine = true;
                    totalMatches = prof.totalMatches || 0;
                    blockedUntil = prof.matchmakingBlockedUntil;
                    dailyCount = prof.matchmakingDailyCount || 0;
                }
            } catch(e) {}

            document.getElementById('ff-stat-participated').innerText = totalMatches;
            
            const reqsLeft = Math.max(0, 5 - dailyCount);
            const limitSpan = document.getElementById('mm-daily-limit');
            if (limitSpan) limitSpan.innerText = `(${reqsLeft}/5 Left)`;

            // Matchmaking state (limits and cooldowns) is now fully handled 
            // by global-matchmaking.js on load via /api/matchmaking/status

            // Fetch dynamic HUB stats
            try {
                const res = await fetch('/api/hub/freefire/stats');
                if(res.ok) {
                    const stats = await res.json();
                    
                    document.getElementById('ff-stat-operators').innerText = stats.activeOperators > 0 ? stats.activeOperators : 0;
                    document.getElementById('ff-stat-tourneys').innerText = stats.activeTournaments;
                }
            } catch(e) {
                console.error("Failed to load hub stats", e);
            }
            // Fetch dynamic tournaments (Live & Upcoming)
            // Event Listener for "View All" Qualification Series
            const viewAllQsBtn = document.getElementById('view-all-qs-btn');
            if(viewAllQsBtn) {
                viewAllQsBtn.addEventListener('click', async (e) => {
                    e.preventDefault();
                    document.getElementById('qs-side-panel').style.right = '0';
                    document.getElementById('qs-panel-content').innerHTML = `
            <div style="background: rgba(255,255,255,0.02); border-radius: 10px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(255,255,255,0.05);">
                <div class="skeleton skeleton-title" style="height:20px; width:50%;"></div>
                <div class="skeleton skeleton-text" style="height:12px; width:80%;"></div>
                <div class="skeleton skeleton-text" style="height:12px; width:70%;"></div>
                <div class="skeleton skeleton-text" style="height:12px; width:60%;"></div>
            </div>
            <div style="background: rgba(255,255,255,0.02); border-radius: 10px; padding: 16px; margin-bottom: 12px; border: 1px solid rgba(255,255,255,0.05);">
                <div class="skeleton skeleton-title" style="height:20px; width:40%;"></div>
                <div class="skeleton skeleton-text" style="height:12px; width:75%;"></div>
                <div class="skeleton skeleton-text" style="height:12px; width:65%;"></div>
                <div class="skeleton skeleton-text" style="height:12px; width:55%;"></div>
            </div>`;
                    
                    try {
                        const token = localStorage.getItem('blaze_token');
                        const tRes = await fetch('/api/tournaments?game=freefire', { headers: { 'x-auth-token': token } });
                        
                        if (tRes.status === 401) {
                            localStorage.removeItem('blaze_token');
                            window.location.href = '/auth';
                            return;
                        }

                        if(tRes.ok) {
                            const tData = await tRes.json();
                            const qsMatches = tData.upcoming.filter(m => m.game === 'CUSTOM SERIES');
                            
                            let html = '';
                            if(qsMatches.length > 0) {
                                qsMatches.forEach(m => {
                                    html += `
                                    <div style="background: linear-gradient(135deg, rgba(15,15,20,0.6) 0%, rgba(10,10,15,0.75) 100%), url('/public/qs_match_bg.png') center/cover no-repeat; border: 1px solid rgba(0, 188, 212, 0.3); border-left: 4px solid var(--blaze-orange); border-radius: 10px; padding: 16px; margin-bottom: 12px; box-shadow: 0 6px 20px rgba(0,0,0,0.5); position: relative; transition: transform 0.2s, border-color 0.2s;" onmouseover="this.style.transform='translateX(-4px)'; this.style.borderColor='rgba(0,188,212,0.6)'" onmouseout="this.style.transform='none'; this.style.borderColor='rgba(0,188,212,0.3)'">
                                        <div style="display:flex; justify-content:space-between; margin-bottom: 8px;">
                                            <div style="color: #fff; font-family: var(--font-display); font-size: 1.1rem;">MATCH #${m.matchNumber || 'TBA'}</div>
                                            <div style="color: var(--blaze-orange); font-size: 0.65rem; font-weight: bold; background: rgba(255,87,34,0.1); padding: 4px 8px; border-radius: 4px;">${m.status}</div>
                                        </div>
                                        <div style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 4px;">Player: <span style="color:#fff; font-weight:600;">${m.playerName || 'Unknown'}</span></div>
                                        <div style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 4px;">Format: <span style="color:#fff">${m.name}</span></div>
                                        <div style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 4px;">Type: <span style="color:#fff; text-transform:capitalize;">${m.team}</span></div>
                                        <div style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 4px;">Date: <span style="color:#fff">${m.date}</span></div>
                                        <div style="color: var(--text-muted); font-size: 0.85rem;">Slot: <span style="color:#fff">${m.timeSlot || m.slot}</span></div>
                                    </div>
                                    `;
                                });
                            } else {
                                html = '<div style="text-align:center; padding: 20px; color: var(--text-muted); font-size: 0.9rem;">No qualification matches available right now.</div>';
                            }
                            document.getElementById('qs-panel-content').innerHTML = html;
                        } else {
                            document.getElementById('qs-panel-content').innerHTML = `<div style="color: #ef4444; padding: 20px; text-align: center;">Server Error: ${tRes.status}</div>`;
                        }
                    } catch(err) {
                        console.error("Side panel error:", err);
                        document.getElementById('qs-panel-content').innerHTML = `<div style="color: #ef4444; padding: 20px; text-align: center;">Failed to load matches: ${err.message}</div>`;
                    }
                });
            }

            // Dynamic Top Clips
            try {
                const clipsRes = await fetch('/api/game/freefire/clips');
                if (clipsRes.ok) {
                    const clipsData = await clipsRes.json();
                    const container = document.getElementById('dynamic-clips-container');
                    const isVotingActive = document.getElementById('voting-prompt-container') && document.getElementById('voting-prompt-container').style.display === 'block';
                    if (container && !isVotingActive) {
                        if (clipsData.length === 0) {
                            container.innerHTML = '<div style="text-align:center; padding: 20px; color: var(--text-muted); font-size: 0.9rem;">No top clips for today yet. Submit yours!</div>';
                        } else {
                            container.innerHTML = clipsData.map(c => `
                                <div class="clip-item">
                                    <a href="${c.url}" target="_blank" class="ci-play" style="text-decoration:none;">▶</a>
                                    <div class="ci-info">
                                        <div class="ci-title">${c.title}</div>
                                        <div class="ci-author">By ${c.author}</div>
                                    </div>
                                </div>
                            `).join('');
                        }
                    }
                }
            } catch (e) {
                console.error("Failed to load clips", e);
            }

            // Clip Submission Logic
            const fileInput = document.getElementById('cs-file');
            const submitBtn = document.getElementById('cs-submit-btn');
            const durationError = document.getElementById('cs-duration-error');
            let isDurationValid = false;
            let playerBlazeId = '';
            try {
                const pRes = await fetch('/api/profile', { headers: { 'x-auth-token': token }, cache: 'no-store' });
                if (pRes.ok) {
                    const pData = await pRes.json();
                    playerBlazeId = pData.playerId || '';
                }
            } catch(e) {}

            if (fileInput) {
                fileInput.addEventListener('change', function(e) {
                    const file = e.target.files[0];
                    if (!file) return;
                    
                    const video = document.createElement('video');
                    video.preload = 'metadata';
                    video.onloadedmetadata = function() {
                        window.URL.revokeObjectURL(video.src);
                        if (video.duration > 11) { // 10s + 1s margin
                            durationError.style.display = 'block';
                            submitBtn.disabled = true;
                            submitBtn.style.opacity = '0.5';
                            isDurationValid = false;
                        } else {
                            durationError.style.display = 'none';
                            submitBtn.disabled = false;
                            submitBtn.style.opacity = '1';
                            isDurationValid = true;
                        }
                    }
                    video.src = URL.createObjectURL(file);
                });
            }
        });

        // Global confirmPlay function
        window.confirmPlay = async function(regId, played) {
            const btnYes = event.target.parentNode.querySelector('button:nth-child(1)');
            const btnNo = event.target.parentNode.querySelector('button:nth-child(2)');
            btnYes.disabled = true;
