<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vote for Best Clip - Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=block" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .dash {
            display: flex; flex-direction: column;
            gap: 14px; padding: 88px 20px 20px; min-height: 100vh;
            max-width: 1500px; margin: 0 auto;
        }

        .header-title {
            text-align: center;
            font-family: var(--font-display);
            font-size: 3rem;
            background: linear-gradient(135deg, #ffd700, #ff5722);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }
        .header-sub {
            text-align: center;
            color: rgba(255,255,255,0.7);
            font-size: 1.1rem;
            margin-bottom: 40px;
        }
        .clips-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        .clip-card {
            background: rgba(20,20,25,0.8);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0,0,0,0.5);
            transition: transform 0.2s, border-color 0.2s;
        }
        .clip-card:hover {
            transform: translateY(-5px);
            border-color: var(--blaze-orange);
        }
        .clip-vid-container {
            width: 100%;
            height: 200px;
            background: #000;
            position: relative;
        }
        .clip-vid-container video {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }
        .clip-info {
            padding: 20px;
        }
        .clip-title {
            font-family: var(--font-display);
            font-size: 1.2rem;
            margin-bottom: 5px;
            color: #fff;
        }
        .clip-author {
            color: var(--blaze-orange);
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 15px;
        }
        .vote-btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #e11d48, #f59e0b);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(225, 29, 72, 0.4);
            transition: filter 0.2s;
        }
        .vote-btn:hover {
            filter: brightness(1.2);
        }
        
        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.8);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .modal-content {
            background: #111;
            padding: 30px;
            border-radius: 12px;
            width: 100%;
            max-width: 500px;
            border: 1px solid rgba(255,87,34,0.3);
            text-align: center;
        }
        .modal input[type="text"] {
            width: 100%;
            padding: 12px;
            margin: 20px 0;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.2);
            color: #fff;
            border-radius: 8px;
            box-sizing: border-box;
        }
        .modal button {
            padding: 12px 24px;
            background: var(--blaze-orange);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            margin: 0 5px;
        }
        .modal button.cancel {
            background: rgba(255,255,255,0.1);
        }

        /* Results */
        #results-container {
            display: none;
        }
        .podium {
            display: flex;
            align-items: flex-end;
            justify-content: center;
            gap: 15px;
            margin: 40px 0;
            height: 250px;
        }
        .podium-item {
            background: rgba(255,87,34,0.1);
            border: 1px solid rgba(255,87,34,0.3);
            border-radius: 8px 8px 0 0;
            width: 120px;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            align-items: center;
            padding-top: 10px;
            text-align: center;
        }
        .podium-1 { height: 100%; background: linear-gradient(to top, rgba(255,215,0,0.1), rgba(255,215,0,0.3)); border-color: #ffd700; }
        .podium-2 { height: 75%; background: linear-gradient(to top, rgba(192,192,192,0.1), rgba(192,192,192,0.3)); border-color: #c0c0c0; }
        .podium-3 { height: 50%; background: linear-gradient(to top, rgba(205,127,50,0.1), rgba(205,127,50,0.3)); border-color: #cd7f32; }
        .podium-rank { font-size: 2rem; font-weight: 800; font-family: var(--font-display); }
        .podium-1 .podium-rank { color: #ffd700; }
        .podium-2 .podium-rank { color: #c0c0c0; }
        .podium-3 .podium-rank { color: #cd7f32; }
        
        .comments-section {
            background: rgba(15,10,12,0.6);
            border-radius: 12px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.05);
        }
        .comment-item {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding-bottom: 20px;
        }
        .comment-item:last-child {
            border-bottom: none; margin-bottom: 0; padding-bottom: 0;
        }
        .comment-avatar {
            width: 40px; height: 40px; border-radius: 50%; background: #333; flex-shrink: 0;
        }
        .comment-body {
            flex: 1;
        }
        .comment-author {
            font-weight: bold; color: #fff; margin-bottom: 5px; font-size: 0.9rem;
        }
        .comment-text {
            color: rgba(255,255,255,0.8); font-size: 0.95rem; line-height: 1.4;
        }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="dash">
        <div id="loading" style="text-align: center; color: rgba(255,255,255,0.5); padding: 50px;">Loading event details...</div>

        <!-- Voting Interface -->
        <div id="voting-interface" style="display: none;">
            <div class="header-title" id="event-title">Top 3 Clips</div>
            <div class="header-sub">Watch the clips below and cast your vote for the best play!</div>

            <div class="clips-grid" id="clips-grid">
                <!-- Clips injected here -->
            </div>
        </div>

        <!-- Results Interface -->
        <div id="results-container">
            <div class="header-title">Voting Results</div>
            <div class="header-sub">Current standings and community thoughts</div>

            <div class="podium" id="podium-display">
                <!-- Podium injected here -->
            </div>

            <div class="comments-section">
                <h3 style="margin-top:0; font-family: var(--font-display); color: #ff5722;">Community Comments</h3>
                <div id="comments-list">
                    <!-- Comments injected here -->
                </div>
            </div>
        </div>
    </div>

    <!-- Vote Modal -->
    <div class="modal" id="vote-modal">
        <div class="modal-content">
            <h2 style="margin-top:0; color: #ffd700;">Cast Your Vote!</h2>
            <p style="color: rgba(255,255,255,0.7); font-size: 0.9rem;">Tell us why this clip deserves to win (optional)</p>
            <input type="text" id="vote-comment" placeholder="e.g. Insane sniper shot at the end!" autocomplete="off">
            <input type="hidden" id="selected-clip-id">
            <input type="hidden" id="active-event-id">
            <div style="display: flex; justify-content: center; gap: 10px;">
                <button class="cancel" onclick="closeVoteModal()">Cancel</button>
                <button onclick="submitVote()">Submit Vote</button>
            </div>
        </div>
    </div>

    <script>
        let currentEvent = null;
        let clipMap = {};

        document.addEventListener('DOMContentLoaded', async () => {
            await loadEvent();
        });

        async function loadEvent() {
            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch('/api/voting-event/active', {
                    headers: token ? { 'x-auth-token': token } : {}
                });
                if (res.ok) {
                    currentEvent = await res.json();
                    document.getElementById('loading').style.display = 'none';

                    if (!currentEvent.isActive) {
                        document.getElementById('voting-interface').style.display = 'none';
                        showResults(currentEvent._id);
                        return;
                    }
                    
                    document.getElementById('voting-interface').style.display = 'block';
                    document.getElementById('event-title').innerText = currentEvent.title;
                    document.getElementById('active-event-id').value = currentEvent._id;

                    const grid = document.getElementById('clips-grid');
                    grid.innerHTML = '';
                    currentEvent.clips.forEach(clip => {
                        clipMap[clip._id] = clip;
                        grid.innerHTML += `
                            <div class="clip-card">
                                <div class="clip-vid-container">
                                    <video src="${clip.videoUrl}" controls preload="metadata"></video>
                                </div>
                                <div class="clip-info">
                                    <div class="clip-title">${clip.title}</div>
                                    <div class="clip-author">Player ID: ${clip.playerId || clip.userId}</div>
                                    <button class="vote-btn" onclick="openVoteModal('${clip._id}')">Vote for this Clip</button>
                                </div>
                            </div>
                        `;
                    });
                } else {
                    document.getElementById('loading').innerText = 'No active voting events at the moment.';
                }
            } catch (e) {
                document.getElementById('loading').innerText = 'Error loading voting event.';
            }
        }

        function openVoteModal(clipId) {
            document.getElementById('selected-clip-id').value = clipId;
            document.getElementById('vote-comment').value = '';
            document.getElementById('vote-modal').style.display = 'flex';
        }

        function closeVoteModal() {
            document.getElementById('vote-modal').style.display = 'none';
        }

        async function submitVote() {
            const clipId = document.getElementById('selected-clip-id').value;
            const eventId = document.getElementById('active-event-id').value;
            const comment = document.getElementById('vote-comment').value;

            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch(`/api/voting-event/${eventId}/vote`, {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json',
                        'x-auth-token': token || ''
                    },
                    body: JSON.stringify({ clipId, comment })
                });
                
                const data = await res.json();
                closeVoteModal();

                if (res.ok || data.msg === 'You have already voted in this event') {
                    if(!res.ok) alert("You have already voted! Here are the results.");
                    await showResults(eventId);
                } else {
                    alert(data.msg || 'Error submitting vote');
                }
            } catch (e) {
                alert('Server error');
            }
        }

        async function showResults(eventId) {
            document.getElementById('voting-interface').style.display = 'none';
            document.getElementById('results-container').style.display = 'block';

            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch(`/api/voting-event/${eventId}/results`, {
                    headers: token ? { 'x-auth-token': token } : {}
                });
                if (res.ok) {
                    const data = await res.json();
                    
                    // Build Podium
                    const podiumEl = document.getElementById('podium-display');
                    podiumEl.innerHTML = '';
                    
                    // We need at most 3 results
                    const top3 = data.rankings.slice(0, 3);
                    
                    // Map to 1st, 2nd, 3rd (DOM order: 2nd, 1st, 3rd for podium effect)
                    const p1 = top3[0];
                    const p2 = top3[1];
                    const p3 = top3[2];

                    if (p2) {
                        podiumEl.innerHTML += renderPodiumItem(2, p2);
                    }
                    if (p1) {
                        podiumEl.innerHTML += renderPodiumItem(1, p1);
                    }
                    if (p3) {
                        podiumEl.innerHTML += renderPodiumItem(3, p3);
                    }

                    // Comments
                    const commentsList = document.getElementById('comments-list');
                    commentsList.innerHTML = '';
                    if (data.comments.length === 0) {
                        commentsList.innerHTML = '<div style="color: rgba(255,255,255,0.5);">No comments yet.</div>';
                    } else {
                        data.comments.forEach(c => {
                            commentsList.innerHTML += `
                                <div class="comment-item">
                                    <div class="comment-avatar"></div>
                                    <div class="comment-body">
                                        <div class="comment-author">${c.userId?.inGameName || c.userId?.username || 'Unknown'}</div>
                                        <div class="comment-text">${c.comment}</div>
                                    </div>
                                </div>
                            `;
                        });
                    }
                }
            } catch (e) {
                console.error(e);
            }
        }

        function renderPodiumItem(rank, result) {
            const clip = clipMap[result._id];
            const title = clip ? clip.title : 'Unknown Clip';
            const votes = result.count;
            return `
                <div class="podium-item podium-${rank}">
                    <div class="podium-rank">#${rank}</div>
                    <div style="font-size: 0.8rem; padding: 10px 5px; word-wrap: break-word;">${title}</div>
                    <div style="margin-top: auto; padding-bottom: 15px; font-weight: bold; color: rgba(255,255,255,0.8);">${votes} Votes</div>
                </div>
            `;
        }
    </script>
</body>
</html>
