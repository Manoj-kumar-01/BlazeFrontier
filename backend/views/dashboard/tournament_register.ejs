<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tournament Registration | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=block" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        .page-wrap { max-width: 900px; margin: 0 auto; padding: 100px 24px 60px; }

        .form-card {
            background: #111116; border: 1px solid rgba(139,92,246,0.3);
            border-radius: 16px; position: relative; overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 40px rgba(139,92,246,0.05);
        }

        .fc-header {
            padding: 40px; border-bottom: 1px solid rgba(255,255,255,0.06);
            background: linear-gradient(180deg, rgba(139,92,246,0.1) 0%, #111116 100%);
        }
        .fc-title { font-family: var(--font-display); font-size: 2.5rem; color: #fff; letter-spacing: 1px; }
        .fc-sub { color: var(--text-muted); font-size: 1rem; margin-top: 8px; line-height: 1.6; }
        .fc-tourney-name { color: #a78bfa; font-weight: 700; }

        .form-body { padding: 40px; }

        .input-group { margin-bottom: 24px; }
        .input-label { display: block; color: #fff; font-size: 0.85rem; font-weight: 600; letter-spacing: 1px; margin-bottom: 10px; text-transform: uppercase; }
        .input-control {
            width: 100%; padding: 16px; background: rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
            color: #fff; font-family: var(--font-body); font-size: 1rem; transition: border-color 0.2s;
        }
        .input-control:focus { outline: none; border-color: #a78bfa; }
        .input-control::placeholder { color: rgba(255,255,255,0.2); }

        .discord-box {
            background: rgba(88, 101, 242, 0.1); border: 1px solid rgba(88, 101, 242, 0.3);
            border-radius: 8px; padding: 24px; margin-bottom: 24px;
            display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap;
        }
        .dc-info { flex: 1; }
        .dc-title { color: #5865F2; font-weight: 700; margin-bottom: 8px; font-size: 1.1rem; }
        .dc-text { color: #fff; font-size: 0.9rem; line-height: 1.5; margin-bottom: 10px; }
        .dc-btn {
            background: #5865F2; color: #fff; padding: 12px 24px; border-radius: 6px; text-decoration: none;
            font-weight: 600; font-size: 0.9rem; transition: background 0.2s; white-space: nowrap; border: none; cursor: pointer;
        }
        .dc-btn:hover { background: #4752C4; }

        .submit-wrapper { padding: 40px; border-top: 1px solid rgba(255,255,255,0.06); background: rgba(0,0,0,0.2); }
        .submit-btn {
            width: 100%; padding: 20px; border-radius: 8px; border: none;
            background: linear-gradient(135deg, #8b5cf6, #6d28d9); color: #fff;
            font-family: var(--font-display); font-size: 1.5rem; letter-spacing: 1.5px;
            cursor: pointer; transition: all 0.3s;
        }
        .submit-btn:hover { box-shadow: 0 10px 30px rgba(139,92,246,0.4); transform: translateY(-2px); }
        .submit-btn:disabled { background: rgba(255,255,255,0.1); color: var(--text-muted); cursor: not-allowed; transform: none; box-shadow: none; }

        .success-overlay {
            background: #111116; border-radius: 16px;
            display: none; flex-direction: column; justify-content: center; align-items: center;
            text-align: center; padding: 80px 40px; animation: fadeIn 0.4s ease;
            position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 10;
        }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .so-icon { font-size: 5rem; color: #a78bfa; margin-bottom: 24px; }
        .so-title { font-family: var(--font-display); font-size: 2.5rem; color: #fff; letter-spacing: 1px; margin-bottom: 16px; }
        .so-text { color: var(--text-muted); font-size: 1.1rem; line-height: 1.6; max-width: 500px; margin-bottom: 32px; }
        .so-btn {
            padding: 14px 32px; border-radius: 8px; border: 1px solid rgba(139,92,246,0.3);
            background: rgba(139,92,246,0.1); color: #a78bfa; font-family: var(--font-display); font-size: 1.2rem;
            letter-spacing: 1px; text-decoration: none; transition: all 0.2s;
        }
        .so-btn:hover { background: rgba(139,92,246,0.2); color: #fff; }

        /* Custom select styling */
        select.input-control { appearance: none; background-image: url("data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%23a78bfa%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-5%200-9.3%201.8-12.9%205.4A17.6%2017.6%200%200%200%200%2082.2c0%205%201.8%209.3%205.4%2012.9l128%20127.9c3.6%203.6%207.8%205.4%2012.8%205.4s9.2-1.8%2012.8-5.4L287%2095c3.5-3.5%205.4-7.8%205.4-12.8%200-5-1.9-9.2-5.5-12.8z%22%2F%3E%3C%2Fsvg%3E"); background-repeat: no-repeat; background-position: right 1rem top 50%; background-size: 0.65rem auto; }
        select.input-control option { background: #111116; color: #fff; padding: 10px; }
    </style>
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="page-wrap">
        <div class="form-card">
            
            <div class="success-overlay" id="success-screen">
                <div class="so-icon">­ƒÅå</div>
                <div class="so-title">REGISTRATION CONFIRMED</div>
                <div class="so-text">You are officially registered. The organizer will reach out to you via Discord regarding match timings and credentials. Keep an eye on your DMs!</div>
                <a href="/dashboard/tournaments" class="so-btn">BACK TO TOURNAMENTS</a>
            </div>

            <div class="fc-header" id="fc-header">
                <div class="fc-title">TOURNAMENT REGISTRATION</div>
                <div class="fc-sub">Registering for: <span class="fc-tourney-name" id="display-t-name">Loading...</span></div>
                <div class="fc-sub" style="font-size:0.85rem; margin-top:4px;">Date: <span id="display-t-date" style="color:#fff;">--</span></div>
            </div>

            <form id="reg-form">
                <input type="hidden" id="tournamentId" value="<%= tournamentId %>">
                <div class="form-body">
                    <div class="input-group" style="margin-bottom: 0;">
                        <div style="background: rgba(255, 87, 34, 0.1); border-left: 4px solid var(--blaze-orange); padding: 16px; border-radius: 4px; margin-bottom: 20px;">
                            <h3 style="color: var(--blaze-orange); margin-top: 0; margin-bottom: 8px; font-size: 1.1rem;">Verification Required</h3>
                            <p style="color: #fff; margin-bottom: 12px; font-size: 0.95rem;">Please confirm your In-game Name and ID are correct:</p>
                            <div style="display: flex; gap: 20px; margin-bottom: 12px; background: rgba(0,0,0,0.3); padding: 10px; border-radius: 6px;">
                                <div>
                                    <span style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase;">In-game Name</span>
                                    <div style="color: #fff; font-weight: 600;" id="display-ign">Loading...</div>
                                </div>
                                <div>
                                    <span style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase;">In-game ID (UID)</span>
                                    <div style="color: #fff; font-weight: 600;" id="display-uid">Loading...</div>
                                </div>
                            </div>
                            <p style="color: #ef4444; font-size: 0.85rem; margin: 0; font-weight: 600;">⚠️ If these details are incorrect, please update them in your profile BEFORE registering. Incorrect details will result in an immediate ban from the Room.</p>
                        </div>
                    </div>
                </div>

                <div class="submit-wrapper">
                    <button type="submit" id="submit-btn" class="submit-btn">SECURE MY SLOT</button>
                    <div id="form-error" style="color: #ef4444; text-align: center; margin-top: 16px; font-size: 0.9rem; display: none;"></div>
                </div>
            </form>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('blaze_token');
        if (!token) {
            window.location.href = '/auth';
        }

        const tid = document.getElementById('tournamentId').value;
        const submitBtn = document.getElementById('submit-btn');
        const formError = document.getElementById('form-error');

        // Fetch tournament details
        async function fetchTourneyDetails() {
            try {
                const res = await fetch('/api/tournaments', { headers: { 'x-auth-token': token }});
                if (res.ok) {
                    const data = await res.json();
                    // Search in live or upcoming
                    const t = data.live.find(x => x._id === tid) || data.upcoming.find(x => x._id === tid);
                    if (t) {
                        document.getElementById('display-t-name').textContent = t.name;
                        document.getElementById('display-t-date').textContent = t.date;
                    } else {
                        document.getElementById('display-t-name').textContent = "Tournament Not Found";
                        submitBtn.disabled = true;
                        submitBtn.textContent = "UNAVAILABLE";
                    }
                }
            } catch(e) {
                console.error(e);
            }
        }
        fetchTourneyDetails();
        
        const applyUserStatus = (prof) => {
            if(prof) {
                document.getElementById('display-ign').textContent = prof.inGameName || 'N/A';
                document.getElementById('display-uid').textContent = prof.gameUid || prof.playerId || 'N/A';
            }
        };

        if (window.globalUserData) {
            applyUserStatus(window.globalUserData);
        } else {
            window.addEventListener('globalUserDataReady', () => {
                if (window.globalUserData) applyUserStatus(window.globalUserData);
            });
        }

        document.getElementById('reg-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            formError.style.display = 'none';
            submitBtn.disabled = true;
            submitBtn.textContent = 'REGISTERING...';

            try {
                const res = await fetch(`/api/tournaments/${tid}/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'x-auth-token': token },
                    body: JSON.stringify({ discord: 'N/A', timeSlot: 'N/A' })
                });

                const data = await res.json();

                if (res.ok) {
                    document.getElementById('success-screen').style.display = 'flex';
                } else {
                    formError.textContent = data.msg || 'Registration failed.';
                    formError.style.display = 'block';
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'SECURE MY SLOT';
                }
            } catch (err) {
                formError.textContent = 'Network error occurred.';
                formError.style.display = 'block';
                submitBtn.disabled = false;
                submitBtn.textContent = 'SECURE MY SLOT';
            }
        });
    </script>
</body>
</html>
