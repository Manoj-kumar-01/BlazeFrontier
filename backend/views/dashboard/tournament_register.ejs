<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Tournament Registration | Blaze Frontier</title>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600;800&display=block" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="/style.css">

    <!-- Tailwind Requirements -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#a855f7",
                        "primary-container": "rgba(168, 85, 247, 0.15)",
                        "on-primary-container": "#d8b4fe",
                        secondary: "#3b82f6",
                        tertiary: "#f59e0b",
                        "cyber-blue": "#06b6d4",
                        surface: "#111118",
                        "surface-variant": "#1a1a24",
                        "on-surface": "#ffffff",
                        "on-surface-variant": "#94a3b8",
                        outline: "#334155",
                        "outline-variant": "#1e293b",
                    },
                    fontFamily: {
                        body: ["Inter", "sans-serif"],
                        headline: ["Inter", "sans-serif"],
                        display: ["Bebas Neue", "cursive"],
                        mono: ["JetBrains Mono", "monospace"]
                    },
                },
            },
        };
    </script>
    
    <style>
        body { background-color: #050709; color: #ffffff; margin: 0; padding: 0; }
        .glass-panel { background: rgba(17, 17, 24, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .btn-primary { background: linear-gradient(135deg, #a855f7 0%, #7e22ce 100%); color: white; transition: all 0.3s ease; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(168, 85, 247, 0.4); }
        .btn-primary:disabled { background: rgba(255,255,255,0.1); color: #94a3b8; transform: none; box-shadow: none; cursor: not-allowed; }
        
        .hero-bg {
            background-image: url('/blaze_arena_bg.png');
            background-size: cover;
            background-position: center;
        }
        
        /* Success Overlay Animation */
        .success-overlay {
            background: #111118;
            display: none; flex-direction: column; justify-content: center; align-items: center;
            text-align: center; animation: fadeIn 0.4s ease;
            position: absolute; top: 0; left: 0; right: 0; bottom: 0; z-index: 50;
        }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body class="font-body antialiased overflow-x-hidden min-h-screen flex flex-col bg-[#050709] text-[#e1e2e7]">

    <%- include('../partials/navbar') %>

    <main class="flex-grow w-full max-w-[1500px] mx-auto px-4 md:px-8 pt-32 pb-16 flex flex-col md:flex-row gap-8">
        
        <!-- Left Column: Tournament Info -->
        <div class="w-full md:w-5/12 flex flex-col gap-6">
            <a href="/dashboard/tournaments" class="text-on-surface-variant hover:text-primary transition-colors flex items-center gap-2 inline-flex w-fit">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span> Back to Tournaments
            </a>
            
            <div class="glass-panel rounded-2xl overflow-hidden shadow-2xl relative h-full min-h-[400px] flex flex-col justify-end">
                <div class="absolute inset-0 hero-bg opacity-50"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-[#050709] via-[#050709]/80 to-transparent"></div>
                
                <div class="relative z-10 p-8 flex flex-col gap-4">
                    <div class="inline-flex items-center gap-2 bg-primary/20 text-primary border border-primary/30 px-3 py-1 rounded-md text-xs font-bold tracking-widest uppercase w-fit shadow-[0_0_10px_rgba(168,85,247,0.3)]">
                        <span class="material-symbols-outlined text-[16px]">local_fire_department</span> Official Tournament
                    </div>
                    
                    <h1 class="font-display text-5xl text-white tracking-wide leading-tight drop-shadow-lg" id="display-t-name">Loading...</h1>
                    
                    <div class="flex flex-col gap-3 mt-4 border-t border-white/10 pt-6">
                        <div class="flex items-center gap-3 text-on-surface-variant">
                            <span class="material-symbols-outlined text-cyber-blue">calendar_month</span>
                            <span class="font-mono text-lg text-white" id="display-t-date">--</span>
                        </div>
                        <div class="flex items-center gap-3 text-on-surface-variant">
                            <span class="material-symbols-outlined text-tertiary">monetization_on</span>
                            <span class="font-mono text-lg text-white">Prize Pool / Rewards Apply</span>
                        </div>
                        <div class="flex items-center gap-3 text-on-surface-variant">
                            <span class="material-symbols-outlined text-[#ef4444]">shield_person</span>
                            <span class="font-mono text-lg text-white">Anti-Cheat Enforced</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Registration Form -->
        <div class="w-full md:w-7/12">
            <div class="glass-panel rounded-2xl p-8 shadow-2xl border-t-2 border-t-primary h-full relative overflow-hidden">
                
                <!-- Success Overlay -->
                <div class="success-overlay rounded-2xl" id="success-screen">
                    <div class="text-[5rem] mb-6 text-primary">
                        <span class="material-symbols-outlined" style="font-size: 80px;">check_circle</span>
                    </div>
                    <div class="font-display text-4xl text-white tracking-wide mb-4">REGISTRATION CONFIRMED</div>
                    <div class="text-on-surface-variant text-lg max-w-md mx-auto mb-8 leading-relaxed">
                        You are officially registered. Please monitor the tournament page for room credentials and match timings when the event begins.
                    </div>
                    <a href="/dashboard/tournaments" class="btn-primary px-8 py-4 rounded-xl font-bold tracking-widest uppercase flex items-center gap-2">
                        RETURN TO ARENA <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                </div>

                <div class="flex items-center gap-3 mb-8 pb-6 border-b border-white/10">
                    <div class="w-12 h-12 rounded-full bg-primary/20 flex items-center justify-center border border-primary/30">
                        <span class="material-symbols-outlined text-primary">assignment</span>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold text-white tracking-wide">SECURE YOUR SLOT</h2>
                        <p class="text-on-surface-variant text-sm mt-1">Complete your verification below to enter.</p>
                    </div>
                </div>

                <form id="reg-form" class="flex flex-col gap-6 h-[calc(100%-120px)] justify-between">
                    <div>
                        <input type="hidden" id="tournamentId" value="<%= tournamentId %>">
                        
                        <!-- Verification Box -->
                        <div class="bg-[#ef4444]/10 border-l-4 border-[#ef4444] rounded-r-xl p-6 shadow-[inset_0_0_20px_rgba(239,68,68,0.05)]">
                            <div class="flex items-center gap-2 text-[#ef4444] font-bold text-lg mb-4">
                                <span class="material-symbols-outlined">gpp_maybe</span> Profile Verification
                            </div>
                            <p class="text-white/90 text-sm mb-6 leading-relaxed">
                                Please confirm that your <strong class="text-white">In-game Name</strong> and <strong class="text-white">In-game ID</strong> are exactly correct. 
                                If these details mismatch your actual game account during the room match, you will be instantly kicked and face a platform ban.
                            </p>
                            
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 bg-black/40 p-5 rounded-lg border border-white/5">
                                <div class="flex flex-col gap-1">
                                    <span class="text-xs text-on-surface-variant uppercase tracking-widest font-bold">In-game Name</span>
                                    <div class="font-mono text-xl text-white break-words" id="display-ign">Loading...</div>
                                </div>
                                <div class="flex flex-col gap-1">
                                    <span class="text-xs text-on-surface-variant uppercase tracking-widest font-bold">In-game ID (UID)</span>
                                    <div class="font-mono text-xl text-white break-words" id="display-uid">Loading...</div>
                                </div>
                            </div>
                            
                            <div class="mt-4 text-xs text-[#ef4444]/80 flex items-start gap-2">
                                <span class="material-symbols-outlined text-[16px]">info</span>
                                <span>Need to change these details? Update them in your Profile Settings before registering.</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-auto pt-6">
                        <div id="form-error" class="bg-[#ef4444]/20 text-[#ffb4ab] border border-[#ef4444]/30 rounded-lg p-4 mb-4 text-sm font-medium hidden flex items-center gap-2">
                            <span class="material-symbols-outlined">error</span> <span id="error-text"></span>
                        </div>
                        
                        <button type="submit" id="submit-btn" class="btn-primary w-full py-5 rounded-xl font-display text-2xl tracking-widest shadow-[0_0_30px_rgba(168,85,247,0.3)]">
                            CONFIRM REGISTRATION
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </main>

    <script src="/script.js?v=1.2"></script>
    <script>
        const token = localStorage.getItem('blaze_token');
        if (!token) {
            window.location.href = '/auth';
        }

        const tid = document.getElementById('tournamentId').value;
        const submitBtn = document.getElementById('submit-btn');
        const formError = document.getElementById('form-error');
        const errorText = document.getElementById('error-text');

        // Fetch tournament details
        async function fetchTourneyDetails() {
            try {
                const res = await fetch('/api/tournaments', { headers: { 'x-auth-token': token }});
                if (res.ok) {
                    const data = await res.json();
                    // Search in live or upcoming
                    const t = data.live.find(x => x._id === tid) || data.upcoming.find(x => x._id === tid);
                    if (t) {
                        document.getElementById('display-t-name').textContent = t.name;
                        document.getElementById('display-t-date').textContent = t.date;
                    } else {
                        document.getElementById('display-t-name').textContent = "Tournament Not Found";
                        submitBtn.disabled = true;
                        submitBtn.textContent = "UNAVAILABLE";
                    }
                }
            } catch(e) {
                console.error(e);
            }
        }
        fetchTourneyDetails();
        
        const applyUserStatus = (prof) => {
            if(prof) {
                document.getElementById('display-ign').textContent = prof.inGameName || 'N/A';
                document.getElementById('display-uid').textContent = prof.gameUid || prof.playerId || 'N/A';
            }
        };

        if (window.globalUserData) {
            applyUserStatus(window.globalUserData);
        } else {
            window.addEventListener('globalUserDataReady', () => {
                if (window.globalUserData) applyUserStatus(window.globalUserData);
            });
        }

        document.getElementById('reg-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            formError.classList.add('hidden');
            submitBtn.disabled = true;
            submitBtn.textContent = 'REGISTERING...';

            try {
                const res = await fetch(`/api/tournaments/${tid}/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'x-auth-token': token },
                    body: JSON.stringify({ discord: 'N/A', timeSlot: 'N/A' })
                });

                const data = await res.json();

                if (res.ok) {
                    document.getElementById('success-screen').style.display = 'flex';
                } else {
                    errorText.textContent = data.msg || 'Registration failed.';
                    formError.classList.remove('hidden');
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'CONFIRM REGISTRATION';
                }
            } catch (err) {
                errorText.textContent = 'Network error occurred.';
                formError.classList.remove('hidden');
                submitBtn.disabled = false;
                submitBtn.textContent = 'CONFIRM REGISTRATION';
            }
        });
    </script>
</body>
</html>
