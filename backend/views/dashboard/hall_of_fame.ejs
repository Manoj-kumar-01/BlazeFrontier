<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hall of Fame | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=block" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        body { background-color: #08080e; margin: 0; color: #fff; overflow-x: hidden; }
        
        /* Neon Background System */
        .bg-scene { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: -2; pointer-events: none; overflow: hidden; }
        .blob { position: absolute; border-radius: 50%; filter: blur(80px); }
        .blob-1 { width: 600px; height: 600px; top: 20%; left: 50%; transform: translateX(-50%); background: radial-gradient(circle, rgba(255, 150, 0, 0.15) 0%, transparent 70%); }
        
        .dash-container {
            display: flex;
            padding: 88px 20px 40px;
            max-width: 1500px;
            margin: 0 auto;
            min-height: 100vh;
        }

        .main-content {
            flex: 1;
            margin-right: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* TP Title */
        .tp-title-container {
            text-align: center;
            margin-bottom: 60px;
            position: relative;
            z-index: 10;
        }

        .tp-title {
            font-family: var(--font-display);
            font-size: 5.5rem;
            color: #ffb700;
            text-align: center;
            margin: 0;
            text-shadow: 0 5px 15px rgba(255, 100, 0, 0.8), 0 0 40px rgba(255, 150, 0, 0.5);
            letter-spacing: 4px;
            transform: perspective(500px) rotateX(10deg);
        }

        .tp-title span {
            color: #fff;
            text-shadow: 0 5px 15px rgba(255, 255, 255, 0.4), 0 0 30px rgba(255, 255, 255, 0.2);
        }

        /* Podium Layout */
        .podium-container {
            display: flex;
            align-items: flex-end;
            justify-content: center;
            position: relative;
            width: 100%;
            height: 500px;
            z-index: 5;
        }

        .podium-col {
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            opacity: 0;
            transform: translateY(100px);
            transition: all 1s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .podium-col.active {
            opacity: 1;
            transform: translateY(0);
        }

        .col-1 { z-index: 3; margin: 0 -15px; }
        .col-2 { z-index: 2; margin-right: -15px; }
        .col-3 { z-index: 1; margin-left: -15px; }

        /* Avatars */
        .player-avatar {
            border-radius: 50%;
            background: #111;
            margin-bottom: -40px;
            position: relative;
            z-index: 10;
            border: 4px solid;
            display: flex; align-items: center; justify-content: center;
            font-size: 4rem;
            background-size: cover;
            background-position: center;
        }
        
        .col-1 .player-avatar { 
            width: 150px; height: 150px; 
            margin-bottom: -50px; 
            border-color: #ffd700; 
            box-shadow: 0 15px 30px rgba(0,0,0,0.8), 0 0 40px rgba(255,215,0,0.4); 
            background-image: url('https://api.dicebear.com/7.x/avataaars/svg?seed=Rohit&backgroundColor=ffb700');
        }
        .col-2 .player-avatar { 
            width: 120px; height: 120px; 
            border-color: #e0e0e0; 
            box-shadow: 0 15px 30px rgba(0,0,0,0.8), 0 0 30px rgba(192,192,192,0.3);
            background-image: url('https://api.dicebear.com/7.x/avataaars/svg?seed=Jessica&backgroundColor=e0e0e0');
        }
        .col-3 .player-avatar { 
            width: 110px; height: 110px; 
            border-color: #cd7f32; 
            box-shadow: 0 15px 30px rgba(0,0,0,0.8), 0 0 30px rgba(205,127,50,0.3);
            background-image: url('https://api.dicebear.com/7.x/avataaars/svg?seed=Alex&backgroundColor=cd7f32');
        }

        /* 3D Podium Blocks */
        .podium-block {
            position: relative;
            display: flex; flex-direction: column; align-items: center;
            box-shadow: 0 25px 50px rgba(0,0,0,0.9), inset 0 2px 10px rgba(255,255,255,0.4);
            border-radius: 4px;
        }

        /* Create the 3D top surface illusion */
        .podium-block::before {
            content: ''; position: absolute;
            top: 0; left: 0; right: 0; height: 25px;
            background: inherit;
            filter: brightness(1.4) contrast(1.2);
            border-radius: 4px 4px 0 0;
            z-index: -1;
            box-shadow: inset 0 -2px 10px rgba(0,0,0,0.3);
            clip-path: polygon(10% 0, 90% 0, 100% 100%, 0% 100%);
            transform: translateY(-20px);
        }

        .gold-block {
            width: 280px; height: 260px;
            background: linear-gradient(160deg, #d4af37 0%, #aa8000 40%, #503c00 100%);
            border: 2px solid #ffdf00; border-bottom: none; border-top: none;
        }
        
        .gold-block::before { background: linear-gradient(90deg, #ffd700, #ffea00); }

        .silver-block {
            width: 240px; height: 200px;
            background: linear-gradient(160deg, #e0e0e0 0%, #9e9e9e 40%, #404040 100%);
            border: 2px solid #ffffff; border-bottom: none; border-top: none;
        }
        
        .silver-block::before { background: linear-gradient(90deg, #ffffff, #e0e0e0); }

        .bronze-block {
            width: 240px; height: 160px;
            background: linear-gradient(160deg, #cd7f32 0%, #8b5a2b 40%, #3a220f 100%);
            border: 2px solid #ffb07c; border-bottom: none; border-top: none;
        }
        
        .bronze-block::before { background: linear-gradient(90deg, #ffb07c, #cd7f32); }

        /* Medallions */
        .medallion {
            width: 70px; height: 70px;
            border-radius: 50%;
            position: absolute;
            top: -20px;
            display: flex; align-items: center; justify-content: center;
            font-family: var(--font-display); font-size: 2.5rem; color: #fff;
            box-shadow: 0 10px 20px rgba(0,0,0,0.6), inset 0 2px 10px rgba(255,255,255,0.7);
            z-index: 10;
        }
        .col-1 .medallion { width: 84px; height: 84px; font-size: 3.2rem; top: -25px; }
        
        .gold-medal { background: radial-gradient(circle at 30% 30%, #ffe600, #b38600); border: 3px solid #ffdf00; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }
        .silver-medal { background: radial-gradient(circle at 30% 30%, #ffffff, #808080); border: 3px solid #e0e0e0; text-shadow: 0 2px 4px rgba(0,0,0,0.5); color: #333;}
        .bronze-medal { background: radial-gradient(circle at 30% 30%, #ffb07c, #8b5a2b); border: 3px solid #cd7f32; text-shadow: 0 2px 4px rgba(0,0,0,0.5); }

        /* Nameplates inside blocks */
        .nameplate {
            margin-top: 55px;
            background: rgba(10, 5, 5, 0.7);
            border-radius: 4px;
            padding: 12px 16px;
            width: 85%;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: inset 0 0 20px rgba(0,0,0,0.8), 0 5px 15px rgba(0,0,0,0.5);
            backdrop-filter: blur(4px);
        }
        
        .col-1 .nameplate { margin-top: 70px; }

        .p-name { font-family: var(--font-display); font-size: 1.8rem; letter-spacing: 1px; margin-bottom: 2px; }
        .col-1 .p-name { color: #ffd700; font-size: 2.2rem; }
        .col-2 .p-name { color: #e0e0e0; }
        .col-3 .p-name { color: #cd7f32; }

        .p-title { font-size: 0.75rem; color: #ffd700; font-weight: 700; text-transform: uppercase; margin-bottom: 5px; letter-spacing: 1px; }
        .p-score { font-family: var(--font-mono); font-size: 1.1rem; color: #fff; font-weight: bold; margin-bottom: 12px; }
        .col-1 .p-score { font-size: 1.3rem; }

        /* Blz IDs */
        .p-id {
            display: inline-block;
            padding: 5px 12px;
            border-radius: 4px;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            font-weight: bold;
            letter-spacing: 1px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 10px rgba(0,0,0,0.4);
        }
        .blz-golden { background: linear-gradient(90deg, #d4af37, #ffe600); color: #000; box-shadow: 0 0 15px rgba(255, 215, 0, 0.4); }
        .blz-silver { background: linear-gradient(90deg, #9e9e9e, #e0e0e0); color: #000; }
        .blz-bronze { background: linear-gradient(90deg, #8b5a2b, #cd7f32); color: #fff; }

        /* Shine on IDs */
        .p-id::after {
            content: ''; position: absolute;
            top: 0; left: -100%; width: 50%; height: 100%;
            background: linear-gradient(to right, transparent, rgba(255,255,255,0.8), transparent);
            transform: skewX(-20deg);
            animation: shine 3s infinite;
        }

        @keyframes shine {
            0% { left: -100%; }
            20% { left: 200%; }
            100% { left: 200%; }
        }

        /* Floating rock base effect */
        .floating-base {
            position: absolute;
            bottom: -60px;
            width: 105%;
            height: 120px;
            background: linear-gradient(180deg, #333340 0%, #111118 100%);
            clip-path: polygon(5% 0, 95% 0, 100% 30%, 80% 100%, 50% 80%, 20% 100%, 0 30%);
            z-index: 0;
            border-top: 4px solid #555566;
            box-shadow: inset 0 20px 40px rgba(0,0,0,0.8);
            filter: drop-shadow(0 40px 50px rgba(0,0,0,0.9));
        }

        /* Confetti / Sparkles */
        .sparkle {
            position: absolute;
            width: 6px; height: 6px;
            background: #ffd700;
            border-radius: 50%;
            animation: float 4s ease-in-out infinite alternate;
            box-shadow: 0 0 10px #ffd700;
        }

        @keyframes float {
            0% { transform: translateY(0) scale(1); opacity: 0.8; }
            100% { transform: translateY(-30px) scale(1.5); opacity: 0.2; }
        }

    </style>
</head>
<body>
    <div class="bg-scene"><div class="blob blob-1"></div></div>
    <div class="stripe-overlay"></div>
    <div class="scanlines"></div>

    <%- include('../partials/navbar') %>

    <div class="dash-container">
        
        <div class="main-content">
            
            <div class="tp-title-container">
                <h1 class="tp-title">TOP <span>PLAYERS</span></h1>
            </div>

            <div class="podium-container">
                <!-- Sparkles -->
                <div class="sparkle" style="top: 10%; left: 20%; animation-delay: 0s;"></div>
                <div class="sparkle" style="top: 30%; right: 25%; animation-delay: 1s;"></div>
                <div class="sparkle" style="top: 50%; left: 35%; animation-delay: 0.5s;"></div>
                <div class="sparkle" style="top: 15%; right: 40%; animation-delay: 1.5s;"></div>

                <!-- 2nd Place -->
                <div class="podium-col col-2" id="winner-2">
                    <div class="player-avatar"></div>
                    <div class="podium-block silver-block">
                        <div class="medallion silver-medal">2</div>
                        <div class="nameplate">
                            <div class="p-name">Jessica</div>
                            <div class="p-score">1180 Points</div>
                            <div class="p-id blz-silver">BLZ-SILVER</div>
                        </div>
                    </div>
                </div>

                <!-- 1st Place -->
                <div class="podium-col col-1" id="winner-1">
                    <div class="player-avatar"></div>
                    <div class="podium-block gold-block">
                        <div class="medallion gold-medal">1</div>
                        <div class="nameplate">
                            <div class="p-name">Rohit</div>
                            <div class="p-title">#1 Champion</div>
                            <div class="p-score">1350 Points</div>
                            <div class="p-id blz-golden">BLZ-GOLDEN</div>
                        </div>
                    </div>
                </div>

                <!-- 3rd Place -->
                <div class="podium-col col-3" id="winner-3">
                    <div class="player-avatar"></div>
                    <div class="podium-block bronze-block">
                        <div class="medallion bronze-medal">3</div>
                        <div class="nameplate">
                            <div class="p-name">Alex</div>
                            <div class="p-score">1050 Points</div>
                            <div class="p-id blz-bronze">BLZ-BRONZE</div>
                        </div>
                    </div>
                </div>

                <!-- Base -->
                <div class="floating-base"></div>
            </div>
            
        </div>

        <div style="width: 340px; margin-top: 40px;">
            <%- include('../partials/sidebar') %>
        </div>
    </div>

    <script>
        // Animate slots on load
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                document.getElementById('winner-3').classList.add('active');
            }, 300);
            
            setTimeout(() => {
                document.getElementById('winner-2').classList.add('active');
            }, 800);
            
            setTimeout(() => {
                document.getElementById('winner-1').classList.add('active');
            }, 1500);
        });
    </script>
</body>
</html>
