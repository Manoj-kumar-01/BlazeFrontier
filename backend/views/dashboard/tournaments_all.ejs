<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>All Leagues | Blaze Frontier</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600;800&display=block" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#a855f7",
                        "primary-container": "rgba(168, 85, 247, 0.15)",
                        "on-primary-container": "#d8b4fe",
                        secondary: "#3b82f6",
                        tertiary: "#f59e0b",
                        "cyber-blue": "#06b6d4",
                        surface: "#111118",
                        "surface-variant": "#1a1a24",
                        "on-surface": "#ffffff",
                        "on-surface-variant": "#94a3b8",
                        outline: "#334155",
                        "outline-variant": "#1e293b",
                    },
                    fontFamily: {
                        body: ["Inter", "sans-serif"],
                        headline: ["Inter", "sans-serif"],
                        display: ["Bebas Neue", "cursive"],
                        mono: ["JetBrains Mono", "monospace"]
                    },
                },
            },
        };
    </script>
    
    <style>
        body { background-color: #050709; color: #ffffff; margin: 0; padding: 0; }
        .glass-panel { background: rgba(17, 17, 24, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.05); }
        .table-row-hover:hover { background-color: rgba(168, 85, 247, 0.08); }
        .btn-primary { background: linear-gradient(135deg, #a855f7 0%, #7e22ce 100%); color: white; transition: all 0.3s ease; }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(168, 85, 247, 0.4); }
    </style>
    
    <link rel="stylesheet" href="/style.css">
</head>
<body class="font-body antialiased overflow-x-hidden min-h-screen flex flex-col bg-[#050709] text-[#e1e2e7]">

    <%- include('../partials/navbar') %>

    <main class="flex-grow w-full max-w-[1500px] mx-auto px-4 md:px-8 pt-32 pb-16">
        
        <div class="mb-8">
            <a href="/dashboard/tournaments" class="text-on-surface-variant hover:text-primary transition-colors flex items-center gap-xs mb-4 inline-flex">
                <span class="material-symbols-outlined text-[18px]">arrow_back</span> Back to Leagues
            </a>
            
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
                <h1 class="text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-primary to-cyber-blue">League Explorer</h1>
                
                <div class="flex items-center gap-3">
                    <label for="status-filter" class="text-sm text-on-surface-variant font-medium uppercase tracking-wider">Filter by Status:</label>
                    <select id="status-filter" class="bg-[#111118] text-white border border-[#334155] rounded-md px-4 py-2 font-medium focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors cursor-pointer">
                        <option value="all" class="bg-[#111118] text-white">All Leagues</option>
                        <option value="live" class="bg-[#111118] text-white">Live Now</option>
                        <option value="upcoming" class="bg-[#111118] text-white">Upcoming</option>
                        <option value="completed" class="bg-[#111118] text-white">Completed</option>
                    </select>
                </div>
            </div>
        </div>

        <section>
            <div id="tournament-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="col-span-full text-center py-10 text-on-surface-variant glass-panel rounded-xl">
                    <span class="material-symbols-outlined animate-spin text-3xl">refresh</span>
                    <p class="mt-2 font-medium tracking-wide">Loading leagues...</p>
                </div>
            </div>
        </section>

    </main>

    <!-- Participants Modal (Reused) -->
    <div id="participants-modal" class="hidden fixed inset-0 bg-black/85 backdrop-blur-md z-50 justify-center items-center p-4">
        <div class="bg-[#111118] border border-[#A855F7]/30 rounded-xl w-full max-w-2xl max-h-[85vh] flex flex-col p-8 relative shadow-2xl">
            <button class="absolute top-4 right-4 text-on-surface-variant hover:text-white transition-colors cursor-pointer" onclick="document.getElementById('participants-modal').classList.add('hidden')">
                <span class="material-symbols-outlined text-[28px]">close</span>
            </button>
            <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">groups</span>
                Registered Participants
            </h2>
            <div class="overflow-y-auto flex-1 pr-2 custom-scrollbar">
                <ul id="modal-participants-list" class="flex flex-col gap-3"></ul>
            </div>
        </div>
    </div>

    <script>
        const token = localStorage.getItem('blaze_token');
        if (!token) window.location.href = '/auth';

        let allData = { live: [], upcoming: [], completed: [] };
        
        const gridContainer = document.getElementById('tournament-grid');
        const statusFilter = document.getElementById('status-filter');

        async function loadTournaments() {
            try {
                const res = await fetch('/api/tournaments?game=freefire', {
                    headers: { 'x-auth-token': token }
                });
                if (res.ok) {
                    allData = await res.json();
                    renderTable();
                } else {
                    throw new Error('Failed to fetch');
                }
            } catch (e) {
                gridContainer.innerHTML = '<div class="col-span-full text-center py-8 text-error glass-panel rounded-xl">Failed to load leagues.</div>';
            }
        }

        function renderTable() {
            const filter = statusFilter.value;
            let list = [];
            
            if (filter === 'all' || filter === 'live') {
                list = list.concat(allData.live.map(t => ({ ...t, status: 'LIVE' })));
            }
            if (filter === 'all' || filter === 'upcoming') {
                list = list.concat(allData.upcoming.map(t => ({ ...t, status: 'UPCOMING' })));
            }
            if (filter === 'all' || filter === 'completed') {
                list = list.concat(allData.completed.map(t => ({ ...t, status: 'COMPLETED' })));
            }

            if (list.length === 0) {
                gridContainer.innerHTML = '<div class="col-span-full text-center py-8 text-on-surface-variant glass-panel rounded-xl">No leagues found for this category.</div>';
                return;
            }

            gridContainer.innerHTML = list.map(t => {
                let badgeColor = 'border-cyber-blue text-cyber-blue bg-cyber-blue/10';
                if (t.status === 'LIVE') badgeColor = 'border-[#ef4444] text-[#ef4444] bg-[#ef4444]/10';
                if (t.status === 'COMPLETED') badgeColor = 'border-outline text-on-surface-variant bg-surface-variant';
                
                let actionBtn = '';
                if (t.status === 'COMPLETED') {
                    actionBtn = `<span class="text-on-surface-variant text-sm font-semibold tracking-wide">Ended</span>`;
                } else if (t.participantListPublished) {
                    actionBtn = `<button class="btn-primary px-4 py-2 text-xs font-bold uppercase tracking-wider rounded-md shadow-[0_0_10px_rgba(168,85,247,0.4)]" onclick="event.stopPropagation(); viewParticipants('${t._id}')">View Roster</button>`;
                } else {
                    actionBtn = `<span class="text-tertiary text-sm font-semibold tracking-wide flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">app_registration</span> Registering</span>`;
                }

                return `
                <div class="glass-panel rounded-xl overflow-hidden cursor-pointer transition-all duration-300 hover:-translate-y-1 hover:border-primary/50 hover:shadow-[0_8px_30px_rgba(168,85,247,0.15)] flex flex-col group" onclick="if('${t.status}' !== 'COMPLETED') window.location.href='/dashboard/tournaments/${t.id || t._id}/register'">
                    <div class="p-5 border-b border-white/5 flex justify-between items-start gap-4 bg-gradient-to-r from-white/5 to-transparent">
                        <h3 class="text-xl font-display tracking-wider text-white group-hover:text-primary transition-colors line-clamp-2 leading-tight">${t.name}</h3>
                        <span class="shrink-0 px-3 py-1 rounded border text-xs font-bold uppercase tracking-widest ${badgeColor}">${t.status}</span>
                    </div>
                    
                    <div class="p-5 flex-1 flex flex-col relative overflow-hidden">
                        <canvas id="shader-canvas-${t.id || t._id}" class="absolute inset-0 w-full h-full z-0 opacity-50" style="display:block; mix-blend-mode: screen;"></canvas>
                        <div class="relative z-10 flex flex-col gap-4">
                            <div class="flex items-center gap-3 text-on-surface-variant">
                                <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center shrink-0">
                                    <span class="material-symbols-outlined text-[18px] text-cyber-blue">calendar_month</span>
                                </div>
                                <span class="font-medium text-white text-sm">${t.date || 'TBA'}</span>
                            </div>
                            
                            <div class="flex items-start gap-3 text-on-surface-variant">
                                <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center shrink-0">
                                    <span class="material-symbols-outlined text-[18px] text-tertiary">emoji_events</span>
                                </div>
                                <div class="text-sm leading-relaxed text-white/95 font-medium drop-shadow-md">
                                    <div class="flex items-center gap-2 mb-1"><span class="text-yellow-400 drop-shadow-[0_0_5px_rgba(250,204,21,0.8)]">🥇</span> 100 Coins + 100 BP</div>
                                    <div class="flex items-center gap-2 mb-1"><span class="text-gray-300 drop-shadow-[0_0_5px_rgba(209,213,219,0.8)]">🥈</span> 50 Coins + 50 BP</div>
                                    <div class="flex items-center gap-2"><span class="text-amber-600 drop-shadow-[0_0_5px_rgba(217,119,6,0.8)]">🥉</span> 25 Coins + 25 BP</div>
                                </div>
                            </div>

                            <div class="flex items-center gap-3 text-on-surface-variant">
                                <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center shrink-0">
                                    <span class="material-symbols-outlined text-[18px] text-primary">groups</span>
                                </div>
                                <span class="font-medium text-white text-sm drop-shadow-md">${t.registeredCount || 0} / ${t.participants || '-'} <span class="text-white/70 font-normal">Registered</span></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-4 bg-black/40 border-t border-white/5 flex justify-between items-center mt-auto">
                        <span class="text-xs text-on-surface-variant font-medium tracking-wide group-hover:text-white transition-colors">Tap for details</span>
                        ${actionBtn}
                    </div>
                </div>`;
            }).join('');
            
            setTimeout(() => {
                list.forEach(t => {
                    const cid = 'shader-canvas-' + (t.id || t._id);
                    if (t.status === 'UPCOMING') initShaderUpcoming(cid);
                    else if (t.status === 'LIVE') initShaderLive(cid);
                    else if (t.status === 'COMPLETED') initShaderCompleted(cid);
                });
            }, 50);
        }

        async function viewParticipants(tid) {
            try {
                const res = await fetch(`/api/tournaments/${tid}/participants`, { headers: { 'x-auth-token': token } });
                const data = await res.json();
                const listEl = document.getElementById('modal-participants-list');
                
                if (res.ok && data.participants && data.participants.length > 0) {
                    listEl.innerHTML = data.participants.map(p => `
                        <li class="p-3 bg-surface rounded border border-white/5 flex items-center justify-between">
                            <span class="text-white font-medium">${p.inGameName}</span>
                            <span class="text-xs text-on-surface-variant font-mono bg-[#050709] px-2 py-1 rounded">UID: ${p.gameUid}</span>
                        </li>
                    `).join('');
                } else {
                    listEl.innerHTML = '<li class="text-on-surface-variant text-center py-4">No participants found or list is not public yet.</li>';
                }
                document.getElementById('participants-modal').classList.remove('hidden');
            } catch (e) {
                console.error(e);
            }
        }

        statusFilter.addEventListener('change', renderTable);
        loadTournaments();

        // Shaders
        function initShaderUpcoming(canvasId) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            function syncSize() {
                const w = canvas.clientWidth || 300;
                const h = canvas.clientHeight || 200;
                if (canvas.width !== w || canvas.height !== h) {
                    canvas.width = w; canvas.height = h;
                }
            }
            if (typeof ResizeObserver !== 'undefined') new ResizeObserver(syncSize).observe(canvas);
            syncSize();
            const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
            if (!gl) return;
            const vs = `attribute vec2 a_position; varying vec2 v_texCoord; void main() { v_texCoord = a_position * 0.5 + 0.5; gl_Position = vec4(a_position, 0.0, 1.0); }`;
            const fs = `precision highp float; uniform float u_time; uniform vec2 u_resolution; varying vec2 v_texCoord;
            void main() {
                vec2 uv = v_texCoord; float time = u_time * 0.2;
                vec2 grid = fract(uv * 40.0);
                float gridLine = smoothstep(0.95, 0.98, grid.x) + smoothstep(0.95, 0.98, grid.y);
                vec2 p = uv * 2.0 - 1.0; p.x *= u_resolution.x / u_resolution.y;
                float noise = 0.0;
                for (int i = 0; i < 5; i++) {
                    p += sin(p.yx * 2.0 + time) * 0.4;
                    noise += abs(dot(sin(p), cos(p.yx + time * 0.5))) * 0.5;
                }
                vec3 base = vec3(0.04, 0.04, 0.05); vec3 accent = vec3(0.2, 0.22, 0.25); vec3 highlight = vec3(0.4, 0.45, 0.5);
                vec3 finalColor = mix(base, accent, noise * 0.3);
                finalColor += highlight * pow(noise, 8.0) * 0.15;
                finalColor += vec3(0.05, 0.07, 0.1) * gridLine * 0.2;
                float dist = length(uv - 0.5);
                finalColor *= smoothstep(1.0, 0.2, dist);
                gl_FragColor = vec4(finalColor, 1.0);
            }`;
            function cs(type, src) { const s = gl.createShader(type); gl.shaderSource(s, src); gl.compileShader(s); return s; }
            const prog = gl.createProgram(); gl.attachShader(prog, cs(gl.VERTEX_SHADER, vs)); gl.attachShader(prog, cs(gl.FRAGMENT_SHADER, fs)); gl.linkProgram(prog); gl.useProgram(prog);
            const buf = gl.createBuffer(); gl.bindBuffer(gl.ARRAY_BUFFER, buf); gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
            const pos = gl.getAttribLocation(prog, 'a_position'); gl.enableVertexAttribArray(pos); gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);
            const uTime = gl.getUniformLocation(prog, 'u_time'); const uRes = gl.getUniformLocation(prog, 'u_resolution');
            function render(t) {
                if (typeof ResizeObserver === 'undefined') syncSize();
                gl.viewport(0, 0, canvas.width, canvas.height);
                if (uTime) gl.uniform1f(uTime, t * 0.001); if (uRes) gl.uniform2f(uRes, canvas.width, canvas.height);
                gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4); requestAnimationFrame(render);
            }
            render(0);
        }

        function initShaderLive(canvasId) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            function syncSize() {
                const w = canvas.clientWidth || 300;
                const h = canvas.clientHeight || 200;
                if (canvas.width !== w || canvas.height !== h) { canvas.width = w; canvas.height = h; }
            }
            if (typeof ResizeObserver !== 'undefined') new ResizeObserver(syncSize).observe(canvas);
            syncSize();
            const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
            if (!gl) return;
            const vs = `attribute vec2 a_position; varying vec2 v_texCoord; void main() { v_texCoord = a_position * 0.5 + 0.5; gl_Position = vec4(a_position, 0.0, 1.0); }`;
            const fs = `precision highp float; uniform float u_time; uniform vec2 u_resolution; varying vec2 v_texCoord;
            float hash(vec2 p) { return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453123); }
            void main() {
                vec2 uv = v_texCoord; float time = u_time * 0.5;
                vec2 p = uv * 10.0; vec2 ip = floor(p); vec2 fp = fract(p); float star = 0.0;
                if (hash(ip) > 0.95) { float size = hash(ip + 1.0) * 0.5; float pulse = sin(time + hash(ip) * 10.0) * 0.5 + 0.5; star = smoothstep(size, 0.0, length(fp - 0.5)) * pulse; }
                vec2 uv2 = uv * 1.5; float flow = 0.0;
                for(int i=0; i<3; i++) { uv2 += sin(uv2.yx * 3.0 + time * 0.3) * 0.5; flow += abs(sin(uv2.x + uv2.y)) * 0.5; }
                vec3 color1 = vec3(0.02, 0.02, 0.05); vec3 color2 = vec3(0.05, 0.1, 0.2); vec3 color3 = vec3(0.0, 0.8, 1.0);
                vec3 finalColor = mix(color1, color2, flow * 0.4); finalColor += color3 * star * 0.8; finalColor += color3 * pow(flow, 10.0) * 0.05;
                finalColor *= smoothstep(1.2, 0.4, length(uv - 0.5));
                gl_FragColor = vec4(finalColor, 1.0);
            }`;
            function cs(type, src) { const s = gl.createShader(type); gl.shaderSource(s, src); gl.compileShader(s); return s; }
            const prog = gl.createProgram(); gl.attachShader(prog, cs(gl.VERTEX_SHADER, vs)); gl.attachShader(prog, cs(gl.FRAGMENT_SHADER, fs)); gl.linkProgram(prog); gl.useProgram(prog);
            const buf = gl.createBuffer(); gl.bindBuffer(gl.ARRAY_BUFFER, buf); gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
            const pos = gl.getAttribLocation(prog, 'a_position'); gl.enableVertexAttribArray(pos); gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);
            const uTime = gl.getUniformLocation(prog, 'u_time'); const uRes = gl.getUniformLocation(prog, 'u_resolution');
            function render(t) {
                if (typeof ResizeObserver === 'undefined') syncSize();
                gl.viewport(0, 0, canvas.width, canvas.height);
                if (uTime) gl.uniform1f(uTime, t * 0.001); if (uRes) gl.uniform2f(uRes, canvas.width, canvas.height);
                gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4); requestAnimationFrame(render);
            }
            render(0);
        }

        function initShaderCompleted(canvasId) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            function syncSize() {
                const w = canvas.clientWidth || 300;
                const h = canvas.clientHeight || 200;
                if (canvas.width !== w || canvas.height !== h) { canvas.width = w; canvas.height = h; }
            }
            if (typeof ResizeObserver !== 'undefined') new ResizeObserver(syncSize).observe(canvas);
            syncSize();
            const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
            if (!gl) return;
            const vs = `attribute vec2 a_position; varying vec2 v_texCoord; void main() { v_texCoord = a_position * 0.5 + 0.5; gl_Position = vec4(a_position, 0.0, 1.0); }`;
            const fs = `precision highp float; uniform float u_time; uniform vec2 u_resolution; varying vec2 v_texCoord;
            float hash(vec2 p) { return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453); }
            void main() {
                vec2 uv = v_texCoord; float time = u_time * 0.5;
                float glitch = step(0.98, hash(vec2(floor(time * 10.0), floor(uv.y * 20.0))));
                float offset = glitch * (hash(vec2(time)) - 0.5) * 0.1; vec2 guv = uv + vec2(offset, 0.0);
                float scan = sin(guv.y * 400.0 + time * 10.0) * 0.02; float flow = 0.0; vec2 p = guv * 1.5;
                for(int i=0; i<3; i++) { p += sin(p.yx * 2.0 + time) * 0.5; flow += abs(dot(sin(p), cos(p.yx))) * 0.3; }
                vec3 col1 = vec3(0.02, 0.0, 0.05); vec3 col2 = vec3(0.15, 0.0, 0.3); vec3 col3 = vec3(0.6, 0.4, 0.8);
                vec3 finalColor = mix(col1, col2, flow); finalColor += col3 * glitch * 0.3; finalColor += col3 * scan;
                finalColor *= smoothstep(1.2, 0.5, length(uv - 0.5));
                gl_FragColor = vec4(finalColor, 1.0);
            }`;
            function cs(type, src) { const s = gl.createShader(type); gl.shaderSource(s, src); gl.compileShader(s); return s; }
            const prog = gl.createProgram(); gl.attachShader(prog, cs(gl.VERTEX_SHADER, vs)); gl.attachShader(prog, cs(gl.FRAGMENT_SHADER, fs)); gl.linkProgram(prog); gl.useProgram(prog);
            const buf = gl.createBuffer(); gl.bindBuffer(gl.ARRAY_BUFFER, buf); gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
            const pos = gl.getAttribLocation(prog, 'a_position'); gl.enableVertexAttribArray(pos); gl.vertexAttribPointer(pos, 2, gl.FLOAT, false, 0, 0);
            const uTime = gl.getUniformLocation(prog, 'u_time'); const uRes = gl.getUniformLocation(prog, 'u_resolution');
            function render(t) {
                gl.viewport(0, 0, canvas.width, canvas.height);
                if (uTime) gl.uniform1f(uTime, t * 0.001); if (uRes) gl.uniform2f(uRes, canvas.width, canvas.height);
                gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4); requestAnimationFrame(render);
            }
            render(0);
        }
    </script>
</body>
</html>
