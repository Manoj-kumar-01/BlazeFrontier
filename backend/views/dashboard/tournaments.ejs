<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blaze Frontier | Tournaments</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        :root { --accent: #e63946; --accent-glow: rgba(230, 57, 70, 0.4); --gold: #f0a500; }
        body {
            background-color: #06060b; color: #f0eef5; font-family: 'Inter', sans-serif; overflow-x: hidden;
            background-image: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(230, 57, 70, 0.15), transparent 70%);
        }
        .font-display { font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; }
        .font-mono { font-family: 'JetBrains Mono', monospace; }
        .blaze-card {
            background: rgba(22, 22, 34, 0.5); border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 12px; backdrop-filter: blur(12px); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); overflow: hidden;
        }
        .blaze-card:hover { transform: translateY(-5px); border-color: rgba(230, 57, 70, 0.5); box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6), 0 0 20px rgba(230, 57, 70, 0.15); }
        .blaze-btn {
            background: var(--accent); color: #fff; border-radius: 8px; font-weight: 600; letter-spacing: 1px;
            text-transform: uppercase; transition: all 0.3s ease; position: relative; overflow: hidden; box-shadow: 0 4px 15px rgba(230, 57, 70, 0.3);
        }
        .blaze-btn::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent); opacity: 0; transition: opacity 0.3s; }
        .blaze-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(230, 57, 70, 0.5); background: #ff4757; }
        .blaze-btn:hover::before { opacity: 1; }
        .blaze-btn-outline { background: transparent; border: 1px solid rgba(255,255,255,0.1); color: #c4c1d4; border-radius: 8px; transition: all 0.3s ease; }
        .blaze-btn-outline:hover { border-color: rgba(255,255,255,0.3); color: #fff; background: rgba(255,255,255,0.05); }
        .motion-blur-img { transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1); filter: saturate(1.1) brightness(0.8); transform: scale(1.05); }
        .group:hover .motion-blur-img, .blaze-card:hover .motion-blur-img { transform: scale(1.12); filter: saturate(1.3) brightness(1); }
        .gradient-text { background: linear-gradient(to bottom, #ff3b3f 0%, #d91c1f 40%, #5c0000 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0px 2px 2px rgba(0, 0, 0, 0.8)); }
        .gradient-text-silver { background: linear-gradient(to bottom, #ffffff 0%, #c4c4c4 40%, #666666 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #06060b; }
        ::-webkit-scrollbar-thumb { background: #222235; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #e63946; }
        @keyframes fadeUpIn { 0% { opacity: 0; transform: translateY(40px) scale(0.95); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
        @keyframes modalPop { 0% { opacity: 0; transform: scale(0.9) translateY(20px); } 100% { opacity: 1; transform: scale(1) translateY(0); } }
        @keyframes hofFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
        @keyframes hofPulseGold { 0%, 100% { box-shadow: 0 0 20px rgba(240,165,0,0.3), 0 0 60px rgba(240,165,0,0.1); } 50% { box-shadow: 0 0 35px rgba(240,165,0,0.6), 0 0 80px rgba(240,165,0,0.2); } }
        @keyframes hofPulseSilver { 0%, 100% { box-shadow: 0 0 15px rgba(192,192,192,0.2), 0 0 40px rgba(192,192,192,0.05); } 50% { box-shadow: 0 0 25px rgba(192,192,192,0.4), 0 0 60px rgba(192,192,192,0.1); } }
        @keyframes hofPulseBronze { 0%, 100% { box-shadow: 0 0 15px rgba(205,127,50,0.2), 0 0 40px rgba(205,127,50,0.05); } 50% { box-shadow: 0 0 25px rgba(205,127,50,0.4), 0 0 60px rgba(205,127,50,0.1); } }
        @keyframes shimmer { 0% { background-position: -200% center; } 100% { background-position: 200% center; } }
        @keyframes sparkle { 0%, 100% { opacity: 0; transform: scale(0) rotate(0deg); } 50% { opacity: 1; transform: scale(1) rotate(180deg); } }
        @keyframes crownBob { 0%, 100% { transform: translateY(0) rotate(-3deg); } 50% { transform: translateY(-5px) rotate(3deg); } }
        .hof-shimmer-text { background: linear-gradient(90deg, #f0a500 0%, #fff6d5 40%, #f0a500 60%, #fff6d5 100%); background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent; animation: shimmer 3s linear infinite; }
        .hof-card { transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
        .hof-card:hover { transform: translateY(-12px) scale(1.03); }
        .hof-avatar { transition: all 0.5s ease; }
        .hof-card:hover .hof-avatar { transform: scale(1.15); filter: brightness(1.2); }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "bg-0": "#06060b", "bg-1": "#0a0a12", "bg-2": "#0e0e18", "bg-3": "#13131f",
                        "accent": "#e63946", "gold": "#f0a500",
                        "text-100": "#f0eef5", "text-200": "#c4c1d4", "text-300": "#8f8ca6", "text-400": "#5c5a72"
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-bg-0 text-text-100 antialiased selection:bg-accent selection:text-white">
    <%- include('../partials/navbar') %>

    <main class="page-wrap pt-20" style="display:none;">
        <div id="spotlight-container">
            <!-- Dynamic Spotlight Hero injected here by JS -->
        </div>

        <div class="max-w-[1400px] mx-auto px-6 -mt-10 relative z-20 pb-16">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 border-b border-white/10 pb-4 gap-4">
                <h2 class="font-display text-4xl text-white tracking-wide uppercase">AVAILABLE TOURNAMENTS</h2>
                <div class="relative w-full md:w-64" id="t-dropdown">
                    <button class="w-full bg-bg-1/80 border border-accent/30 text-white px-4 py-3 rounded-lg font-mono text-sm tracking-wide flex justify-between items-center backdrop-blur-md hover:border-accent/60 transition-colors" id="t-dropdown-btn">
                        <span id="cd-selected">LIVE NOW</span>
                        <span class="material-symbols-outlined text-[20px]">arrow_drop_down</span>
                    </button>
                    <div class="absolute top-full left-0 w-full mt-2 bg-bg-1 border border-accent/20 rounded-lg overflow-hidden backdrop-blur-xl transform origin-top scale-y-0 opacity-0 transition-all duration-300 z-50 cd-menu shadow-[0_10px_30px_rgba(0,0,0,0.8)]">
                        <div class="px-4 py-3 text-text-300 font-mono text-sm tracking-wide cursor-pointer hover:bg-accent/10 hover:text-accent hover:pl-6 transition-all border-b border-white/5 cd-item active" data-view="live">LIVE NOW</div>
                        <div class="px-4 py-3 text-text-300 font-mono text-sm tracking-wide cursor-pointer hover:bg-accent/10 hover:text-accent hover:pl-6 transition-all border-b border-white/5 cd-item" data-view="upcoming">FUTURE / UPCOMING</div>
                        <div class="px-4 py-3 text-text-300 font-mono text-sm tracking-wide cursor-pointer hover:bg-accent/10 hover:text-accent hover:pl-6 transition-all cd-item" data-view="completed">COMPLETED</div>
                    </div>
                </div>
            </div>

            <div id="t-content">
                <div class="flex justify-center py-20"><div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-accent"></div></div>
            </div>
        </div>

        <!-- Tournaments Bottom Sections -->
        <div class="max-w-[1400px] mx-auto px-4 md:px-6 relative z-20 pb-24">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                <!-- Hall of Fame / Pro Rankings -->
                <div class="lg:col-span-7 flex flex-col">
                    <div class="flex items-center gap-4 mb-8">
                        <div class="w-12 h-1 bg-gold rounded-full shadow-[0_0_15px_rgba(240,165,0,0.5)]"></div>
                        <h4 class="font-display text-4xl text-white uppercase tracking-wider m-0">HALL OF FAME</h4>
                    </div>
                    
                    <div id="hof-container" class="flex-1 relative overflow-hidden rounded-2xl min-h-[480px]">
                        <!-- Dynamically populated by loadHallOfFame() -->
                        <div class="flex justify-center items-center h-full min-h-[480px]"><div class="animate-spin rounded-full h-10 w-10 border-t-2 border-b-2 border-gold"></div></div>
                    </div>
                </div>

                <!-- Competitive Ecosystem -->
                <div class="lg:col-span-5 flex flex-col gap-6">
                    <div class="flex items-center gap-4 mb-2">
                        <div class="w-12 h-1 bg-accent rounded-full shadow-[0_0_15px_rgba(230,57,70,0.5)]"></div>
                        <h4 class="font-display text-4xl text-white uppercase tracking-wider m-0">ECOSYSTEM</h4>
                    </div>

                    <!-- Integrity Card -->
                    <div class="relative bg-gradient-to-br from-bg-2 to-bg-1 border border-white/10 rounded-2xl p-6 md:p-8 overflow-hidden group hover:border-accent/30 transition-all duration-500">
                        <div class="absolute top-0 right-0 p-6 opacity-5 group-hover:opacity-10 transition-opacity transform group-hover:scale-110 duration-700">
                            <span class="material-symbols-outlined text-[100px] text-accent">shield</span>
                        </div>
                        <div class="relative z-10">
                            <div class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center mb-6 border border-accent/20 shadow-[0_0_20px_rgba(230,57,70,0.1)] group-hover:bg-accent/20 transition-colors">
                                <span class="material-symbols-outlined text-accent">gpp_good</span>
                            </div>
                            <h5 class="font-display text-2xl text-white mb-2 uppercase">Anti-Cheat Enforced</h5>
                            <p class="text-sm text-text-300 font-medium leading-relaxed">Blaze Frontier employs strict verification and server-side analysis to ensure 100% fair play. Cheaters are permanently hardware-banned.</p>
                        </div>
                    </div>

                    <!-- Verified Only Card -->
                    <div class="relative bg-gradient-to-br from-bg-2 to-bg-1 border border-white/10 rounded-2xl p-6 md:p-8 overflow-hidden group hover:border-gold/30 transition-all duration-500">
                        <div class="absolute top-0 right-0 p-6 opacity-5 group-hover:opacity-10 transition-opacity transform group-hover:scale-110 duration-700">
                            <span class="material-symbols-outlined text-[100px] text-gold">verified</span>
                        </div>
                        <div class="relative z-10">
                            <div class="w-12 h-12 rounded-full bg-gold/10 flex items-center justify-center mb-6 border border-gold/20 shadow-[0_0_20px_rgba(240,165,0,0.1)] group-hover:bg-gold/20 transition-colors">
                                <span class="material-symbols-outlined text-gold">workspace_premium</span>
                            </div>
                            <h5 class="font-display text-2xl text-white mb-2 uppercase">Verified Elite Only</h5>
                            <p class="text-sm text-text-300 font-medium leading-relaxed">Access to prize-pool tournaments is strictly limited to manually verified players. This maintains the highest caliber of competition.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Participants Modal -->
    <div id="participants-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); backdrop-filter:blur(15px); z-index:10000; justify-content:center; align-items:center; padding:16px;">
        <div class="w-full max-w-[700px] max-h-[85vh] flex flex-col p-6 md:p-8 relative bg-bg-3 border border-accent/30 rounded-2xl shadow-[0_30px_60px_rgba(0,0,0,0.8),_0_0_40px_rgba(230,57,70,0.1)]" style="animation:modalPop 0.4s cubic-bezier(0.16, 1, 0.3, 1);">
            <button onclick="closeParticipantsModal()" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-accent transition-colors">&times;</button>
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-1 bg-accent rounded-full"></div>
                <h2 id="p-modal-title" class="m-0 font-display text-3xl tracking-wide text-white uppercase">PARTICIPANTS</h2>
            </div>
            <div id="p-modal-content" style="flex: 1; overflow-y: auto; padding-right: 8px;">
                <div class="flex justify-center py-10"><div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-accent"></div></div>
            </div>
        </div>
    </div>

    <script src="/script.js?v=1.2"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('blaze_token');
            if (!token) { window.location.href = '/auth'; return; }

            const applyUserStatus = (prof) => {
                if (!prof.isGenuine) {
                    const modal = document.getElementById('tournaments-lock-modal');
                    if (modal) {
                        modal.style.display = 'flex';
                        const btn = modal.querySelector('button');
                        if(btn) btn.onclick = () => { window.location.href = '/dashboard'; };
                    } else {
                        window.location.href = '/dashboard';
                    }
                } else {
                    document.querySelector('.page-wrap').style.display = 'block';
                }
            };

            if (window.globalUserData) {
                applyUserStatus(window.globalUserData);
            } else {
                const fallbackTimeout = setTimeout(() => {
                    document.querySelector('.page-wrap').style.display = 'block';
                }, 1500); 
                window.addEventListener('globalUserDataReady', () => {
                    clearTimeout(fallbackTimeout);
                    if (window.globalUserData) applyUserStatus(window.globalUserData);
                    else document.querySelector('.page-wrap').style.display = 'block';
                });
            }

            const dropdown = document.getElementById('t-dropdown');
            const dropdownBtn = document.getElementById('t-dropdown-btn');
            const dropdownItems = dropdown.querySelectorAll('.cd-item');
            const selectedText = document.getElementById('cd-selected');
            const cdMenu = dropdown.querySelector('.cd-menu');

            dropdownBtn.addEventListener('click', () => {
                if(cdMenu.style.transform === 'scaleY(1)') {
                    cdMenu.style.transform = 'scaleY(0)'; cdMenu.style.opacity = '0';
                } else {
                    cdMenu.style.transform = 'scaleY(1)'; cdMenu.style.opacity = '1';
                }
            });

            document.addEventListener('click', (e) => {
                if (!dropdown.contains(e.target)) {
                    cdMenu.style.transform = 'scaleY(0)'; cdMenu.style.opacity = '0';
                }
            });

            dropdownItems.forEach(item => {
                item.addEventListener('click', () => {
                    dropdownItems.forEach(i => i.classList.remove('active', 'text-accent', 'pl-6'));
                    item.classList.add('active', 'text-accent', 'pl-6');
                    selectedText.innerText = item.innerText;
                    cdMenu.style.transform = 'scaleY(0)'; cdMenu.style.opacity = '0';
                    renderView(item.dataset.view);
                });
            });

            const renderSpotlight = (data) => {
                const container = document.getElementById('spotlight-container');
                let spotlightT = null;
                const pool = [...(data.live || []), ...(data.upcoming || [])];
                
                if (pool.length > 0) {
                    pool.sort((a, b) => {
                        let aTot = 0, bTot = 0;
                        if (a.participants && a.participants.includes('/')) aTot = parseInt(a.participants.split('/')[0]);
                        if (b.participants && b.participants.includes('/')) bTot = parseInt(b.participants.split('/')[0]);
                        return bTot - aTot;
                    });
                    spotlightT = pool[0];
                }

                if (spotlightT) {
                    container.innerHTML = `
                        <section class="relative w-full overflow-hidden flex items-center py-12 mb-10 rounded-2xl border border-white/10 bg-bg-1 mx-auto max-w-[1400px]">
                            <div class="absolute inset-0 z-0">
                                <img class="w-full h-full object-cover object-center opacity-30 mix-blend-luminosity" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDlRpS-qC062vwWYVxY3Uv3yZ4aroC8gpFRBDu2YR0Lw1RGTWoPAL6QFijLGjCStaxx15fsprScjZdb_-qtQTcBT7aCXMfdYCt36SWLVFFyqj_C47W2EfwHFc0_WzrznMEdRbmbBn9eQZAAhT35-wTG8m1ovsZAmJM42yWFU2gd6a61EFv1UblAY062XHqEaHiiQHg5s45dd0XJHMIUotIn0UxHKxnElcPqwam2svN-VKIT0JrHmmNw" alt="Hero Background"/>
                                <div class="absolute inset-0 bg-gradient-to-r from-bg-0 via-bg-0/90 to-transparent"></div>
                                <div class="absolute right-0 top-1/4 w-96 h-96 bg-accent rounded-full mix-blend-screen filter blur-[120px] opacity-20 animate-pulse"></div>
                            </div>
                            
                            <div class="relative z-10 px-6 md:px-10 w-full">
                                <div class="max-w-3xl">
                                    <div class="inline-flex items-center gap-3 mb-4 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/10">
                                        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
                                        <span class="font-mono text-[10px] md:text-xs font-bold text-accent tracking-widest uppercase">FEATURED TOURNAMENT</span>
                                    </div>
                                    
                                    <h1 class="font-display text-5xl md:text-[4rem] text-white mb-4 uppercase leading-[0.9] drop-shadow-2xl break-words">
                                        ${spotlightT.name.replace(' ', '<br/>')}
                                    </h1>
                                    
                                    <div class="flex flex-wrap items-center gap-4 md:gap-6 mb-6 border-l-2 border-accent pl-4 md:pl-5">
                                        <div>
                                            <div class="font-mono text-[10px] text-text-400 tracking-widest uppercase">GAME</div>
                                            <div class="font-medium text-text-100">${spotlightT.game}</div>
                                        </div>
                                        <div>
                                            <div class="font-mono text-[10px] text-text-400 tracking-widest uppercase">REWARD POOL</div>
                                            <div class="font-bold text-gold">${spotlightT.prize || 'Elite Standing'}</div>
                                        </div>
                                        <div>
                                            <div class="font-mono text-[10px] text-text-400 tracking-widest uppercase">REGISTERED</div>
                                            <div class="font-medium text-accent font-bold">${spotlightT.participants || '0'}</div>
                                        </div>
                                    </div>
                                    
                                    <div class="flex flex-col sm:flex-row flex-wrap items-stretch sm:items-center gap-4 md:gap-5">
                                        <a href="/dashboard/tournaments/${spotlightT.id || spotlightT._id}/register" class="px-6 md:px-8 py-3 blaze-btn font-mono text-sm md:text-base flex justify-center items-center gap-3 w-fit">
                                            REGISTER NOW
                                            <span class="material-symbols-outlined text-sm">app_registration</span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </section>
                    `;
                } else {
                    container.innerHTML = `
                        <section class="relative w-full overflow-hidden flex items-center py-12 mb-10 rounded-2xl border border-gold/20 bg-bg-1 mx-auto max-w-[1400px]">
                            <div class="relative z-10 px-6 md:px-10 w-full text-center">
                                <div class="inline-flex items-center gap-3 mb-4 px-4 py-1.5 rounded-full border border-gold/30 bg-gold/10">
                                    <span class="font-mono text-xs font-bold text-gold tracking-widest uppercase">ELITE ACCESS</span>
                                </div>
                                <h1 class="font-display text-4xl md:text-5xl text-white mb-4 uppercase tracking-wide drop-shadow-2xl">TRUSTED TOURNAMENTS</h1>
                                <p class="text-base text-text-300 max-w-2xl mx-auto">Exclusive high-stakes series and tournaments reserved for verified genuine players. Prove your worth in the highest tiers of Blaze Frontier.</p>
                            </div>
                        </section>
                    `;
                }
            };

            const loadTournaments = async () => {
                const container = document.getElementById('t-content');
                try {
                    const res = await fetch('/api/tournaments', { headers: { 'x-auth-token': token } });
                    if (res.ok) {
                        window.tournamentData = await res.json();
                        renderSpotlight(window.tournamentData);
                        renderView('live');
                    } else throw new Error('Failed to fetch');
                } catch (e) {
                    container.innerHTML = '<div class="text-center py-20 text-text-400 font-mono">Unable to load tournaments at this time.</div>';
                }
            };

            window.renderView = (view) => {
                const container = document.getElementById('t-content');
                if (!window.tournamentData) return;
                
                const list = window.tournamentData[view];
                let html = '';

                if (view === 'live') {
                    if (!list || list.length === 0) {
                        html = '<div class="text-center py-20 text-text-400 font-mono">No live elite tournaments at the moment.</div>';
                    } else {
                        html = '<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">' + list.map((t, index) => `
                            <div class="relative h-[420px] blaze-card flex flex-col justify-end p-8 cursor-pointer group rounded-2xl border-accent/20 hover:border-accent/80 overflow-hidden" style="animation: fadeUpIn 0.6s ease forwards; animation-delay: ${index * 0.1}s; opacity: 0;">
                                <div class="absolute inset-0 z-0 overflow-hidden">
                                    <img class="w-full h-full object-cover object-center motion-blur-img opacity-50 transition-transform duration-700 group-hover:scale-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCp0T-wxpyfI26kRykEmZGI52t7KWalgXs59G7cWnbe5iTPmxzdVz17gjhzl1rVjbqwuWM7v_ATKzo8svPmGnoiRUP7MRjweVX6l_7odJVdlBIZBp_DEFatNuP9e-vSkghQhNcV5wf7QW8stSsQF6yXLANFB7nijL6tlekxDkF5aWuZxvW3yQam9Oln0-i9PnghJVhVHuCKcO8JoYmzUNpJf4aPigymcVuWUzak1Tk9yAzTSP-dq6Ky" alt="Live Match" />
                                    <div class="absolute inset-0 bg-gradient-to-t from-bg-0 via-bg-0/60 to-transparent"></div>
                                    <div class="absolute inset-0 bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                                </div>
                                <div class="relative z-10 w-full flex flex-col h-full transform transition-transform duration-500 group-hover:-translate-y-2">
                                    <div class="flex justify-between items-start mb-4">
                                        <span class="bg-accent text-white px-3 py-1 font-mono text-[10px] md:text-xs font-bold rounded shadow-[0_0_15px_rgba(230,57,70,0.5)] flex items-center gap-2">
                                            <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span> LIVE NOW
                                        </span>
                                        <span class="font-mono text-[10px] md:text-sm text-white bg-white/10 px-3 py-1 rounded backdrop-blur-md font-bold uppercase tracking-widest break-all border border-white/5 group-hover:border-white/20 transition-colors">${t.game}</span>
                                    </div>
                                    <h3 class="font-display text-3xl md:text-4xl text-white mb-4 uppercase tracking-wide leading-none break-words line-clamp-2 drop-shadow-lg">${t.name}</h3>
                                    
                                    <div class="flex flex-wrap items-center gap-2 md:gap-4 mb-4 text-[10px] md:text-xs font-mono text-text-200 mt-auto bg-bg-1/40 p-3 rounded-lg backdrop-blur-sm border border-white/5">
                                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px] text-text-400">group</span> <span class="text-white">${t.participants}</span></span>
                                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px] text-text-400">swords</span> <span class="text-white">${t.team || 'Solo'}</span></span>
                                        <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px] text-gold">trophy</span> <span class="text-gold break-all line-clamp-1 font-bold">${t.prize || 'Elite'}</span></span>
                                    </div>
                                    
                                    <div class="flex flex-col sm:flex-row items-stretch justify-between pt-2 gap-3 opacity-90 group-hover:opacity-100 transition-opacity">
                                        <a href="/dashboard/leaderboards" class="flex-1 text-center py-3 bg-white text-bg-0 hover:bg-accent hover:text-white rounded font-mono font-bold text-sm transition-colors flex items-center justify-center gap-2 shadow-lg">
                                            SPECTATE
                                        </a>
                                        ${t.isListPublished ? `<button onclick="viewParticipants('${t.id || t._id}', '${t.name.replace(/'/g, "\\'")}')" class="flex-1 text-center py-3 blaze-btn-outline font-mono font-bold text-sm relative z-20 hover:border-white hover:text-white bg-black/20">ROSTER</button>` : ''}
                                    </div>
                                </div>
                            </div>
                        `).join('') + '</div>';
                    }
                } else if (view === 'upcoming') {
                    if (!list || list.length === 0) {
                        html = '<div class="text-center py-20 text-text-400 font-mono">No upcoming elite tournaments scheduled. Check back soon.</div>';
                    } else {
                        html = '<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">' + list.map((t, index) => `
                            <div class="relative h-[420px] blaze-card flex flex-col justify-end p-8 cursor-pointer group rounded-2xl border-white/10 hover:border-gold/40 overflow-hidden" style="animation: fadeUpIn 0.6s ease forwards; animation-delay: ${index * 0.1}s; opacity: 0;">
                                <div class="absolute inset-0 z-0 overflow-hidden">
                                    <img class="w-full h-full object-cover object-left motion-blur-img opacity-40 transition-transform duration-700 group-hover:scale-110" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDlEqRxv13oTOeCqd3yqm4y7DXMTpEv6mvwlnPU9Q3LMZMsxeVVikZ8JSRHEZlpeaE0HyaxaHbGCVRVtis5_c_WeTndUvTuJ5smUnpUW0D5QK7mG4kNnDVX9N-0vXnPOVqkD9g72mkjAV0larpbRGppyGzDWWKMd8d6OkFtQtZEqtiufVLa6iNDEufJqNWVwad3dhSfIlbpTJU9xdg0KABgP5eVZ-7MAkDCH158VIuBK3vOu-JphQKS" alt="Upcoming Match"/>
                                    <div class="absolute inset-0 bg-gradient-to-t from-bg-0 via-bg-0/70 to-transparent"></div>
                                    <div class="absolute inset-0 bg-gold/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                                </div>
                                <div class="relative z-10 w-full flex flex-col h-full transform transition-transform duration-500 group-hover:-translate-y-2">
                                    <div class="flex justify-between items-start mb-4">
                                        <span class="bg-white/90 text-bg-0 px-3 py-1 font-mono text-[10px] md:text-xs font-bold rounded shadow-[0_0_10px_rgba(255,255,255,0.2)]">UPCOMING</span>
                                        <span class="font-mono text-[10px] md:text-sm text-white bg-white/10 px-3 py-1 rounded backdrop-blur-md font-bold uppercase tracking-widest break-all border border-white/5 group-hover:border-white/20 transition-colors">${t.game}</span>
                                    </div>
                                    <h3 class="font-display text-2xl md:text-3xl text-white mb-4 uppercase tracking-wide leading-tight break-words line-clamp-2 drop-shadow-md">${t.name}</h3>
                                    
                                    <div class="flex flex-col gap-2 mb-6 text-[10px] md:text-xs font-mono text-text-200 mt-auto bg-bg-1/50 p-4 rounded-lg backdrop-blur-sm border border-white/5">
                                        <div class="flex justify-between items-center pb-2 border-b border-white/5"><span>Date:</span> <span class="text-white font-bold text-right">${t.date}</span></div>
                                        <div class="flex justify-between items-center pb-2 border-b border-white/5"><span>Time:</span> <span class="text-white font-bold text-right">${t.timeSlot || 'TBA'}</span></div>
                                        <div class="flex justify-between items-center pb-2 border-b border-white/5"><span>Format:</span> <span class="text-white font-bold text-right">${t.team || 'Solo'}</span></div>
                                        <div class="flex justify-between items-center"><span>Reward:</span> <span class="text-gold font-bold text-right break-words max-w-[150px] line-clamp-1">${t.prize || 'Elite'}</span></div>
                                    </div>
                                    
                                    <div class="flex flex-col sm:flex-row items-stretch gap-3 opacity-90 group-hover:opacity-100 transition-opacity">
                                        ${t.canRegister ? `<a href="/dashboard/tournaments/${t.id || t._id}/register" class="flex-1 text-center py-3 bg-gradient-to-r from-gold to-yellow-500 text-bg-0 font-mono font-bold text-sm relative z-20 rounded shadow-[0_0_15px_rgba(240,165,0,0.3)] hover:shadow-[0_0_25px_rgba(240,165,0,0.6)] hover:-translate-y-0.5 transition-all">SECURE SLOT</a>` : ''}
                                        ${t.isListPublished ? `<button onclick="viewParticipants('${t.id || t._id}', '${t.name.replace(/'/g, "\\'")}')" class="flex-1 text-center py-3 blaze-btn-outline font-mono font-bold text-sm relative z-20 hover:border-white hover:text-white bg-black/20">ROSTER</button>` : ''}
                                    </div>
                                </div>
                            </div>
                        `).join('') + '</div>';
                    }
                } else if (view === 'completed') {
                    if (!list || list.length === 0) {
                        html = '<div class="text-center py-20 text-text-400 font-mono">No completed matches available yet.</div>';
                    } else {
                        html = '<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">' + list.map((t, index) => `
                            <div class="relative h-[300px] blaze-card flex flex-col justify-end p-8 border-white/10 bg-bg-1/80 grayscale-[50%]" style="animation: fadeUpIn 0.6s ease forwards; animation-delay: ${index * 0.1}s; opacity: 0;">
                                <div class="relative z-10 w-full">
                                    <div class="flex justify-between items-start mb-4">
                                        <span class="bg-bg-3 text-text-300 border border-white/10 px-3 py-1 font-mono text-xs font-bold rounded">COMPLETED</span>
                                        <span class="font-mono text-sm text-text-400 font-bold uppercase tracking-widest">${t.game}</span>
                                    </div>
                                    <h3 class="font-display text-2xl text-text-100 mb-2 uppercase tracking-wide leading-tight">${t.name}</h3>
                                    <p class="font-mono text-xs text-text-400 mb-6 tracking-widest">${t.date}</p>
                                    
                                    <a href="/dashboard/leaderboards" class="block w-full text-center py-3 blaze-btn-outline font-mono text-sm">VIEW RESULTS</a>
                                </div>
                            </div>
                        `).join('') + '</div>';
                    }
                }
                container.innerHTML = html;
            };

            await loadTournaments();
            await loadHallOfFame();
        });

        // ===== HALL OF FAME: Dynamic Leaderboard =====
        async function loadHallOfFame() {
            const container = document.getElementById('hof-container');
            const token = localStorage.getItem('blaze_token');
            try {
                const res = await fetch('/api/leaderboard', { headers: { 'x-auth-token': token } });
                if (!res.ok) throw new Error('Failed');
                const lb = await res.json();
                let top3 = lb.slice(0, 3);

                if (top3.length === 0) {
                    top3 = [
                        { rank: 1, name: 'Manoj', bp: 15400, avatar: 'https://ui-avatars.com/api/?name=Ma&background=f0a500&color=fff&size=128' },
                        { rank: 2, name: 'Phantom', bp: 12100, avatar: 'https://ui-avatars.com/api/?name=Ph&background=c0c0c0&color=fff&size=128' },
                        { rank: 3, name: 'Striker', bp: 9800, avatar: 'https://ui-avatars.com/api/?name=St&background=cd7f32&color=fff&size=128' }
                    ];
                }

                // Pad if less than 3
                while (top3.length < 3) top3.push({ rank: top3.length + 1, name: '???', bp: 0 });

                const colors = [
                    { border: '#f0a500', bg: 'rgba(240,165,0,', text: '#f0a500', label: 'Champion', pulse: 'hofPulseGold', icon: 'emoji_events' },
                    { border: '#c0c0c0', bg: 'rgba(192,192,192,', text: '#c0c0c0', label: 'Elite Contender', pulse: 'hofPulseSilver', icon: '' },
                    { border: '#cd7f32', bg: 'rgba(205,127,50,', text: '#cd7f32', label: 'Rising Star', pulse: 'hofPulseBronze', icon: '' }
                ];

                // Order: [#2, #1, #3] for visual podium
                const order = [1, 0, 2];
                const heights = ['320px', '420px', '280px'];
                const avatarSizes = ['w-16 h-16', 'w-24 h-24', 'w-14 h-14'];
                const rankSizes = ['text-4xl', 'text-6xl', 'text-3xl'];
                const nameSizes = ['text-xl', 'text-2xl md:text-3xl', 'text-lg'];
                const delays = ['0.15s', '0s', '0.3s'];

                let cardsHtml = '';
                order.forEach((idx, pos) => {
                    const p = top3[idx];
                    const c = colors[idx];
                    const isChamp = idx === 0;
                    const avatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(p.name)}&background=${c.border.replace('#','')}&color=fff&size=128&bold=true`;

                    cardsHtml += `
                    <div class="relative flex-1 min-w-0 hof-card" style="animation: fadeUpIn 0.7s ease both; animation-delay: ${delays[pos]};">
                        <div class="relative flex flex-col items-center text-center rounded-2xl border-2 p-6 md:p-8 overflow-hidden"
                             style="border-color: ${c.border}40; background: linear-gradient(180deg, ${c.bg}0.08) 0%, rgba(10,10,18,0.95) 100%); min-height: ${heights[pos]}; animation: ${c.pulse} 4s ease-in-out infinite;">
                            
                            <!-- Ambient glow -->
                            <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-40 h-40 rounded-full blur-[80px] pointer-events-none" style="background: ${c.bg}0.15);"></div>
                            <div class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none" style="background: linear-gradient(to top, ${c.bg}0.1), transparent);"></div>
                            
                            ${isChamp ? `
                            <!-- Crown -->
                            <div class="absolute -top-1 left-1/2 -translate-x-1/2" style="animation: crownBob 3s ease-in-out infinite;">
                                <span class="material-symbols-outlined text-[44px] drop-shadow-[0_0_20px_rgba(240,165,0,0.8)]" style="color: ${c.border}; font-variation-settings: 'FILL' 1;">emoji_events</span>
                            </div>` : ''}
                            
                            <!-- Avatar -->
                            <div class="relative mt-${isChamp ? '10' : '6'} mb-5">
                                <div class="absolute inset-0 rounded-full blur-lg pointer-events-none" style="background: ${c.bg}0.3); transform: scale(1.3);"></div>
                                <img src="${avatarUrl}" class="${avatarSizes[pos]} rounded-full relative z-10 hof-avatar" style="border: 3px solid ${c.border}; box-shadow: 0 0 20px ${c.bg}0.4);">
                            </div>
                            
                            <!-- Rank Number -->
                            <div class="font-display ${rankSizes[pos]} leading-none mb-2" style="color: ${c.border}; text-shadow: 0 0 20px ${c.bg}0.5);">
                                #${p.rank}
                            </div>
                            
                            <!-- Name -->
                            <h5 class="font-display ${nameSizes[pos]} text-white uppercase tracking-wider truncate w-full max-w-[200px] ${isChamp ? 'hof-shimmer-text' : ''}">
                                ${p.name}
                            </h5>
                            
                            <!-- Title -->
                            <div class="font-mono text-[9px] md:text-[10px] tracking-[3px] uppercase mt-1 mb-4" style="color: ${c.bg}0.7);">${c.label}</div>
                            
                            <!-- Points -->
                            <div class="font-mono text-base md:text-lg font-bold px-5 py-2 rounded-lg mt-auto" style="color: ${c.border}; background: ${c.bg}0.1); border: 1px solid ${c.bg}0.25);">
                                ${p.bp.toLocaleString()} <span class="text-[10px] text-text-400 uppercase tracking-widest">BP</span>
                            </div>
                        </div>
                    </div>`;
                });

                container.innerHTML = `
                    <div class="relative bg-bg-1/40 border border-white/5 rounded-2xl p-6 md:p-10 backdrop-blur-xl overflow-hidden">
                        <!-- Deep background glows -->
                        <div class="absolute -top-40 -right-40 w-[500px] h-[500px] bg-gold/8 rounded-full blur-[150px] pointer-events-none"></div>
                        <div class="absolute -bottom-40 -left-40 w-[500px] h-[500px] bg-accent/8 rounded-full blur-[150px] pointer-events-none"></div>
                        
                        <!-- Podium Cards -->
                        <div class="relative z-10 flex flex-col sm:flex-row justify-center items-end gap-4 lg:gap-6">
                            ${cardsHtml}
                        </div>
                        
                        <!-- Bottom CTA -->
                        <a href="/dashboard/leaderboards" class="relative z-20 block w-full mt-8 text-center py-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl font-mono text-xs tracking-widest text-text-200 hover:text-white transition-all uppercase backdrop-blur-md hover:border-gold/30">
                            View Full Global Leaderboard
                        </a>
                    </div>`;

            } catch (e) {
                container.innerHTML = `
                    <div class="flex flex-col items-center justify-center h-full min-h-[480px] bg-bg-1/40 border border-white/5 rounded-2xl backdrop-blur-xl p-10">
                        <span class="material-symbols-outlined text-[50px] text-text-400 mb-4">signal_wifi_off</span>
                        <p class="font-mono text-sm text-text-400">Could not load Hall of Fame data.</p>
                    </div>`;
            }
        }

        async function viewParticipants(id, name) {
            document.getElementById('p-modal-title').textContent = name.toUpperCase();
            document.getElementById('participants-modal').style.display = 'flex';
            const content = document.getElementById('p-modal-content');
            content.innerHTML = '<div class="flex justify-center py-10"><div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-accent"></div></div>';

            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch(`/api/tournaments/${id}/participants`, { headers: { 'x-auth-token': token } });
                if (res.ok) {
                    const participants = await res.json();
                    if (participants.length === 0) {
                        content.innerHTML = '<div class="text-center py-10 text-text-400 font-mono">Roster is currently empty.</div>';
                    } else {
                        content.innerHTML = '<div class="grid grid-cols-2 md:grid-cols-3 gap-4">' + participants.map((p, i) => `
                            <div class="p-4 bg-white/5 border border-white/10 rounded-lg flex items-center gap-4 transition-all hover:bg-accent/10 hover:border-accent/30 hover:-translate-y-1">
                                <div class="font-mono text-accent font-bold bg-accent/20 w-8 h-8 flex items-center justify-center rounded">${i + 1}</div>
                                <div class="font-display text-white tracking-wide text-lg truncate" title="${p}">${p}</div>
                            </div>
                        `).join('') + '</div>';
                    }
                } else {
                    content.innerHTML = '<div class="text-center py-10 text-accent font-mono">Could not load participants.</div>';
                }
            } catch (e) {
                content.innerHTML = '<div class="text-center py-10 text-accent font-mono">Network error. Please try again.</div>';
            }
        }

        function closeParticipantsModal() {
            document.getElementById('participants-modal').style.display = 'none';
        }
    </script>
</body>
</html>
