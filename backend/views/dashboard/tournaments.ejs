<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Global Pro Circuit - Leagues</title>
    
    <!-- Keep existing font & stylesheet so navbar stays styled correctly -->
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600;800&display=block" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">

    <!-- Tailwind Requirements -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "outline": "#988d9f",
                        "on-primary-fixed": "#2c0051",
                        "secondary-fixed-dim": "#adc6ff",
                        "on-background": "#e1e2e7",
                        "error": "#ffb4ab",
                        "inverse-surface": "#e1e2e7",
                        "tertiary-fixed-dim": "#fabc4e",
                        "on-secondary-fixed-variant": "#004395",
                        "surface": "#111417",
                        "secondary": "#adc6ff",
                        "tertiary-container": "#bd871a",
                        "on-primary-fixed-variant": "#6900b3",
                        "outline-variant": "#4d4354",
                        "tertiary-fixed": "#ffdead",
                        "inverse-on-surface": "#2e3134",
                        "on-secondary-container": "#e6ecff",
                        "on-error-container": "#ffdad6",
                        "on-surface": "#e1e2e7",
                        "surface-tint": "#ddb7ff",
                        "on-primary-container": "#400071",
                        "on-tertiary-fixed": "#281900",
                        "secondary-fixed": "#d8e2ff",
                        "on-secondary": "#002e6a",
                        "on-tertiary": "#432c00",
                        "surface-dim": "#111417",
                        "on-secondary-fixed": "#001a42",
                        "on-surface-variant": "#cfc2d6",
                        "on-tertiary-fixed-variant": "#604100",
                        "surface-bright": "#37393d",
                        "on-primary": "#490080",
                        "background": "#111417",
                        "surface-variant": "#323538",
                        "primary": "#ddb7ff",
                        "on-tertiary-container": "#3a2600",
                        "on-error": "#690005",
                        "secondary-container": "#0566d9",
                        "surface-container-lowest": "#0b0e11",
                        "surface-container-highest": "#323538",
                        "tertiary": "#fabc4e",
                        "primary-fixed": "#f0dbff",
                        "primary-fixed-dim": "#ddb7ff",
                        "surface-container-low": "#191c1f",
                        "error-container": "#93000a",
                        "inverse-primary": "#842bd2",
                        "primary-container": "#b76dff",
                        "surface-container-high": "#272a2e",
                        "surface-container": "#1d2023"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "md": "16px",
                        "margin-mobile": "16px",
                        "xs": "4px",
                        "base": "4px",
                        "container-max": "1280px",
                        "sm": "8px",
                        "lg": "24px",
                        "xl": "40px",
                        "gutter": "24px"
                    },
                    "fontFamily": {
                        "body-md": ["Inter"],
                        "label-sm": ["Inter"],
                        "headline-md": ["Inter"],
                        "headline-lg-mobile": ["Inter"],
                        "body-lg": ["Inter"],
                        "display-lg": ["Inter"],
                        "headline-lg": ["Inter"],
                        "label-md": ["Inter"]
                    },
                    "fontSize": {
                        "body-md": ["16px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "label-sm": ["12px", { "lineHeight": "1.2", "fontWeight": "500" }],
                        "headline-md": ["24px", { "lineHeight": "1.3", "fontWeight": "600" }],
                        "headline-lg-mobile": ["24px", { "lineHeight": "1.2", "fontWeight": "700" }],
                        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "display-lg": ["48px", { "lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "800" }],
                        "headline-lg": ["32px", { "lineHeight": "1.2", "letterSpacing": "-0.01em", "fontWeight": "700" }],
                        "label-md": ["14px", { "lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "600" }]
                    }
                }
            }
        }
    </script>
    <style>
        /* Existing global bg doesn't override tailwind classes if we scope it */
        .glass-panel { background: rgba(17, 24, 39, 0.6); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .glass-panel:hover { border-color: rgba(255, 255, 255, 0.3); box-shadow: inset 0 0 10px rgba(221, 183, 255, 0.2); transition: all 0.3s ease; }
        .btn-primary { background-color: #A855F7; color: white; transition: all 0.3s ease; }
        .btn-primary:hover { filter: drop-shadow(0 0 8px rgba(168, 85, 247, 0.8)); }
        .text-cyber-blue { color: #3B82F6; }
        .border-cyber-blue { border-color: #3B82F6; }
        .bg-cyber-blue { background-color: #3B82F6; }
        .table-row-hover:hover { background-color: rgba(17, 24, 39, 0.8); }

        /* Loader */
        .t-spinner {
            display: inline-block; width: 36px; height: 36px;
            border: 3px solid rgba(168, 85, 247, 0.2);
            border-top-color: #A855F7;
            border-radius: 50%;
            animation: spin 0.8s cubic-bezier(0.5, 0, 0.5, 1) infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body class="font-body-md text-body-md antialiased overflow-x-hidden min-h-screen flex flex-col bg-[#050709] text-[#e1e2e7]">

    <%- include('../partials/navbar') %>

    <!-- Hero Section -->
    <header class="relative w-full min-h-[600px] h-auto pt-32 pb-16 flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/blaze_arena_bg.png'); opacity: 0.5;"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#050709] via-transparent to-[#050709]/50"></div>
        
        <div class="relative z-10 text-center max-w-container-max mx-auto px-margin-mobile md:px-xl flex flex-col items-center gap-lg">
            <h1 class="font-display-lg text-display-lg bg-clip-text text-transparent bg-gradient-to-r from-primary via-[#ffb700] to-cyber-blue drop-shadow-[0_2px_10px_rgba(168,85,247,0.4)] tracking-wide" style="line-height: 1.1;">ELITE COMPETITIVE CIRCUIT</h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl">Enter the arena. Compete in high-stakes leagues against the world's best.</p>
            
            <div class="flex flex-wrap justify-center gap-lg mt-md">
                <div class="glass-panel px-lg py-md rounded-lg flex flex-col items-center min-w-[150px]">
                    <span class="font-headline-md text-headline-md text-primary" id="stat-live">0</span>
                    <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Active Leagues</span>
                </div>
                <div class="glass-panel px-lg py-md rounded-lg flex flex-col items-center min-w-[150px]">
                    <span class="font-headline-md text-headline-md text-tertiary" id="stat-upcoming">0</span>
                    <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Upcoming Matches</span>
                </div>
                <div class="glass-panel px-lg py-md rounded-lg flex flex-col items-center min-w-[150px]">
                    <span class="font-headline-md text-headline-md text-cyber-blue" id="stat-players">0</span>
                    <span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Players Registered</span>
                </div>
            </div>
            
            <a href="#t-page" class="btn-primary mt-lg px-xl py-md rounded-full font-label-md text-label-md uppercase tracking-widest cursor-pointer inline-flex items-center gap-sm shadow-[0_0_20px_rgba(168,85,247,0.8)] hover:scale-105 hover:shadow-[0_0_30px_rgba(168,85,247,1)]">
                <span class="font-bold">PROVE YOUR DOMINANCE</span>
                <span class="material-symbols-outlined text-[20px]">swords</span>
            </a>
        </div>
    </header>

    <main class="flex-grow max-w-container-max w-full mx-auto px-margin-mobile md:px-xl py-xl flex flex-col gap-[64px]" id="t-page">
        <!-- Featured Leagues -->
        <section class="flex flex-col gap-lg">
            <div class="flex items-center justify-between">
                <h2 class="text-xl md:text-2xl font-bold font-display text-white flex items-center gap-sm whitespace-nowrap">
                    <span class="material-symbols-outlined text-primary text-[24px]">local_fire_department</span>
                    Featured Leagues
                </h2>
                <a class="font-label-md text-label-md text-primary hover:text-primary-fixed transition-colors flex items-center gap-xs flex-shrink-0 whitespace-nowrap" href="/dashboard/tournaments/all">
                    View All <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                </a>
            </div>
            
            <div class="flex flex-nowrap overflow-x-auto gap-gutter pb-sm snap-x snap-mandatory custom-scrollbar" id="featured-grid">
                <div class="w-full text-center py-xl"><div class="t-spinner"></div></div>
            </div>
        </section>

        <!-- Bento Grid Layout for Table & Leaderboard -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
            
            <!-- Tournament Table (Spans 2 columns on lg) -->
            <section class="lg:col-span-2 flex flex-col gap-md glass-panel rounded-xl p-md md:p-lg">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-md mb-sm">
                    <h2 class="font-headline-md text-headline-md text-white flex items-center gap-sm">
                        <span class="material-symbols-outlined text-cyber-blue">calendar_month</span>
                        Upcoming Matches
                    </h2>
                    <a href="/dashboard/tournaments/all" class="text-cyber-blue hover:text-white font-label-md text-label-md transition-colors flex items-center gap-xs">
                        View All <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                    </a>
                </div>
                
                <div class="flex flex-col gap-3" id="upcoming-list">
                    <div class="text-center py-xl"><div class="t-spinner"></div></div>
                </div>
            </section>

            <!-- Community Leaderboard -->
            <section class="glass-panel rounded-xl p-md md:p-lg flex flex-col gap-md border-t-2 border-t-tertiary shadow-[0_-5px_20px_rgba(250,188,78,0.15)] bg-gradient-to-b from-[#1a1408] to-transparent">
                <h2 class="font-headline-md text-headline-md text-white flex items-center gap-sm mb-xs">
                    <span class="material-symbols-outlined text-tertiary drop-shadow-[0_0_8px_rgba(250,188,78,0.8)]">leaderboard</span>
                    Top Warriors
                </h2>
                <div class="flex flex-col gap-sm" id="hof-podium">
                    <div class="text-center py-lg"><div class="t-spinner"></div></div>
                </div>
            </section>
        </div>
    </main>

    <!-- ===================== PARTICIPANTS MODAL ===================== -->
    <div id="participants-modal" class="hidden fixed inset-0 bg-black/85 backdrop-blur-md z-50 justify-center items-center p-4">
        <div class="bg-[#111118] border border-[#A855F7]/30 rounded-xl w-full max-w-2xl max-h-[85vh] flex flex-col p-8 relative shadow-2xl">
            <button onclick="closeParticipantsModal()" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-white/10 transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-1 bg-primary rounded-full"></div>
                <h2 class="text-2xl font-bold text-white uppercase tracking-wider" id="p-modal-title">PARTICIPANTS</h2>
            </div>
            <div class="flex-1 overflow-y-auto pr-2" id="p-modal-content">
                <div class="text-center py-10"><div class="t-spinner"></div></div>
            </div>
        </div>
    </div>

    <!-- JS Logic -->
    <script src="/script.js?v=1.2"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('blaze_token');
            if (!token) { window.location.href = '/auth'; return; }

            // Animated Number Counter
            const animateValue = (id, start, end, duration) => {
                const el = document.getElementById(id);
                if (!el || start === end) {
                    if (el) el.textContent = end;
                    return;
                }
                let startTimestamp = null;
                const step = (timestamp) => {
                    if (!startTimestamp) startTimestamp = timestamp;
                    const progress = Math.min((timestamp - startTimestamp) / duration, 1);
                    const easeProgress = progress * (2 - progress);
                    el.textContent = Math.floor(easeProgress * (end - start) + start);
                    if (progress < 1) {
                        window.requestAnimationFrame(step);
                    } else {
                        el.textContent = end;
                    }
                };
                window.requestAnimationFrame(step);
            };

            // Backgrounds for Featured Leagues
            const featuredBgs = [
                "https://lh3.googleusercontent.com/aida-public/AB6AXuA_v-Vip_ysVL2hIakmU6m4sg5MyPmJchfbNJ8uYtv4ppGxuz8tOvJ9sdl4JpAXF4To7o94Qx2NYHvzmRwaHMXqh4L53BQu9YAa2-U5INzGdyx6s-yGKtG45zs4TnvKJ6j7X0oRIzbBncZRgnD0wTX7taD4dJ2Etd3VNbl7VkKEBwUdgJPrYAaLbyKIIU96Wsp2Gxmxh-hySWVppRibtH1xnhHic-x7nsGJDDr0LgwsRzNzdc-fv8WHNA",
                "https://lh3.googleusercontent.com/aida-public/AB6AXuCuIve0PsNoKVv6dNKORuEbmgqQA1h6fKNRVrPaapPiOJXzaisvWsjxkt1nNBJlXkFaXjmKJU14lEb_9g1dvJpmSyVaLO7_WGq-IfXeppVZ4GytjcjI6oQJGohjqAXAbGsW0l-4hZqA4lqCbXVFM2Jrdnj_p2fiTGjCGvuNwvlO5q74joD4wpWCZybkOmejcqrkBkQZHsWJ1yLvVhovZNlcWvlCuFndSjjXtdwFQXg71ISocILZaHAoDw"
            ];

            // Load tournaments from API
            const loadTournaments = async () => {
                const featuredGrid = document.getElementById('featured-grid');
                
                try {
                    const res = await fetch('/api/tournaments?game=freefire', { headers: { 'x-auth-token': token } });
                    if (!res.ok) throw new Error('Failed');
                    const data = await res.json();
                    
                    // Update stats with animation
                    animateValue('stat-live', 0, (data.live || []).length, 1500);
                    animateValue('stat-upcoming', 0, (data.upcoming || []).length, 1500);
                    
                    let totalParticipants = 0;
                    [...(data.live || []), ...(data.upcoming || []), ...(data.completed || [])].forEach(t => {
                        if (t.participants && !isNaN(parseInt(t.participants))) totalParticipants += parseInt(t.participants);
                    });
                    if (totalParticipants === 0) totalParticipants = 1200; // Fallback
                    animateValue('stat-players', 0, totalParticipants, 2000);

                    // Combine live and upcoming for the main feed, excluding Qualification Series
                    const allTournaments = [...(data.live || []), ...(data.upcoming || [])].filter(t => t.game !== 'CUSTOM SERIES');
                    
                    // 1. Render Featured (Top 2)
                    if (allTournaments.length === 0) {
                        featuredGrid.innerHTML = '<div class="col-span-1 md:col-span-2 text-center text-on-surface-variant">No Active Leagues currently available.</div>';
                        const listContainer = document.getElementById('upcoming-list');
                        if (listContainer) listContainer.innerHTML = '<div class="text-center py-md text-on-surface-variant bg-surface/50 rounded-xl border border-white/5">No matches scheduled.</div>';
                        return;
                    }

                    const featuredTournaments = allTournaments.slice(0, 2);
                    featuredGrid.innerHTML = featuredTournaments.map((t, i) => {
                        const bg = featuredBgs[i % featuredBgs.length];
                        const statusClass = t.status === 'LIVE' ? 'bg-[#22c55e]' : 'bg-[#A855F7]';
                        const statusText = t.status === 'LIVE' ? 'LIVE NOW' : 'S-Tier';
                        const safeName = (t.name || '').replace(/'/g, "\\'");
                        const isRegClosed = t.isListPublished || (t.registrationEndTime && new Date(t.registrationEndTime).getTime() < Date.now());
                        const onClickAttr = isRegClosed 
                            ? `onclick="viewParticipants(event, '${t.id || t._id}', '${safeName}')"`
                            : `onclick="window.location.href='/dashboard/tournaments/${t.id || t._id}/register'"`;
                        
                        return `
                        <div class="glass-panel rounded-xl overflow-hidden group cursor-pointer relative h-[180px] flex flex-col justify-end min-w-[300px] md:min-w-0 md:flex-1 shrink-0 snap-center" ${onClickAttr}>
                            <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-105" style="background-image: url('${bg}'); opacity: 0.5;"></div>
                            <div class="absolute inset-0 bg-gradient-to-t from-[#050709] to-transparent"></div>
                            
                            <div class="absolute top-md right-md ${statusClass} text-white font-label-sm text-label-sm px-sm py-xs rounded flex items-center gap-xs shadow-[0_0_10px_rgba(168,85,247,0.5)]">
                                ${statusText}
                            </div>
                            
                            <div class="relative z-10 p-lg w-full">
                                <h3 class="text-lg md:text-xl font-bold font-display text-white mb-xs group-hover:text-primary transition-colors truncate" title="${t.name}">${t.name}</h3>
                                <div class="flex items-center justify-between mt-md border-t border-white/10 pt-sm">
                                    <div class="flex items-center gap-sm">
                                        <span class="material-symbols-outlined text-tertiary shrink-0">monetization_on</span>
                                        <span class="font-label-md text-label-md text-white truncate max-w-[120px] md:max-w-[180px]" title="${t.prize || ''}">${t.prize || 'TBA'}</span>
                                    </div>
                                    <div class="flex items-center gap-sm">
                                        <span class="material-symbols-outlined text-cyber-blue shrink-0">groups</span>
                                        <span class="font-label-md text-label-md text-on-surface-variant truncate">${t.participants || '—'} Slots</span>
                                    </div>
                                </div>
                            </div>
                        </div>`;
                    }).join('');

                    // 2. Render List (Upcoming Tournaments)
                    const upcomingTournaments = (data.upcoming || []).filter(t => t.game !== 'CUSTOM SERIES');
                    const listContainer = document.getElementById('upcoming-list');
                    if (upcomingTournaments.length === 0) {
                        listContainer.innerHTML = '<div class="text-center py-md text-on-surface-variant bg-surface/50 rounded-xl border border-white/5">No upcoming matches scheduled.</div>';
                    } else {
                        listContainer.innerHTML = upcomingTournaments.map(t => {
                            const isLive = t.status === 'LIVE';
                            const badgeColor = isLive ? 'text-[#22c55e] border-[#22c55e]/30 bg-[#22c55e]/10' : 'text-cyber-blue border-cyber-blue/30 bg-cyber-blue/10';
                            
                            const safeName = (t.name || '').replace(/'/g, "\\'");
                            const isRegClosed = t.isListPublished || (t.registrationEndTime && new Date(t.registrationEndTime).getTime() < Date.now());
                            const onClickAttr = isRegClosed
                                ? `onclick="viewParticipants(event, '${t.id || t._id}', '${safeName}')"`
                                : `onclick="window.location.href='/dashboard/tournaments/${t.id || t._id}/register'"`;

                            let rosterHtml = '';
                            if (t.isListPublished) {
                                rosterHtml = `<button onclick="viewParticipants(event, '${t.id || t._id}', '${safeName}')" class="px-3 py-1.5 rounded-lg bg-surface border border-outline-variant hover:border-primary hover:bg-primary/10 text-xs font-semibold transition-colors flex items-center gap-1 shrink-0 text-white"><span class="material-symbols-outlined text-[14px]">groups</span> Roster</button>`;
                            }

                            return `
                            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 p-4 rounded-xl border border-white/5 bg-white/5 hover:bg-white/10 transition-all cursor-pointer group shadow-sm hover:shadow-md" ${onClickAttr}>
                                <div class="flex items-center gap-4 flex-1 overflow-hidden">
                                    <div class="w-12 h-12 rounded-full bg-surface border border-white/10 flex items-center justify-center shrink-0 group-hover:border-primary/50 group-hover:bg-primary/10 transition-colors">
                                        <span class="material-symbols-outlined text-[24px] ${isLive ? 'text-[#22c55e]' : 'text-primary'}">sports_esports</span>
                                    </div>
                                    <div class="flex flex-col flex-1 overflow-hidden">
                                        <div class="text-white font-bold text-lg truncate group-hover:text-primary transition-colors">${t.name}</div>
                                        <div class="text-on-surface-variant text-sm flex items-center gap-1.5 mt-1">
                                            <span class="material-symbols-outlined text-[14px] text-cyber-blue">calendar_month</span> ${(t.date || 'TBA').replace('T', '&nbsp;&nbsp;|&nbsp;&nbsp;')}
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center justify-between md:justify-end gap-6 shrink-0 border-t border-white/10 md:border-0 pt-3 md:pt-0 mt-2 md:mt-0 w-full md:w-auto">
                                    <div class="flex items-center gap-2 w-1/2 md:w-auto">
                                        <span class="material-symbols-outlined text-[16px] text-tertiary">emoji_events</span>
                                        <span class="text-tertiary text-sm font-semibold truncate max-w-[120px]" title="${t.prize || ''}">${t.prize || '—'}</span>
                                    </div>
                                    <div class="flex items-center gap-3 w-1/2 md:w-auto justify-end">
                                        <span class="inline-block px-2.5 py-1 rounded-md border ${badgeColor} text-xs font-bold tracking-widest shrink-0">${t.participants || '0'} SLOTS</span>
                                        ${rosterHtml}
                                    </div>
                                </div>
                            </div>`;
                        }).join('');
                    }
                } catch (e) {
                    featuredGrid.innerHTML = '<div class="col-span-1 md:col-span-2 text-center text-error">Failed to load leagues.</div>';
                    const listContainer = document.getElementById('upcoming-list');
                    if (listContainer) listContainer.innerHTML = '<div class="text-center py-md text-error bg-error/10 rounded-xl">Failed to load leagues.</div>';
                }
            };

            // Load Hall of Fame (Top 5)
            const loadHallOfFame = async () => {
                const container = document.getElementById('hof-podium');
                try {
                    const res = await fetch('/api/leaderboard?region=india', { headers: { 'x-auth-token': token } });
                    if (!res.ok) throw new Error('Failed');
                    let lb = await res.json();
                    let top5 = lb.slice(0, 5);

                    while (top5.length < 5) top5.push({ rank: top5.length + 1, name: 'TBA', bp: 0, region: 'India' });

                    container.innerHTML = top5.map((p, i) => {
                        const isRank1 = i === 0;
                        const bgClass = isRank1 ? 'bg-surface-container-highest border-l-2 border-tertiary' : 'bg-surface/50 hover:bg-surface-container-high';
                        const rankColor = isRank1 ? 'text-tertiary' : 'text-on-surface-variant';
                        const labelClass = isRank1 ? 'font-headline-md' : 'font-label-md';

                        return `
                        <div class="flex items-center gap-sm p-sm rounded ${bgClass} transition-colors cursor-pointer" onclick="window.location.href='/dashboard/hall-of-fame'">
                            <span class="${labelClass} ${rankColor} w-6 text-center">${p.rank}</span>
                            <div class="flex-grow">
                                <div class="font-label-md text-white">${p.name.toUpperCase()}</div>
                                <div class="font-label-sm text-on-surface-variant">${p.region || 'India'}</div>
                            </div>
                            <div class="font-label-md text-cyber-blue">${p.bp.toLocaleString()} pts</div>
                        </div>`;
                    }).join('');
                } catch (e) {
                    container.innerHTML = '<div class="text-center py-md text-on-surface-variant">Could not load rankings.</div>';
                }
            };

            await loadTournaments();
            await loadHallOfFame();
        });

        // Participants modal functions
        window.viewParticipants = async function(e, id, name) {
            e.stopPropagation(); // prevent row click
            document.getElementById('p-modal-title').textContent = name.toUpperCase();
            
            const modal = document.getElementById('participants-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            const content = document.getElementById('p-modal-content');
            content.innerHTML = '<div class="text-center py-10"><div class="t-spinner"></div></div>';

            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch(`/api/tournaments/${id}/participants`, { headers: { 'x-auth-token': token } });
                if (res.ok) {
                    const participants = await res.json();
                    if (participants.length === 0) {
                        content.innerHTML = '<div class="text-center py-10 text-on-surface-variant font-body-md">Roster is currently empty.</div>';
                    } else {
                        content.innerHTML = '<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">' + participants.map((p, i) => `
                            <div class="bg-white/5 border border-white/10 rounded-lg py-2 px-3 flex items-center gap-3">
                                <div class="bg-primary/20 text-primary font-bold min-w-[28px] h-7 flex items-center justify-center rounded text-sm">${i + 1}</div>
                                <div class="font-bold text-white whitespace-nowrap overflow-hidden text-ellipsis text-sm">${p}</div>
                            </div>
                        `).join('') + '</div>';
                    }
                } else {
                    content.innerHTML = '<div class="text-center py-10 text-error">Could not load participants.</div>';
                }
            } catch (err) {
                content.innerHTML = '<div class="text-center py-10 text-error">Network error. Please try again.</div>';
            }
        };

        window.closeParticipantsModal = function() {
            const modal = document.getElementById('participants-modal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        };

        document.getElementById('participants-modal').addEventListener('click', (e) => {
            if (e.target === e.currentTarget) closeParticipantsModal();
        });
    </script>
</body>
</html>
