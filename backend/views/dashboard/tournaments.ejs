<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blaze Frontier | Tournaments</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/style.css">
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        :root { --accent: #e63946; --accent-glow: rgba(230, 57, 70, 0.4); --gold: #f0a500; }
        body {
            background-color: #06060b; color: #f0eef5; font-family: 'Inter', sans-serif; overflow-x: hidden;
            background-image: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(230, 57, 70, 0.15), transparent 70%);
        }
        .font-display { font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; }
        .font-mono { font-family: 'JetBrains Mono', monospace; }
        .blaze-card {
            background: rgba(22, 22, 34, 0.5); border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 12px; backdrop-filter: blur(12px); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); overflow: hidden;
        }
        .blaze-card:hover { transform: translateY(-5px); border-color: rgba(230, 57, 70, 0.5); box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6), 0 0 20px rgba(230, 57, 70, 0.15); }
        .blaze-btn {
            background: var(--accent); color: #fff; border-radius: 8px; font-weight: 600; letter-spacing: 1px;
            text-transform: uppercase; transition: all 0.3s ease; position: relative; overflow: hidden; box-shadow: 0 4px 15px rgba(230, 57, 70, 0.3);
        }
        .blaze-btn::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent); opacity: 0; transition: opacity 0.3s; }
        .blaze-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(230, 57, 70, 0.5); background: #ff4757; }
        .blaze-btn:hover::before { opacity: 1; }
        .blaze-btn-outline { background: transparent; border: 1px solid rgba(255,255,255,0.1); color: #c4c1d4; border-radius: 8px; transition: all 0.3s ease; }
        .blaze-btn-outline:hover { border-color: rgba(255,255,255,0.3); color: #fff; background: rgba(255,255,255,0.05); }
        .motion-blur-img { transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1); filter: saturate(1.1) brightness(0.8); transform: scale(1.05); }
        .group:hover .motion-blur-img, .blaze-card:hover .motion-blur-img { transform: scale(1.12); filter: saturate(1.3) brightness(1); }
        .gradient-text { background: linear-gradient(to bottom, #ff3b3f 0%, #d91c1f 40%, #5c0000 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0px 2px 2px rgba(0, 0, 0, 0.8)); }
        .gradient-text-silver { background: linear-gradient(to bottom, #ffffff 0%, #c4c4c4 40%, #666666 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #06060b; }
        ::-webkit-scrollbar-thumb { background: #222235; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #e63946; }
        @keyframes fadeUpIn { 0% { opacity: 0; transform: translateY(40px) scale(0.95); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
        @keyframes modalPop { 0% { opacity: 0; transform: scale(0.9) translateY(20px); } 100% { opacity: 1; transform: scale(1) translateY(0); } }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "bg-0": "#06060b", "bg-1": "#0a0a12", "bg-2": "#0e0e18", "bg-3": "#13131f",
                        "accent": "#e63946", "gold": "#f0a500",
                        "text-100": "#f0eef5", "text-200": "#c4c1d4", "text-300": "#8f8ca6", "text-400": "#5c5a72"
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-bg-0 text-text-100 antialiased selection:bg-accent selection:text-white">
    <%- include('../partials/navbar') %>

    <main class="page-wrap pt-20" style="display:none;">
        <div id="spotlight-container">
            <!-- Dynamic Spotlight Hero injected here by JS -->
        </div>

        <div class="max-w-[1400px] mx-auto px-6 -mt-10 relative z-20 pb-16">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 border-b border-white/10 pb-4 gap-4">
                <h2 class="font-display text-4xl text-white tracking-wide uppercase">AVAILABLE TOURNAMENTS</h2>
                <div class="relative w-full md:w-64" id="t-dropdown">
                    <button class="w-full bg-bg-1/80 border border-accent/30 text-white px-4 py-3 rounded-lg font-mono text-sm tracking-wide flex justify-between items-center backdrop-blur-md hover:border-accent/60 transition-colors" id="t-dropdown-btn">
                        <span id="cd-selected">LIVE NOW</span>
                        <span class="material-symbols-outlined text-[20px]">arrow_drop_down</span>
                    </button>
                    <div class="absolute top-full left-0 w-full mt-2 bg-bg-1 border border-accent/20 rounded-lg overflow-hidden backdrop-blur-xl transform origin-top scale-y-0 opacity-0 transition-all duration-300 z-50 cd-menu shadow-[0_10px_30px_rgba(0,0,0,0.8)]">
                        <div class="px-4 py-3 text-text-300 font-mono text-sm tracking-wide cursor-pointer hover:bg-accent/10 hover:text-accent hover:pl-6 transition-all border-b border-white/5 cd-item active" data-view="live">LIVE NOW</div>
                        <div class="px-4 py-3 text-text-300 font-mono text-sm tracking-wide cursor-pointer hover:bg-accent/10 hover:text-accent hover:pl-6 transition-all border-b border-white/5 cd-item" data-view="upcoming">FUTURE / UPCOMING</div>
                        <div class="px-4 py-3 text-text-300 font-mono text-sm tracking-wide cursor-pointer hover:bg-accent/10 hover:text-accent hover:pl-6 transition-all cd-item" data-view="completed">COMPLETED</div>
                    </div>
                </div>
            </div>

            <div id="t-content">
                <div class="flex justify-center py-20"><div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-accent"></div></div>
            </div>
        </div>

        <!-- Pro Rankings & Battle Pass Promo -->
        <div class="max-w-[1400px] mx-auto px-6 relative z-20 pb-24">
            <div class="flex flex-col md:flex-row gap-6 items-stretch">
                <!-- Pro Rankings -->
                <div class="w-full md:w-1/3 blaze-card p-8 border-t-2 border-t-accent">
                    <h4 class="font-display text-3xl text-white mb-6 uppercase tracking-wider flex items-center gap-3">
                        <span class="material-symbols-outlined text-accent">leaderboard</span> PRO RANKINGS
                    </h4>
                    <div class="space-y-3">
                        <div class="flex items-center gap-4 bg-bg-2/80 p-4 rounded-lg border border-accent/20 hover:border-accent/60 hover:bg-bg-3 transition-all cursor-pointer">
                            <span class="font-display text-3xl text-accent font-bold w-8">1</span>
                            <div class="flex-1">
                                <p class="text-white font-bold text-lg">Viper_99</p>
                                <p class="text-xs text-accent font-mono">2,450 PTS</p>
                            </div>
                            <span class="material-symbols-outlined text-text-400">chevron_right</span>
                        </div>
                        <div class="flex items-center gap-4 bg-bg-1/50 p-4 rounded-lg border border-white/5 hover:border-white/20 transition-all cursor-pointer">
                            <span class="font-display text-3xl text-text-400 font-bold w-8">2</span>
                            <div class="flex-1">
                                <p class="text-text-100 font-semibold text-base">Ghost_Protocol</p>
                                <p class="text-xs text-text-400 font-mono">2,210 PTS</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4 bg-bg-1/50 p-4 rounded-lg border border-white/5 hover:border-white/20 transition-all cursor-pointer">
                            <span class="font-display text-3xl text-text-400 font-bold w-8">3</span>
                            <div class="flex-1">
                                <p class="text-text-100 font-semibold text-base">N7_Slayer</p>
                                <p class="text-xs text-text-400 font-mono">1,980 PTS</p>
                            </div>
                        </div>
                    </div>
                    <button class="w-full mt-6 py-2.5 text-center font-mono text-sm text-text-300 hover:text-white border border-white/10 rounded hover:bg-white/5 transition-colors">
                        VIEW FULL BOARD
                    </button>
                </div>
                
                <!-- Battle Pass Promo -->
                <div class="w-full md:w-2/3 relative overflow-hidden rounded-xl bg-gradient-to-br from-bg-2 to-bg-1 border border-white/10 p-10 flex items-center group">
                    <div class="absolute right-0 top-0 w-1/2 h-full bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-accent/20 via-transparent to-transparent opacity-50 group-hover:opacity-100 transition-opacity duration-700"></div>
                    <div class="absolute right-[-5%] top-[-20%] font-display text-[14rem] text-white/5 leading-none select-none pointer-events-none transform -rotate-6 transition-transform duration-700 group-hover:-rotate-12 group-hover:scale-110">
                        PASS
                    </div>
                    
                    <div class="relative z-10 w-full flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
                        <div class="max-w-md">
                            <div class="inline-block px-3 py-1 bg-white text-bg-0 font-mono font-bold text-xs rounded mb-4 shadow-[0_0_15px_rgba(255,255,255,0.3)]">
                                SEASON 4 EXCLUSIVE
                            </div>
                            <h4 class="font-display text-5xl text-white mb-4 uppercase leading-none tracking-wide">
                                BLAZE ELITE <span class="text-accent">BATTLE PASS</span>
                            </h4>
                            <p class="text-text-300 text-lg mb-0 font-medium">
                                Unlock exclusive tactical skins, custom banners, and priority matchmaking before the season ends.
                            </p>
                        </div>
                        <div class="shrink-0">
                            <button class="px-8 py-4 blaze-btn font-mono text-lg shadow-[0_0_30px_rgba(230,57,70,0.4)]">
                                GET PASS NOW
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Participants Modal -->
    <div id="participants-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); backdrop-filter:blur(15px); z-index:10000; justify-content:center; align-items:center; padding:20px;">
        <div style="background:#13131f; border:1px solid rgba(230,57,70,0.3); border-radius:16px; width:100%; max-width:700px; max-height:85vh; display:flex; flex-direction:column; padding:32px; position:relative; animation:modalPop 0.4s cubic-bezier(0.16, 1, 0.3, 1); box-shadow: 0 30px 60px rgba(0,0,0,0.8), 0 0 40px rgba(230,57,70,0.1);">
            <button onclick="closeParticipantsModal()" class="absolute top-6 right-6 w-10 h-10 rounded-full bg-white/5 border border-white/10 text-white flex items-center justify-center hover:bg-accent transition-colors">&times;</button>
            <div class="flex items-center gap-3 mb-6">
                <div class="w-10 h-1 bg-accent rounded-full"></div>
                <h2 id="p-modal-title" class="m-0 font-display text-3xl tracking-wide text-white uppercase">PARTICIPANTS</h2>
            </div>
            <div id="p-modal-content" style="flex: 1; overflow-y: auto; padding-right: 8px;">
                <div class="flex justify-center py-10"><div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-accent"></div></div>
            </div>
        </div>
    </div>

    <script src="/script.js?v=1.2"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('blaze_token');
            if (!token) { window.location.href = '/auth'; return; }

            const applyUserStatus = (prof) => {
                if (!prof.isGenuine) {
                    const modal = document.getElementById('tournaments-lock-modal');
                    if (modal) {
                        modal.style.display = 'flex';
                        const btn = modal.querySelector('button');
                        if(btn) btn.onclick = () => { window.location.href = '/dashboard'; };
                    } else {
                        window.location.href = '/dashboard';
                    }
                } else {
                    document.querySelector('.page-wrap').style.display = 'block';
                }
            };

            if (window.globalUserData) {
                applyUserStatus(window.globalUserData);
            } else {
                const fallbackTimeout = setTimeout(() => {
                    document.querySelector('.page-wrap').style.display = 'block';
                }, 1500); 
                window.addEventListener('globalUserDataReady', () => {
                    clearTimeout(fallbackTimeout);
                    if (window.globalUserData) applyUserStatus(window.globalUserData);
                    else document.querySelector('.page-wrap').style.display = 'block';
                });
            }

            const dropdown = document.getElementById('t-dropdown');
            const dropdownBtn = document.getElementById('t-dropdown-btn');
            const dropdownItems = dropdown.querySelectorAll('.cd-item');
            const selectedText = document.getElementById('cd-selected');
            const cdMenu = dropdown.querySelector('.cd-menu');

            dropdownBtn.addEventListener('click', () => {
                if(cdMenu.style.transform === 'scaleY(1)') {
                    cdMenu.style.transform = 'scaleY(0)'; cdMenu.style.opacity = '0';
                } else {
                    cdMenu.style.transform = 'scaleY(1)'; cdMenu.style.opacity = '1';
                }
            });

            document.addEventListener('click', (e) => {
                if (!dropdown.contains(e.target)) {
                    cdMenu.style.transform = 'scaleY(0)'; cdMenu.style.opacity = '0';
                }
            });

            dropdownItems.forEach(item => {
                item.addEventListener('click', () => {
                    dropdownItems.forEach(i => i.classList.remove('active', 'text-accent', 'pl-6'));
                    item.classList.add('active', 'text-accent', 'pl-6');
                    selectedText.innerText = item.innerText;
                    cdMenu.style.transform = 'scaleY(0)'; cdMenu.style.opacity = '0';
                    renderView(item.dataset.view);
                });
            });

            const renderSpotlight = (data) => {
                const container = document.getElementById('spotlight-container');
                let spotlightT = null;
                const pool = [...(data.live || []), ...(data.upcoming || [])];
                
                if (pool.length > 0) {
                    pool.sort((a, b) => {
                        let aTot = 0, bTot = 0;
                        if (a.participants && a.participants.includes('/')) aTot = parseInt(a.participants.split('/')[1]);
                        if (b.participants && b.participants.includes('/')) bTot = parseInt(b.participants.split('/')[1]);
                        return bTot - aTot;
                    });
                    spotlightT = pool[0];
                }

                if (spotlightT) {
                    container.innerHTML = `
                        <section class="relative w-full min-h-[60vh] overflow-hidden flex items-center py-24 mb-16">
                            <div class="absolute inset-0 z-0">
                                <img class="w-full h-full object-cover object-center opacity-30 mix-blend-luminosity" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDlRpS-qC062vwWYVxY3Uv3yZ4aroC8gpFRBDu2YR0Lw1RGTWoPAL6QFijLGjCStaxx15fsprScjZdb_-qtQTcBT7aCXMfdYCt36SWLVFFyqj_C47W2EfwHFc0_WzrznMEdRbmbBn9eQZAAhT35-wTG8m1ovsZAmJM42yWFU2gd6a61EFv1UblAY062XHqEaHiiQHg5s45dd0XJHMIUotIn0UxHKxnElcPqwam2svN-VKIT0JrHmmNw" alt="Hero Background"/>
                                <div class="absolute inset-0 bg-gradient-to-r from-bg-0 via-bg-0/90 to-transparent"></div>
                                <div class="absolute right-0 top-1/4 w-96 h-96 bg-accent rounded-full mix-blend-screen filter blur-[120px] opacity-20 animate-pulse"></div>
                            </div>
                            
                            <div class="relative z-10 max-w-[1400px] mx-auto px-6 w-full">
                                <div class="max-w-3xl">
                                    <div class="inline-flex items-center gap-3 mb-6 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/10">
                                        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
                                        <span class="font-mono text-xs font-bold text-accent tracking-widest uppercase">FEATURED EVENT</span>
                                    </div>
                                    
                                    <h1 class="font-display text-6xl md:text-[5rem] text-white mb-6 uppercase leading-[0.9] drop-shadow-2xl">
                                        ${spotlightT.name.replace(' ', '<br/>')}
                                    </h1>
                                    
                                    <div class="flex flex-wrap items-center gap-6 mb-10 border-l-2 border-accent pl-5">
                                        <div>
                                            <div class="font-mono text-[10px] text-text-400 tracking-widest uppercase">GAME</div>
                                            <div class="font-medium text-text-100">${spotlightT.game}</div>
                                        </div>
                                        <div>
                                            <div class="font-mono text-[10px] text-text-400 tracking-widest uppercase">REWARD POOL</div>
                                            <div class="font-bold text-gold">${spotlightT.prize || 'Elite Standing'}</div>
                                        </div>
                                        <div>
                                            <div class="font-mono text-[10px] text-text-400 tracking-widest uppercase">FORMAT</div>
                                            <div class="font-medium text-text-100">${spotlightT.team || 'Solo'}</div>
                                        </div>
                                    </div>
                                    
                                    <div class="flex flex-wrap items-center gap-5">
                                        <a href="${spotlightT.canRegister ? \`/dashboard/tournaments/${spotlightT.id || spotlightT._id}/register\` : '/dashboard/leaderboards'}" class="px-8 py-4 blaze-btn font-mono text-base flex items-center gap-3">
                                            ${spotlightT.canRegister ? 'SECURE SLOT' : 'SPECTATE LIVE'}
                                            <span class="material-symbols-outlined text-sm">arrow_forward</span>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </section>
                    `;
                } else {
                    container.innerHTML = `
                        <section class="relative w-full min-h-[50vh] overflow-hidden flex items-center py-24 mb-16">
                            <div class="relative z-10 max-w-[1400px] mx-auto px-6 w-full text-center">
                                <div class="inline-flex items-center gap-3 mb-6 px-4 py-1.5 rounded-full border border-gold/30 bg-gold/10">
                                    <span class="font-mono text-xs font-bold text-gold tracking-widest uppercase">ELITE ACCESS</span>
                                </div>
                                <h1 class="font-display text-5xl text-white mb-6 uppercase tracking-wide drop-shadow-2xl">TRUSTED TOURNAMENTS</h1>
                                <p class="text-lg text-text-300 max-w-2xl mx-auto">Exclusive high-stakes series and tournaments reserved for verified genuine players. Prove your worth in the highest tiers of Blaze Frontier.</p>
                            </div>
                        </section>
                    `;
                }
            };

            const loadTournaments = async () => {
                const container = document.getElementById('t-content');
                try {
                    const res = await fetch('/api/tournaments', { headers: { 'x-auth-token': token } });
                    if (res.ok) {
                        window.tournamentData = await res.json();
                        renderSpotlight(window.tournamentData);
                        renderView('live');
                    } else throw new Error('Failed to fetch');
                } catch (e) {
                    container.innerHTML = '<div class="text-center py-20 text-text-400 font-mono">Unable to load tournaments at this time.</div>';
                }
            };

            window.renderView = (view) => {
                const container = document.getElementById('t-content');
                if (!window.tournamentData) return;
                
                const list = window.tournamentData[view];
                let html = '';

                if (view === 'live') {
                    if (!list || list.length === 0) {
                        html = '<div class="text-center py-20 text-text-400 font-mono">No live elite tournaments at the moment.</div>';
                    } else {
                        html = '<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">' + list.map((t, index) => `
                            <div class="relative h-[420px] blaze-card flex flex-col justify-end p-8 cursor-pointer group" style="animation: fadeUpIn 0.6s ease forwards; animation-delay: ${index * 0.1}s; opacity: 0;">
                                <div class="absolute inset-0 z-0 overflow-hidden">
                                    <img class="w-full h-full object-cover object-center motion-blur-img opacity-50" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCp0T-wxpyfI26kRykEmZGI52t7KWalgXs59G7cWnbe5iTPmxzdVz17gjhzl1rVjbqwuWM7v_ATKzo8svPmGnoiRUP7MRjweVX6l_7odJVdlBIZBp_DEFatNuP9e-vSkghQhNcV5wf7QW8stSsQF6yXLANFB7nijL6tlekxDkF5aWuZxvW3yQam9Oln0-i9PnghJVhVHuCKcO8JoYmzUNpJf4aPigymcVuWUzak1Tk9yAzTSP-dq6Ky" alt="Live Match" />
                                    <div class="absolute inset-0 bg-gradient-to-t from-bg-0 via-bg-0/60 to-transparent"></div>
                                </div>
                                <div class="relative z-10 w-full">
                                    <div class="flex justify-between items-start mb-4">
                                        <span class="bg-accent text-white px-3 py-1 font-mono text-xs font-bold rounded shadow-[0_0_15px_rgba(230,57,70,0.5)]">LIVE NOW</span>
                                        <span class="font-mono text-sm text-text-300 font-bold uppercase tracking-widest">${t.game}</span>
                                    </div>
                                    <h3 class="font-display text-4xl text-white mb-4 uppercase tracking-wide leading-none">${t.name}</h3>
                                    
                                    <div class="flex items-center gap-4 mb-4 text-xs font-mono text-text-300">
                                        <span>P: <span class="text-white">${t.participants}</span></span>
                                        <span>F: <span class="text-white">${t.team || 'Solo'}</span></span>
                                        <span>R: <span class="text-gold">${t.prize || 'Elite'}</span></span>
                                    </div>
                                    
                                    <div class="flex items-center justify-between border-t border-white/10 pt-5 mt-auto gap-3">
                                        <a href="/dashboard/leaderboards" class="flex-1 text-center py-2.5 bg-white text-bg-0 hover:bg-text-200 rounded font-mono font-bold text-sm transition-colors flex items-center justify-center gap-2">
                                            SPECTATE
                                        </a>
                                        ${t.isListPublished ? `<button onclick="viewParticipants('${t.id || t._id}', '${t.name.replace(/'/g, "\\'")}')" class="flex-1 text-center py-2.5 blaze-btn-outline font-mono font-bold text-sm relative z-20">ROSTER</button>` : ''}
                                    </div>
                                </div>
                            </div>
                        `).join('') + '</div>';
                    }
                } else if (view === 'upcoming') {
                    if (!list || list.length === 0) {
                        html = '<div class="text-center py-20 text-text-400 font-mono">No upcoming elite tournaments scheduled. Check back soon.</div>';
                    } else {
                        html = '<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">' + list.map((t, index) => `
                            <div class="relative h-[420px] blaze-card flex flex-col justify-end p-8 cursor-pointer group" style="animation: fadeUpIn 0.6s ease forwards; animation-delay: ${index * 0.1}s; opacity: 0;">
                                <div class="absolute inset-0 z-0 overflow-hidden">
                                    <img class="w-full h-full object-cover object-left motion-blur-img opacity-40" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDlEqRxv13oTOeCqd3yqm4y7DXMTpEv6mvwlnPU9Q3LMZMsxeVVikZ8JSRHEZlpeaE0HyaxaHbGCVRVtis5_c_WeTndUvTuJ5smUnpUW0D5QK7mG4kNnDVX9N-0vXnPOVqkD9g72mkjAV0larpbRGppyGzDWWKMd8d6OkFtQtZEqtiufVLa6iNDEufJqNWVwad3dhSfIlbpTJU9xdg0KABgP5eVZ-7MAkDCH158VIuBK3vOu-JphQKS" alt="Upcoming Match"/>
                                    <div class="absolute inset-0 bg-gradient-to-t from-bg-0 via-bg-0/60 to-transparent"></div>
                                </div>
                                <div class="relative z-10 w-full">
                                    <div class="flex justify-between items-start mb-4">
                                        <span class="bg-white text-bg-0 px-3 py-1 font-mono text-xs font-bold rounded">UPCOMING</span>
                                        <span class="font-mono text-sm text-text-300 font-bold uppercase tracking-widest">${t.game}</span>
                                    </div>
                                    <h3 class="font-display text-3xl text-white mb-2 uppercase tracking-wide leading-tight">${t.name}</h3>
                                    
                                    <div class="flex flex-col gap-1 mb-6 text-xs font-mono text-text-300">
                                        <div class="flex justify-between"><span>Date:</span> <span class="text-white">${t.date}</span></div>
                                        <div class="flex justify-between"><span>Time:</span> <span class="text-white">${t.timeSlot || 'TBA'}</span></div>
                                        <div class="flex justify-between"><span>Format:</span> <span class="text-white">${t.team || 'Solo'}</span></div>
                                        <div class="flex justify-between"><span>Reward:</span> <span class="text-gold">${t.prize || 'Elite'}</span></div>
                                    </div>
                                    
                                    <div class="flex items-center gap-3 mt-auto">
                                        ${t.canRegister ? `<a href="/dashboard/tournaments/${t.id || t._id}/register" class="flex-1 text-center py-3 blaze-btn font-mono text-sm relative z-20">SECURE SLOT</a>` : ''}
                                        ${t.isListPublished ? `<button onclick="viewParticipants('${t.id || t._id}', '${t.name.replace(/'/g, "\\'")}')" class="flex-1 text-center py-3 blaze-btn-outline font-mono text-sm relative z-20">ROSTER</button>` : ''}
                                    </div>
                                </div>
                            </div>
                        `).join('') + '</div>';
                    }
                } else if (view === 'completed') {
                    if (!list || list.length === 0) {
                        html = '<div class="text-center py-20 text-text-400 font-mono">No completed matches available yet.</div>';
                    } else {
                        html = '<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">' + list.map((t, index) => `
                            <div class="relative h-[300px] blaze-card flex flex-col justify-end p-8 border-white/10 bg-bg-1/80 grayscale-[50%]" style="animation: fadeUpIn 0.6s ease forwards; animation-delay: ${index * 0.1}s; opacity: 0;">
                                <div class="relative z-10 w-full">
                                    <div class="flex justify-between items-start mb-4">
                                        <span class="bg-bg-3 text-text-300 border border-white/10 px-3 py-1 font-mono text-xs font-bold rounded">COMPLETED</span>
                                        <span class="font-mono text-sm text-text-400 font-bold uppercase tracking-widest">${t.game}</span>
                                    </div>
                                    <h3 class="font-display text-2xl text-text-100 mb-2 uppercase tracking-wide leading-tight">${t.name}</h3>
                                    <p class="font-mono text-xs text-text-400 mb-6 tracking-widest">${t.date}</p>
                                    
                                    <a href="/dashboard/leaderboards" class="block w-full text-center py-3 blaze-btn-outline font-mono text-sm">VIEW RESULTS</a>
                                </div>
                            </div>
                        `).join('') + '</div>';
                    }
                }
                container.innerHTML = html;
            };

            await loadTournaments();
        });

        async function viewParticipants(id, name) {
            document.getElementById('p-modal-title').textContent = name.toUpperCase();
            document.getElementById('participants-modal').style.display = 'flex';
            const content = document.getElementById('p-modal-content');
            content.innerHTML = '<div class="flex justify-center py-10"><div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-accent"></div></div>';

            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch(`/api/tournaments/${id}/participants`, { headers: { 'x-auth-token': token } });
                if (res.ok) {
                    const participants = await res.json();
                    if (participants.length === 0) {
                        content.innerHTML = '<div class="text-center py-10 text-text-400 font-mono">Roster is currently empty.</div>';
                    } else {
                        content.innerHTML = '<div class="grid grid-cols-2 md:grid-cols-3 gap-4">' + participants.map((p, i) => `
                            <div class="p-4 bg-white/5 border border-white/10 rounded-lg flex items-center gap-4 transition-all hover:bg-accent/10 hover:border-accent/30 hover:-translate-y-1">
                                <div class="font-mono text-accent font-bold bg-accent/20 w-8 h-8 flex items-center justify-center rounded">${i + 1}</div>
                                <div class="font-display text-white tracking-wide text-lg truncate" title="${p}">${p}</div>
                            </div>
                        `).join('') + '</div>';
                    }
                } else {
                    content.innerHTML = '<div class="text-center py-10 text-accent font-mono">Could not load participants.</div>';
                }
            } catch (e) {
                content.innerHTML = '<div class="text-center py-10 text-accent font-mono">Network error. Please try again.</div>';
            }
        }

        function closeParticipantsModal() {
            document.getElementById('participants-modal').style.display = 'none';
        }
    </script>
</body>
</html>
