<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elite Tournaments | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600;800&display=block" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        :root {
            --elite-gold: #FFD700;
            --elite-gold-glow: rgba(255, 215, 0, 0.4);
            --elite-gold-dim: rgba(255, 215, 0, 0.1);
            --elite-bg: #09090b;
            --elite-card: rgba(20, 20, 24, 0.8);
            --elite-border: rgba(255, 255, 255, 0.08);
        }

        body {
            background-color: var(--elite-bg);
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(255, 215, 0, 0.03), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(255, 87, 34, 0.04), transparent 25%);
            color: #fff;
        }

        .page-wrap { max-width: 1200px; margin: 0 auto; padding: 100px 24px 80px; display: none; }

        /* ELITE HERO SECTION */
        .elite-hero {
            position: relative;
            padding: 60px 40px;
            border-radius: 24px;
            background: linear-gradient(135deg, rgba(20, 20, 25, 0.9) 0%, rgba(10, 10, 12, 0.95) 100%);
            border: 1px solid var(--elite-border);
            overflow: hidden;
            margin-bottom: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: flex-start;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            animation: slideDownFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .elite-hero::before {
            content: ''; position: absolute; inset: 0;
            background: url('https://www.transparenttextures.com/patterns/cubes.png');
            opacity: 0.03; mix-blend-mode: overlay; pointer-events: none;
        }
        .elite-glow {
            position: absolute; width: 400px; height: 400px;
            background: radial-gradient(circle, var(--elite-gold-dim) 0%, transparent 70%);
            top: -200px; right: -100px; border-radius: 50%;
            pointer-events: none;
        }
        .elite-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(255, 215, 0, 0.15);
            border: 1px solid rgba(255, 215, 0, 0.3);
            color: var(--elite-gold);
            padding: 6px 16px; border-radius: 30px;
            font-family: var(--font-mono); font-size: 0.8rem; font-weight: 800; letter-spacing: 2px;
            margin-bottom: 20px;
            box-shadow: 0 0 20px var(--elite-gold-glow);
        }
        .elite-title {
            font-family: var(--font-display);
            font-size: 4.5rem;
            line-height: 1;
            margin: 0 0 16px 0;
            background: linear-gradient(180deg, #FFFFFF 0%, #A0A0A0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 2px;
            text-transform: uppercase;
        }
        .elite-title span {
            background: linear-gradient(180deg, #FFE259 0%, #FFA751 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .elite-desc {
            font-size: 1.1rem; color: #a1a1aa; max-width: 600px; line-height: 1.6; margin: 0;
        }

        /* ELITE TABS */
        .elite-tabs-wrapper { display: flex; justify-content: center; margin-bottom: 40px; }
        .elite-tabs {
            display: inline-flex; background: rgba(0,0,0,0.4);
            padding: 6px; border-radius: 12px;
            border: 1px solid var(--elite-border);
            position: relative;
            backdrop-filter: blur(10px);
        }
        .elite-tab {
            position: relative; z-index: 1;
            padding: 12px 32px; border: none; background: transparent;
            font-family: var(--font-display); font-size: 1.2rem; letter-spacing: 2px;
            color: #71717a; cursor: pointer; transition: all 0.3s;
            display: flex; align-items: center; gap: 8px;
            border-radius: 8px;
        }
        .elite-tab:hover { color: #fff; }
        .elite-tab.active { color: #fff; }
        .elite-tab.active::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(90deg, rgba(255, 215, 0, 0.1), rgba(255, 87, 34, 0.1));
            border-bottom: 2px solid var(--elite-gold);
            border-radius: 8px; z-index: -1;
            animation: fadeIn 0.3s forwards;
        }

        .pulse-dot {
            width: 8px; height: 8px; background: #22c55e; border-radius: 50%;
            box-shadow: 0 0 10px #22c55e;
            animation: pulse 1.5s infinite;
        }

        /* ELITE GRID & CARDS */
        .t-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 24px; perspective: 1000px; }
        
        .elite-card {
            position: relative; background: var(--elite-card);
            border: 1px solid var(--elite-border);
            border-radius: 16px; padding: 28px;
            backdrop-filter: blur(20px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            overflow: hidden;
            display: flex; flex-direction: column;
            animation: fadeUpIn 0.6s backwards;
        }
        .elite-card::after {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255, 215, 0, 0.06), transparent 40%);
            opacity: 0; transition: opacity 0.3s; pointer-events: none;
        }
        .elite-card:hover { 
            transform: translateY(-8px) scale(1.02); 
            border-color: rgba(255, 215, 0, 0.3);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6), 0 0 20px rgba(255, 215, 0, 0.05);
        }
        .elite-card:hover::after { opacity: 1; }

        .ec-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
        .ec-game { font-family: var(--font-mono); font-size: 0.75rem; font-weight: 800; color: var(--elite-gold); letter-spacing: 2px; background: rgba(255,215,0,0.1); padding: 4px 10px; border-radius: 4px; border: 1px solid rgba(255,215,0,0.2); }
        .ec-status { font-family: var(--font-display); font-size: 1rem; letter-spacing: 1.5px; padding: 4px 12px; border-radius: 20px; }
        .ec-status.live { background: rgba(34,197,94,0.1); color: #22c55e; border: 1px solid rgba(34,197,94,0.3); }
        .ec-status.upcoming { background: rgba(255,165,0,0.1); color: #ffa500; border: 1px solid rgba(255,165,0,0.3); }
        .ec-status.completed { background: rgba(161,161,170,0.1); color: #a1a1aa; border: 1px solid rgba(161,161,170,0.3); }
        
        .ec-title { font-family: var(--font-display); font-size: 2rem; color: #fff; margin: 0 0 24px 0; line-height: 1.1; letter-spacing: 1px; }

        .ec-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
        .ec-stat { background: rgba(0,0,0,0.3); padding: 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.03); }
        .ec-stat-label { font-size: 0.7rem; color: #71717a; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; display: block; }
        .ec-stat-val { font-family: var(--font-mono); color: #fff; font-size: 1.1rem; font-weight: 600; }

        .ec-prize { background: linear-gradient(90deg, rgba(255,215,0,0.05), transparent); border-left: 3px solid var(--elite-gold); padding: 12px 16px; margin-bottom: 24px; border-radius: 0 8px 8px 0; }
        .ec-prize-label { font-size: 0.7rem; color: var(--elite-gold); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; font-weight: bold; }
        .ec-prize-val { color: #fff; font-size: 0.95rem; }

        .ec-cred { background: rgba(0, 188, 212, 0.1); border: 1px solid rgba(0, 188, 212, 0.3); padding: 16px; border-radius: 8px; margin-bottom: 24px; text-align: center; }
        .ec-cred-title { font-size: 0.75rem; color: #00bcd4; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px; font-weight: bold; }
        .ec-cred-val { color: #fff; font-family: var(--font-mono); font-size: 1.1rem; font-weight: bold; letter-spacing: 1px; }

        .ec-btn-primary { 
            display: block; width: 100%; text-align: center; background: linear-gradient(90deg, #FFD700, #FFA500); 
            color: #000; font-family: var(--font-display); font-size: 1.2rem; letter-spacing: 2px; 
            padding: 14px; border-radius: 8px; text-decoration: none; border: none; cursor: pointer;
            transition: all 0.3s; font-weight: bold; box-shadow: 0 4px 15px rgba(255,215,0,0.2);
            margin-top: auto;
        }
        .ec-btn-primary:hover { box-shadow: 0 6px 25px rgba(255,215,0,0.4); transform: translateY(-2px); }

        .ec-btn-secondary {
            display: block; width: 100%; text-align: center; background: transparent; 
            color: #fff; font-family: var(--font-display); font-size: 1.1rem; letter-spacing: 1px; 
            padding: 14px; border-radius: 8px; text-decoration: none; border: 1px solid rgba(255,255,255,0.2); cursor: pointer;
            transition: all 0.3s; margin-top: auto;
        }
        .ec-btn-secondary:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.4); }

        .ec-btn-green {
            display: block; width: 100%; text-align: center; background: rgba(34, 197, 94, 0.1); 
            color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3);
            font-family: var(--font-display); font-size: 1.2rem; letter-spacing: 2px; 
            padding: 14px; border-radius: 8px; text-decoration: none; cursor: pointer;
            transition: all 0.3s; margin-top: auto;
        }
        .ec-btn-green:hover { background: rgba(34, 197, 94, 0.2); transform: translateY(-2px); }

        .empty-state { text-align: center; padding: 100px 0; color: #71717a; font-size: 1.1rem; }
        
        .spinner-ring {
            display: inline-block; width: 32px; height: 32px;
            border: 3px solid rgba(255,215,0,0.1); border-top-color: var(--elite-gold);
            border-radius: 50%; animation: spin 0.8s cubic-bezier(0.5, 0, 0.5, 1) infinite;
        }
        
        /* FEATURED SPOTLIGHT STYLES */
        .spotlight-card {
            background: linear-gradient(135deg, rgba(255,87,34,0.1) 0%, rgba(10,10,12,0.95) 100%);
            border: 1px solid rgba(255,87,34,0.3);
            border-radius: 20px;
            padding: 40px;
            margin-bottom: 40px;
            display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 10px 40px rgba(255,87,34,0.15);
        }
        .spotlight-info h2 { font-family: var(--font-display); font-size: 3rem; color: #fff; margin: 0 0 10px; letter-spacing: 1px; }
        .spotlight-info p { font-size: 1.1rem; color: rgba(255,255,255,0.7); max-width: 500px; line-height: 1.6; }
        
        /* NEW HALL OF FAME STYLES */
        .hof-section { margin-top: 60px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 60px; }
        .hof-header { text-align: center; margin-bottom: 40px; }
        .hof-header h2 { font-family: var(--font-display); font-size: 3rem; color: #fff; letter-spacing: 2px; margin: 0; }
        .hof-header p { color: var(--elite-gold); font-family: var(--font-mono); font-size: 0.9rem; letter-spacing: 3px; font-weight: bold; }
        
        .hof-grid { 
            display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1000px; margin: 0 auto; 
        }
        .hof-card {
            background: rgba(15,15,20,0.8);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 16px;
            padding: 30px;
            text-align: center;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(10px);
            transition: transform 0.3s;
        }
        .hof-card:hover { transform: translateY(-5px); }
        .hof-card.rank-1 { border: 1px solid rgba(255,215,0,0.4); box-shadow: 0 10px 40px rgba(255,215,0,0.1); background: linear-gradient(180deg, rgba(255,215,0,0.05) 0%, rgba(15,15,20,0.9) 100%); }
        .hof-card.rank-2 { border: 1px solid rgba(192,192,192,0.4); background: linear-gradient(180deg, rgba(192,192,192,0.05) 0%, rgba(15,15,20,0.9) 100%); }
        .hof-card.rank-3 { border: 1px solid rgba(205,127,50,0.4); background: linear-gradient(180deg, rgba(205,127,50,0.05) 0%, rgba(15,15,20,0.9) 100%); }
        
        .hof-rank-num { position: absolute; top: -15px; left: -10px; font-family: var(--font-display); font-size: 5rem; opacity: 0.1; line-height: 1; z-index: 0; }
        .hof-card.rank-1 .hof-rank-num { color: #FFD700; opacity: 0.2; }
        .hof-card.rank-2 .hof-rank-num { color: #C0C0C0; opacity: 0.2; }
        .hof-card.rank-3 .hof-rank-num { color: #CD7F32; opacity: 0.2; }

        .hof-avatar { width: 80px; height: 80px; border-radius: 50%; border: 3px solid rgba(255,255,255,0.1); margin: 0 auto 20px; position: relative; z-index: 1; }
        .hof-card.rank-1 .hof-avatar { width: 100px; height: 100px; border-color: #FFD700; box-shadow: 0 0 20px rgba(255,215,0,0.4); }
        .hof-card.rank-2 .hof-avatar { border-color: #C0C0C0; box-shadow: 0 0 15px rgba(192,192,192,0.2); }
        .hof-card.rank-3 .hof-avatar { border-color: #CD7F32; box-shadow: 0 0 15px rgba(205,127,50,0.2); }

        .hof-name { font-family: var(--font-display); font-size: 1.8rem; color: #fff; margin: 0 0 5px; position: relative; z-index: 1; letter-spacing: 1px; }
        .hof-bp { display: inline-block; background: rgba(255,255,255,0.05); padding: 6px 16px; border-radius: 20px; font-family: var(--font-mono); font-size: 1.1rem; font-weight: bold; position: relative; z-index: 1; }
        .hof-card.rank-1 .hof-bp { background: rgba(255,215,0,0.1); color: #FFD700; border: 1px solid rgba(255,215,0,0.2); }
        .hof-card.rank-2 .hof-bp { background: rgba(192,192,192,0.1); color: #C0C0C0; border: 1px solid rgba(192,192,192,0.2); }
        .hof-card.rank-3 .hof-bp { background: rgba(205,127,50,0.1); color: #CD7F32; border: 1px solid rgba(205,127,50,0.2); }

        /* Animations */
        @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(34,197,94,0.4); } 70% { box-shadow: 0 0 0 10px rgba(34,197,94,0); } 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0); } }
        @keyframes spin { to { transform: rotate(360deg); } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes fadeUpIn { 0% { opacity: 0; transform: translateY(40px) scale(0.95); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
        @keyframes slideDownFade { 0% { opacity: 0; transform: translateY(-30px); } 100% { opacity: 1; transform: translateY(0); } }
        @keyframes modalPop { 0% { opacity: 0; transform: scale(0.9) translateY(20px); } 100% { opacity: 1; transform: scale(1) translateY(0); } }

        @media (max-width: 768px) {
            .elite-title { font-size: 3rem; }
            .elite-hero { padding: 40px 24px; text-align: center; align-items: center; }
            .t-grid { grid-template-columns: 1fr; }
            
            .spotlight-card { flex-direction: column; text-align: center; padding: 24px; }
            .spotlight-info h2 { font-size: 2.2rem; }
            .spotlight-card .ec-btn-primary { margin-top: 24px; }
            
            .hof-grid { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 20px; margin: 0 -24px; padding: 0 24px 24px; -webkit-overflow-scrolling: touch; }
            .hof-card { min-width: 280px; scroll-snap-align: center; }
            /* Hide scrollbar for clean look */
            .hof-grid::-webkit-scrollbar { display: none; }
            .hof-grid { -ms-overflow-style: none; scrollbar-width: none; }
        }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="page-wrap">
        <div class="elite-hero">
            <div class="elite-glow"></div>
            <div class="elite-badge">💎 ELITE ACCESS</div>
            <h1 class="elite-title">TRUSTED <span>TOURNAMENTS</span></h1>
            <p class="elite-desc">Exclusive high-stakes series and tournaments reserved for verified genuine players. Prove your worth in the highest tiers of Blaze Frontier.</p>
        </div>

        <div id="spotlight-container"></div>

        <div class="elite-tabs-wrapper">
            <div class="elite-tabs" id="view-tabs">
                <button class="elite-tab active" data-view="live">
                    <span class="pulse-dot"></span> LIVE NOW
                </button>
                <button class="elite-tab" data-view="upcoming">
                    UPCOMING
                </button>
                <button class="elite-tab" data-view="completed">
                    COMPLETED
                </button>
            </div>
        </div>

        <div class="t-grid" id="t-content">
            <div style="text-align:center;padding:100px;grid-column: 1/-1;"><div class="spinner-ring"></div></div>
        </div>
        
        <div class="hof-section">
            <div class="hof-header">
                <h2>HALL OF FAME</h2>
                <p>THE ELITE GLOBAL RANKINGS</p>
            </div>
            <div class="hof-grid" id="hof-container">
                <div style="text-align:center;padding:50px;grid-column: 1/-1;"><div class="spinner-ring"></div></div>
            </div>
        </div>
    </div>

    <!-- Participants Modal -->
    <div id="participants-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); backdrop-filter:blur(15px); z-index:10000; justify-content:center; align-items:center; padding:20px;">
        <div style="background:#111116; border:1px solid var(--elite-gold-glow); border-radius:16px; width:100%; max-width:700px; max-height:85vh; display:flex; flex-direction:column; padding:32px; position:relative; animation:modalPop 0.4s cubic-bezier(0.16, 1, 0.3, 1); box-shadow: 0 30px 60px rgba(0,0,0,0.8), 0 0 40px rgba(255,215,0,0.1);">
            <button onclick="closeParticipantsModal()" style="position:absolute; top:24px; right:24px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); width:40px; height:40px; border-radius:50%; color:#fff; font-size:1.5rem; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.2s;">&times;</button>
            
            <div style="display:flex; align-items:center; gap:12px; margin-bottom: 24px;">
                <div style="width:40px; height:4px; background:var(--elite-gold); border-radius:2px;"></div>
                <h2 id="p-modal-title" style="margin:0; font-family:var(--font-display); font-size:2rem; letter-spacing:1px; color:#fff;">PARTICIPANTS</h2>
            </div>
            
            <div id="p-modal-content" style="flex: 1; overflow-y: auto; padding-right: 8px;">
                <div style="text-align:center; padding:40px;"><div class="spinner-ring"></div></div>
            </div>
        </div>
    </div>

    <script src="/script.js?v=1.2"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('blaze_token');
            if (!token) { window.location.href = '/auth'; return; }

            const applyUserStatus = (prof) => {
                if (!prof.isGenuine) {
                    const modal = document.getElementById('tournaments-lock-modal');
                    if (modal) {
                        modal.style.display = 'flex';
                        const btn = modal.querySelector('button');
                        if(btn) btn.onclick = () => { window.location.href = '/dashboard'; };
                    } else {
                        window.location.href = '/dashboard';
                    }
                } else {
                    document.querySelector('.page-wrap').style.display = 'block';
                }
            };

            if (window.globalUserData) {
                applyUserStatus(window.globalUserData);
            } else {
                window.addEventListener('globalUserDataReady', () => {
                    if (window.globalUserData) applyUserStatus(window.globalUserData);
                });
            }

            let view = 'live'; // live, upcoming, completed
            
            // Tab switching
            document.querySelectorAll('.elite-tab').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    document.querySelectorAll('.elite-tab').forEach(b => {
                        b.classList.remove('active');
                        const pd = b.querySelector('.pulse-dot');
                        if(pd) pd.remove();
                    });
                    const target = e.currentTarget;
                    target.classList.add('active');
                    if(target.dataset.view === 'live') {
                        target.innerHTML = '<span class="pulse-dot"></span> LIVE NOW';
                    }
                    view = target.dataset.view;
                    loadTournaments();
                });
            });

            const renderSpotlight = (data) => {
                const container = document.getElementById('spotlight-container');
                // The most highly registered UPCOMING tournament
                let spotlightT = null;
                if (data.upcoming && data.upcoming.length > 0) {
                    spotlightT = data.upcoming.reduce((prev, curr) => (curr.registered > prev.registered) ? curr : prev, data.upcoming[0]);
                } else if (data.live && data.live.length > 0) {
                    spotlightT = data.live[0];
                }

                if (spotlightT) {
                    container.innerHTML = \`
                        <div class="spotlight-card">
                            <div class="spotlight-info">
                                <div style="display:inline-block; background:rgba(255,87,34,0.1); color:#ff5722; font-family:var(--font-mono); font-size:0.8rem; font-weight:bold; letter-spacing:2px; padding:4px 12px; border-radius:20px; border:1px solid rgba(255,87,34,0.3); margin-bottom:12px;">FEATURED EVENT</div>
                                <h2>\${spotlightT.name.toUpperCase()}</h2>
                                <p>Join the most anticipated battle in Blaze Frontier. Limited slots remaining. Register now and secure your entry into the elite bracket.</p>
                            </div>
                            <div style="min-width: 200px;">
                                <a href="/dashboard/tournaments/register" class="ec-btn-primary" style="background: linear-gradient(90deg, #ff5722, #ff9800); color: #fff;">REGISTER NOW</a>
                            </div>
                        </div>
                    \`;
                } else {
                    container.innerHTML = '';
                }
            };

            const loadTournaments = async () => {
                const container = document.getElementById('t-content');
                container.innerHTML = '<div style="text-align:center;padding:100px;grid-column: 1/-1;"><div class="spinner-ring"></div></div>';
                try {
                    const res = await fetch('/api/tournaments?game=freefire', { headers: { 'x-auth-token': token } });
                    if (!res.ok) throw new Error('Failed');
                    const data = await res.json();
                    
                    if(view === 'live') renderSpotlight(data);
                    else document.getElementById('spotlight-container').innerHTML = '';

                    let list = [];
                    if(view === 'live') list = data.live || [];
                    else if(view === 'upcoming') list = data.upcoming || [];
                    else list = data.completed || [];
                    
                    if (list.length === 0) {
                        container.innerHTML = \`<div class="empty-state" style="grid-column: 1/-1;">No \${view} tournaments found.</div>\`;
                        return;
                    }

                    let html = '';
                    list.forEach((t, i) => {
                        let statusHtml = '';
                        if (view === 'live') statusHtml = '<span class="ec-status live">LIVE NOW</span>';
                        else if (view === 'upcoming') statusHtml = '<span class="ec-status upcoming">UPCOMING</span>';
                        else statusHtml = '<span class="ec-status completed">COMPLETED</span>';

                        let btnHtml = '';
                        if (view === 'live') {
                            btnHtml = \`<a href="/dashboard/tournaments/register" class="ec-btn-green" style="margin-bottom: 12px;">WATCH STREAM</a>\`;
                        } else if (view === 'upcoming') {
                            btnHtml = \`<a href="/dashboard/tournaments/register" class="ec-btn-primary" style="margin-bottom: 12px;">REGISTER SLOT</a>\`;
                        } else {
                            btnHtml = \`<a href="/dashboard/leaderboards" class="ec-btn-secondary" style="margin-bottom: 12px;">VIEW RESULTS</a>\`;
                        }

                        if (t.isListPublished) {
                            btnHtml += \`<button onclick="viewParticipants('\${t.id || t._id}', '\${t.name.replace(/'/g, "\\\\'")}')" class="ec-btn-secondary" style="margin-bottom: 0;">VIEW ROSTER</button>\`;
                        }

                        html += \`
                        <div class="elite-card" style="animation-delay: \${i * 0.1}s">
                            <div class="ec-header">
                                <span class="ec-game">\${t.game}</span>
                                \${statusHtml}
                            </div>
                            <h3 class="ec-title">\${t.name}</h3>
                            
                            <div class="ec-grid">
                                <div class="ec-stat">
                                    <span class="ec-stat-label">Format</span>
                                    <span class="ec-stat-val">\${t.format}</span>
                                </div>
                                <div class="ec-stat">
                                    <span class="ec-stat-label">Mode</span>
                                    <span class="ec-stat-val">\${t.mode}</span>
                                </div>
                            </div>
                            
                            <div class="ec-prize">
                                <div class="ec-prize-label">Prize Pool</div>
                                <div class="ec-prize-val">\${t.prize}</div>
                            </div>
                            
                            <div class="ec-cred">
                                <div class="ec-cred-title">Schedule</div>
                                <div class="ec-cred-val">\${t.date}</div>
                            </div>
                            
                            \${btnHtml}
                        </div>\`;
                    });

                    container.innerHTML = html;
                } catch(e) {
                    container.innerHTML = '<div class="empty-state" style="grid-column: 1/-1; color:#ef4444;">Could not load tournaments. Please try again later.</div>';
                }
            };

            const loadHallOfFame = async () => {
                const container = document.getElementById('hof-container');
                try {
                    const res = await fetch('/api/leaderboard', { headers: { 'x-auth-token': token } });
                    if (!res.ok) throw new Error('Failed');
                    const lb = await res.json();
                    let top3 = lb.slice(0, 3);

                    if (top3.length === 0) {
                        top3 = [
                            { rank: 1, name: 'Manoj', bp: 15400 },
                            { rank: 2, name: 'Phantom', bp: 12100 },
                            { rank: 3, name: 'Striker', bp: 9800 }
                        ];
                    }
                    while (top3.length < 3) top3.push({ rank: top3.length + 1, name: '???', bp: 0 });

                    const colors = [
                        { rank: 1, class: 'rank-1' },
                        { rank: 2, class: 'rank-2' },
                        { rank: 3, class: 'rank-3' }
                    ];

                    let html = '';
                    top3.forEach((p, i) => {
                        const avatarUrl = \`https://ui-avatars.com/api/?name=\${encodeURIComponent(p.name)}&background=111116&color=fff&size=128&bold=true\`;
                        html += \`
                        <div class="hof-card \${colors[i].class}">
                            <div class="hof-rank-num">#\${p.rank}</div>
                            <img src="\${avatarUrl}" class="hof-avatar" alt="\${p.name}">
                            <h4 class="hof-name">\${p.name}</h4>
                            <div class="hof-bp">\${p.bp.toLocaleString()} BP</div>
                        </div>\`;
                    });
                    container.innerHTML = html;
                } catch (e) {
                    container.innerHTML = '<div style="grid-column:1/-1;text-align:center;color:#ef4444;font-family:var(--font-mono);">Could not load Hall of Fame rankings.</div>';
                }
            };

            await loadTournaments();
            await loadHallOfFame();
        });

        async function viewParticipants(id, name) {
            document.getElementById('p-modal-title').textContent = name.toUpperCase();
            document.getElementById('participants-modal').style.display = 'flex';
            const content = document.getElementById('p-modal-content');
            content.innerHTML = '<div style="text-align:center; padding:40px;"><div class="spinner-ring"></div></div>';

            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch(\`/api/tournaments/\${id}/participants\`, { headers: { 'x-auth-token': token } });
                if (res.ok) {
                    const participants = await res.json();
                    if (participants.length === 0) {
                        content.innerHTML = '<div style="text-align:center; padding:40px; color:#71717a; font-family:var(--font-mono);">Roster is currently empty.</div>';
                    } else {
                        content.innerHTML = '<div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(200px, 1fr)); gap:16px;">' + participants.map((p, i) => \`
                            <div style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:8px; padding:12px 16px; display:flex; align-items:center; gap:12px;">
                                <div style="background:rgba(255,215,0,0.1); color:var(--elite-gold); font-family:var(--font-mono); font-weight:bold; width:30px; height:30px; display:flex; align-items:center; justify-content:center; border-radius:4px;">\${i + 1}</div>
                                <div style="font-family:var(--font-display); font-size:1.1rem; color:#fff; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">\${p}</div>
                            </div>
                        \`).join('') + '</div>';
                    }
                } else {
                    content.innerHTML = '<div style="text-align:center; padding:40px; color:#ef4444; font-family:var(--font-mono);">Could not load participants.</div>';
                }
            } catch (e) {
                content.innerHTML = '<div style="text-align:center; padding:40px; color:#ef4444; font-family:var(--font-mono);">Network error. Please try again.</div>';
            }
        }

        function closeParticipantsModal() {
            document.getElementById('participants-modal').style.display = 'none';
        }
    </script>
</body>
</html>
