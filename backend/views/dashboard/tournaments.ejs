<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elite Tournaments | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600;800&display=block" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        :root {
            --elite-gold: #FFD700;
            --elite-gold-glow: rgba(255, 215, 0, 0.4);
            --elite-gold-dim: rgba(255, 215, 0, 0.1);
            --elite-bg: #09090b;
            --elite-card: rgba(20, 20, 24, 0.8);
            --elite-border: rgba(255, 255, 255, 0.08);
        }

        body {
            background-color: var(--elite-bg);
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(255, 215, 0, 0.03), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(255, 87, 34, 0.04), transparent 25%);
            color: #fff;
        }
        .page-wrap { max-width: 1200px; margin: 0 auto; padding: 100px 24px 80px; }
        /* GLOSSY SPOTLIGHT HERO */
        .spotlight-hero {
            position: relative; overflow: hidden; padding: 60px 50px; 
            background: linear-gradient(135deg, rgba(20,20,25,0.8) 0%, rgba(5,5,5,0.95) 100%);
            border: 1px solid rgba(255, 215, 0, 0.3);
            border-radius: 24px; margin-bottom: 50px;
            box-shadow: 0 40px 80px rgba(0,0,0,0.9), inset 0 2px 20px rgba(255, 215, 0, 0.15);
            display: flex; flex-direction: column; justify-content: center;
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            animation: slideDownFade 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            transform-style: preserve-3d;
            perspective: 1000px;
        }

        .spotlight-hero::before {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle at center, rgba(255, 215, 0, 0.15) 0%, transparent 60%);
            opacity: 0.8; pointer-events: none;
            animation: slowRotate 20s linear infinite;
        }

        .spotlight-hero::after {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(180deg, rgba(255,255,255,0.03) 0%, transparent 100%);
            pointer-events: none;
        }

        .sh-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: linear-gradient(90deg, rgba(255, 215, 0, 0.2), rgba(255, 165, 0, 0.2));
            border: 1px solid rgba(255, 215, 0, 0.4);
            color: var(--elite-gold);
            padding: 6px 16px; border-radius: 30px;
            font-family: var(--font-mono); font-size: 0.8rem; font-weight: 800; letter-spacing: 2px;
            margin-bottom: 20px; width: fit-content;
            box-shadow: 0 0 20px var(--elite-gold-glow);
            text-transform: uppercase;
        }

        .sh-title {
            font-family: var(--font-display);
            font-size: 4.5rem; line-height: 1.1; margin: 0 0 16px 0;
            background: linear-gradient(180deg, #FFFFFF 0%, #FFE259 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            letter-spacing: 2px; text-transform: uppercase;
            text-shadow: 0 10px 30px rgba(255,215,0,0.2);
            position: relative; z-index: 2;
        }

        .sh-meta {
            display: flex; gap: 24px; margin-bottom: 32px; position: relative; z-index: 2;
        }

        .sh-stat {
            background: rgba(0,0,0,0.5); padding: 12px 20px; border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px);
            border-left: 3px solid #ffd700;
        }

        .sh-btn {
            background: linear-gradient(90deg, #FFD700, #FFA500);
            color: #000; font-family: var(--font-display); font-size: 1.5rem; letter-spacing: 2px;
            padding: 16px 40px; border-radius: 12px; text-decoration: none; border: none; cursor: pointer;
            transition: all 0.3s; font-weight: bold; box-shadow: 0 10px 30px rgba(255,215,0,0.4);
            display: inline-block; width: fit-content; position: relative; z-index: 2;
        }
        .sh-btn:hover {
            transform: translateY(-3px) scale(1.05); box-shadow: 0 15px 40px rgba(255,215,0,0.6);
        }

        /* SECTION HEADER & DROPDOWN */
        .tournaments-header {
            display: flex; justify-content: space-between; align-items: flex-end;
            margin-bottom: 32px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 16px;
        }

        .section-title {
            font-family: var(--font-display); font-size: 2.5rem; color: #fff; margin: 0; letter-spacing: 1.5px;
        }

        .custom-dropdown {
            position: relative; width: 220px;
        }
        .cd-btn {
            width: 100%; background: rgba(15,15,20,0.8); border: 1px solid rgba(255,215,0,0.3);
            color: #fff; padding: 14px 20px; border-radius: 12px; font-family: var(--font-display);
            font-size: 1.2rem; letter-spacing: 1px; cursor: pointer; display: flex; justify-content: space-between; align-items: center;
            backdrop-filter: blur(10px); transition: all 0.3s;
        }
        .cd-btn:hover { border-color: rgba(255,215,0,0.6); box-shadow: 0 0 15px rgba(255,215,0,0.2); }
        .cd-menu {
            position: absolute; top: calc(100% + 8px); left: 0; width: 100%;
            background: rgba(15,15,20,0.95); border: 1px solid rgba(255,215,0,0.2);
            border-radius: 12px; overflow: hidden; backdrop-filter: blur(20px);
            transform-origin: top; transform: scaleY(0); opacity: 0; transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: 100;
        }
        .custom-dropdown.open .cd-menu { transform: scaleY(1); opacity: 1; box-shadow: 0 20px 40px rgba(0,0,0,0.8); }
        .cd-item {
            padding: 14px 20px; color: #a1a1aa; font-family: var(--font-display); font-size: 1.1rem; letter-spacing: 1px;
            cursor: pointer; transition: all 0.2s; border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .cd-item:hover, .cd-item.active { background: rgba(255,215,0,0.1); color: #ffd700; padding-left: 28px; }


        .pulse-dot {
            width: 8px; height: 8px; background: #22c55e; border-radius: 50%;
            box-shadow: 0 0 10px #22c55e;
            animation: pulse 1.5s infinite;
        }

        /* ELITE GRID & CARDS (Live Tournaments) */
        .t-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 32px; perspective: 1000px; }
        
        .elite-card {
            position: relative; background: rgba(10, 10, 15, 0.6);
            border: 1px solid rgba(255, 215, 0, 0.15);
            border-radius: 20px; padding: 32px;
            backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px);
            transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
            overflow: hidden; display: flex; flex-direction: column;
            animation: fadeUpIn 0.6s backwards;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
        }
        
        .elite-card::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(180deg, rgba(255,215,0,0.05) 0%, transparent 100%);
            opacity: 0; transition: opacity 0.4s;
        }

        .elite-card::after {
            content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle at center, rgba(255, 215, 0, 0.1) 0%, transparent 50%);
            opacity: 0; transition: opacity 0.4s; pointer-events: none;
            transform: translate(var(--mouse-x, 0), var(--mouse-y, 0));
        }

        .elite-card:hover { 
            transform: translateY(-10px) scale(1.02); 
            border-color: rgba(255, 215, 0, 0.4);
            box-shadow: 0 25px 50px rgba(0,0,0,0.7), 0 0 30px rgba(255, 215, 0, 0.1);
        }
        .elite-card:hover::before, .elite-card:hover::after { opacity: 1; }

        .ec-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; position: relative; z-index: 2; }
        .ec-game { font-family: var(--font-mono); font-size: 0.8rem; font-weight: 800; color: var(--elite-gold); letter-spacing: 2px; text-transform: uppercase; }
        .ec-status { font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 2px; padding: 6px 14px; border-radius: 6px; font-weight: bold; text-transform: uppercase; }
        .ec-status.live { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(74,222,128,0.3); box-shadow: 0 0 15px rgba(34,197,94,0.2); }
        .ec-status.upcoming { background: rgba(255,215,0,0.1); color: #ffd700; border: 1px solid rgba(255,215,0,0.3); }
        .ec-status.completed { background: rgba(161,161,170,0.1); color: #a1a1aa; border: 1px solid rgba(161,161,170,0.3); }
        
        .ec-title { font-family: var(--font-display); font-size: 2.2rem; color: #fff; margin: 0 0 24px 0; line-height: 1.1; letter-spacing: 1px; position: relative; z-index: 2; text-shadow: 0 2px 10px rgba(0,0,0,0.5); }

        /* LUXURY LIST VIEW (Upcoming/Completed) */
        .t-list { display: flex; flex-direction: column; gap: 16px; }
        .elite-list-item {
            background: rgba(15, 15, 20, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-left: 3px solid #ffd700;
            border-radius: 12px; padding: 20px 24px;
            display: flex; align-items: center; justify-content: space-between;
            transition: all 0.3s;
            backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            animation: slideDownFade 0.4s backwards;
        }
        .elite-list-item:hover {
            background: rgba(25, 25, 30, 0.9);
            border-color: rgba(255, 215, 0, 0.3);
            transform: translateX(5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }
        .li-main { flex: 2; }
        .li-meta { flex: 3; display: flex; gap: 32px; align-items: center; }
        .li-actions { flex: 1; text-align: right; }
        .li-title { font-family: var(--font-display); font-size: 1.4rem; color: #fff; margin-bottom: 4px; }
        .li-subtitle { font-family: var(--font-mono); font-size: 0.8rem; color: var(--elite-gold); letter-spacing: 1px; }
        .li-stat { display: flex; flex-direction: column; }
        .li-stat-label { font-size: 0.7rem; color: #71717a; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 2px; }
        .li-stat-val { color: #e4e4e7; font-family: var(--font-mono); font-size: 1rem; font-weight: bold; }


        .ec-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
        .ec-stat { background: rgba(0,0,0,0.3); padding: 12px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.03); }
        .ec-stat-label { font-size: 0.7rem; color: #71717a; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; display: block; }
        .ec-stat-val { font-family: var(--font-mono); color: #fff; font-size: 1.1rem; font-weight: 600; }

        .ec-prize { background: linear-gradient(90deg, rgba(255,215,0,0.05), transparent); border-left: 3px solid var(--elite-gold); padding: 12px 16px; margin-bottom: 24px; border-radius: 0 8px 8px 0; }
        .ec-prize-label { font-size: 0.7rem; color: var(--elite-gold); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; font-weight: bold; }
        .ec-prize-val { color: #fff; font-size: 0.95rem; }

        .ec-cred { background: rgba(0, 188, 212, 0.1); border: 1px solid rgba(0, 188, 212, 0.3); padding: 16px; border-radius: 8px; margin-bottom: 24px; text-align: center; }
        .ec-cred-title { font-size: 0.75rem; color: #00bcd4; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px; font-weight: bold; }
        .ec-cred-val { color: #fff; font-family: var(--font-mono); font-size: 1.1rem; font-weight: bold; letter-spacing: 1px; }

        .ec-btn-primary { 
            display: block; width: 100%; text-align: center; background: linear-gradient(90deg, #FFD700, #FFA500); 
            color: #000; font-family: var(--font-display); font-size: 1.2rem; letter-spacing: 2px; 
            padding: 14px; border-radius: 8px; text-decoration: none; border: none; cursor: pointer;
            transition: all 0.3s; font-weight: bold; box-shadow: 0 4px 15px rgba(255,215,0,0.2);
            margin-top: auto;
        }
        .ec-btn-primary:hover { box-shadow: 0 6px 25px rgba(255,215,0,0.4); transform: translateY(-2px); }

        .ec-btn-secondary {
            display: block; width: 100%; text-align: center; background: transparent; 
            color: #fff; font-family: var(--font-display); font-size: 1.1rem; letter-spacing: 1px; 
            padding: 14px; border-radius: 8px; text-decoration: none; border: 1px solid rgba(255,255,255,0.2); cursor: pointer;
            transition: all 0.3s; margin-top: auto;
        }
        .ec-btn-secondary:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.4); }

        .ec-btn-green {
            display: block; width: 100%; text-align: center; background: rgba(34, 197, 94, 0.1); 
            color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3);
            font-family: var(--font-display); font-size: 1.2rem; letter-spacing: 2px; 
            padding: 14px; border-radius: 8px; text-decoration: none; cursor: pointer;
            transition: all 0.3s; margin-top: auto;
        }
        .ec-btn-green:hover { background: rgba(34, 197, 94, 0.2); transform: translateY(-2px); }

        .empty-state { text-align: center; padding: 100px 0; color: #71717a; font-size: 1.1rem; }
        
        .spinner-ring {
            display: inline-block; width: 32px; height: 32px;
            border: 3px solid rgba(255,215,0,0.1); border-top-color: var(--elite-gold);
            border-radius: 50%; animation: spin 0.8s cubic-bezier(0.5, 0, 0.5, 1) infinite;
        }

        /* Animations */
        @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(34,197,94,0.4); } 70% { box-shadow: 0 0 0 10px rgba(34,197,94,0); } 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0); } }
        @keyframes spin { to { transform: rotate(360deg); } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes fadeUpIn { 0% { opacity: 0; transform: translateY(40px) scale(0.95); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
        @keyframes slideDownFade { 0% { opacity: 0; transform: translateY(-30px); } 100% { opacity: 1; transform: translateY(0); } }
        @keyframes modalPop { 0% { opacity: 0; transform: scale(0.9) translateY(20px); } 100% { opacity: 1; transform: scale(1) translateY(0); } }
        @keyframes slowRotate { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(360deg); } }

        @media (max-width: 768px) {
            .sh-title { font-size: 3rem; }
            .spotlight-hero { padding: 40px 24px; text-align: center; align-items: center; }
            .sh-meta { flex-direction: column; gap: 12px; }
            .t-grid { grid-template-columns: 1fr; }
            .tournaments-header { flex-direction: column; align-items: flex-start; gap: 16px; }
            .custom-dropdown { width: 100%; }
        }
    </style>
</head>
<body>

    <%- include('../partials/navbar') %>

    <div class="page-wrap">
        
        <div id="spotlight-container">
            <!-- Dynamic Spotlight Hero injected here by JS -->
        </div>

        <div class="tournaments-header">
            <h2 class="section-title">AVAILABLE TOURNAMENTS</h2>
            <div class="custom-dropdown" id="t-dropdown">
                <button class="cd-btn" id="t-dropdown-btn">
                    <span id="cd-selected">LIVE NOW</span>
                    <span style="font-size:0.8rem">▼</span>
                </button>
                <div class="cd-menu">
                    <div class="cd-item active" data-view="live">LIVE NOW</div>
                    <div class="cd-item" data-view="upcoming">FUTURE / UPCOMING</div>
                    <div class="cd-item" data-view="completed">COMPLETED</div>
                </div>
            </div>
        </div>

        <div id="t-content">
            <div style="text-align:center;padding:100px"><div class="spinner-ring"></div></div>
        </div>
    </div>

    <!-- Participants Modal -->
    <div id="participants-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); backdrop-filter:blur(15px); z-index:10000; justify-content:center; align-items:center; padding:20px;">
        <div style="background:#111116; border:1px solid var(--elite-gold-glow); border-radius:16px; width:100%; max-width:700px; max-height:85vh; display:flex; flex-direction:column; padding:32px; position:relative; animation:modalPop 0.4s cubic-bezier(0.16, 1, 0.3, 1); box-shadow: 0 30px 60px rgba(0,0,0,0.8), 0 0 40px rgba(255,215,0,0.1);">
            <button onclick="closeParticipantsModal()" style="position:absolute; top:24px; right:24px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); width:40px; height:40px; border-radius:50%; color:#fff; font-size:1.5rem; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:all 0.2s;">&times;</button>
            
            <div style="display:flex; align-items:center; gap:12px; margin-bottom: 24px;">
                <div style="width:40px; height:4px; background:var(--elite-gold); border-radius:2px;"></div>
                <h2 id="p-modal-title" style="margin:0; font-family:var(--font-display); font-size:2rem; letter-spacing:1px; color:#fff;">PARTICIPANTS</h2>
            </div>
            
            <div id="p-modal-content" style="flex: 1; overflow-y: auto; padding-right: 8px;">
                <div style="text-align:center; padding:40px;"><div class="spinner-ring"></div></div>
            </div>
        </div>
    </div>

    <script src="/script.js?v=1.2"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const token = localStorage.getItem('blaze_token');
            if (!token) { window.location.href = '/auth'; return; }

            const applyUserStatus = (prof) => {
                if (!prof.isGenuine) {
                    const modal = document.getElementById('tournaments-lock-modal');
                    if (modal) {
                        modal.style.display = 'flex';
                        const btn = modal.querySelector('button');
                        if(btn) btn.onclick = () => { window.location.href = '/dashboard'; };
                    } else {
                        window.location.href = '/dashboard';
                    }
                } else {
                    document.querySelector('.page-wrap').style.display = 'block';
                }
            };

            if (window.globalUserData) {
                applyUserStatus(window.globalUserData);
            } else {
                const fallbackTimeout = setTimeout(() => {
                    document.querySelector('.page-wrap').style.display = 'block';
                }, 1500); // Prevent infinite blank page
                
                window.addEventListener('globalUserDataReady', () => {
                    clearTimeout(fallbackTimeout);
                    if (window.globalUserData) {
                        applyUserStatus(window.globalUserData);
                    } else {
                        document.querySelector('.page-wrap').style.display = 'block';
                    }
                });
            }

            // Interactive cards glow effect
            document.addEventListener('mousemove', (e) => {
                document.querySelectorAll('.elite-card').forEach(card => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    card.style.setProperty('--mouse-x', `${x}px`);
                    card.style.setProperty('--mouse-y', `${y}px`);
                });
            });

            // Dropdown Logic
            const dropdown = document.getElementById('t-dropdown');
            const dropdownBtn = document.getElementById('t-dropdown-btn');
            const dropdownMenu = dropdown.querySelector('.cd-menu');
            const dropdownItems = dropdown.querySelectorAll('.cd-item');
            const selectedText = document.getElementById('cd-selected');

            dropdownBtn.addEventListener('click', () => {
                dropdown.classList.toggle('open');
            });

            document.addEventListener('click', (e) => {
                if (!dropdown.contains(e.target)) dropdown.classList.remove('open');
            });

            dropdownItems.forEach(item => {
                item.addEventListener('click', () => {
                    dropdownItems.forEach(i => i.classList.remove('active'));
                    item.classList.add('active');
                    selectedText.innerText = item.innerText;
                    dropdown.classList.remove('open');
                    renderView(item.dataset.view);
                });
            });

            const renderSpotlight = (data) => {
                const container = document.getElementById('spotlight-container');
                let spotlightT = null;
                const pool = [...(data.live || []), ...(data.upcoming || [])];
                
                if (pool.length > 0) {
                    pool.sort((a, b) => {
                        let aTot = 0, bTot = 0;
                        if (a.participants && a.participants.includes('/')) aTot = parseInt(a.participants.split('/')[1]);
                        if (b.participants && b.participants.includes('/')) bTot = parseInt(b.participants.split('/')[1]);
                        return bTot - aTot;
                    });
                    spotlightT = pool[0];
                }

                if (spotlightT) {
                    container.innerHTML = `
                        <div class="spotlight-hero" onmousemove="const rect = this.getBoundingClientRect(); const x = event.clientX - rect.left; const y = event.clientY - rect.top; const xc = rect.width/2; const yc = rect.height/2; const dx = x - xc; const dy = y - yc; this.style.transform = \\`rotateY(\\${dx/40}deg) rotateX(\\${-dy/40}deg)\\`;" onmouseleave="this.style.transform = 'rotateY(0) rotateX(0)';">
                            <div class="sh-badge">🔥 FEATURED EVENT</div>
                            <h1 class="sh-title">${spotlightT.name}</h1>
                            <div class="sh-meta">
                                <div class="sh-stat">
                                    <div class="li-stat-label">GAME</div>
                                    <div class="li-stat-val" style="color:#fff;">${spotlightT.game}</div>
                                </div>
                                <div class="sh-stat">
                                    <div class="li-stat-label">REWARD POOL</div>
                                    <div class="li-stat-val" style="color:var(--elite-gold);">${spotlightT.prize || 'Elite Standing'}</div>
                                </div>
                                <div class="sh-stat">
                                    <div class="li-stat-label">FORMAT</div>
                                    <div class="li-stat-val" style="color:#fff;">${spotlightT.team || 'Solo'}</div>
                                </div>
                            </div>
                            <a href="${spotlightT.canRegister ? `/dashboard/tournaments/${spotlightT.id || spotlightT._id}/register` : '/dashboard/leaderboards'}" class="sh-btn">
                                ${spotlightT.canRegister ? 'SECURE YOUR SLOT NOW' : 'SPECTATE LIVE'}
                            </a>
                        </div>
                    `;
                } else {
                    container.innerHTML = `
                        <div class="spotlight-hero">
                            <div class="sh-badge">💎 ELITE ACCESS</div>
                            <h1 class="sh-title">TRUSTED <span>TOURNAMENTS</span></h1>
                            <p class="elite-desc" style="position:relative; z-index:2; color:#a1a1aa; font-size:1.1rem; max-width:600px; line-height:1.6;">Exclusive high-stakes series and tournaments reserved for verified genuine players. Prove your worth in the highest tiers of Blaze Frontier.</p>
                        </div>
                    `;
                }
            };

            const loadTournaments = async () => {
                const container = document.getElementById('t-content');
                container.innerHTML = '<div style="text-align:center;padding:100px"><div class="spinner-ring"></div></div>';

                try {
                    const res = await fetch('/api/tournaments', { headers: { 'x-auth-token': token } });
                    if (res.ok) {
                        window.tournamentData = await res.json();
                        renderSpotlight(window.tournamentData);
                        renderView('live');
                    } else {
                        throw new Error('Failed to fetch');
                    }
                } catch (e) {
                    container.innerHTML = '<div class="empty-state">Unable to load tournaments at this time.</div>';
                }
            };

            window.renderView = (view) => {
                const container = document.getElementById('t-content');
                if (!window.tournamentData) return;
                
                const list = window.tournamentData[view];
                let html = '';


                if (view === 'live') {
                    if (!list || list.length === 0) {
                        html = '<div class="empty-state">No live elite tournaments at the moment.</div>';
                    } else {
                        html = '<div class="t-grid">' + list.map((t, index) => `
                            <div class="elite-card" style="animation-delay: ${index * 0.1}s; border-color: rgba(34,197,94,0.3);">
                                <div class="ec-header">
                                    <span class="ec-game">${t.game}</span>
                                    <span class="ec-status live">LIVE NOW</span>
                                </div>
                                <h3 class="ec-title">${t.name}</h3>
                                
                                <div class="ec-grid">
                                    <div class="ec-stat">
                                        <span class="ec-stat-label">Players</span>
                                        <span class="ec-stat-val">${t.participants}</span>
                                    </div>
                                    <div class="ec-stat">
                                        <span class="ec-stat-label">Format</span>
                                        <span class="ec-stat-val">${t.team || 'Solo'}</span>
                                    </div>
                                </div>

                                <div class="ec-prize">
                                    <div class="ec-prize-label">Rewards Pool</div>
                                    <div class="ec-prize-val">${t.prize || 'Elite Leaderboard Standing'}</div>
                                </div>

                                <a href="/dashboard/leaderboards" class="ec-btn-green" style="margin-bottom: 12px;">SPECTATE / LEADERBOARD</a>
                                ${t.isListPublished ? `<button onclick="viewParticipants('${t.id || t._id}', '${t.name.replace(/'/g, "\\'")}')" class="ec-btn-secondary">VIEW ROSTER</button>` : ''}
                            </div>
                        `).join('') + '</div>';
                    }
                } else if (view === 'upcoming') {
                    if (!list || list.length === 0) {
                        html = '<div class="empty-state">No upcoming elite tournaments scheduled. Check back soon.</div>';
                    } else {
                        html = '<div class="t-list">' + list.map((t, index) => `
                            <div class="elite-list-item" style="animation-delay: ${index * 0.1}s;">
                                <div class="li-main">
                                    <div class="li-subtitle">${t.game}</div>
                                    <div class="li-title">${t.name}</div>
                                    <div class="ec-status upcoming" style="display:inline-block; font-size:0.7rem; padding: 2px 8px;">UPCOMING</div>
                                </div>
                                
                                <div class="li-meta">
                                    <div class="li-stat">
                                        <span class="li-stat-label">Date</span>
                                        <span class="li-stat-val">${t.date}</span>
                                    </div>
                                    <div class="li-stat">
                                        <span class="li-stat-label">Timing</span>
                                        <span class="li-stat-val">${t.timeSlot || 'TBA'}</span>
                                    </div>
                                    <div class="li-stat">
                                        <span class="li-stat-label">Format</span>
                                        <span class="li-stat-val">${t.team || 'Solo'}</span>
                                    </div>
                                    <div class="li-stat">
                                        <span class="li-stat-label">Rewards</span>
                                        <span class="li-stat-val" style="color: var(--elite-gold);">${t.prize || 'Elite Standing'}</span>
                                    </div>
                                </div>

                                <div class="li-actions">
                                    ${t.canRegister ? `<a href="/dashboard/tournaments/${t.id || t._id}/register" class="ec-btn-primary" style="padding: 10px 20px; font-size: 1rem; display: inline-block; width: auto; margin:0;">SECURE SLOT</a>` : ''}
                                    ${t.isListPublished ? `<button onclick="viewParticipants('${t.id || t._id}', '${t.name.replace(/'/g, "\\'")}')" class="ec-btn-secondary" style="padding: 10px 20px; font-size: 1rem; display: inline-block; width: auto; margin:0;">ROSTER</button>` : ''}
                                </div>
                            </div>
                        `).join('') + '</div>';
                    }
                } else if (view === 'completed') {
                    if (!list || list.length === 0) {
                        html = '<div class="empty-state">No completed matches available yet.</div>';
                    } else {
                        html = '<div class="t-list">' + list.map((t, index) => `
                            <div class="elite-list-item" style="animation-delay: ${index * 0.1}s; opacity: 0.8; border-color: rgba(255,255,255,0.1); border-left-color: #a1a1aa;">
                                <div class="li-main">
                                    <div class="li-subtitle" style="color: #a1a1aa;">${t.game}</div>
                                    <div class="li-title" style="color: #d4d4d8;">${t.name}</div>
                                    <div class="ec-status completed" style="display:inline-block; font-size:0.7rem; padding: 2px 8px;">COMPLETED</div>
                                </div>
                                
                                <div class="li-meta">
                                    <div class="li-stat">
                                        <span class="li-stat-label">Date Played</span>
                                        <span class="li-stat-val" style="color: #a1a1aa;">${t.date}</span>
                                    </div>
                                    <div class="li-stat">
                                        <span class="li-stat-label">Format</span>
                                        <span class="li-stat-val" style="color: #a1a1aa;">${t.team || 'Solo'}</span>
                                    </div>
                                </div>

                                <div class="li-actions">
                                    <a href="/dashboard/leaderboards" class="ec-btn-secondary" style="padding: 10px 20px; font-size: 1rem; display: inline-block; width: auto; margin:0;">VIEW RESULTS</a>
                                </div>
                            </div>
                        `).join('') + '</div>';
                    }
                }
                
                container.innerHTML = html;
            };

            // View Tabs
            document.querySelectorAll('#view-tabs .elite-tab').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('#view-tabs .elite-tab').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    renderView(btn.dataset.view);
                });
            });

            // Initial load
            await loadTournaments();
        });

        async function viewParticipants(id, name) {
            document.getElementById('p-modal-title').textContent = name.toUpperCase();
            document.getElementById('participants-modal').style.display = 'flex';
            const content = document.getElementById('p-modal-content');
            content.innerHTML = '<div style="text-align:center; padding:40px;"><div class="spinner-ring"></div></div>';

            try {
                const token = localStorage.getItem('blaze_token');
                const res = await fetch(`/api/tournaments/${id}/participants`, {
                    headers: { 'x-auth-token': token }
                });
                if (res.ok) {
                    const participants = await res.json();
                    if (participants.length === 0) {
                        content.innerHTML = '<div style="padding: 40px; text-align: center; color: #a1a1aa; font-size: 1.1rem;">Roster is currently empty.</div>';
                    } else {
                        content.innerHTML = '<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px;">' + participants.map((p, i) => `
                            <div style="padding: 16px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; display: flex; align-items: center; gap: 16px; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,215,0,0.05)'; this.style.borderColor='rgba(255,215,0,0.3)'; this.style.transform='translateY(-2px)'" onmouseout="this.style.background='rgba(255,255,255,0.03)'; this.style.borderColor='rgba(255,255,255,0.08)'; this.style.transform='translateY(0)'">
                                <div style="font-family: var(--font-mono); color: var(--elite-gold); font-size: 0.9rem; font-weight: 800; background: rgba(255,215,0,0.1); width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 8px;">${i + 1}</div>
                                <div style="font-weight: 600; color: #fff; font-family: var(--font-display); letter-spacing: 0.5px; font-size: 1.1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="${p}">${p}</div>
                            </div>
                        `).join('') + '</div>';
                    }
                } else {
                    content.innerHTML = '<div style="padding: 40px; text-align: center; color: #ef4444;">Could not load participants.</div>';
                }
            } catch (e) {
                content.innerHTML = '<div style="padding: 40px; text-align: center; color: #ef4444;">Network error. Please try again.</div>';
            }
        }

        function closeParticipantsModal() {
            document.getElementById('participants-modal').style.display = 'none';
        }
    </script>
</body>
</html>
