<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Command Center | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <style>
        body {
            background-color: var(--bg-0);
            color: var(--text-100);
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
            display: flex;
        }

        /* Sidebar Styling */
        .admin-sidebar {
            width: 280px;
            background: rgba(6, 6, 11, 0.8);
            backdrop-filter: blur(20px);
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            flex-direction: column;
            padding: 30px 0;
            z-index: 10;
        }

        .admin-brand {
            padding: 0 30px;
            margin-bottom: 40px;
        }

        .admin-logo-text {
            font-family: var(--font-display);
            font-size: 2.5rem;
            background: linear-gradient(135deg, #FFD700 0%, #FF4E00 60%, #CC0000 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 2px;
            line-height: 1;
        }

        .admin-nav {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding: 0 15px;
        }

        .nav-link {
            padding: 14px 20px;
            border-radius: 10px;
            cursor: pointer;
            color: var(--text-300);
            font-weight: 500;
            font-size: 0.95rem;
            transition: all 0.3s var(--ease);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.03);
            color: var(--text-100);
        }

        .nav-link.active {
            background: rgba(230, 57, 70, 0.1);
            color: var(--accent);
            font-weight: 600;
        }

        .nav-link svg {
            width: 20px;
            height: 20px;
            opacity: 0.7;
        }

        .nav-link.active svg {
            opacity: 1;
        }

        /* Content Styling */
        .admin-content {
            flex: 1;
            overflow-y: auto;
            padding: 40px 50px;
            background: radial-gradient(circle at top right, rgba(230, 57, 70, 0.03), transparent 50%), var(--bg-0);
        }

        .tab-pane {
            display: none;
            animation: fadeUp 0.4s var(--ease-out);
        }

        .tab-pane.active {
            display: block;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-title {
            font-family: var(--font-display);
            font-size: 3.5rem;
            letter-spacing: 2px;
            margin: 0;
            line-height: 1;
        }

        .page-desc {
            color: var(--text-300);
            font-size: 1rem;
            margin-top: 10px;
        }

        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
            gap: 24px;
        }

        /* Glass Cards */
        .glass-card {
            background: var(--bg-1);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-lg);
            padding: 30px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        .glass-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
        }

        .card-title {
            font-family: var(--font-display);
            font-size: 1.5rem;
            color: var(--text-200);
            letter-spacing: 1px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .input-group {
            margin-bottom: 15px;
        }

        .admin-input {
            width: 100%;
            padding: 14px 16px;
            background: rgba(0,0,0,0.4);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 8px;
            color: #fff;
            font-family: var(--font-body);
            font-size: 0.95rem;
            transition: all 0.3s;
        }

        .admin-input:focus {
            outline: none;
            border-color: var(--accent);
            background: rgba(0,0,0,0.6);
        }

        .btn-action {
            width: 100%;
            padding: 14px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 10px;
        }

        .btn-action:hover {
            background: #d32f3e;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(230, 57, 70, 0.3);
        }

        /* Data Tables */
        .table-container {
            width: 100%;
            overflow-x: auto;
            background: var(--bg-1);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-lg);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .data-table th {
            background: rgba(255,255,255,0.02);
            padding: 16px 20px;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-400);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .data-table td {
            padding: 16px 20px;
            font-size: 0.9rem;
            border-bottom: 1px solid rgba(255,255,255,0.02);
            color: var(--text-200);
            vertical-align: middle;
        }

        .data-table tr:hover td {
            background: rgba(255,255,255,0.01);
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .badge-admin { background: rgba(139, 92, 246, 0.2); color: #a78bfa; }
        .badge-genuine { background: rgba(0, 229, 255, 0.2); color: #00e5ff; }
        .badge-pending { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }
        .badge-approved { background: rgba(34, 197, 94, 0.2); color: #4ade80; }

        .btn-sm {
            padding: 6px 12px;
            font-size: 0.75rem;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }

        .btn-danger { background: rgba(230, 57, 70, 0.1); color: var(--accent); border: 1px solid rgba(230, 57, 70, 0.2); }
        .btn-danger:hover { background: var(--accent); color: #fff; }
        
        .btn-success { background: rgba(34, 197, 94, 0.1); color: #4ade80; border: 1px solid rgba(34, 197, 94, 0.2); }
        .btn-success:hover { background: #22c55e; color: #fff; }
        
        .btn-outline { background: transparent; border: 1px solid rgba(255,255,255,0.1); color: var(--text-200); }
        .btn-outline:hover { background: rgba(255,255,255,0.05); color: #fff; }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="admin-brand">
            <div class="admin-logo-text">COMMAND CENTER</div>
        </div>
        <div class="admin-nav">
            <div class="nav-link" onclick="switchTab('stats', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"></path><path d="M18 20V4"></path><path d="M6 20v-4"></path></svg>
                Match Stats
            </div>
            <div class="nav-link active" onclick="switchTab('users', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                User Directory
            </div>
            <div class="nav-link" onclick="switchTab('banned', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>
                Banned Users
            </div>
            <div class="nav-link" onclick="switchTab('registrations', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                Registrations
            </div>
            <div class="nav-link" onclick="switchTab('season-regs', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
                Season Matches
            </div>
            <div class="nav-link" onclick="switchTab('updates', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 16.1A5 5 0 0 1 5.9 20M2 12.05A9 9 0 0 1 9.95 20M2 8V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-6"></path><line x1="2" y1="20" x2="2.01" y2="20"></line></svg>
                Platform Updates
            </div>
            <div class="nav-link" onclick="switchTab('daily-content', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect><polygon points="10 8 16 12 10 16 10 8"></polygon></svg>
                Daily Content
            </div>
            <div class="nav-link" onclick="switchTab('clips', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect><line x1="7" y1="2" x2="7" y2="22"></line><line x1="17" y1="2" x2="17" y2="22"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="7" x2="7" y2="7"></line><line x1="2" y1="17" x2="7" y2="17"></line><line x1="17" y1="17" x2="22" y2="17"></line><line x1="17" y1="7" x2="22" y2="7"></line></svg>
                Clip Submissions
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="admin-content">
        
        <!-- Tab: Match Stats -->
        <div id="tab-stats" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title">Match Statistics</h1>
                <div class="page-desc">Manually process post-match analytics and leaderboard points.</div>
            </div>
            <div class="admin-grid">
                <div class="glass-card">
                    <div class="card-title">INPUT MATCH DATA</div>
                    <div class="input-group" style="display:flex; gap:10px;">
                        <input type="text" id="stat-match" class="admin-input" placeholder="Match ID">
                        <button class="btn-action" style="margin-top:0; width:auto; padding:0 20px; background:#4f46e5;" onclick="fetchMatchDetails()">FETCH</button>
                    </div>
                    
                    <!-- Match Details Panel -->
                    <div id="match-details-panel" style="display:none; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.05); padding:15px; border-radius:8px; margin-bottom:15px; font-size:0.85rem;">
                        <div style="color:var(--text-300); margin-bottom:5px;">SERIES: <span id="detail-series" style="color:#fff; font-weight:600;"></span></div>
                        <div style="color:var(--text-300); margin-bottom:5px;">FORMAT: <span id="detail-format" style="color:var(--cyan); font-weight:600; text-transform:uppercase;"></span> • <span id="detail-mode" style="color:var(--cyan); text-transform:uppercase;"></span></div>
                        <div style="color:var(--text-300); margin-bottom:5px;">PLAYER: <span id="detail-player" style="color:#fff; font-weight:600;"></span></div>
                        <div style="color:var(--text-300);">STATUS: <span id="detail-status" class="badge"></span></div>
                    </div>

                    <div id="stats-input-section" style="opacity:0.5; pointer-events:none; transition:all 0.3s;">
                        <div class="input-group" style="display:flex; gap:10px;">
                            <input type="number" id="stat-kills" class="admin-input" placeholder="Kills">
                            <input type="number" id="stat-survival" class="admin-input" placeholder="Survival Time (Mins)">
                        </div>
                        <div class="input-group">
                            <input type="number" id="stat-placement" class="admin-input" placeholder="Placement (1-100)">
                        </div>
                        <button class="btn-action" style="background: var(--cyan);" onclick="submitStats()">CALCULATE & SUBMIT STATS</button>
                    </div>
                </div>
                

            </div>
        </div>

        <!-- Tab: User Directory -->
        <div id="tab-users" class="tab-pane active">
            <div class="page-header">
                <h1 class="page-title">User Intelligence</h1>
                <div class="page-desc">Manage verified operators and eliminate cheaters.</div>
            </div>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Operator</th>
                            <th>Player ID</th>
                            <th>Status Flags</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="user-list">
                        <tr><td colspan="4" style="text-align:center;">Loading database...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tab: Banned Users -->
        <div id="tab-banned" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title" style="color: var(--accent);">Blacklist</h1>
                <div class="page-desc">Permanently severed accounts due to TOS violations.</div>
            </div>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Operator</th>
                            <th>Player ID</th>
                            <th>Ban Reason</th>
                            <th style="text-align:right;">Timestamp</th>
                        </tr>
                    </thead>
                    <tbody id="banned-list">
                        <tr><td colspan="4" style="text-align:center;">Loading blacklist...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tab: Registrations -->
        <div id="tab-registrations" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title">Queue Requests</h1>
                <div class="page-desc">Approve or reject pending tournament entries.</div>
            </div>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Applicant</th>
                            <th>Discord / Comm</th>
                            <th>Format & Mode</th>
                            <th>Schedule</th>
                            <th>Status</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="reg-list">
                        <tr><td colspan="6" style="text-align:center;">Loading queue...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tab: Season Registrations -->
        <div id="tab-season-regs" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title">Season Matches</h1>
                <div class="page-desc">Track and manage verified player registrations for Season Matches.</div>
            </div>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Operator</th>
                            <th>Discord</th>
                            <th>Match Series</th>
                            <th>Date Submited</th>
                            <th>Status</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="season-reg-list">
                        <tr><td colspan="6" style="text-align:center;">Loading season queue...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tab: Platform Updates -->
        <div id="tab-updates" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title">Broadcast Network</h1>
                <div class="page-desc">Push live intel to all operator dashboards globally.</div>
            </div>
            <div class="admin-grid">
                <div class="glass-card">
                    <div class="card-title">COMPOSE BROADCAST</div>
                    <div class="input-group">
                        <input type="text" id="news-title" class="admin-input" placeholder="Headline / Message">
                    </div>
                    <div class="input-group">
                        <select id="news-tag" class="admin-input" onchange="updateTagClass()">
                            <option value="UPDATE">UPDATE</option>
                            <option value="MAINTENANCE">MAINTENANCE</option>
                            <option value="NEW SEASON">NEW SEASON</option>
                            <option value="ESPORTS">ESPORTS</option>
                        </select>
                        <input type="hidden" id="news-tagClass" value="tag-update">
                    </div>
                    <button class="btn-action" style="background: #8b5cf6;" onclick="publishUpdate()">TRANSMIT INTEL</button>
                </div>
                
                <div class="glass-card">
                    <div class="card-title">SET PLAYER OF THE DAY</div>
                    <form id="potd-form" onsubmit="submitPOTD(event)">
                        <div class="input-group">
                            <input type="text" id="potd-player" class="admin-input" placeholder="Blaze ID of the Player" required>
                        </div>
                        <div class="input-group">
                            <input type="text" id="potd-title" class="admin-input" placeholder="Highlight Title (e.g., Insane 1v4 Clutch)" required>
                        </div>
                        <div class="input-group">
                            <label style="color:var(--text-300); font-size:0.8rem; margin-bottom: 5px; display:block;">Upload Video Clip (MP4/WebM, Max 50MB)</label>
                            <input type="file" id="potd-clip" class="admin-input" accept="video/mp4,video/webm" required>
                        </div>
                        <button type="submit" class="btn-action" style="background: #eab308;">SET PLAYER OF THE DAY</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tab: Daily Content -->
        <div id="tab-daily-content" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title">Daily Content</h1>
                <div class="page-desc">Set the YouTube and Facebook embed links for today's showcases.</div>
            </div>
            <div class="admin-grid">
                <div class="glass-card" style="grid-column: 1 / -1;">
                    <div class="card-title">UPDATE DAILY HIGHLIGHTS</div>
                    <form id="daily-content-form" onsubmit="submitDailyContent(event)">
                        <div class="input-group">
                            <label style="color:var(--text-300); font-size:0.85rem; margin-bottom:8px; display:block;">YouTube Embed Link</label>
                            <input type="text" id="dc-yt" class="admin-input" placeholder="e.g. https://www.youtube.com/embed/XXXXXX" required>
                        </div>
                        <div class="input-group">
                            <label style="color:var(--text-300); font-size:0.85rem; margin-bottom:8px; display:block;">Facebook Embed Link</label>
                            <input type="text" id="dc-fb" class="admin-input" placeholder="e.g. https://www.facebook.com/plugins/video.php?href=..." required>
                        </div>
                        <button type="submit" class="btn-action" style="background: var(--cyan); width: 250px;">SAVE DAILY CONTENT</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tab: Clip Submissions -->
        <div id="tab-clips" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title">Clip Review</h1>
                <div class="page-desc">Approve top plays to feature them on the hub and award 50 BlazeCoins.</div>
            </div>
            <div class="admin-grid" id="clip-list">
                <div style="color:var(--text-muted); padding:20px;">Loading submissions...</div>
            </div>
        </div>

    </div>

    <!-- Scripts -->
    <script>
        function switchTab(tabId, element) {
            document.querySelectorAll('.tab-pane').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'));
            document.getElementById('tab-' + tabId).classList.add('active');
            element.classList.add('active');
            
            localStorage.setItem('adminActiveTab', tabId);

            // Auto refresh specific tabs
            if(tabId === 'users') loadUsers();
            if(tabId === 'banned') loadBannedUsers();
            if(tabId === 'registrations') loadRegistrations();
            if(tabId === 'season-regs') loadSeasonRegistrations();
            if(tabId === 'clips') loadClips();
            if(tabId === 'daily-content') loadDailyContent();
        }

        async function loadDailyContent() {
            try {
                const res = await fetch('<%= adminPrefix %>/api/daily-content', { cache: 'no-store' });
                if(res.ok) {
                    const data = await res.json();
                    if(data) {
                        document.getElementById('dc-yt').value = data.youtubeLink || '';
                        document.getElementById('dc-fb').value = data.facebookLink || '';
                    }
                }
            } catch(e) { console.error(e); }
        }

        async function submitDailyContent(e) {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            const originalText = btn.innerText;
            btn.innerText = 'SAVING...';
            
            try {
                const res = await fetch('<%= adminPrefix %>/api/daily-content', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        youtubeLink: document.getElementById('dc-yt').value,
                        facebookLink: document.getElementById('dc-fb').value
                    })
                });
                
                if(res.ok) {
                    btn.innerText = 'SAVED SUCCESSFULLY';
                    btn.style.background = '#22c55e';
                    setTimeout(() => {
                        btn.innerText = originalText;
                        btn.style.background = 'var(--cyan)';
                    }, 2000);
                } else {
                    alert('Error saving daily content');
                    btn.innerText = originalText;
                }
            } catch(err) {
                alert('Server error');
                btn.innerText = originalText;
            }
        }

        async function loadUsers() {
            const list = document.getElementById('user-list');
            try {
                const res = await fetch('<%= adminPrefix %>/api/users', { cache: 'no-store' });
                if(!res.ok) return list.innerHTML = '<tr><td colspan="4" style="text-align:center;">Access Denied.</td></tr>';
                const users = await res.json();
                if(users.length === 0) return list.innerHTML = '<tr><td colspan="4" style="text-align:center;">No users found.</td></tr>';
                
                list.innerHTML = users.map(u => `
                    <tr>
                        <td style="font-weight:600; color:#fff;">${u.username}</td>
                        <td style="font-family:var(--font-mono); font-size:0.8rem;">${u.playerId}</td>
                        <td>
                            ${u.isAdmin ? '<span class="badge badge-admin">ADMIN</span>' : ''}
                            ${u.isGenuine ? '<span class="badge badge-genuine">GENUINE</span>' : ''}
                            ${!u.isAdmin && !u.isGenuine ? '<span style="color:var(--text-400); font-size:0.8rem;">Standard</span>' : ''}
                        </td>
                        <td style="text-align:right;">
                            <div style="display:flex; justify-content:flex-end; gap:8px;">
                                ${!u.isAdmin ? `<button class="btn-sm btn-outline" onclick="toggleVerifyUser('${u._id}')">${u.isGenuine ? 'Revoke Genuine' : 'Make Genuine'}</button>` : ''}
                                ${!u.isAdmin ? `<button class="btn-sm btn-danger" onclick="banUser('${u._id}')">FLAG CHEATER</button>` : ''}
                            </div>
                        </td>
                    </tr>
                `).join('');
            } catch(e) { console.error(e); }
        }

        async function loadBannedUsers() {
            const list = document.getElementById('banned-list');
            try {
                const res = await fetch('<%= adminPrefix %>/api/banned-users', { cache: 'no-store' });
                if(!res.ok) return list.innerHTML = '<tr><td colspan="4" style="text-align:center;">Failed to load.</td></tr>';
                const banned = await res.json();
                if(banned.length === 0) return list.innerHTML = '<tr><td colspan="4" style="text-align:center;">No banned users. Good job!</td></tr>';
                
                list.innerHTML = banned.map(b => `
                    <tr>
                        <td style="font-weight:600; color:var(--accent);">${b.username}</td>
                        <td style="font-family:var(--font-mono); font-size:0.8rem;">${b.playerId}</td>
                        <td style="font-size:0.8rem;">${b.reason}</td>
                        <td style="text-align:right; font-size:0.8rem; color:var(--text-400);">${new Date(b.bannedAt).toLocaleDateString()}</td>
                    </tr>
                `).join('');
            } catch(e) { console.error(e); }
        }

        async function loadRegistrations() {
            const list = document.getElementById('reg-list');
            try {
                const res = await fetch('<%= adminPrefix %>/api/registrations', { cache: 'no-store' });
                if(!res.ok) return;
                const regs = await res.json();
                if(regs.length === 0) return list.innerHTML = '<tr><td colspan="6" style="text-align:center;">No pending requests.</td></tr>';
                
                const filteredRegs = regs.filter(r => r.format !== 'Season Match');
                if(filteredRegs.length === 0) return list.innerHTML = '<tr><td colspan="6" style="text-align:center;">No pending tournament requests.</td></tr>';

                list.innerHTML = filteredRegs.map(r => {
                    const badgeClass = r.status === 'Approved' ? 'badge-approved' : (r.status === 'Pending' ? 'badge-pending' : '');
                    const badgeHtml = r.status !== 'Rejected' ? `<span class="badge ${badgeClass}">${r.status}</span>` : `<span class="badge" style="background:rgba(230,57,70,0.2);color:var(--accent);">${r.status}</span>`;
                    return `
                    <tr>
                        <td style="font-weight:600; color:#fff;">${r.userId ? (r.userId.inGameName || r.userId.username) : 'Unknown'}</td>
                        <td style="color:var(--cyan); font-size:0.85rem;">${r.discord}</td>
                        <td style="font-size:0.85rem;">
                            ${r.format.toUpperCase()} • ${r.mode.toUpperCase()}
                            ${r.matchId ? `<div style="color:var(--blaze-orange); font-size:0.75rem; margin-top:4px; font-weight:600;">Match #${r.matchId}</div>` : ''}
                            ${r.teamMembers && r.teamMembers.length > 0 ? `<div style="color:var(--orange); font-size:0.75rem; margin-top:4px;">Team: ${r.teamMembers.join(', ')}</div>` : ''}
                        </td>
                        <td style="font-size:0.85rem;"><div style="color:#fff;">${r.startDate || 'N/A'}</div><div style="color:var(--text-muted);">${r.timeSlot || 'N/A'}</div></td>
                        <td>${badgeHtml}</td>
                        <td style="text-align:right;">
                            ${r.status === 'Pending' ? `
                                <div style="display:flex; justify-content:flex-end; gap:8px;">
                                    <button class="btn-sm btn-success" onclick="updateRegistration('${r._id}', 'Approved')">APPROVE</button>
                                    <button class="btn-sm btn-danger" style="background:#dc2626;" onclick="deleteRegistration('${r._id}')">REJECT & DELETE</button>
                                </div>
                            ` : (r.status === 'Awaiting Verification' ? `
                                <div style="display:flex; justify-content:flex-end; gap:8px;">
                                    <button class="btn-sm btn-success" style="background:#fbbf24; color:#000; padding: 6px 12px; font-weight: bold; border-radius: 4px;" onclick="verifyPlayer('${r._id}')">✨ VERIFY PLAYER ✨</button>
                                    <button class="btn-sm btn-danger" style="background:#dc2626; padding: 6px 12px;" onclick="deleteRegistration('${r._id}')">REJECT</button>
                                </div>
                            ` : `
                                <div style="display:flex; justify-content:flex-end; gap:8px; align-items: center;">
                                    <span style="color:var(--text-400); font-size:0.8rem; margin-right: 8px;">Processed</span>
                                    <button class="btn-sm btn-danger" style="background:#dc2626; padding: 4px 8px;" onclick="deleteRegistration('${r._id}')">DELETE</button>
                                </div>
                            `)}
                        </td>
                    </tr>
                `}).join('');
            } catch(e) { console.error(e); }
        }

        async function loadSeasonRegistrations() {
            const list = document.getElementById('season-reg-list');
            try {
                const res = await fetch('<%= adminPrefix %>/api/registrations', { cache: 'no-store' });
                if(!res.ok) return;
                const regs = await res.json();
                
                const filteredRegs = regs.filter(r => r.format === 'Season Match');
                if(filteredRegs.length === 0) return list.innerHTML = '<tr><td colspan="6" style="text-align:center;">No pending season matches.</td></tr>';

                list.innerHTML = filteredRegs.map(r => {
                    const badgeClass = r.status === 'Approved' ? 'badge-approved' : (r.status === 'Pending' ? 'badge-pending' : '');
                    const badgeHtml = r.status !== 'Rejected' ? `<span class="badge ${badgeClass}">${r.status}</span>` : `<span class="badge" style="background:rgba(230,57,70,0.2);color:var(--accent);">${r.status}</span>`;
                    return `
                    <tr>
                        <td style="font-weight:600; color:#fff;">${r.userId ? (r.userId.inGameName || r.userId.username) : 'Unknown'}</td>
                        <td style="color:var(--cyan); font-size:0.85rem;">${r.discord}</td>
                        <td style="font-size:0.85rem;">
                            <span style="color:var(--blaze-orange); font-weight:600;">${r.mode.toUpperCase()}</span>
                        </td>
                        <td style="font-size:0.85rem; color:var(--text-muted);">${new Date(r.createdAt).toLocaleDateString()}</td>
                        <td>${badgeHtml}</td>
                        <td style="text-align:right;">
                            ${r.status === 'Pending' ? `
                                <div style="display:flex; justify-content:flex-end; gap:8px;">
                                    <button class="btn-sm btn-success" onclick="updateRegistration('${r._id}', 'Approved')">APPROVE</button>
                                    <button class="btn-sm btn-danger" style="background:#dc2626;" onclick="deleteRegistration('${r._id}')">DELETE</button>
                                </div>
                            ` : `
                                <div style="display:flex; justify-content:flex-end; gap:8px; align-items: center;">
                                    <span style="color:var(--text-400); font-size:0.8rem; margin-right: 8px;">Processed</span>
                                    <button class="btn-sm btn-danger" style="background:#dc2626; padding: 4px 8px;" onclick="deleteRegistration('${r._id}')">DELETE</button>
                                </div>
                            `}
                        </td>
                    </tr>
                `}).join('');
            } catch(e) { console.error(e); }
        }

        // Action Functions
        async function submitPotd(e) {
            e.preventDefault();
            const playerId = document.getElementById('potd-blaze-id').value;
            const title = document.getElementById('potd-title').value;
            const videoFile = document.getElementById('potd-video').files[0];

            if (!playerId || !videoFile) {
                alert("Blaze ID and Video File are required!");
                return;
            }

            const formData = new FormData();
            formData.append('playerId', playerId);
            formData.append('title', title);
            formData.append('video', videoFile);

            try {
                const btn = e.target.querySelector('button');
                const origText = btn.innerText;
                btn.innerText = "UPLOADING...";
                btn.disabled = true;

                const response = await fetch('<%= adminPrefix %>/api/potd', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();
                if (response.ok) {
                    alert('Player of the Day updated successfully!');
                    document.getElementById('potd-upload-form').reset();
                } else {
                    alert('Error: ' + data.msg);
                }
            } catch (err) {
                console.error(err);
                alert('Upload failed. Please check the console.');
            } finally {
                const btn = e.target.querySelector('button');
                btn.innerText = "UPLOAD POTD VIDEO";
                btn.disabled = false;
            }
        }
        async function fetchMatchDetails() {
            const matchId = document.getElementById('stat-match').value;
            if(!matchId) return alert('Enter Match ID first');
            
            try {
                const res = await fetch(`<%= adminPrefix %>/api/match/${matchId}`);
                if(!res.ok) {
                    alert('Match not found or error fetching details.');
                    document.getElementById('match-details-panel').style.display = 'none';
                    document.getElementById('stats-input-section').style.opacity = '0.5';
                    document.getElementById('stats-input-section').style.pointerEvents = 'none';
                    return;
                }
                const match = await res.json();
                
                // Populate UI
                document.getElementById('detail-series').innerText = match.seriesId ? `${match.seriesId.name} (Match #${match.matchNumber})` : 'Unknown Series';
                document.getElementById('detail-format').innerText = match.format || 'SQUAD';
                document.getElementById('detail-mode').innerText = match.mode || 'BR';
                document.getElementById('detail-player').innerText = match.playerId ? (match.playerId.inGameName || match.playerId.username) : 'Unknown Player';
                
                const statusBadge = document.getElementById('detail-status');
                statusBadge.innerText = match.status;
                if(match.status === 'COMPLETED') { statusBadge.className = 'badge badge-approved'; }
                else { statusBadge.className = 'badge badge-pending'; }
                
                document.getElementById('match-details-panel').style.display = 'block';
                document.getElementById('stats-input-section').style.opacity = '1';
                document.getElementById('stats-input-section').style.pointerEvents = 'auto';
                
            } catch(e) {
                console.error(e);
            }
        }

        async function submitStats() {
            const matchId = document.getElementById('stat-match').value;
            const kills = document.getElementById('stat-kills').value;
            const survival = document.getElementById('stat-survival').value;
            const placement = document.getElementById('stat-placement').value;
            const res = await fetch(`<%= adminPrefix %>/api/match/${matchId}/score`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ kills, survivalTimeMinutes: survival, placement })
            });
            if(res.ok) { alert('Stats submitted successfully!'); }
        }

        async function banUser(userId) {
            if(!confirm('CONFIRM BAN: This will permanently delete the user and migrate them to the Banned Database. Proceed?')) return;
            const res = await fetch(`<%= adminPrefix %>/api/ban/${userId}`, { method: 'POST' });
            if(res.ok) { 
                alert('Operator Terminated.'); 
                loadUsers(); 
                loadBannedUsers(); 
            } else {
                const text = await res.text();
                alert('Failed to ban user. Server says: ' + text);
            }
        }

        async function toggleVerifyUser(userId) {
            const res = await fetch(`<%= adminPrefix %>/api/users/${userId}/verify`, { method: 'PUT' });
            if(res.ok) { loadUsers(); }
        }

        async function updateRegistration(id, status) {
            const res = await fetch(`<%= adminPrefix %>/api/registrations/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            if(res.ok) { loadRegistrations(); }
        }

        async function verifyPlayer(id) {
            if (!confirm('Are you sure you want to verify this player? They will receive the Golden Badge and 100 BlazeCoins!')) return;
            const res = await fetch(`<%= adminPrefix %>/api/verify-player/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' }
            });
            if(res.ok) { 
                alert('Player verified successfully!');
                loadRegistrations(); 
            } else {
                const data = await res.json();
                alert(data.msg || 'Error verifying player');
            }
        }

        async function deleteRegistration(id) {
            const reason = prompt('Are you sure you want to completely delete this registration? \n\nPlease enter the reason for rejection/deletion (this will be emailed to the user):');
            if (reason === null) return; // User cancelled
            
            const res = await fetch(`<%= adminPrefix %>/api/registrations/${id}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason: reason || 'No reason provided.' })
            });
            if(res.ok) { 
                loadRegistrations(); 
                loadSeasonRegistrations();
            }
        }

        function updateTagClass() {
            const tag = document.getElementById('news-tag').value;
            const classMap = { 'UPDATE': 'tag-update', 'MAINTENANCE': 'tag-maint', 'NEW SEASON': 'tag-season', 'ESPORTS': 'tag-esports' };
            document.getElementById('news-tagClass').value = classMap[tag] || 'tag-update';
        }

        async function publishUpdate() {
            const title = document.getElementById('news-title').value;
            const tag = document.getElementById('news-tag').value;
            const tagClass = document.getElementById('news-tagClass').value;
            if(!title) return alert('Title required');
            const res = await fetch('<%= adminPrefix %>/api/news', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title, tag, tagClass })
            });
            if(res.ok) { alert('Intel Transmitted!'); document.getElementById('news-title').value = ''; }
        }

        async function submitPOTD(e) {
            e.preventDefault();
            const playerId = document.getElementById('potd-player').value;
            const title = document.getElementById('potd-title').value;
            const clipFile = document.getElementById('potd-clip').files[0];

            if (!playerId || !title || !clipFile) return alert('All fields required');
            if (clipFile.size > 50 * 1024 * 1024) return alert('File size must be under 50MB');

            const formData = new FormData();
            formData.append('playerId', playerId);
            formData.append('title', title);
            formData.append('clip', clipFile);

            const btn = e.target.querySelector('button');
            const originalText = btn.innerText;
            btn.innerText = 'UPLOADING...';
            btn.disabled = true;

            try {
                const res = await fetch('<%= adminPrefix %>/api/player-of-the-day', {
                    method: 'POST',
                    body: formData
                });
                if(res.ok) {
                    alert('Player of the Day Updated!');
                    e.target.reset();
                } else {
                    const data = await res.json();
                    alert('Failed: ' + (data.msg || 'Unknown error'));
                }
            } catch (err) {
                console.error(err);
                alert('An error occurred during upload.');
            } finally {
                btn.innerText = originalText;
                btn.disabled = false;
            }
        }

        async function loadClips() {
            const list = document.getElementById('clip-list');
            try {
                const res = await fetch('<%= adminPrefix %>/api/clip-submissions', { cache: 'no-store' });
                if(!res.ok) return list.innerHTML = '<div style="color:#ef4444;">Failed to load clips.</div>';
                const clips = await res.json();
                if(clips.length === 0) return list.innerHTML = '<div style="color:var(--text-muted);">No pending clip submissions.</div>';
                
                list.innerHTML = clips.map(c => `
                    <div class="glass-card" style="padding:0; overflow:hidden;">
                        <video src="${c.videoUrl}" controls style="width:100%; height:200px; background:#000;"></video>
                        <div style="padding: 20px;">
                            <div style="font-family:var(--font-display); font-size:1.3rem; margin-bottom:5px;">${c.title}</div>
                            <div style="color:var(--text-muted); font-size:0.85rem; margin-bottom:15px;">By ${c.userId ? (c.userId.inGameName || c.userId.username) : 'Unknown'} (${c.playerId})</div>
                            <div style="display:flex; gap:10px;">
                                <button class="btn-action" style="background:#22c55e; margin-top:0;" onclick="approveClip('${c._id}')">APPROVE (+50 BC)</button>
                                <button class="btn-action" style="background:#dc2626; margin-top:0;" onclick="rejectClip('${c._id}')">REJECT</button>
                            </div>
                        </div>
                    </div>
                `).join('');
            } catch(e) { console.error(e); }
        }

        async function approveClip(id) {
            if(!confirm('Approve this clip? This will publish it to the dashboard and instantly award 50 BlazeCoins.')) return;
            const res = await fetch(`<%= adminPrefix %>/api/clip-submissions/${id}/approve`, { method: 'POST' });
            if(res.ok) { 
                alert('Clip Approved & Rewarded!'); 
                loadClips(); 
            } else {
                alert('Error: ' + await res.text());
            }
        }

        async function rejectClip(id) {
            if(!confirm('Reject this clip?')) return;
            const res = await fetch(`<%= adminPrefix %>/api/clip-submissions/${id}/reject`, { method: 'POST' });
            if(res.ok) { 
                loadClips(); 
            } else {
                alert('Error: ' + await res.text());
            }
        }

        // Initialize Data
        loadUsers();
        loadBannedUsers();
        loadRegistrations();
        loadSeasonRegistrations();

        // Restore Tab State
        const savedTab = localStorage.getItem('adminActiveTab');
        if (savedTab) {
            const tabElement = document.querySelector(`.nav-link[onclick="switchTab('${savedTab}', this)"]`);
            if (tabElement) switchTab(savedTab, tabElement);
        }
    </script>
</body>
</html>
