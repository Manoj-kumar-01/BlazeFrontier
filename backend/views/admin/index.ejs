                    <div class="input-group">
                        <label
                            style="color:var(--text-300); font-size:0.85rem; margin-bottom:8px; display:block; font-weight:600;">Highlight
                            Title</label>
                        <input type="text" id="potd-title" class="admin-input" placeholder="e.g., Insane 1v4 Clutch"
                            required>
                    </div>
                    <div class="input-group">
                        <label
                            style="color:var(--text-300); font-size:0.85rem; margin-bottom:8px; display:block; font-weight:600;">Upload
                            Video Clip (Max 50MB)</label>
                        <div
                            style="background:rgba(0,0,0,0.2); border:1px dashed rgba(255,255,255,0.2); border-radius:8px; padding:15px; text-align:center;">
                            <input type="file" id="potd-clip" accept="video/mp4,video/webm"
                                style="color:var(--text-200); font-size:0.85rem;" required>
