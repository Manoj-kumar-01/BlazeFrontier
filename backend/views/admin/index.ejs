        function openCredsModal(matchId, regDataStr) {
            let data = {};
            try { data = JSON.parse(regDataStr); } catch (e) { console.error(e); }

            document.getElementById('modal-match-id').value = matchId;
            document.getElementById('modal-player-name').innerText = data.inGameName || 'Unknown';
            document.getElementById('modal-m-id').innerText = data.matchId ? `#${data.matchId}` : 'N/A';
            document.getElementById('modal-date').innerText = data.startDate || 'N/A';
            document.getElementById('modal-slot').innerText = data.timeSlot || 'N/A';
            document.getElementById('modal-email').innerText = data.email || 'N/A';
            document.getElementById('modal-guid').innerText = data.gameUid || 'N/A';
            document.getElementById('modal-bid').innerText = data.playerId || 'N/A';

            document.getElementById('modal-room-id').value = '';
            document.getElementById('modal-room-pass').value = '';
            document.getElementById('creds-modal').style.display = 'flex';
