<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Host | Blaze Frontier</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=block"
        rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <script src="/public/custom-confirm.js"></script>
    <style>
        body {
            background-color: var(--bg-0);
            color: var(--text-100);
            margin: 0;
            padding: 0;
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* Sidebar Styling */
        .admin-sidebar {
            width: 100%;
            height: 70px;
            background: rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            flex-direction: row;
            align-items: center;
            padding: 0 20px;
            z-index: 10;
        }

        .admin-brand {
            padding: 0 30px 0 0;
            margin-bottom: 0;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            margin-right: 20px;
            display: flex;
            align-items: center;
        }

        .admin-logo-text {
            font-family: var(--font-display);
            font-size: 2rem;
            background: linear-gradient(135deg, #FFD700 0%, #FF4E00 60%, #CC0000 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 2px;
            line-height: 1;
        }

        .admin-nav {
            display: flex;
            flex-direction: row;
            gap: 8px;
            padding: 0;
            flex: 1;
            overflow-x: auto;
            align-items: center;
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        .admin-nav::-webkit-scrollbar {
            display: none;
        }

        .nav-link {
            padding: 10px 16px;
            border-radius: 10px;
            cursor: pointer;
            color: var(--text-300);
            font-weight: 500;
            font-size: 0.95rem;
            white-space: nowrap;
            transition: all 0.3s var(--ease);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.03);
            color: var(--text-100);
        }

        .nav-link.active {
            background: rgba(230, 57, 70, 0.1);
            color: var(--accent);
            font-weight: 600;
        }

        .nav-link svg {
            width: 20px;
            height: 20px;
            opacity: 0.7;
        }

        .nav-link.active svg {
            opacity: 1;
        }

        /* Content Styling */
        .admin-content {
            flex: 1;
            overflow-y: auto;
            padding: 40px 50px;
            background: radial-gradient(circle at top right, rgba(230, 57, 70, 0.03), transparent 50%), var(--bg-0);
        }

        .tab-pane {
            display: none;
            animation: fadeUp 0.4s var(--ease-out);
        }

        .tab-pane.active {
            display: block;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-title {
            font-family: var(--font-display);
            font-size: 3.5rem;
            letter-spacing: 2px;
            margin: 0;
            line-height: 1;
        }

        .page-desc {
            color: var(--text-300);
            font-size: 1rem;
            margin-top: 10px;
        }

        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
            gap: 24px;
        }

        /* Glass Cards */
        .glass-card {
            background: var(--bg-1);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-lg);
            padding: 30px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        }

        .glass-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
        }

        .card-title {
            font-family: var(--font-display);
            font-size: 1.5rem;
            color: var(--text-200);
            letter-spacing: 1px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .input-group {
            margin-bottom: 15px;
        }

        .admin-input {
            width: 100%;
            padding: 14px 16px;
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            color: #fff;
            font-family: var(--font-body);
            font-size: 0.95rem;
            transition: all 0.3s;
        }

        .admin-input:focus {
            outline: none;
            border-color: var(--accent);
            background: rgba(0, 0, 0, 0.6);
        }

        .btn-action {
            width: 100%;
            padding: 14px;
            background: var(--accent);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 10px;
        }

        .btn-action:hover {
            background: #d32f3e;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(230, 57, 70, 0.3);
        }

        /* Data Tables */
        .table-container {
            width: 100%;
            overflow-x: auto;
            background: var(--bg-1);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: var(--radius-lg);
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .data-table th {
            background: rgba(255, 255, 255, 0.02);
            padding: 16px 20px;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-400);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .data-table td {
            padding: 16px 20px;
            font-size: 0.9rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.02);
            color: var(--text-200);
            vertical-align: middle;
        }

        .data-table tr:hover td {
            background: rgba(255, 255, 255, 0.01);
        }

        .badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .badge-admin {
            background: rgba(139, 92, 246, 0.2);
            color: #a78bfa;
        }

        .badge-genuine {
            background: rgba(0, 229, 255, 0.2);
            color: #00e5ff;
        }

        .badge-pending {
            background: rgba(245, 158, 11, 0.2);
            color: #f59e0b;
        }

        .badge-approved {
            background: rgba(34, 197, 94, 0.2);
            color: #4ade80;
        }

        .btn-sm {
            padding: 6px 12px;
            font-size: 0.75rem;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
        }

        .btn-danger {
            background: rgba(230, 57, 70, 0.1);
            color: var(--accent);
            border: 1px solid rgba(230, 57, 70, 0.2);
        }

        .btn-danger:hover {
            background: var(--accent);
            color: #fff;
        }

        .btn-success {
            background: rgba(34, 197, 94, 0.1);
            color: #4ade80;
            border: 1px solid rgba(34, 197, 94, 0.2);
        }

        .btn-success:hover {
            background: #22c55e;
            color: #fff;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--text-200);
        }

        .btn-outline:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
        }
    </style>
</head>

<body>

    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="admin-brand">
            <div class="admin-logo-text">HOST</div>
        </div>
        <div class="admin-nav">
            <div class="nav-link" onclick="switchTab('stats', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20V10"></path>
                    <path d="M18 20V4"></path>
                    <path d="M6 20v-4"></path>
                </svg>
                Match Stats
            </div>
            <div class="nav-link active" onclick="switchTab('users', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
                User Directory
            </div>
            <div class="nav-link" onclick="switchTab('banned', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
                </svg>
                Banned Users
            </div>
            <div class="nav-link" onclick="switchTab('trusted', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="8.5" cy="7" r="4"></circle>
                    <polyline points="17 11 19 13 23 9"></polyline>
                </svg>
                Trusted Players
            </div>
            <div class="nav-link" onclick="switchTab('registrations', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
                Registrations
            </div>
            <div class="nav-link" onclick="switchTab('qualification', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon
                        points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2">
                    </polygon>
                </svg>
                Qualification Matches
            </div>
            <div class="nav-link" onclick="switchTab('season-regs', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                    <polyline points="2 17 12 22 22 17"></polyline>
                    <polyline points="2 12 12 17 22 12"></polyline>
                </svg>
                Season Matches
            </div>

            <div class="nav-link" onclick="switchTab('updates', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path
                        d="M2 16.1A5 5 0 0 1 5.9 20M2 12.05A9 9 0 0 1 9.95 20M2 8V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-6">
                    </path>
                    <line x1="2" y1="20" x2="2.01" y2="20"></line>
                </svg>
                Platform Updates
            </div>
            <div class="nav-link" onclick="switchTab('daily-content', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect>
                    <polygon points="10 8 16 12 10 16 10 8"></polygon>
                </svg>
                Daily Content
            </div>
            <div class="nav-link" onclick="switchTab('clips', this)">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"></rect>
                    <line x1="7" y1="2" x2="7" y2="22"></line>
                    <line x1="17" y1="2" x2="17" y2="22"></line>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <line x1="2" y1="7" x2="7" y2="7"></line>
                    <line x1="2" y1="17" x2="7" y2="17"></line>
                    <line x1="17" y1="17" x2="22" y2="17"></line>
                    <line x1="17" y1="7" x2="22" y2="7"></line>
                </svg>
                Clip Submissions
            </div>
        </div>
    </div>

    <!-- Content -->
    <div class="admin-content">

        <!-- Tab: Match Intel -->
        <div id="tab-stats" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title">Match Intel</h1>
                <div class="page-desc">View full team formations, slots, and player data for registered matches.</div>
            </div>
            <div class="admin-grid">
                <div class="glass-card" style="grid-column: 1 / -1;">
                    <div class="card-title">FETCH MATCH ROSTER</div>
                    <div class="input-group" style="display:flex; gap:10px; max-width: 400px;">
                        <input type="text" id="stat-match" class="admin-input" placeholder="Numeric Match ID (e.g. 3)">
                        <button class="btn-action" style="margin-top:0; width:auto; padding:0 20px; background:#4f46e5;"
                            onclick="fetchMatchDetails()">FETCH</button>
                    </div>

                    <!-- Match Intel Details Panel -->
                    <div id="match-details-panel" style="display:none; margin-top: 25px;">
                        <div style="display:flex; gap: 30px; flex-wrap: wrap; margin-bottom: 20px; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.05); padding:20px; border-radius:10px;">
                            <div style="flex: 1; min-width: 200px;">
                                <div style="color:var(--text-400); font-size:0.75rem; letter-spacing:1px; margin-bottom:5px;">FORMAT & MODE</div>
                                <div id="intel-format" style="color:var(--cyan); font-weight:600; font-size:1.1rem; text-transform:uppercase;">—</div>
                            </div>
                            <div style="flex: 1; min-width: 200px;">
                                <div style="color:var(--text-400); font-size:0.75rem; letter-spacing:1px; margin-bottom:5px;">SCHEDULE</div>
                                <div id="intel-schedule" style="color:#fff; font-size:1.1rem; font-weight:600;">—</div>
                            </div>
                            <div style="flex: 1; min-width: 200px;">
                                <div style="color:var(--text-400); font-size:0.75rem; letter-spacing:1px; margin-bottom:5px;">ROOM INFO</div>
                                <div id="intel-room" style="color:var(--text-200); font-family:var(--font-mono); font-size:1rem;">—</div>
                            </div>
                        </div>

                        <div class="card-title" style="font-size: 1.2rem; margin-bottom: 15px;">TEAM FORMATION</div>
                        <div class="table-container">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Operator</th>
                                        <th>Blaze ID</th>
                                        <th>In-Game ID</th>
                                        <th>Discord</th>
                                        <th style="text-align:right;">Profile</th>
                                    </tr>
                                </thead>
                                <tbody id="intel-team-list">
                                    <!-- Populated dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>


            </div>
        </div>

        <!-- Tab: User Directory -->
        <div id="tab-users" class="tab-pane active">
            <div class="page-header">
                <h1 class="page-title">User Intelligence</h1>
                <div class="page-desc">Manage verified operators and eliminate cheaters.</div>
            </div>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Operator</th>
                            <th>Player ID</th>
                            <th>Status Flags</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="user-list">
                        <tr>
                            <td colspan="4" style="text-align:center;">Loading database...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tab: Banned Users -->
        <div id="tab-banned" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title" style="color: var(--accent);">Blacklist</h1>
                <div class="page-desc">Permanently severed accounts due to TOS violations.</div>
            </div>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Operator</th>
                            <th>Player ID</th>
                            <th>Ban Reason</th>
                            <th style="text-align:right;">Timestamp</th>
                        </tr>
                    </thead>
                    <tbody id="banned-list">
                        <tr>
                            <td colspan="4" style="text-align:center;">Loading blacklist...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tab: Trusted Players -->
        <div id="tab-trusted" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title" style="color: #00e5ff;">Trusted Players</h1>
                <div class="page-desc">The elite verified members of the community.</div>
            </div>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Operator</th>
                            <th>Player ID</th>
                            <th>Email</th>
                            <th style="text-align:right;">Status</th>
                        </tr>
                    </thead>
                    <tbody id="trusted-list">
                        <tr>
                            <td colspan="4" style="text-align:center;">Loading trusted players...</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="page-header" style="margin-top: 40px;">
                <h1 class="page-title">Verified Matches</h1>
                <div class="page-desc">History of matches that have been successfully verified and completed.</div>
            </div>
            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Operator</th>
                            <th>Discord / Comm</th>
                            <th>Format & Mode</th>
                            <th>Schedule</th>
                            <th>Status</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="verified-list">
                        <tr>
                            <td colspan="6" style="text-align:center;">Loading verified matches...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tab: Registrations -->
        <div id="tab-registrations" class="tab-pane">
            <div class="page-header">
                <h1 class="page-title">Queue Requests</h1>
                <div class="page-desc">Approve or reject pending tournament entries.</div>
            </div>

            <div class="glass-card" style="margin-bottom: 30px;">
                <div class="card-title">7-DAY SLOT REPORT</div>
                <div style="color:var(--text-400); font-size:0.85rem; margin-bottom:20px;">Overview of booked slots (Approved) for the next 7 days.</div>
                <div id="slot-report-container" style="display: flex; gap: 15px; flex-wrap: wrap;">
                    <div style="color:var(--text-muted); font-size:0.9rem;">Loading report...</div>
                </div>
            </div>

            <div class="table-container">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Applicant</th>
                            <th>Discord / Comm</th>
                            <th>Format & Mode</th>
                            <th>Schedule</th>
                            <th>Status</th>
                            <th>Feedback</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="reg-list">
                        <tr>
                            <td colspan="6" style="text-align:center;">Loading queue...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    <!-- Tab: Qualification Matches -->
    <div id="tab-qualification" class="tab-pane">
        <div class="page-header">
            <h1 class="page-title">Qualification Matches</h1>
            <div class="page-desc">Track all registered matches and manually mark them as Completed or Not Completed.
            </div>
        </div>
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Match ID</th>
                        <th>Operator</th>
                        <th>Schedule</th>
                        <th>Room Info</th>
                        <th>Status</th>
                        <th>Player Feedback</th>
                        <th style="text-align:right;">Admin Actions</th>
                    </tr>
                </thead>
                <tbody id="qual-list">
                    <tr>
                        <td colspan="7" style="text-align:center;">Loading matches...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Tab: Season Registrations -->
    <div id="tab-season-regs" class="tab-pane">
        <div class="page-header">
            <h1 class="page-title">Season Matches</h1>
            <div class="page-desc">Track and manage verified player registrations for Season Matches.</div>
        </div>
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Operator</th>
                        <th>Discord</th>
                        <th>Match Series</th>
                        <th>Date Submitted</th>
                        <th>Status</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody id="season-reg-list">
                    <tr>
                        <td colspan="6" style="text-align:center;">Loading season queue...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>



    <!-- Tab: Platform Updates -->
    <div id="tab-updates" class="tab-pane">
        <div class="page-header">
            <h1 class="page-title">Broadcast Network</h1>
            <div class="page-desc">Push live intel to all operator dashboards globally.</div>
        </div>
        <div class="admin-grid">
            <div class="glass-card">
                <div class="card-title">COMPOSE BROADCAST</div>
                <div style="color:var(--text-400); font-size:0.85rem; margin-bottom:20px;">Send a live notification to
                    all connected players on the Hub.</div>
                <div class="input-group">
                    <label
                        style="color:var(--text-300); font-size:0.85rem; margin-bottom:8px; display:block; font-weight:600;">Headline
                        / Message</label>
                    <input type="text" id="news-title" class="admin-input" placeholder="Enter broadcast message...">
                </div>
                <div class="input-group">
                    <label
                        style="color:var(--text-300); font-size:0.85rem; margin-bottom:8px; display:block; font-weight:600;">Broadcast
                        Tag</label>
                    <select id="news-tag" class="admin-input" onchange="updateTagClass()">
                        <option value="UPDATE">UPDATE</option>
                        <option value="MAINTENANCE">MAINTENANCE</option>
                        <option value="NEW SEASON">NEW SEASON</option>
                        <option value="ESPORTS">ESPORTS</option>
                    </select>
                    <input type="hidden" id="news-tagClass" value="tag-update">
                </div>
                <button class="btn-action"
