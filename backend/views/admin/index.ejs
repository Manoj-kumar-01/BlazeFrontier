    <!-- Scripts -->
    <script>
        function switchTab(tabId, element) {
            document.querySelectorAll('.tab-pane').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'));
            document.getElementById('tab-' + tabId).classList.add('active');
            element.classList.add('active');

            localStorage.setItem('adminActiveTab', tabId);

            // Auto refresh specific tabs
            if (tabId === 'users') loadUsers();
            if (tabId === 'banned') loadBannedUsers();
            if (tabId === 'registrations') loadRegistrations();
            if (tabId === 'qualification') loadQualificationMatches();
            if (tabId === 'season-regs') loadSeasonRegistrations();
            if (tabId === 'clips') loadClips();
            if (tabId === 'daily-content') loadDailyContent();
        }

        async function loadDailyContent() {
            try {
                const res = await fetch('<%= adminPrefix %>/api/daily-content', { cache: 'no-store' });
                if (res.ok) {
                    const data = await res.json();
                    if (data) {
                        document.getElementById('dc-yt').value = data.youtubeLink || '';
                        document.getElementById('dc-fb').value = data.facebookLink || '';
                    }
                }
            } catch (e) { console.error(e); }
        }

        async function submitDailyContent(e) {
            e.preventDefault();
            const btn = e.target.querySelector('button');
            const originalText = btn.innerText;
            btn.innerText = 'SAVING...';

            try {
                const res = await fetch('<%= adminPrefix %>/api/daily-content', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        youtubeLink: document.getElementById('dc-yt').value,
                        facebookLink: document.getElementById('dc-fb').value
                    })
                });

                if (res.ok) {
                    btn.innerText = 'SAVED SUCCESSFULLY';
                    btn.style.background = '#22c55e';
                    setTimeout(() => {
                        btn.innerText = originalText;
                        btn.style.background = 'var(--cyan)';
                    }, 2000);
                } else {
                    alert('Error saving daily content');
                    btn.innerText = originalText;
                }
            } catch (err) {
                alert('Server error');
                btn.innerText = originalText;
            }
        }

        async function loadUsers() {
            const list = document.getElementById('user-list');
            try {
                const res = await fetch(`<%= adminPrefix %>/api/users?t=${Date.now()}`, { cache: 'no-store' });
                if (!res.ok) return list.innerHTML = '<tr><td colspan="4" style="text-align:center;">Access Denied.</td></tr>';
                const users = await res.json();
                if (users.length === 0) return list.innerHTML = '<tr><td colspan="4" style="text-align:center;">No users found.</td></tr>';

                list.innerHTML = users.map(u => `
                    <tr>
                        <td style="font-weight:600; color:#fff;">${u.username}</td>
                        <td style="font-family:var(--font-mono); font-size:0.8rem;">${u.playerId}</td>
                        <td>
                            ${u.isAdmin ? '<span class="badge badge-admin">ADMIN</span>' : ''}
                            ${u.isGenuine ? '<span class="badge badge-genuine">GENUINE</span>' : ''}
                            ${!u.isAdmin && !u.isGenuine ? '<span style="color:var(--text-400); font-size:0.8rem;">Standard</span>' : ''}
                        </td>
                        <td style="text-align:right;">
                            <div style="display:flex; justify-content:flex-end; gap:8px;">
                                ${!u.isAdmin ? `<button class="btn-sm btn-danger" onclick="banUser('${u._id}')">FLAG CHEATER</button>` : ''}
                            </div>
                        </td>
                    </tr>
                `).join('');

                const trustedUsers = users.filter(u => u.isGenuine);
                const tList = document.getElementById('trusted-list');
                if (trustedUsers.length === 0) {
                    tList.innerHTML = '<tr><td colspan="4" style="text-align:center;">No trusted players yet.</td></tr>';
                } else {
                    tList.innerHTML = trustedUsers.map(u => `
                        <tr>
                            <td style="font-weight:600; color:#fff;">${u.inGameName || u.username}</td>
                            <td style="font-family:var(--font-mono); font-size:0.8rem;">${u.playerId}</td>
                            <td style="color:var(--text-300); font-size:0.85rem;">${u.email || 'N/A'}</td>
                            <td style="text-align:right;">
                                <span class="badge badge-genuine" style="box-shadow: 0 0 10px rgba(0, 229, 255, 0.4);">✔ VERIFIED</span>
                        </tr>
                    `).join('');
                }

                // Also load verified matches
                const regRes = await fetch(`<%= adminPrefix %>/api/registrations?t=${Date.now()}`, { cache: 'no-store' });
                if (regRes.ok) {
                    const regs = await regRes.json();
                    const verifiedRegs = regs.filter(r => r.status === 'Verified' || r.status === 'Completed').sort((a, b) => (a.matchId || 0) - (b.matchId || 0));
                    const vList = document.getElementById('verified-list');
                    if (verifiedRegs.length === 0) {
                        vList.innerHTML = '<tr><td colspan="6" style="text-align:center;">No verified matches yet.</td></tr>';
                    } else {
                        vList.innerHTML = verifiedRegs.map(r => {
                            return `
                            <tr>
                                <td style="font-weight:600; color:#fff;">
                                    ${r.userId ? (r.userId.inGameName || r.userId.username) : 'Unknown'}
                                    ${r.userId && r.userId.email ? `<div style="color:var(--text-muted); font-size:0.75rem; font-weight:normal; margin-top:2px; user-select:all;">${r.userId.email}</div>` : ''}
                                </td>
                                <td style="color:var(--cyan); font-size:0.85rem;">${r.discord}</td>
                                <td style="font-size:0.85rem;">
                                    ${r.format.toUpperCase()} • ${r.mode.toUpperCase()}
                                    ${r.matchId ? `<div style="color:var(--blaze-orange); font-size:0.75rem; margin-top:4px; font-weight:600;">Match #${r.matchId}</div>` : ''}
                                    ${r.teamMembers && r.teamMembers.length > 0 ? `<div style="color:var(--orange); font-size:0.75rem; margin-top:4px;">Team: ${r.teamMembers.join(', ')}</div>` : ''}
                                </td>
                                <td style="font-size:0.85rem;"><div style="color:#fff;">${r.startDate || 'N/A'}</div><div style="color:var(--text-muted);">${r.timeSlot || 'N/A'}</div></td>
                                <td><span class="badge" style="background:rgba(34,197,94,0.2);color:#22c55e;">Verified</span></td>
                                <td style="text-align:right;">
                                    <div style="display:flex; flex-direction:column; gap:6px; align-items:stretch; min-width:140px;">
                                        <button class="btn-sm btn-danger" style="background:#dc2626;" onclick="deleteRegistration('${r._id}')">DELETE RECORD</button>
                                    </div>
                                </td>
                            </tr>
                            `;
                        }).join('');
                    }
                }
            } catch (e) { console.error(e); }
        }

        async function loadBannedUsers() {
            const list = document.getElementById('banned-list');
            try {
                const res = await fetch(`<%= adminPrefix %>/api/banned-users?t=${Date.now()}`, { cache: 'no-store' });
                if (!res.ok) return list.innerHTML = '<tr><td colspan="4" style="text-align:center;">Failed to load.</td></tr>';
                const banned = await res.json();
                if (banned.length === 0) return list.innerHTML = '<tr><td colspan="4" style="text-align:center;">No banned users. Good job!</td></tr>';

                list.innerHTML = banned.map(b => `
                    <tr>
                        <td style="font-weight:600; color:var(--accent);">${b.username}</td>
                        <td style="font-family:var(--font-mono); font-size:0.8rem;">${b.playerId}</td>
                        <td style="font-size:0.8rem;">${b.reason}</td>
                        <td style="text-align:right; font-size:0.8rem; color:var(--text-400);">${new Date(b.bannedAt).toLocaleDateString()}</td>
                    </tr>
                `).join('');
            } catch (e) { console.error(e); }
        }

        function canSendCreds(dateStr, timeStr) {
            if (!dateStr || !timeStr) return true;
            try {
                const [time, modifier] = timeStr.split(' ');
                let [hours, minutes] = time.split(':');
                if (hours === '12') hours = '00';
                if (modifier && modifier.toUpperCase() === 'PM') hours = (parseInt(hours, 10) + 12).toString();

                const slotDate = new Date(`${dateStr}T${hours.padStart(2, '0')}:${minutes.padStart(2, '0')}:00`);
                const now = new Date();
                const diffMins = (slotDate - now) / 60000;

                return diffMins <= 20;
            } catch (e) {
                return true;
            }
        }

        function isMatchCompleted(dateStr, timeStr) {
            if (!dateStr || !timeStr) return false;
            try {
                const [time, modifier] = timeStr.split(' ');
                let [hours, minutes] = time.split(':');
                if (hours === '12') hours = '00';
                if (modifier && modifier.toUpperCase() === 'PM') hours = (parseInt(hours, 10) + 12).toString();

                const slotDate = new Date(`${dateStr}T${hours.padStart(2, '0')}:${minutes.padStart(2, '0')}:00`);
                const now = new Date();
                const diffMins = (slotDate - now) / 60000;

                return diffMins <= -30;
            } catch (e) {
                return false;
            }
        }

        async function loadRegistrations() {
            const list = document.getElementById('reg-list');
            const reportContainer = document.getElementById('slot-report-container');
            
            if (reportContainer) {
                try {
                    const rRes = await fetch(`<%= adminPrefix %>/api/slot-report?t=${Date.now()}`, { cache: 'no-store' });
                    if (rRes.ok) {
                        const report = await rRes.json();
                        reportContainer.innerHTML = report.map(r => `
                            <div style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.05); border-radius:8px; padding:15px; min-width: 120px; text-align: center; flex: 1;">
                                <div style="color:var(--text-400); font-size:0.85rem; margin-bottom: 8px; font-weight:600;">${r.date}</div>
                                <div style="color:var(--cyan); font-size:1.8rem; font-family:var(--font-display);">${r.count} <span style="font-size:0.9rem; color:var(--text-muted);">/ 5</span></div>
                            </div>
                        `).join('');
                    }
                } catch(e) { console.error('Error loading slot report', e); }
            }

            try {
                const res = await fetch(`<%= adminPrefix %>/api/registrations?t=${Date.now()}`, { cache: 'no-store' });
                if (!res.ok) return;
                const regs = await res.json();

                const baseRegs = regs.filter(r => r.format !== 'Season Match').sort((a, b) => (a.matchId || 0) - (b.matchId || 0));
                const pendingRegs = baseRegs.filter(r => r.status !== 'Verified' && r.status !== 'Completed');

                if (pendingRegs.length === 0) {
                    list.innerHTML = '<tr><td colspan="7" style="text-align:center;">No pending queue requests.</td></tr>';
                } else {
                    list.innerHTML = pendingRegs.map(r => {
                        const badgeClass = r.status === 'Approved' ? 'badge-approved' : (r.status === 'Pending' ? 'badge-pending' : (r.status === 'Awaiting Verification' ? 'badge-pending' : ''));
                        let badgeHtml = r.status !== 'Rejected' ? `<span class="badge ${badgeClass}">${r.status}</span>` : `<span class="badge" style="background:rgba(230,57,70,0.2);color:var(--accent);">${r.status}</span>`;

                        if (r.status === 'Awaiting Verification') {
                            badgeHtml = `<span class="badge" style="background:rgba(252, 211, 77, 0.2);color:#fcd34d;">Awaiting Verification</span>`;
                        }

                        let btnHtml = '';
                        if (r.status === 'Pending') {
                            btnHtml = `
                                <div style="display:flex; flex-direction:column; gap:6px; align-items:stretch; min-width:140px;">
                                    <button class="btn-sm btn-success" onclick="updateRegistration('${r._id}', 'Approved')">APPROVE</button>
                                    <button class="btn-sm btn-danger" style="background:#dc2626;" onclick="deleteRegistration('${r._id}')">REJECT & DELETE</button>
                                </div>
                        `;
                        } else if (r.status === 'Awaiting Verification') {
                            btnHtml = `
                                <div style="display:flex; flex-direction:column; gap:6px; align-items:stretch; min-width:140px;">
                                    <button class="btn-sm btn-success" style="background:#fbbf24; color:#000; font-weight:bold;" onclick="verifyPlayer('${r._id}')">✨ VERIFY PLAYER ✨</button>
                                    <button class="btn-sm btn-danger" style="background:#dc2626;" onclick="deleteRegistration('${r._id}')">REJECT</button>
                                </div>
                        `;
                        } else if (r.status === 'Approved') {
                            const canSend = canSendCreds(r.startDate, r.timeSlot);
                            const isCompleted = isMatchCompleted(r.startDate, r.timeSlot);
                            const regData = JSON.stringify({
                                matchId: r.matchId || 'TBA',
                                startDate: r.startDate || 'N/A',
                                timeSlot: r.timeSlot || 'N/A',
                                format: r.format || 'N/A',
                                mode: r.mode || 'N/A',
                                inGameName: r.userId ? (r.userId.inGameName || r.userId.username) : 'Unknown',
                                email: r.userId ? r.userId.email : 'N/A',
                                gameUid: r.userId ? r.userId.gameUid : 'N/A',
                                playerId: r.userId ? r.userId.playerId : 'N/A'
                            }).replace(/\"/g, '&quot;');

                            if (isCompleted) {
                                btnHtml = `
                                <div style="display:flex; flex-direction:column; gap:6px; align-items:stretch; min-width:140px;">
                                    <button class="btn-sm btn-success" style="background:linear-gradient(90deg, #ff8a00, #e52e71); color:#fff; font-weight:bold; box-shadow: 0 0 10px rgba(255,138,0,0.5);" onclick="openVerifySquadModal('${r._id}', this.getAttribute('data-reg'))" data-reg="${regData}">🏆 VERIFY PLAYERS</button>
                                    <button class="btn-sm btn-danger" style="background:#dc2626;" onclick="deleteRegistration('${r._id}')">DELETE</button>
                                </div>
                            `;
                            } else if (canSend) {
                                btnHtml = `
                                <div style="display:flex; flex-direction:column; gap:6px; align-items:stretch; min-width:140px;">
