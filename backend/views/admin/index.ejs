        async function loadQualificationMatches() {
            const list = document.getElementById('qual-list');
            try {
                const res = await fetch(`<%= adminPrefix %>/api/registrations?t=${Date.now()}`, { cache: 'no-store' });
                if (!res.ok) return;
                const regs = await res.json();

                const filteredRegs = regs.filter(r => r.format !== 'Season Match' && r.status !== 'Verified').sort((a, b) => (a.matchId || 0) - (b.matchId || 0));
                if (filteredRegs.length === 0) return list.innerHTML = '<tr><td colspan="6" style="text-align:center;">No qualification matches found.</td></tr>';

                list.innerHTML = filteredRegs.map(r => {
                    const statusColor = r.isCompleted ? '#22c55e' : 'var(--text-400)';
                    const statusText = r.isCompleted ? 'COMPLETED' : 'INCOMPLETE';
                    return `
                    <tr>
                        <td style="font-weight:bold; color:var(--blaze-orange); font-size: 1.1rem;">#${r.matchId || '-'}</td>
                        <td style="font-weight:600; color:#fff;">
                            ${r.userId ? (r.userId.inGameName || r.userId.username) : 'Unknown'}
                        </td>
                        <td style="color:var(--text-300); font-size:0.85rem;">
                            ${r.startDate || 'N/A'} <br> <span style="color:var(--cyan);">${r.timeSlot || 'N/A'}</span>
                        </td>
                        <td>
                            ${r.roomId ? `
                                <div style="font-family:var(--font-mono); font-size:0.8rem; background:rgba(0,188,212,0.1); border:1px solid rgba(0,188,212,0.3); padding:4px 8px; border-radius:4px; color:#00bcd4;">
                                    ID: <span style="color:#fff;">${r.roomId}</span><br>
                                    Pass: <span style="color:#fff;">${r.roomPassword}</span>
                                </div>
                            ` : `<span style="color:var(--text-muted); font-size:0.8rem;">Not Dispatched</span>`}
                        </td>
                        <td><span style="font-weight:bold; color:${statusColor};">${statusText}</span></td>
                        <td style="font-size:0.85rem; font-weight:600; color: ${r.playerFeedback === 'Completed' ? '#4ade80' : r.playerFeedback === 'Not Completed' ? '#f87171' : 'var(--text-400)'};">${r.playerFeedback || 'Pending'}</td>
                        <td style="text-align:right;">
                            <div style="display:flex; flex-direction:row; justify-content:flex-end; gap:6px; flex-wrap:wrap; min-width:200px;">
                                <button class="btn-sm btn-success" style="font-weight:bold; color:#4ade80;" onclick="markMatchCompleted('${r._id}', true)"><i class="fas fa-check"></i> COMPLETED</button>
                                <button class="btn-sm btn-danger" style="font-weight:bold; color:#f87171;" onclick="markMatchCompleted('${r._id}', false)"><i class="fas fa-times"></i> INCOMPLETE</button>
                            </div>
                        </td>
                    </tr>
                `}).join('');
            } catch (e) { console.error(e); }
        }

        async function markMatchCompleted(id, isCompleted) {
            try {
                const res = await fetch(`<%= adminPrefix %>/api/registrations/${id}/completion`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ isCompleted })
                });
                if (res.ok) {
                    loadQualificationMatches();
                } else {
                    alert('Error marking match status.');
                }
            } catch (e) { console.error(e); }
        }


