            <div id="squad-members-list" style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px;">
                <div style="text-align:center; padding: 20px; color:var(--text-muted);">Loading squad details...</div>
            </div>

            <div style="text-align: center;">
                <button type="button" id="btn-verify-squad-submit" class="btn-action"
                    style="background: linear-gradient(90deg, #ff8a00, #e52e71); width: 100%; box-shadow: 0 4px 15px rgba(255,138,0,0.3);">VERIFY
                    ALL MEMBERS</button>
