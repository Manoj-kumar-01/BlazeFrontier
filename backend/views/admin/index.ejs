    <!-- Squad Verify Modal -->
    <div id="squad-verify-modal"
        style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.85); z-index:9999; justify-content:center; align-items:center;">
        <div class="glass-card" style="width: 550px; max-height: 80vh; overflow-y: auto; position:relative;">
            <button type="button" onclick="document.getElementById('squad-verify-modal').style.display='none'"
                style="position:absolute; top:15px; right:15px; background:none; border:none; color:var(--text-muted); font-size:1.5rem; cursor:pointer;">&times;</button>
            <div class="card-title" id="verify-modal-title" style="margin-bottom: 5px;">VERIFY SQUAD</div>
            <div style="color:var(--text-muted); margin-bottom:15px; font-size:0.85rem;">Review match participants
                before granting Trusted Player status.</div>

            <div
                style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.05); border-radius:8px; padding:15px; margin-bottom:20px; font-size:0.85rem;">
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
                    <div><span style="color:var(--text-400);">Match ID:</span> <span id="v-modal-m-id"
                            style="color:var(--blaze-orange); font-weight:bold;"></span></div>
                    <div><span style="color:var(--text-400);">Date:</span> <span id="v-modal-date"
                            style="color:#fff;"></span></div>
                    <div><span style="color:var(--text-400);">Slot:</span> <span id="v-modal-slot"
                            style="color:var(--cyan);"></span></div>
