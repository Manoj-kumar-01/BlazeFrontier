        async function openVerifySquadModal(matchId, regDataStr) {
            let regData = {};
            try { regData = JSON.parse(regDataStr); } catch (e) { console.error(e); }

            document.getElementById('v-modal-m-id').innerText = regData.matchId ? `#${regData.matchId}` : 'N/A';
            document.getElementById('v-modal-date').innerText = regData.startDate || 'N/A';
            document.getElementById('v-modal-slot').innerText = regData.timeSlot || 'N/A';
            document.getElementById('v-modal-format').innerText = regData.format ? `${regData.format} (${regData.mode})` : 'N/A';

            document.getElementById('squad-members-list').innerHTML = '<div style="text-align:center; padding: 20px; color:var(--text-muted);">Loading squad details...</div>';
            document.getElementById('squad-verify-modal').style.display = 'flex';

            try {
                const res = await fetch(`<%= adminPrefix %>/api/squad-details/${matchId}`);
                if (!res.ok) throw new Error('Failed to load squad details');
                const data = await res.json();

                let html = '';
                if (data.squad && data.squad.length > 0) {
                    html = data.squad.map(u => `
                        <div style="background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.05); border-radius:8px; padding:15px; font-size:0.85rem;">
                            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                                <div>
                                    <div style="color:#fff; font-weight:bold; font-size: 1rem; margin-bottom: 4px;">${u.inGameName || u.username}</div>
                                    <div style="color:var(--text-400);">Email: <span style="color:#fff;">${u.email || 'N/A'}</span></div>
                                </div>
                                <div style="text-align: right;">
                                    <div style="color:var(--text-400);">Game UID: <span style="color:#fff;">${u.gameUid || 'N/A'}</span></div>
                                    <div style="color:var(--text-400);">Blaze ID: <span style="color:var(--blaze-orange); font-family:var(--font-mono);">${u.playerId || 'N/A'}</span></div>
                                </div>
                            </div>
                        </div>
                    `).join('');
                } else {
                    html = '<div style="text-align:center; padding: 20px; color:var(--text-muted);">No members found.</div>';
                }

                let titleText = 'VERIFY SQUAD';
                let btnText = 'VERIFY ALL MEMBERS';
                if (data.squad) {
                    if (data.squad.length === 1) {
                        titleText = 'VERIFY PLAYER';
                        btnText = 'VERIFY PLAYER';
                    } else if (data.squad.length === 2) {
                        titleText = 'VERIFY DUO';
                        btnText = 'VERIFY BOTH MEMBERS';
                    }
                }

                const titleEl = document.getElementById('verify-modal-title');
                if (titleEl) titleEl.innerText = titleText;

                document.getElementById('squad-members-list').innerHTML = html;
                const btnSubmit = document.getElementById('btn-verify-squad-submit');
                btnSubmit.innerText = btnText;
                btnSubmit.onclick = () => verifySquadSubmit(matchId);
            } catch (err) {
                console.error(err);
                document.getElementById('squad-members-list').innerHTML = '<div style="text-align:center; padding: 20px; color:#ef4444;">Error loading squad.</div>';
            }
        }

        async function verifySquadSubmit(matchId) {
            const btn = document.getElementById('btn-verify-squad-submit');
            btn.disabled = true;
            btn.innerText = 'VERIFYING...';

            try {
                const res = await fetch(`<%= adminPrefix %>/api/verify-squad/${matchId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (res.ok) {
                    document.getElementById('squad-verify-modal').style.display = 'none';
                    loadRegistrations();
                    loadQualificationMatches();
                } else {
                    const data = await res.json();
                    alert(data.msg || 'Error verifying squad');
                }
            } catch (err) {
                console.error(err);
                alert('Server error while verifying squad');
            } finally {
                btn.disabled = false;
                btn.innerText = 'VERIFY ALL MEMBERS';
            }
        }

        async function submitCredentials(e) {
            e.preventDefault();
            const id = document.getElementById('modal-match-id').value;
            const roomId = document.getElementById('modal-room-id').value;
            const roomPassword = document.getElementById('modal-room-pass').value;

            if (!id) return alert('No match selected');

            const btn = e.target.querySelector('button');
            const origText = btn.innerText;
            btn.innerText = "DISPATCHING...";
            btn.disabled = true;

            try {
                const res = await fetch(`<%= adminPrefix %>/api/registrations/${id}/credentials`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ roomId, roomPassword })
                });

                if (res.ok) {
                    alert('Credentials sent successfully!');
                    document.getElementById('creds-modal').style.display = 'none';
                    loadRegistrations(); // reload registrations tab
                } else {
                    const data = await res.json();
                    alert('Error: ' + data.msg);
                }
            } catch (err) {
                alert('Failed to send credentials.');
            } finally {
                btn.innerText = origText;
                btn.disabled = false;
            }
        }

        async function submitPotd(e) {
            e.preventDefault();
            const playerId = document.getElementById('potd-player').value;
            const playerName = document.getElementById('potd-name').value;
            const title = document.getElementById('potd-title').value;
            const videoFile = document.getElementById('potd-clip').files[0];

            if (!playerId || !videoFile) {
                alert("Blaze ID and Video File are required!");
                return;
            }

            const formData = new FormData();
            formData.append('playerId', playerId);
            if (playerName) formData.append('playerName', playerName);
            formData.append('title', title);
            formData.append('video', videoFile);

            try {
                const btn = e.target.querySelector('button');
                const origText = btn.innerText;
                btn.innerText = "UPLOADING...";
                btn.disabled = true;

                const response = await fetch('<%= adminPrefix %>/api/potd', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();
                if (response.ok) {
                    alert('Player of the Day updated successfully!');
                    document.getElementById('potd-form').reset();
                } else {
                    alert('Error: ' + data.msg);
                }
            } catch (err) {
                console.error(err);
                alert('Upload failed. Please check the console.');
            } finally {
                const btn = e.target.querySelector('button');
                btn.innerText = "SET PLAYER OF THE DAY";
                btn.disabled = false;
            }
        }

        async function fetchMatchDetails() {
            const matchId = document.getElementById('stat-match').value;
            if (!matchId) return alert('Enter Match ID first');

            try {
                const res = await fetch(`<%= adminPrefix %>/api/registration/match-id/${matchId}`);
                
                if (!res.ok) {
                    alert('Match Registration not found.');
                    document.getElementById('match-details-panel').style.display = 'none';
                    return;
                }
                
                const data = await res.json();
                const reg = data.registration;
                const team = data.teamDetails || [];

                document.getElementById('intel-format').innerText = `${reg.format} • ${reg.mode}`;
                document.getElementById('intel-schedule').innerText = `${reg.startDate} @ ${reg.timeSlot}`;
                document.getElementById('intel-room').innerHTML = reg.roomId ? `ID: <span style="color:#fff">${reg.roomId}</span> | Pass: <span style="color:#fff">${reg.roomPassword}</span>` : '<span style="color:var(--text-400)">Not Dispatched</span>';

                const tbody = document.getElementById('intel-team-list');
                tbody.innerHTML = '';
                
                if (team.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="5" style="text-align:center;">No player data fetched.</td></tr>`;
                } else {
                    team.forEach(u => {
                        const isLeader = reg.userId && reg.userId._id === u._id;
                        const leaderBadge = isLeader ? `<span style="background:var(--blaze-orange); color:#fff; padding:2px 6px; border-radius:4px; font-size:0.7rem; font-weight:bold; margin-left:8px;">LEADER</span>` : '';
                        
                        tbody.innerHTML += `
                            <tr>
                                <td>
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <img src="${u.profilePic || '/public/blaze_avatar.png'}" style="width:30px; height:30px; border-radius:50%; object-fit:cover;">
                                        <span style="font-weight:600; color:#fff;">${u.username || 'Unknown'} ${leaderBadge}</span>
                                    </div>
                                </td>
                                <td style="font-family:var(--font-mono); color:var(--text-300);">${u.playerId || '—'}</td>
                                <td style="color:#fff;">${u.inGameName || '—'}</td>
                                <td><span style="color:#5865F2; font-family:var(--font-mono);">${u.discordId || '—'}</span></td>
                                <td style="text-align:right;">
                                    <a href="<%= adminPrefix %>/player/${u.playerId}" target="_blank" class="btn-sm btn-outline" style="text-decoration:none; display:inline-block; border-color:var(--cyan); color:var(--cyan);">VIEW PROFILE</a>
                                </td>
                            </tr>
                        `;
                    });
                }

                document.getElementById('match-details-panel').style.display = 'block';

            } catch (e) {
                console.error(e);
            }
        }

        async function submitStats() {
            const matchId = document.getElementById('stat-match').value;
            const kills = document.getElementById('stat-kills').value;
            const survival = document.getElementById('stat-survival').value;
            const placement = document.getElementById('stat-placement').value;
            const res = await fetch(`<%= adminPrefix %>/api/match/${matchId}/score`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ kills, survivalTimeMinutes: survival, placement })
            });
            if (res.ok) { alert('Stats submitted successfully!'); }
        }

        async function banUser(userId) {
            if (!(await customConfirm('CONFIRM BAN: This will permanently delete the user and migrate them to the Banned Database. Proceed?'))) return;
            const res = await fetch(`<%= adminPrefix %>/api/ban/${userId}`, { method: 'POST' });
            if (res.ok) {
                alert('Operator Terminated.');
                loadUsers();
                loadBannedUsers();
            } else {
                const text = await res.text();
                alert('Failed to ban user. Server says: ' + text);
            }
        }

        async function toggleVerifyUser(userId) {
            const res = await fetch(`<%= adminPrefix %>/api/users/${userId}/verify`, { method: 'PUT' });
            if (res.ok) { loadUsers(); }
        }

        async function updateRegistration(id, status) {
            const res = await fetch(`<%= adminPrefix %>/api/registrations/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            if (res.ok) { loadRegistrations(); }
        }

        async function verifyPlayer(id) {
            if (!(await customConfirm('Are you sure you want to verify this player? They will receive the Golden Badge and 100 BlazeCoins!'))) return;
            const res = await fetch(`<%= adminPrefix %>/api/verify-player/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' }
            });
            if (res.ok) {
                alert('Player verified successfully!');
                loadRegistrations();
            } else {
                const data = await res.json();
                alert(data.msg || 'Error verifying player');
            }
        }

        async function deleteRegistration(id) {
            const reason = prompt('Are you sure you want to completely delete this registration? \n\nPlease enter the reason for rejection/deletion (this will be emailed to the user):');
            if (reason === null) return; // User cancelled

            const res = await fetch(`<%= adminPrefix %>/api/registrations/${id}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reason: reason || 'No reason provided.' })
            });
            if (res.ok) {
                loadRegistrations();
                loadSeasonRegistrations();
            }
        }

        function updateTagClass() {
            const tag = document.getElementById('news-tag').value;
            const classMap = { 'UPDATE': 'tag-update', 'MAINTENANCE': 'tag-maint', 'NEW SEASON': 'tag-season', 'ESPORTS': 'tag-esports' };
            document.getElementById('news-tagClass').value = classMap[tag] || 'tag-update';
        }

        async function publishUpdate() {
            const title = document.getElementById('news-title').value;
            const tag = document.getElementById('news-tag').value;
            const tagClass = document.getElementById('news-tagClass').value;
            if (!title) return alert('Title required');
            const res = await fetch('<%= adminPrefix %>/api/news', {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title, tag, tagClass })
            });
            if (res.ok) { alert('Intel Transmitted!'); document.getElementById('news-title').value = ''; }
        }

        async function submitPOTD(e) {
            e.preventDefault();
            const playerId = document.getElementById('potd-player').value;
            const title = document.getElementById('potd-title').value;
            const clipFile = document.getElementById('potd-clip').files[0];

            if (!playerId || !title || !clipFile) return alert('All fields required');
            if (clipFile.size > 50 * 1024 * 1024) return alert('File size must be under 50MB');

            const formData = new FormData();
            formData.append('playerId', playerId);
            formData.append('title', title);
            formData.append('clip', clipFile);

            const btn = e.target.querySelector('button');
            const originalText = btn.innerText;
            btn.innerText = 'UPLOADING...';
            btn.disabled = true;

            try {
                const res = await fetch('<%= adminPrefix %>/api/player-of-the-day', {
                    method: 'POST',
                    body: formData
                });
                if (res.ok) {
                    alert('Player of the Day Updated!');
                    e.target.reset();
                } else {
                    const data = await res.json();
                    alert('Failed: ' + (data.msg || 'Unknown error'));
                }
            } catch (err) {
                console.error(err);
                alert('An error occurred during upload.');
            } finally {
                btn.innerText = originalText;
                btn.disabled = false;
            }
        }

        async function loadClips() {
            const list = document.getElementById('clip-list');
            try {
                const res = await fetch(`<%= adminPrefix %>/api/clip-submissions?t=${Date.now()}`, { cache: 'no-store' });
                if (!res.ok) return list.innerHTML = '<div style="color:#ef4444;">Failed to load clips.</div>';
                const clips = await res.json();
                if (clips.length === 0) return list.innerHTML = '<div style="color:var(--text-muted);">No pending clip submissions.</div>';

                list.innerHTML = clips.map(c => `
                    <div class="glass-card" style="padding:0; overflow:hidden;">
                        <video src="${c.videoUrl}" controls style="width:100%; height:200px; background:#000;"></video>
                        <div style="padding: 20px;">
                            <div style="font-family:var(--font-display); font-size:1.3rem; margin-bottom:5px;">${c.title}</div>
                            <div style="color:var(--text-muted); font-size:0.85rem; margin-bottom:15px;">By ${c.userId ? (c.userId.inGameName || c.userId.username) : 'Unknown'} (${c.playerId})</div>
                            <div style="display:flex; gap:10px;">
                                <button class="btn-action" style="background:#22c55e; margin-top:0;" onclick="approveClip('${c._id}')">APPROVE (+50 BC)</button>
                                <button class="btn-action" style="background:#dc2626; margin-top:0;" onclick="rejectClip('${c._id}')">REJECT</button>
                            </div>
                        </div>
                    </div>
                `).join('');
            } catch (e) { console.error(e); }
        }

        async function approveClip(id) {
            if (!(await customConfirm('Approve this clip? This will publish it to the dashboard and instantly award 50 BlazeCoins.'))) return;
            const res = await fetch(`<%= adminPrefix %>/api/clip-submissions/${id}/approve`, { method: 'POST' });
            if (res.ok) {
                alert('Clip Approved & Rewarded!');
                loadClips();
            } else {
                alert('Error: ' + await res.text());
            }
        }

        async function rejectClip(id) {
            if (!(await customConfirm('Reject this clip?'))) return;
            const res = await fetch(`<%= adminPrefix %>/api/clip-submissions/${id}/reject`, { method: 'POST' });
            if (res.ok) {
                loadClips();
            } else {
                alert('Error: ' + await res.text());
            }
        }

        // Initialize Data
        loadUsers();
        loadBannedUsers();
        loadRegistrations();
        loadSeasonRegistrations();

        // Restore Tab State
        const savedTab = localStorage.getItem('adminActiveTab');
        if (savedTab) {
            const tabElement = document.querySelector(`.nav-link[onclick="switchTab('${savedTab}', this)"]`);
            if (tabElement) switchTab(savedTab, tabElement);
        }
    </script>
</body>

</html>
