<script>
    // Session / Idle Tracking (30 mins inactivity = signout)
    (function() {
        const token = localStorage.getItem('blaze_token');
        if (!token) {
            window.location.href = '/auth';
            return;
        }

        const IDLE_TIMEOUT_MS = 30 * 60 * 1000; // 30 minutes
        const checkIdle = () => {
            const lastActive = localStorage.getItem('blaze_last_active');
            if (lastActive && (Date.now() - parseInt(lastActive) > IDLE_TIMEOUT_MS)) {
                localStorage.removeItem('blaze_token');
                localStorage.removeItem('blaze_last_active');
                window.location.href = '/auth';
            }
        };

        const updateActivity = () => {
            localStorage.setItem('blaze_last_active', Date.now().toString());
        };

        // Initial check on load
        checkIdle();
        updateActivity();

        // Update on user activity (Throttled to max 1 update per 5 seconds)
        ['mousemove', 'keydown', 'click', 'scroll'].forEach(evt => {
            document.addEventListener(evt, () => {
                const now = Date.now();
                const last = parseInt(localStorage.getItem('blaze_last_active') || '0');
                if (now - last > 5000) {
                    updateActivity();
                }
            }, { passive: true });
        });

        // Periodic check while browser is open
        setInterval(checkIdle, 60000);
    })();

    const mobileToggle = document.getElementById('mobile-toggle');
    const navMenu = document.getElementById('nav-menu');

    if (mobileToggle && navMenu) {
        mobileToggle.addEventListener('click', (e) => {
            e.stopImmediatePropagation();
            mobileToggle.classList.toggle('active');
            navMenu.classList.toggle('active');
        });
    }



    const notifBell = document.getElementById('notif-bell');
    const notifDropdown = document.getElementById('notif-dropdown');

    if (notifBell && notifDropdown) {
        notifBell.addEventListener('click', (e) => {
            if (e.target.closest('#notif-dropdown')) return; // Don't close when clicking inside dropdown
            notifDropdown.style.display = notifDropdown.style.display === 'none' ? 'block' : 'none';
            
            if (notifDropdown.style.display === 'block' && window.hasUnreadNotifs) {
                const token = localStorage.getItem('blaze_token');
                if (token) {
                    fetch('/api/user/notifications/clear', { method: 'DELETE', headers: { 'x-auth-token': token } });
                    window.hasUnreadNotifs = false;
                }
            }
        });

        // Close on outside click
        document.addEventListener('click', (e) => {
            if (!notifBell.contains(e.target)) {
                notifDropdown.style.display = 'none';
            }
        });
        
        // Hover effect on svg
        notifBell.addEventListener('mouseenter', () => { notifBell.querySelector('svg').style.color = '#fff'; });
        notifBell.addEventListener('mouseleave', () => { notifBell.querySelector('svg').style.color = 'var(--text-muted)'; });
    }

    // Fetch Notifications and Profile via GraphQL
    document.addEventListener('DOMContentLoaded', async () => {
        const token = localStorage.getItem('blaze_token');
        if (!token) {
            window.location.href = '/auth';
            return;
        }
        
        try {
            const graphqlQuery = {
                query: `
                    query {
                        getGlobalNavData {
                            user { isGenuine hasCompletedTwoSeries role inGameName gameUid playerId isSetupComplete }
                            tournaments { id game format mode status date }
                            notifications { id title message type isRead createdAt }
                        }
                    }
                `
            };

                const res = await fetch('/graphql', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'x-auth-token': token
                    },
                    body: JSON.stringify(graphqlQuery)
                });

                if (res.ok) {
                    const { data } = await res.json();
                    if(!data || !data.getGlobalNavData) return;
                    
                    const navData = data.getGlobalNavData;

                    // Enforce Setup Completion globally
                    if (navData.user && !navData.user.isSetupComplete) {
                        window.location.href = '/onboarding';
                        return;
                    }

                    // Store globally so other pages don't need to refetch profile
                    window.globalUserData = navData.user;
                    
                    // Dispatch custom event so pages know global user data is ready
                    window.dispatchEvent(new Event('globalUserDataReady'));

                    // Process Profile
                    if (navData.user && (navData.user.isGenuine || navData.user.role === 'organizer')) {
                        const tTab = document.getElementById('nav-tournaments-tab');
                        if (tTab) {
                            tTab.style.filter = 'none';
                            tTab.style.opacity = '1';
                            tTab.innerHTML = 'Tournaments';
                            tTab.href = '/dashboard/tournaments';
                            tTab.removeAttribute('onclick');
                        }
                    }

                    let html = '';
                    let count = 0;

                    // Process Tournaments (Pending Requests)
                    if (navData.tournaments && navData.tournaments.length > 0) {
                        const pendingReqs = navData.tournaments.filter(r => r.status === 'Pending');
                        if (pendingReqs.length > 0) {
                            count += pendingReqs.length;
                            pendingReqs.forEach(r => {
                                let statusColor = r.status === 'Approved' ? '#22c55e' : (r.status === 'Rejected' ? '#ef4444' : '#f59e0b');
                                html += `
                                    <div style="padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.04); display: flex; flex-direction: column; gap: 6px; transition: background 0.2s;">
                                        <div style="display:flex; justify-content:space-between; align-items: center; width:100%;">
                                            <div style="color:#fff; font-family: var(--font-display); font-size: 1rem; letter-spacing: 1px;">${(r.game || '').toUpperCase()}</div>
                                            <div style="font-size: 0.65rem; padding: 2px 8px; border-radius: 4px; background: ${statusColor}22; color: ${statusColor}; font-weight:700; letter-spacing: 0.5px;">${r.status.toUpperCase()}</div>
                                        </div>
                                        <div style="color: var(--text-muted); font-size: 0.8rem; font-weight: 500;">Format: <span style="color:#e0e0e0">${r.format}</span> • Mode: <span style="color:#e0e0e0">${r.mode}</span></div>
                                        <div style="color: var(--text-muted); font-size: 0.75rem; font-family: var(--font-mono);">Start: ${r.date}</div>
                                    </div>
                                `;
                            });
                        }
                    }


                // Process Notifications
                if (navData.notifications && navData.notifications.length > 0) {
                    window.hasUnreadNotifs = true;
                    count += navData.notifications.length;
                    navData.notifications.forEach(n => {
                        let statusColor = n.type === 'success' ? '#22c55e' : (n.type === 'error' ? '#ef4444' : '#f0a500');
                        html += `
                            <div style="padding: 12px 16px; border-bottom: 1px solid rgba(255,255,255,0.04); display: flex; flex-direction: column; gap: 4px; transition: background 0.2s;">
                                <div style="display:flex; justify-content:space-between; align-items: center; width:100%;">
                                    <div style="color:${statusColor}; font-family: var(--font-display); font-size: 1rem; letter-spacing: 1px;">${n.title}</div>
                                </div>
                                <div style="color: var(--text-muted); font-size: 0.85rem; font-weight: 400; line-height: 1.3;">${n.message}</div>
                                <div style="color: rgba(255,255,255,0.3); font-size: 0.7rem; font-family: var(--font-mono); margin-top: 4px;">${n.createdAt}</div>
                            </div>
                        `;
                    });
                }

                if (count > 0) {
                    document.getElementById('notif-badge').style.display = 'block';
                    document.getElementById('notif-badge').innerText = count;
                    document.getElementById('nav-notifications-container').innerHTML = html;
                } else {
                    document.getElementById('nav-notifications-container').innerHTML = '<div style="text-align:center; padding: 20px; color: var(--text-muted); font-size: 0.8rem;">No recent notifications.</div>';
                }
            }
        } catch (err) {
            console.error("GraphQL Navbar fetch error:", err);
        }
    });
</script>
