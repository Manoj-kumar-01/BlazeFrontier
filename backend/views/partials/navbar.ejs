        </div>
        
        <div id="mm-chat-box" style="flex:1; height:300px; overflow-y:auto; padding:20px; display:flex; flex-direction:column; gap:10px; background:rgba(0,0,0,0.3);">
            <div style="text-align:center; color:var(--text-muted); font-size:0.8rem; margin-bottom:10px;">Match confirmed! You may now share credentials. Chat is restricted to pre-defined phrases.</div>
        </div>

        <div style="padding:20px; background:rgba(255,255,255,0.02); border-top:1px solid rgba(255,255,255,0.06);">
            <div style="display:flex; gap:8px; margin-bottom:15px; flex-wrap:wrap;">
                <button class="mm-quick-msg" style="background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; padding:8px 12px; border-radius:6px; font-size:0.8rem; cursor:pointer; flex:1;">Who will create the room?</button>
                <button class="mm-quick-msg" style="background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; padding:8px 12px; border-radius:6px; font-size:0.8rem; cursor:pointer; flex:1;">I will create the room</button>
                <button class="mm-quick-msg" style="background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:#fff; padding:8px 12px; border-radius:6px; font-size:0.8rem; cursor:pointer; flex:1;">You create the room</button>
                <button class="mm-quick-msg" style="background:rgba(34,197,94,0.2); border:1px solid #22c55e; color:#22c55e; padding:8px 12px; border-radius:6px; font-size:0.8rem; cursor:pointer; flex:1;">Joined!</button>
            </div>
            
            <div style="display:flex; gap:10px; align-items:flex-end;">
                <div style="flex:1;">
                    <label style="color:var(--text-300); font-size:0.75rem; margin-bottom:4px; display:block;">Room ID (Max 10 digits)</label>
                    <input type="text" id="mm-room-id" maxlength="10" pattern="\d*" placeholder="0000000000" style="width:100%; padding:10px; background:rgba(0,0,0,0.5); border:1px solid rgba(255,255,255,0.2); border-radius:6px; color:#fff; font-family:var(--font-mono);">
                </div>
                <div style="flex:1;">
                    <label style="color:var(--text-300); font-size:0.75rem; margin-bottom:4px; display:block;">Password (Max 10 digits)</label>
                    <input type="text" id="mm-room-pass" maxlength="10" pattern="\d*" placeholder="0000000000" style="width:100%; padding:10px; background:rgba(0,0,0,0.5); border:1px solid rgba(255,255,255,0.2); border-radius:6px; color:#fff; font-family:var(--font-mono);">
                </div>
                <button id="mm-send-creds-btn" style="background:#00bcd4; color:#fff; border:none; padding:10px 20px; border-radius:6px; font-weight:bold; cursor:pointer;">SEND</button>
            </div>
        </div>
