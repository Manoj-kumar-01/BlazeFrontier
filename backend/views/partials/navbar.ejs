        <div style="padding:20px; border-bottom:1px solid rgba(255,255,255,0.06); display:flex; justify-content:space-between; align-items:center; background:rgba(0,188,212,0.1);">
            <div style="font-family:var(--font-display); color:#fff; font-size:1.3rem; letter-spacing:1px;">MATCH ROOM <span id="mm-chat-opponent" style="color:#00bcd4; font-size:0.9rem; margin-left:10px;">Opponent</span></div>
