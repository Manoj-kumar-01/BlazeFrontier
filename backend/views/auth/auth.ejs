<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authenticate | Blaze Frontier</title>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=block" rel="stylesheet">
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
        :root {
            --blaze-orange: #ff5722;
            --blaze-red: #e63946;
            --bg-dark: #07070a;
            --bg-panel: #111116;
            --text-light: #ffffff;
            --text-muted: #a0a0ab;
            --font-display: 'Bebas Neue', sans-serif;
            --font-body: 'Inter', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--bg-dark);
            color: var(--text-light);
            height: 100vh;
            overflow: hidden;
            display: flex;
        }

        /* Left Side: Branding */
        .brand-side {
            flex: 1;
            position: relative;
            background: radial-gradient(circle at top left, rgba(255,87,34,0.1) 0%, rgba(7,7,10,1) 60%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            border-right: 1px solid rgba(255,255,255,0.05);
            overflow: hidden;
        }

        /* Subtle grid background */
        .brand-side::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
            background-size: 30px 30px;
            z-index: 0;
        }

        .logo-container {
            z-index: 10;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .main-logo {
            width: 280px;
            height: auto;
            margin-bottom: 30px;
            filter: drop-shadow(0 10px 30px rgba(0,0,0,0.5));
            transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .main-logo:hover {
            transform: scale(1.05);
        }

        .brand-title {
            font-family: var(--font-display);
            font-size: 4rem;
            font-weight: 800;
            letter-spacing: 4px;
            transform: skewX(-12deg);
            display: inline-block;
            background: linear-gradient(to bottom, #ff3b3f 0%, #d91c1f 40%, #5c0000 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0px 4px 4px rgba(0,0,0,0.8));
            text-transform: uppercase;
            line-height: 1;
            margin-bottom: 20px;
        }

        .brand-title span {
            font-family: var(--font-display);
            font-weight: 800;
            background: linear-gradient(to bottom, #ffffff 0%, #c4c4c4 40%, #666666 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-left: 12px;
            letter-spacing: 4px;
        }

        .brand-tagline {
            font-size: 1rem;
            color: var(--text-muted);
            max-width: 380px;
            line-height: 1.6;
            font-weight: 400;
        }

        /* Right Side: Auth Panel */
        .auth-side {
            flex: 0 0 500px;
            background: var(--bg-panel);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 40px;
            position: relative;
        }

        .auth-card {
            width: 100%;
            max-width: 400px;
            padding: 40px;
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
            backdrop-filter: blur(10px);
        }

        .auth-header {
            margin-bottom: 32px;
            text-align: center;
        }

        .auth-title {
            font-family: var(--font-display);
            font-size: 2.2rem;
            letter-spacing: 1px;
            color: #fff;
            margin-bottom: 8px;
        }

        .auth-subtitle {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.5;
        }

        #error-msg {
            background: rgba(230, 57, 70, 0.1);
            border-left: 3px solid var(--blaze-red);
            color: #ff8a8a;
            padding: 12px 16px;
            border-radius: 4px 8px 8px 4px;
            margin-bottom: 24px;
            font-size: 0.85rem;
            font-weight: 500;
            display: none;
        }

        .google-btn-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 10px;
            padding: 10px 0;
            background: rgba(255,255,255,0.03);
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.05);
            transition: background 0.2s;
        }

        .google-btn-wrapper:hover {
            background: rgba(255,255,255,0.05);
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.8rem;
            margin: 30px 0;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .divider:not(:empty)::before { margin-right: .5em; }
        .divider:not(:empty)::after { margin-left: .5em; }

        .secure-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            color: var(--text-muted);
            font-size: 0.8rem;
            font-weight: 500;
            margin-top: 30px;
        }

        .secure-badge svg {
            width: 16px; height: 16px;
            fill: #22c55e;
        }

        .mobile-logo {
            display: none;
            width: 120px;
            margin: 0 auto 24px;
            filter: drop-shadow(0 8px 16px rgba(0,0,0,0.4));
        }

        @media (max-width: 900px) {
            body { flex-direction: column; }
            .brand-side { display: none; }
            .auth-side { flex: 1; width: 100%; border-left: none; padding: 10px; }
            .auth-card { padding: 15px; border: none; background: transparent; box-shadow: none; }
            .mobile-logo { display: block; }
        }
    </style>
</head>
<body>
    
    <!-- Left Branding Side -->
    <div class="brand-side">
        <div class="logo-container">
            <!-- Using the new logo -->
            <img src="/public/NEWLOGO.webp" alt="Blaze Frontier Logo" class="main-logo">
            <h1 class="brand-title">BLAZE<span>FRONTIER</span></h1>
            <p class="brand-tagline">The premier competitive ecosystem. Sync your stats, dominate tournaments, and climb the global ranks.</p>
        </div>
    </div>

    <!-- Right Authentication Side -->
    <div class="auth-side">
        <div class="auth-card">
            <div class="auth-header">
                <img src="/public/NEWLOGO.webp" alt="Blaze Frontier" class="mobile-logo">
                <h2 class="auth-title">AUTHENTICATION</h2>
                <p class="auth-subtitle">Verify your identity to access the portal.</p>
            </div>
            
            <div id="error-msg"></div>

            <div class="google-btn-wrapper">
                <div id="google-signin-btn"></div>
            </div>

            <div id="auth-retry" style="display:none; text-align:center; margin-top:16px;">
                <p style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 12px;">Google Sign-In didn't load. Try again or check your connection.</p>
                <button onclick="initGoogleSignIn()" style="background: var(--blaze-orange); color: #fff; border: none; padding: 12px 24px; border-radius: 8px; font-family: var(--font-display); font-size: 1rem; letter-spacing: 1px; cursor: pointer; transition: all 0.2s;">RETRY SIGN IN</button>
            </div>

            <div class="divider">SECURE CONNECTION</div>

            <div class="secure-badge">
                <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
                <span>End-to-End Encrypted via Google Auth</span>
            </div>
        </div>
    </div>

    <script>
        // Check if already logged in
        if (localStorage.getItem('blaze_token')) {
            window.location.href = '/dashboard';
        }

        const GOOGLE_CLIENT_ID = '<%= clientId %>';

        function initGoogleSignIn() {
            const retryDiv = document.getElementById('auth-retry');
            retryDiv.style.display = 'none';

            if (typeof google === 'undefined' || !google.accounts) {
                console.error('Google Identity Services not loaded');
                retryDiv.style.display = 'block';
                return;
            }

            try {
                google.accounts.id.initialize({
                    client_id: GOOGLE_CLIENT_ID,
                    callback: handleCredentialResponse,
                    ux_mode: 'popup',
                    context: 'signin',
                    auto_select: false,
                    itp_support: true,
                    use_fedcm_for_prompt: false
                });

                let containerPadding = window.innerWidth <= 900 ? 50 : 80;
                let btnWidth = Math.min(window.innerWidth - containerPadding, 320);

                google.accounts.id.renderButton(
                    document.getElementById('google-signin-btn'),
                    {
                        type: 'standard',
                        shape: 'rectangular',
                        theme: 'filled_black',
                        text: 'continue_with',
                        size: 'large',
                        logo_alignment: 'left',
                        width: btnWidth
                    }
                );

                // Check if button rendered after a delay
                setTimeout(() => {
                    const btn = document.getElementById('google-signin-btn');
                    if (btn && btn.children.length === 0) {
                        retryDiv.style.display = 'block';
                    }
                }, 3000);
            } catch (err) {
                console.error('Google Sign-In init error:', err);
                retryDiv.style.display = 'block';
            }
        }

        // Wait for Google script to load then initialize
        window.addEventListener('load', () => {
            // Small delay to ensure google.accounts is ready
            setTimeout(initGoogleSignIn, 500);
        });

        async function handleCredentialResponse(response) {
            const errorMsg = document.getElementById('error-msg');
            errorMsg.style.display = 'none';

            try {
                // Send the credential to our backend
                const res = await fetch('/api/auth/google', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ credential: response.credential })
                });

                const data = await res.json();

                if (!res.ok) {
                    errorMsg.innerText = data.msg || 'Authentication failed. Please try again.';
                    errorMsg.style.display = 'block';
                } else {
                    // Success! Save token and redirect
                    localStorage.setItem('blaze_token', data.token);
                    if (!data.user.isSetupComplete) {
                        window.location.href = '/onboarding';
                    } else {
                        window.location.href = '/dashboard';
                    }
                }
            } catch (err) {
                errorMsg.innerText = 'Network error. Please check your connection.';
                errorMsg.style.display = 'block';
            }
        }
    </script>
</body>
</html>

